{"metadata":{"kernelspec":{"language":"python","display_name":"Python 3","name":"python3"},"language_info":{"name":"python","version":"3.12.12","mimetype":"text/x-python","codemirror_mode":{"name":"ipython","version":3},"pygments_lexer":"ipython3","nbconvert_exporter":"python","file_extension":".py"},"kaggle":{"accelerator":"none","dataSources":[],"dockerImageVersionId":31328,"isInternetEnabled":true,"language":"python","sourceType":"notebook","isGpuEnabled":false}},"nbformat_minor":4,"nbformat":4,"cells":[{"cell_type":"code","source":"","metadata":{"_uuid":"8f2839f25d086af736a60e9eeb907d3b93b6e0e5","_cell_guid":"b1076dfc-b9ad-4769-8c92-a6c4dae69d19","trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# Run this cell first to install all required packages\n!pip install pystac-client planetary-computer stackstac pyproj rioxarray dask -q","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-24T23:30:51.358066Z","iopub.execute_input":"2026-04-24T23:30:51.358344Z","iopub.status.idle":"2026-04-24T23:31:01.338345Z","shell.execute_reply.started":"2026-04-24T23:30:51.358315Z","shell.execute_reply":"2026-04-24T23:31:01.337371Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"\"\"\"\nflood_image_downloader.py\n=========================\nSensor routing:\n  BEFORE window -> Sentinel-2 L2A (dry season, cloud-free)\n                   Purpose: MNDWI permanent-water baseline + RGB visual context\n  AFTER  window -> Sentinel-1 RTC (all-weather SAR)\n                   Purpose: per-acquisition VV/VH chips for Sen1Floods11 model inference\n  AFTER  visual -> Sentinel-2 L2A (optional, heavily relaxed cloud threshold)\n                   Purpose: RGB visual only; never used for flood mask generation\n\nSen1Floods11 model expects 2-channel float32 (VV, VH) in dB scale.\nPlanetary Computer collection: sentinel-1-rtc (linear sigma0 -> converted to dB here).\n\"\"\"\n\nimport pystac_client\nimport planetary_computer\nimport stackstac\nimport pyproj\nimport numpy as np\nimport xarray as xr\nfrom shapely.geometry import box\nfrom shapely.ops import transform\nfrom dask.diagnostics import ProgressBar\nimport rioxarray\nimport warnings\nfrom scipy.ndimage import median_filter\nfrom scipy.spatial import cKDTree\nfrom typing import List, Optional, Tuple\nfrom PIL import Image, ImageEnhance\nimport time\nimport os\n\n\n# ==========================================\n# 1. UTM ALIGNMENT\n# ==========================================\ndef get_utm_params(lat: float, lon: float, radius_km: float):\n    utm_zone = int((lon + 180) / 6) + 1\n    epsg = 32600 + utm_zone if lat >= 0 else 32700 + utm_zone\n    wgs84 = pyproj.CRS(\"EPSG:4326\")\n    utm   = pyproj.CRS.from_epsg(epsg)\n    to_utm = pyproj.Transformer.from_crs(wgs84, utm, always_xy=True).transform\n    to_wgs = pyproj.Transformer.from_crs(utm, wgs84, always_xy=True).transform\n\n    x_c, y_c = to_utm(lon, lat)\n    x_c, y_c = round(x_c / 10) * 10, round(y_c / 10) * 10\n    r_m = radius_km * 1000\n\n    utm_bounds = (x_c - r_m, y_c - r_m, x_c + r_m, y_c + r_m)\n    wgs_bounds = transform(to_wgs, box(*utm_bounds)).bounds\n    return utm_bounds, epsg, wgs_bounds\n\n\n# ==========================================\n# 2. VISUAL ENHANCEMENT (S2 only)\n# ==========================================\ndef apply_visual_enhancement(\n    data: xr.DataArray,\n    gamma: float = 0.55,\n    low_pct: float = 1.0,\n    high_pct: float = 98.0,\n    saturation_boost: float = 1.3\n) -> np.ndarray:\n    \"\"\"\n    Float32 reflectance -> uint8 RGB.\n    Band order in data: [B02, B03, B04, B08, B11, B12] -> RGB uses indices [2, 1, 0].\n    \"\"\"\n    rgb_indices = [2, 1, 0]  # B04 (R), B03 (G), B02 (B)\n    channels = []\n\n    for idx in rgb_indices:\n        band = data[idx].values.astype(np.float32)\n        valid = band[~np.isnan(band)]\n        if len(valid) == 0:\n            channels.append(np.zeros(band.shape, dtype=np.float32))\n            continue\n\n        lo, hi = np.percentile(valid, [low_pct, high_pct])\n        band = np.clip(band, lo, hi)\n        band = (band - lo) / (hi - lo + 1e-10)\n        band = np.where(np.isnan(band), 0.0, band)\n        band = np.power(band, gamma)\n        channels.append(band)\n\n    rgb = np.stack(channels, axis=-1)\n\n    try:\n        pil_img = Image.fromarray((rgb * 255).astype(np.uint8), mode='RGB')\n        pil_img = ImageEnhance.Color(pil_img).enhance(saturation_boost)\n        rgb = np.array(pil_img).astype(np.float32) / 255.0\n    except Exception:\n        pass\n\n    return (rgb * 255).astype(np.uint8)\n\n\ndef save_visual_png(data: xr.DataArray, path: str, **kw):\n    arr = apply_visual_enhancement(data, **kw)\n    Image.fromarray(arr, mode='RGB').save(path)\n    h, w = arr.shape[:2]\n    print(f\"   PNG saved: {os.path.basename(path)} ({w}x{h}px)\")\n\n\n# ==========================================\n# 3. SHARED UTILITIES\n# ==========================================\ndef interpolate_missing_pixels(data: xr.DataArray, max_distance: int = 80) -> xr.DataArray:\n    out = data.copy()\n    for bi in range(data.shape[0]):\n        band = data[bi].values.copy()\n        nan_n = int(np.sum(np.isnan(band)))\n        if nan_n == 0:\n            continue\n        valid_coords   = np.argwhere(~np.isnan(band))\n        invalid_coords = np.argwhere(np.isnan(band))\n        if len(valid_coords) == 0:\n            continue\n        tree = cKDTree(valid_coords)\n        dists, idxs = tree.query(invalid_coords, k=1)\n        for i in np.where(dists < max_distance)[0]:\n            iy, ix = invalid_coords[i]\n            vy, vx = valid_coords[idxs[i]]\n            band[iy, ix] = band[vy, vx]\n        filled = nan_n - int(np.sum(np.isnan(band)))\n        print(f\"      Band {bi+1}: {filled:,} filled, {int(np.sum(np.isnan(band))):,} remain\")\n        out[bi].values = band\n    return out\n\n\ndef apply_selective_filtering(data: xr.DataArray, filter_size: int = 3) -> xr.DataArray:\n    out = data.copy()\n    for bi in range(data.shape[0]):\n        band = data[bi].values\n        valid = ~np.isnan(band)\n        if not np.any(valid):\n            continue\n        tmp = band.copy()\n        tmp[~valid] = float(np.median(band[valid]))\n        filtered = median_filter(tmp, size=filter_size, mode='nearest')\n        band[valid] = filtered[valid]\n        out[bi].values = band\n    return out\n\n\ndef report_statistics(data: xr.DataArray, names: List[str]):\n    print(\"   \" + \"-\" * 65)\n    print(\"   {:14} {:>9} {:>9} {:>9} {:>9} {:>9}\".format(\n        \"Band\", \"Mean\", \"Std\", \"Min\", \"Max\", \"NaN%\"))\n    print(\"   \" + \"-\" * 65)\n    for i in range(data.shape[0]):\n        b = data[i].values\n        v = b[~np.isnan(b)]\n        nm = names[i] if i < len(names) else f\"Band {i}\"\n        if len(v) > 0:\n            print(\"   {:14} {:>9.4f} {:>9.4f} {:>9.4f} {:>9.4f} {:>8.2f}%\".format(\n                nm, float(np.mean(v)), float(np.std(v)),\n                float(np.min(v)), float(np.max(v)),\n                np.sum(np.isnan(b)) / b.size * 100))\n        else:\n            print(f\"   {nm:14} ALL NaN\")\n\n\ndef open_catalog() -> pystac_client.Client:\n    return pystac_client.Client.open(\n        \"https://planetarycomputer.microsoft.com/api/stac/v1\",\n        modifier=planetary_computer.sign_inplace\n    )\n\n\n# ==========================================\n# 4. SENTINEL-2 BASELINE DOWNLOADER\n#    Used for: dry-season permanent-water mask (MNDWI) + RGB visual\n#    NOT used for: flood detection\n# ==========================================\ndef download_s2_baseline(\n    lat: float,\n    lon: float,\n    radius_km: float,\n    date_start: str,\n    date_end: str,\n    label: str,\n    max_cloud: int = 30,\n    max_items: int = 15,\n    output_dir: str = \".\",\n    gamma: float = 0.55,\n    low_pct: float = 1.0,\n    high_pct: float = 98.0,\n) -> Optional[xr.DataArray]:\n    \"\"\"\n    Download Sentinel-2 L2A median composite for the DRY-SEASON baseline window.\n    Output bands: [B02, B03, B04, B08, B11, B12] float32 reflectance.\n    Downstream use:\n      - MNDWI = (B03 - B11) / (B03 + B11) > 0.0  ->  permanent water mask\n      - RGB visual for UI before-panel\n    \"\"\"\n    os.makedirs(output_dir, exist_ok=True)\n    t0 = time.time()\n\n    print(f\"\\n{'='*70}\")\n    print(f\"  [S2 BASELINE] {label}  |  {date_start} -> {date_end}\")\n    print(f\"  Cloud <{max_cloud}%  |  Max scenes: {max_items}\")\n    print(f\"{'='*70}\")\n\n    utm_bounds, epsg, wgs_bounds = get_utm_params(lat, lon, radius_km)\n    catalog = open_catalog()\n\n    search = catalog.search(\n        collections=[\"sentinel-2-l2a\"],\n        bbox=wgs_bounds,\n        datetime=f\"{date_start}/{date_end}\",\n        query={\"eo:cloud_cover\": {\"lt\": max_cloud}},\n        sortby=[{\"field\": \"properties.eo:cloud_cover\", \"direction\": \"asc\"}],\n        max_items=50\n    )\n    items = list(search.items())\n\n    if not items:\n        relaxed = min(max_cloud + 15, 50)\n        print(f\"  No scenes at <{max_cloud}%. Retrying at <{relaxed}%...\")\n        search = catalog.search(\n            collections=[\"sentinel-2-l2a\"],\n            bbox=wgs_bounds,\n            datetime=f\"{date_start}/{date_end}\",\n            query={\"eo:cloud_cover\": {\"lt\": relaxed}},\n            sortby=[{\"field\": \"properties.eo:cloud_cover\", \"direction\": \"asc\"}],\n            max_items=50\n        )\n        items = list(search.items())\n\n    if not items:\n        print(\"  FAILED: No S2 scenes found. Cannot build baseline.\")\n        return None\n\n    n = min(max_items, len(items))\n    print(f\"  Found {len(items)} scenes, stacking top {n}\")\n\n    reflectance_bands = [\"B02\", \"B03\", \"B04\", \"B08\", \"B11\", \"B12\"]\n    slices = []\n\n    for i, item in enumerate(items[:n]):\n        pb = item.properties.get(\"s2:processing_baseline\", \"02.00\")\n        try:\n            is_new = float(pb) >= 4.0\n        except (ValueError, TypeError):\n            is_new = str(pb) >= \"04.00\"\n        cc = item.properties.get(\"eo:cloud_cover\", \"?\")\n        dt = item.properties.get(\"datetime\", \"?\")[:10]\n\n        try:\n            cube = stackstac.stack(\n                item,\n                assets=reflectance_bands + [\"SCL\"],\n                bounds=utm_bounds,\n                epsg=epsg,\n                resolution=10,\n                dtype=\"float64\",\n                rescale=True,\n                fill_value=np.nan\n            ).squeeze()\n        except Exception as e:\n            print(f\"    [{i+1}/{n}] SKIP: {e}\")\n            continue\n\n        if is_new:\n            for b in reflectance_bands:\n                if b in cube.band.values:\n                    cube.loc[dict(band=b)] -= 0.1\n\n        if \"SCL\" in cube.band.values:\n            bad = cube.sel(band=\"SCL\").isin([0, 1, 3, 8, 9, 10])\n            for b in reflectance_bands:\n                if b in cube.band.values:\n                    cube.loc[dict(band=b)] = cube.sel(band=b).where(~bad)\n\n        slices.append(cube.sel(band=reflectance_bands))\n        print(f\"    [{i+1}/{n}] {dt} | cloud:{cc:.1f}%\")\n\n    if not slices:\n        print(\"  FAILED: All scenes errored during stacking.\")\n        return None\n\n    print(f\"\\n  Computing S2 median composite ({len(slices)} scenes)...\")\n    cube = xr.concat(slices, dim=\"time\", combine_attrs='override')\n    with ProgressBar():\n        data = cube.median(dim=\"time\", skipna=True).compute().astype(\"float32\")\n        data = data.where(data >= 0, 0)\n\n    data = data.rio.write_nodata(np.nan).rio.write_crs(f\"EPSG:{epsg}\")\n\n    print(\"  Interpolating missing pixels...\")\n    data = interpolate_missing_pixels(data, max_distance=80)\n    data = apply_selective_filtering(data, filter_size=3)\n\n    print(\"  Statistics:\")\n    report_statistics(data, ['Blue(B02)', 'Green(B03)', 'Red(B04)',\n                              'NIR(B08)', 'SWIR1(B11)', 'SWIR2(B12)'])\n\n    stem = f\"{label}_s2_baseline_{date_start}_{date_end}\"\n    tif_path = os.path.join(output_dir, stem + \".tif\")\n    data.rio.to_raster(tif_path, compress=\"LZW\", tiled=True,\n                       blockxsize=256, blockysize=256, dtype=\"float32\", nodata=np.nan)\n    print(f\"  GeoTIFF: {tif_path}\")\n\n    png_path = os.path.join(output_dir, stem + \"_visual.png\")\n    save_visual_png(data, png_path, gamma=gamma, low_pct=low_pct, high_pct=high_pct)\n\n    print(f\"  Done in {time.time()-t0:.1f}s | Shape: {data.shape[2]}x{data.shape[1]}px\")\n    return data\n\n\n# ==========================================\n# 5. SENTINEL-1 EVENT DOWNLOADER\n#    Used for: active flood detection\n#    Feeds directly into Sen1Floods11 model inference\n#    Output: per-acquisition 2-band (VV, VH) chips in dB\n# ==========================================\ndef download_s1_event(\n    lat: float,\n    lon: float,\n    radius_km: float,\n    date_start: str,\n    date_end: str,\n    label: str,\n    output_dir: str = \".\",\n    orbit_direction: Optional[str] = None,   # \"ascending\" | \"descending\" | None (both)\n    save_composite: bool = True,\n) -> List[Tuple[str, xr.DataArray]]:\n    \"\"\"\n    Download Sentinel-1 RTC acquisitions for the ACTIVE FLOOD WINDOW.\n    Returns list of (acquisition_date, DataArray) tuples.\n    Each DataArray: shape (2, H, W), band 0 = VV dB, band 1 = VH dB.\n\n    This is what Sen1Floods11 model inference consumes directly.\n    S1 revisit: ~6 days globally. Expect 4-10 acquisitions per 60-day window.\n\n    dB conversion: 10 * log10(linear_sigma0), clipped to [-35, 5] dB.\n    Water:           VV ~ -20 to -15 dB  (specular reflection away from sensor)\n    Flooded veg:     VV ~ -5 to 0 dB    (double-bounce, anomalously high)\n    Dry land:        VV ~ -10 to -5 dB\n    \"\"\"\n    os.makedirs(output_dir, exist_ok=True)\n    t0 = time.time()\n\n    print(f\"\\n{'='*70}\")\n    print(f\"  [S1 EVENT] {label}  |  {date_start} -> {date_end}\")\n    orbit_str = orbit_direction if orbit_direction else \"both\"\n    print(f\"  Sentinel-1 RTC | Orbit: {orbit_str} | All-weather, no cloud filter\")\n    print(f\"{'='*70}\")\n\n    utm_bounds, epsg, wgs_bounds = get_utm_params(lat, lon, radius_km)\n    catalog = open_catalog()\n\n    query_filter = {}\n    if orbit_direction:\n        query_filter[\"sat:orbit_state\"] = {\"eq\": orbit_direction}\n\n    search = catalog.search(\n        collections=[\"sentinel-1-rtc\"],\n        bbox=wgs_bounds,\n        datetime=f\"{date_start}/{date_end}\",\n        query=query_filter if query_filter else None,\n        sortby=[{\"field\": \"properties.datetime\", \"direction\": \"asc\"}],\n        max_items=100\n    )\n    items = list(search.items())\n\n    if not items:\n        print(\"  FAILED: No S1-RTC scenes found.\")\n        print(\"  Check sentinel-1-rtc availability on Planetary Computer for this bbox/window.\")\n        return []\n\n    print(f\"  Found {len(items)} S1 acquisitions\")\n\n    acquisitions = []\n    acq_dates    = []\n\n    for i, item in enumerate(items):\n        dt     = item.properties.get(\"datetime\", \"?\")[:10]\n        orbit  = item.properties.get(\"sat:orbit_state\", \"?\")\n        plat   = item.properties.get(\"platform\", \"?\")\n\n        try:\n            cube = stackstac.stack(\n                item,\n                assets=[\"vv\", \"vh\"],\n                bounds=utm_bounds,\n                epsg=epsg,\n                resolution=10,\n                dtype=\"float64\",\n                rescale=False,      # keep linear sigma0; convert to dB below\n                fill_value=np.nan\n            ).squeeze()\n\n            with ProgressBar():\n                arr = cube.compute().astype(\"float32\")\n\n        except Exception as e:\n            print(f\"    [{i+1}/{len(items)}] {dt} SKIP: {e}\")\n            continue\n\n        # Convert linear sigma0 -> dB, guard against zeros/negatives (nodata artifacts)\n        arr_db = arr.copy()\n        for bi in range(arr.shape[0]):\n            band = arr[bi].values.copy()\n            valid = (band > 0) & ~np.isnan(band)\n            band[~valid] = np.nan\n            band[valid] = 10.0 * np.log10(band[valid])\n            band = np.clip(band, -35.0, 5.0)\n            arr_db[bi].values = band\n\n        arr_db = arr_db.rio.write_nodata(np.nan).rio.write_crs(f\"EPSG:{epsg}\")\n\n        acq_stem = f\"{label}_s1_{dt}_{orbit}\"\n        tif_path = os.path.join(output_dir, acq_stem + \".tif\")\n        arr_db.rio.to_raster(\n            tif_path,\n            compress=\"LZW\",\n            tiled=True,\n            blockxsize=256,\n            blockysize=256,\n            dtype=\"float32\",\n            nodata=np.nan\n        )\n\n        acquisitions.append((dt, arr_db))\n        acq_dates.append(dt)\n        print(f\"    [{i+1}/{len(items)}] {dt} | {orbit} | {plat} -> {os.path.basename(tif_path)}\")\n\n    if not acquisitions:\n        print(\"  FAILED: All S1 acquisitions errored.\")\n        return []\n\n    # Temporal mean composite for visual QC (NOT for model inference)\n    if save_composite:\n        print(f\"\\n  Building mean composite over {len(acquisitions)} acquisitions (QC only)...\")\n        stacked   = xr.concat([a[1] for a in acquisitions], dim=\"time\")\n        composite = stacked.mean(dim=\"time\", skipna=True).astype(\"float32\")\n        composite = composite.rio.write_nodata(np.nan).rio.write_crs(f\"EPSG:{epsg}\")\n\n        comp_path = os.path.join(output_dir,\n                                 f\"{label}_s1_composite_{date_start}_{date_end}.tif\")\n        composite.rio.to_raster(comp_path, compress=\"LZW\", tiled=True,\n                                blockxsize=256, blockysize=256,\n                                dtype=\"float32\", nodata=np.nan)\n        print(f\"  Composite saved: {comp_path}\")\n\n        # False-color PNG: VV -> R, VH -> G, VV-VH ratio -> B\n        try:\n            def stretch(arr, lo=2, hi=98):\n                v = arr[~np.isnan(arr)]\n                if len(v) == 0:\n                    return np.zeros_like(arr, dtype=np.float32)\n                lv, hv = np.percentile(v, [lo, hi])\n                out = np.clip(arr, lv, hv)\n                out = (out - lv) / (hv - lv + 1e-10)\n                return np.where(np.isnan(out), 0.0, out)\n\n            vv    = composite[0].values\n            vh    = composite[1].values\n            ratio = np.where((~np.isnan(vv)) & (~np.isnan(vh)), vv - vh, np.nan)\n            rgb   = np.stack([\n                (stretch(vv)    * 255).astype(np.uint8),\n                (stretch(vh)    * 255).astype(np.uint8),\n                (stretch(ratio) * 255).astype(np.uint8),\n            ], axis=-1)\n            fc_path = os.path.join(output_dir,\n                                   f\"{label}_s1_falsecolor_{date_start}_{date_end}.png\")\n            Image.fromarray(rgb, mode='RGB').save(fc_path)\n            print(f\"  False-color PNG: {fc_path}\")\n        except Exception as e:\n            print(f\"  False-color PNG failed: {e}\")\n\n    print(f\"\\n  S1 done: {len(acquisitions)} chips | Dates: {', '.join(acq_dates)}\")\n    print(f\"  Elapsed: {time.time()-t0:.1f}s\")\n    return acquisitions\n\n\n# ==========================================\n# 6. OPTIONAL: S2 VISUAL AFTER\n#    Post-event S2 for RGB display only.\n#    Never used for flood mask generation.\n# ==========================================\ndef download_s2_visual_after(\n    lat: float,\n    lon: float,\n    radius_km: float,\n    date_start: str,\n    date_end: str,\n    label: str,\n    max_cloud: int = 70,\n    max_items: int = 8,\n    output_dir: str = \".\",\n    gamma: float = 0.55,\n    low_pct: float = 1.0,\n    high_pct: float = 98.0,\n) -> Optional[xr.DataArray]:\n    \"\"\"\n    Best-effort S2 composite for after-event period. Purpose: UI RGB visual only.\n    NaN coverage may be high for monsoon events; that is acceptable.\n    If average NaN > 40%, a warning is raised and the caller should fall back\n    to the S1 false-color composite for the UI after-panel.\n    \"\"\"\n    os.makedirs(output_dir, exist_ok=True)\n    t0 = time.time()\n\n    print(f\"\\n{'='*70}\")\n    print(f\"  [S2 VISUAL AFTER] {label}  |  {date_start} -> {date_end}\")\n    print(f\"  Cloud <{max_cloud}% (relaxed) | DISPLAY ONLY — NOT used for flood masks\")\n    print(f\"{'='*70}\")\n\n    utm_bounds, epsg, wgs_bounds = get_utm_params(lat, lon, radius_km)\n    catalog = open_catalog()\n\n    search = catalog.search(\n        collections=[\"sentinel-2-l2a\"],\n        bbox=wgs_bounds,\n        datetime=f\"{date_start}/{date_end}\",\n        query={\"eo:cloud_cover\": {\"lt\": max_cloud}},\n        sortby=[{\"field\": \"properties.eo:cloud_cover\", \"direction\": \"asc\"}],\n        max_items=50\n    )\n    items = list(search.items())\n\n    if not items:\n        print(\"  No S2 scenes found. Use S1 false-color PNG for UI after-panel.\")\n        return None\n\n    n = min(max_items, len(items))\n    print(f\"  Found {len(items)} scenes, using top {n}\")\n\n    reflectance_bands = [\"B02\", \"B03\", \"B04\", \"B08\", \"B11\", \"B12\"]\n    slices = []\n\n    for i, item in enumerate(items[:n]):\n        pb = item.properties.get(\"s2:processing_baseline\", \"02.00\")\n        try:\n            is_new = float(pb) >= 4.0\n        except (ValueError, TypeError):\n            is_new = str(pb) >= \"04.00\"\n        cc = item.properties.get(\"eo:cloud_cover\", \"?\")\n        dt = item.properties.get(\"datetime\", \"?\")[:10]\n\n        try:\n            cube = stackstac.stack(\n                item,\n                assets=reflectance_bands + [\"SCL\"],\n                bounds=utm_bounds,\n                epsg=epsg,\n                resolution=10,\n                dtype=\"float64\",\n                rescale=True,\n                fill_value=np.nan\n            ).squeeze()\n        except Exception as e:\n            print(f\"    [{i+1}/{n}] SKIP: {e}\")\n            continue\n\n        if is_new:\n            for b in reflectance_bands:\n                if b in cube.band.values:\n                    cube.loc[dict(band=b)] -= 0.1\n\n        if \"SCL\" in cube.band.values:\n            bad = cube.sel(band=\"SCL\").isin([0, 1, 3, 8, 9, 10])\n            for b in reflectance_bands:\n                if b in cube.band.values:\n                    cube.loc[dict(band=b)] = cube.sel(band=b).where(~bad)\n\n        slices.append(cube.sel(band=reflectance_bands))\n        print(f\"    [{i+1}/{n}] {dt} | cloud:{cc:.1f}%\")\n\n    if not slices:\n        print(\"  All scenes errored. Use S1 false-color for UI.\")\n        return None\n\n    cube = xr.concat(slices, dim=\"time\", combine_attrs='override')\n    with ProgressBar():\n        data = cube.median(dim=\"time\", skipna=True).compute().astype(\"float32\")\n        data = data.where(data >= 0, 0)\n\n    data = data.rio.write_nodata(np.nan).rio.write_crs(f\"EPSG:{epsg}\")\n    data = interpolate_missing_pixels(data, max_distance=120)\n    data = apply_selective_filtering(data, filter_size=3)\n\n    avg_nan = float(np.mean([\n        np.sum(np.isnan(data[i].values)) / data[i].values.size * 100\n        for i in range(data.shape[0])\n    ]))\n    if avg_nan > 40:\n        print(f\"  WARNING: {avg_nan:.1f}% average NaN — visual quality poor.\")\n        print(f\"  Recommend using S1 false-color for the UI after-panel.\")\n    else:\n        print(f\"  NaN coverage: {avg_nan:.1f}% — visual quality acceptable.\")\n\n    stem = f\"{label}_s2_visual_after_{date_start}_{date_end}\"\n    tif_path = os.path.join(output_dir, stem + \".tif\")\n    data.rio.to_raster(tif_path, compress=\"LZW\", tiled=True,\n                       blockxsize=256, blockysize=256, dtype=\"float32\", nodata=np.nan)\n\n    png_path = os.path.join(output_dir, stem + \".png\")\n    save_visual_png(data, png_path, gamma=gamma, low_pct=low_pct, high_pct=high_pct)\n\n    print(f\"  Done in {time.time()-t0:.1f}s\")\n    return data\n\n\n# ==========================================\n# 7. FLOOD PAIR ORCHESTRATOR\n# ==========================================\ndef download_flood_pair(\n    lat: float,\n    lon: float,\n    radius_km: float,\n    baseline_start: str,\n    baseline_end: str,\n    event_start: str,\n    event_end: str,\n    label: str,\n    orbit_direction: Optional[str] = None,\n    output_dir: str = \".\",\n    fetch_s2_visual_after: bool = True,\n    gamma: float = 0.55,\n    low_pct: float = 1.0,\n    high_pct: float = 98.0,\n) -> dict:\n    \"\"\"\n    Full sensor-routed flood pair download.\n\n    Step 1: S2 baseline [dry season, cloud-free]  -> permanent water mask + before visual\n    Step 2: S1 event    [all-weather SAR]          -> per-acquisition chips for model inference\n    Step 3: S2 visual   [optional, relaxed cloud]  -> after visual for UI only\n\n    Returns dict: 's2_baseline', 's1_acquisitions', 's2_visual_after'\n    \"\"\"\n    print(f\"\\n{'#'*70}\")\n    print(f\"  FLOOD PAIR: {label.upper()}\")\n    print(f\"  Baseline  : {baseline_start} -> {baseline_end}  [S2 optical]\")\n    print(f\"  Event     : {event_start} -> {event_end}  [S1 SAR primary]\")\n    print(f\"{'#'*70}\")\n\n    results = {}\n\n    results['s2_baseline'] = download_s2_baseline(\n        lat, lon, radius_km,\n        baseline_start, baseline_end,\n        label,\n        max_cloud=30, max_items=15,\n        output_dir=output_dir,\n        gamma=gamma, low_pct=low_pct, high_pct=high_pct\n    )\n\n    results['s1_acquisitions'] = download_s1_event(\n        lat, lon, radius_km,\n        event_start, event_end,\n        label,\n        output_dir=output_dir,\n        orbit_direction=orbit_direction,\n        save_composite=True\n    )\n\n    if fetch_s2_visual_after:\n        results['s2_visual_after'] = download_s2_visual_after(\n            lat, lon, radius_km,\n            event_start, event_end,\n            label,\n            max_cloud=70, max_items=8,\n            output_dir=output_dir,\n            gamma=gamma, low_pct=low_pct, high_pct=high_pct\n        )\n    else:\n        results['s2_visual_after'] = None\n\n    n_acq = len(results['s1_acquisitions'])\n    print(f\"\\n{'#'*70}\")\n    print(f\"  SUMMARY: {label}\")\n    print(f\"  S2 baseline    : {'OK' if results['s2_baseline'] is not None else 'FAILED'}\")\n    print(f\"  S1 acquisitions: {n_acq} chips {'(ready for inference)' if n_acq > 0 else '(FAILED)'}\")\n    s2v = results['s2_visual_after']\n    print(f\"  S2 visual after: {'OK' if s2v is not None else 'Not available — use S1 false-color'}\")\n    if n_acq == 0:\n        print(f\"  ACTION: S1 retrieval failed. Verify sentinel-1-rtc on Planetary Computer\")\n        print(f\"  covers this bbox. Try a wider radius or check PC data availability map.\")\n    print(f\"{'#'*70}\\n\")\n\n    return results\n\n\n# ==========================================\n# 8. MAIN\n# ==========================================\nif __name__ == \"__main__\":\n    warnings.filterwarnings(\"ignore\")\n\n    OUTPUT_DIR = \"./flood_composites\"\n    GAMMA    = 0.55\n    LOW_PCT  = 1.0\n    HIGH_PCT = 98.0\n\n    # Pakistan 2022 flood event\n    # Baseline: Jan-Jun 2022 (dry season, pre-monsoon)\n    # Event   : Aug-Sep 2022 (peak inundation)\n    pakistan_locations = [\n        {\"lat\": 26.73, \"lon\": 67.78, \"radius_km\": 20, \"label\": \"Dadu_Sindh\"},\n        {\"lat\": 27.70, \"lon\": 68.87, \"radius_km\": 20, \"label\": \"Sukkur_Sindh\"},\n        {\"lat\": 28.28, \"lon\": 68.43, \"radius_km\": 20, \"label\": \"Jacobabad_Sindh\"},\n        {\"lat\": 30.06, \"lon\": 70.64, \"radius_km\": 20, \"label\": \"DG_Khan_Punjab\"},\n        {\"lat\": 34.01, \"lon\": 71.99, \"radius_km\": 20, \"label\": \"Nowshera_KPK\"},\n    ]\n\n    # International events (each has its own temporal window)\n    international_locations = [\n        {\n            \"lat\": 24.90, \"lon\": 91.87, \"radius_km\": 20,\n            \"label\": \"Sylhet_Bangladesh\",\n            \"baseline_start\": \"2022-01-01\", \"baseline_end\": \"2022-04-30\",\n            \"event_start\":    \"2022-06-01\", \"event_end\":    \"2022-07-31\",\n        },\n        {\n            \"lat\": 46.64, \"lon\": 32.62, \"radius_km\": 20,\n            \"label\": \"Kherson_Ukraine\",\n            \"baseline_start\": \"2023-03-01\", \"baseline_end\": \"2023-05-31\",\n            \"event_start\":    \"2023-06-06\", \"event_end\":    \"2023-07-31\",\n        },\n        {\n            \"lat\": -29.86, \"lon\": 31.01, \"radius_km\": 20,\n            \"label\": \"KwaZuluNatal_SA\",\n            \"baseline_start\": \"2022-01-01\", \"baseline_end\": \"2022-03-31\",\n            \"event_start\":    \"2022-04-11\", \"event_end\":    \"2022-05-31\",\n        },\n    ]\n\n    for loc in pakistan_locations:\n        try:\n            download_flood_pair(\n                lat=loc[\"lat\"], lon=loc[\"lon\"], radius_km=loc[\"radius_km\"],\n                baseline_start=\"2022-01-01\", baseline_end=\"2022-06-30\",\n                event_start=\"2022-08-01\",    event_end=\"2022-09-30\",\n                label=loc[\"label\"],\n                orbit_direction=None,\n                output_dir=OUTPUT_DIR,\n                fetch_s2_visual_after=True,\n                gamma=GAMMA, low_pct=LOW_PCT, high_pct=HIGH_PCT\n            )\n        except Exception as e:\n            print(f\"  ERROR [{loc['label']}]: {type(e).__name__}: {e}\")\n\n    for loc in international_locations:\n        try:\n            download_flood_pair(\n                lat=loc[\"lat\"], lon=loc[\"lon\"], radius_km=loc[\"radius_km\"],\n                baseline_start=loc[\"baseline_start\"], baseline_end=loc[\"baseline_end\"],\n                event_start=loc[\"event_start\"],       event_end=loc[\"event_end\"],\n                label=loc[\"label\"],\n                orbit_direction=None,\n                output_dir=OUTPUT_DIR,\n                fetch_s2_visual_after=Tru