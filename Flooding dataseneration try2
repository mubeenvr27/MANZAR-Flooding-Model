{"metadata":{"kernelspec":{"language":"python","display_name":"Python 3","name":"python3"},"language_info":{"name":"python","version":"3.12.12","mimetype":"text/x-python","codemirror_mode":{"name":"ipython","version":3},"pygments_lexer":"ipython3","nbconvert_exporter":"python","file_extension":".py"},"kaggle":{"accelerator":"nvidiaTeslaT4","dataSources":[{"sourceType":"modelInstanceVersion","sourceId":847241,"databundleVersionId":16904755,"modelInstanceId":644235,"modelId":656197,"isSourceIdPinned":false}],"dockerImageVersionId":31329,"isInternetEnabled":true,"language":"python","sourceType":"notebook","isGpuEnabled":true}},"nbformat_minor":4,"nbformat":4,"cells":[{"cell_type":"code","source":"","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"# Libararies","metadata":{}},{"cell_type":"code","source":"# Run this cell first to install all required packages\n!pip install pystac-client planetary-computer stackstac pyproj rioxarray dask -q\n!pip install segmentation-models-pytorch rasterio -q","metadata":{"_uuid":"8f2839f25d086af736a60e9eeb907d3b93b6e0e5","_cell_guid":"b1076dfc-b9ad-4769-8c92-a6c4dae69d19","trusted":true,"execution":{"iopub.status.busy":"2026-04-26T09:11:51.046965Z","iopub.execute_input":"2026-04-26T09:11:51.047230Z","iopub.status.idle":"2026-04-26T09:12:03.920568Z","shell.execute_reply.started":"2026-04-26T09:11:51.047202Z","shell.execute_reply":"2026-04-26T09:12:03.919815Z"}},"outputs":[{"name":"stdout","text":"\u001b[2K   \u001b[90m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m \u001b[32m41.8/41.8 kB\u001b[0m \u001b[31m1.6 MB/s\u001b[0m eta \u001b[36m0:00:00\u001b[0m\n\u001b[2K   \u001b[90m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m \u001b[32m64.3/64.3 kB\u001b[0m \u001b[31m3.5 MB/s\u001b[0m eta \u001b[36m0:00:00\u001b[0m\n\u001b[2K   \u001b[90m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m \u001b[32m72.0/72.0 kB\u001b[0m \u001b[31m5.2 MB/s\u001b[0m eta \u001b[36m0:00:00\u001b[0m\n\u001b[2K   \u001b[90m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m \u001b[32m208.5/208.5 kB\u001b[0m \u001b[31m8.4 MB/s\u001b[0m eta \u001b[36m0:00:00\u001b[0m\n\u001b[2K   \u001b[90m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m \u001b[32m1.4/1.4 MB\u001b[0m \u001b[31m34.6 MB/s\u001b[0m eta \u001b[36m0:00:00\u001b[0m00:01\u001b[0m\n\u001b[2K   \u001b[90m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m \u001b[32m154.8/154.8 kB\u001b[0m \u001b[31m3.3 MB/s\u001b[0m eta \u001b[36m0:00:00\u001b[0m00:01\u001b[0m\n\u001b[?25h","output_type":"stream"}],"execution_count":1},{"cell_type":"markdown","source":"# Image Downloader","metadata":{}},{"cell_type":"code","source":"\"\"\"\nflood_image_downloader.py\n=========================\nSensor routing:\n  BEFORE  -> Sentinel-2 L2A (dry season, cloud-free)\n             Purpose: MNDWI permanent-water baseline + RGB visual\n  AFTER   -> Sentinel-1 RTC, SINGLE ORBIT DIRECTION (all-weather SAR)\n             Purpose: per-acquisition VV/VH chips for Sen1Floods11 inference\n  VISUAL  -> Sentinel-2 L2A (optional, relaxed cloud, display only)\n\nORBIT DIRECTION POLICY\n======================\nNever mix ascending and descending passes in the same temporal stack.\nAscending and descending SAR acquisitions have opposite look angles.\nStacking them averages illuminated terrain with radar shadow, layover-left\nwith layover-right, and different incidence angles that change baseline\nsigma0 for vegetation and soil. On flat ground this creates a noisy\ncomposite; on terrain (Nowshera, DG Khan) it produces geometric garbage.\n\nPer-location orbit directions below are selected based on:\n1. Which direction has denser Sentinel-1 revisit coverage over Pakistan\n2. Look angle relative to dominant terrain orientation\n3. Minimising layover/shadow for the specific AOI\n\nPakistan SAR coverage notes:\n  - Sentinel-1A/B descending passes cover Pakistan at ~6-day revisit\n  - Ascending passes are available but less dense over western Pakistan\n  - For flat floodplains (Sindh): either works; descending chosen for consistency\n  - For terrain (Nowshera, DG Khan): descending look angle (right-looking,\n    from NW) gives better valley illumination than ascending\n  - Sialkot (Punjab plains): ascending chosen (better east-facing illumination\n    for the Siwalik foothills edge; more acquisitions in 2025 window)\n\nIf auto_select_orbit=True is passed, the function queries both directions,\ncounts acquisitions, and picks whichever has MORE acquisitions for the\ngiven AOI and date window. This is the safe default for new AOIs.\n\"\"\"\n\nimport pystac_client\nimport planetary_computer\nimport stackstac\nimport pyproj\nimport numpy as np\nimport xarray as xr\nfrom shapely.geometry import box\nfrom shapely.ops import transform\nfrom dask.diagnostics import ProgressBar\nimport rioxarray\nimport warnings\nfrom scipy.ndimage import median_filter\nfrom scipy.spatial import cKDTree\nfrom typing import List, Optional, Tuple\nfrom PIL import Image, ImageEnhance\nimport time\nimport os\n\n\n# ==========================================\n# 1. UTM ALIGNMENT\n# ==========================================\ndef get_utm_params(lat: float, lon: float, radius_km: float):\n    utm_zone = int((lon + 180) / 6) + 1\n    epsg = 32600 + utm_zone if lat >= 0 else 32700 + utm_zone\n    wgs84 = pyproj.CRS(\"EPSG:4326\")\n    utm   = pyproj.CRS.from_epsg(epsg)\n    to_utm = pyproj.Transformer.from_crs(wgs84, utm, always_xy=True).transform\n    to_wgs = pyproj.Transformer.from_crs(utm, wgs84, always_xy=True).transform\n\n    x_c, y_c = to_utm(lon, lat)\n    x_c, y_c = round(x_c / 10) * 10, round(y_c / 10) * 10\n    r_m = radius_km * 1000\n\n    utm_bounds = (x_c - r_m, y_c - r_m, x_c + r_m, y_c + r_m)\n    wgs_bounds = transform(to_wgs, box(*utm_bounds)).bounds\n    return utm_bounds, epsg, wgs_bounds\n\n\n# ==========================================\n# 2. VISUAL ENHANCEMENT (S2 only)\n# ==========================================\ndef apply_visual_enhancement(\n    data: xr.DataArray,\n    gamma: float = 0.55,\n    low_pct: float = 1.0,\n    high_pct: float = 98.0,\n    saturation_boost: float = 1.3,\n) -> np.ndarray:\n    rgb_indices = [2, 1, 0]   # B04(R), B03(G), B02(B)\n    channels = []\n    for idx in rgb_indices:\n        band = data[idx].values.astype(np.float32)\n        valid = band[~np.isnan(band)]\n        if len(valid) == 0:\n            channels.append(np.zeros(band.shape, dtype=np.float32))\n            continue\n        lo, hi = np.percentile(valid, [low_pct, high_pct])\n        band = np.clip(band, lo, hi)\n        band = (band - lo) / (hi - lo + 1e-10)\n        band = np.where(np.isnan(band), 0.0, band)\n        band = np.power(band, gamma)\n        channels.append(band)\n    rgb = np.stack(channels, axis=-1)\n    try:\n        pil_img = Image.fromarray((rgb * 255).astype(np.uint8), mode=\"RGB\")\n        pil_img = ImageEnhance.Color(pil_img).enhance(saturation_boost)\n        rgb = np.array(pil_img).astype(np.float32) / 255.0\n    except Exception:\n        pass\n    return (rgb * 255).astype(np.uint8)\n\n\ndef save_visual_png(data: xr.DataArray, path: str, **kw):\n    arr = apply_visual_enhancement(data, **kw)\n    Image.fromarray(arr, mode=\"RGB\").save(path)\n    h, w = arr.shape[:2]\n    print(f\"   PNG: {os.path.basename(path)} ({w}x{h}px)\")\n\n\n# ==========================================\n# 3. SHARED UTILITIES\n# ==========================================\ndef interpolate_missing_pixels(data: xr.DataArray, max_distance: int = 80) -> xr.DataArray:\n    out = data.copy()\n    for bi in range(data.shape[0]):\n        band = data[bi].values.copy()\n        nan_n = int(np.sum(np.isnan(band)))\n        if nan_n == 0:\n            continue\n        valid_coords   = np.argwhere(~np.isnan(band))\n        invalid_coords = np.argwhere(np.isnan(band))\n        if len(valid_coords) == 0:\n            continue\n        from scipy.spatial import cKDTree\n        tree = cKDTree(valid_coords)\n        dists, idxs = tree.query(invalid_coords, k=1)\n        for i in np.where(dists < max_distance)[0]:\n            iy, ix = invalid_coords[i]\n            vy, vx = valid_coords[idxs[i]]\n            band[iy, ix] = band[vy, vx]\n        filled = nan_n - int(np.sum(np.isnan(band)))\n        print(f\"      Band {bi+1}: {filled:,} filled, {int(np.sum(np.isnan(band))):,} remain\")\n        out[bi].values = band\n    return out\n\n\ndef apply_selective_filtering(data: xr.DataArray, filter_size: int = 3) -> xr.DataArray:\n    out = data.copy()\n    for bi in range(data.shape[0]):\n        band = data[bi].values\n        valid = ~np.isnan(band)\n        if not np.any(valid):\n            continue\n        tmp = band.copy()\n        tmp[~valid] = float(np.median(band[valid]))\n        filtered = median_filter(tmp, size=filter_size, mode=\"nearest\")\n        band[valid] = filtered[valid]\n        out[bi].values = band\n    return out\n\n\ndef report_statistics(data: xr.DataArray, names: List[str]):\n    print(\"   \" + \"-\" * 65)\n    print(\"   {:14} {:>9} {:>9} {:>9} {:>9} {:>9}\".format(\n        \"Band\", \"Mean\", \"Std\", \"Min\", \"Max\", \"NaN%\"))\n    print(\"   \" + \"-\" * 65)\n    for i in range(data.shape[0]):\n        b = data[i].values\n        v = b[~np.isnan(b)]\n        nm = names[i] if i < len(names) else f\"Band {i}\"\n        if len(v) > 0:\n            print(\"   {:14} {:>9.4f} {:>9.4f} {:>9.4f} {:>9.4f} {:>8.2f}%\".format(\n                nm, float(np.mean(v)), float(np.std(v)),\n                float(np.min(v)), float(np.max(v)),\n                np.sum(np.isnan(b)) / b.size * 100))\n        else:\n            print(f\"   {nm:14} ALL NaN\")\n\n\ndef open_catalog() -> pystac_client.Client:\n    return pystac_client.Client.open(\n        \"https://planetarycomputer.microsoft.com/api/stac/v1\",\n        modifier=planetary_computer.sign_inplace,\n    )\n\n\n# ==========================================\n# 4. ORBIT AUTO-SELECTOR\n# ==========================================\ndef select_best_orbit(\n    wgs_bounds: tuple,\n    date_start: str,\n    date_end: str,\n    catalog: pystac_client.Client,\n) -> str:\n    \"\"\"\n    Query both ascending and descending passes for the given bbox + window.\n    Return whichever direction has MORE available acquisitions.\n    Tie goes to descending (historically denser over South Asia).\n\n    This is called automatically when orbit_direction=None is passed to\n    download_s1_event(). Call it explicitly if you want to inspect counts\n    before committing.\n    \"\"\"\n    counts = {}\n    for direction in (\"ascending\", \"descending\"):\n        result = catalog.search(\n            collections=[\"sentinel-1-rtc\"],\n            bbox=wgs_bounds,\n            datetime=f\"{date_start}/{date_end}\",\n            query={\"sat:orbit_state\": {\"eq\": direction}},\n            max_items=200,\n        )\n        counts[direction] = len(list(result.items()))\n        print(f\"  Orbit survey: {direction:12s} -> {counts[direction]} acquisitions\")\n\n    best = max(counts, key=counts.get)\n    if counts[\"ascending\"] == counts[\"descending\"]:\n        best = \"descending\"   # tie-break: descending more consistent over Pakistan\n    print(f\"  Auto-selected orbit: {best.upper()} \"\n          f\"({counts[best]} acqs vs {counts['ascending' if best == 'descending' else 'descending']} other)\")\n    return best\n\n\n# ==========================================\n# 5. SENTINEL-2 BASELINE\n# ==========================================\ndef download_s2_baseline(\n    lat: float,\n    lon: float,\n    radius_km: float,\n    date_start: str,\n    date_end: str,\n    label: str,\n    max_cloud: int = 30,\n    max_items: int = 15,\n    output_dir: str = \".\",\n    gamma: float = 0.55,\n    low_pct: float = 1.0,\n    high_pct: float = 98.0,\n) -> Optional[xr.DataArray]:\n    \"\"\"\n    Download Sentinel-2 L2A dry-season median composite.\n    Outputs [B02, B03, B04, B08, B11, B12] float32 reflectance.\n    Used for: MNDWI permanent-water mask + before-panel visual.\n    \"\"\"\n    os.makedirs(output_dir, exist_ok=True)\n    t0 = time.time()\n\n    print(f\"\\n{'='*70}\")\n    print(f\"  [S2 BASELINE] {label}  |  {date_start} -> {date_end}\")\n    print(f\"  Cloud <{max_cloud}%  |  Max scenes: {max_items}\")\n    print(f\"{'='*70}\")\n\n    utm_bounds, epsg, wgs_bounds = get_utm_params(lat, lon, radius_km)\n    catalog = open_catalog()\n\n    search = catalog.search(\n        collections=[\"sentinel-2-l2a\"],\n        bbox=wgs_bounds,\n        datetime=f\"{date_start}/{date_end}\",\n        query={\"eo:cloud_cover\": {\"lt\": max_cloud}},\n        sortby=[{\"field\": \"properties.eo:cloud_cover\", \"direction\": \"asc\"}],\n        max_items=50,\n    )\n    items = list(search.items())\n\n    if not items:\n        relaxed = min(max_cloud + 15, 50)\n        print(f\"  No scenes at <{max_cloud}%. Retrying at <{relaxed}%...\")\n        search = catalog.search(\n            collections=[\"sentinel-2-l2a\"],\n            bbox=wgs_bounds,\n            datetime=f\"{date_start}/{date_end}\",\n            query={\"eo:cloud_cover\": {\"lt\": relaxed}},\n            sortby=[{\"field\": \"properties.eo:cloud_cover\", \"direction\": \"asc\"}],\n            max_items=50,\n        )\n        items = list(search.items())\n\n    if not items:\n        print(\"  FAILED: No S2 scenes found.\")\n        return None\n\n    n = min(max_items, len(items))\n    print(f\"  Found {len(items)} scenes, stacking top {n}\")\n\n    reflectance_bands = [\"B02\", \"B03\", \"B04\", \"B08\", \"B11\", \"B12\"]\n    slices = []\n\n    for i, item in enumerate(items[:n]):\n        pb = item.properties.get(\"s2:processing_baseline\", \"02.00\")\n        try:\n            is_new = float(pb) >= 4.0\n        except (ValueError, TypeError):\n            is_new = str(pb) >= \"04.00\"\n        cc = item.properties.get(\"eo:cloud_cover\", \"?\")\n        dt = item.properties.get(\"datetime\", \"?\")[:10]\n\n        try:\n            cube = stackstac.stack(\n                item,\n                assets=reflectance_bands + [\"SCL\"],\n                bounds=utm_bounds,\n                epsg=epsg,\n                resolution=10,\n                dtype=\"float64\",\n                rescale=True,\n                fill_value=np.nan,\n            ).squeeze()\n        except Exception as e:\n            print(f\"    [{i+1}/{n}] SKIP: {e}\")\n            continue\n\n        if is_new:\n            for b in reflectance_bands:\n                if b in cube.band.values:\n                    cube.loc[dict(band=b)] -= 0.1\n\n        if \"SCL\" in cube.band.values:\n            bad = cube.sel(band=\"SCL\").isin([0, 1, 3, 8, 9, 10])\n            for b in reflectance_bands:\n                if b in cube.band.values:\n                    cube.loc[dict(band=b)] = cube.sel(band=b).where(~bad)\n\n        slices.append(cube.sel(band=reflectance_bands))\n        print(f\"    [{i+1}/{n}] {dt} | cloud:{cc:.1f}%\")\n\n    if not slices:\n        print(\"  FAILED: All scenes errored.\")\n        return None\n\n    print(f\"\\n  Computing median composite ({len(slices)} scenes)...\")\n    cube = xr.concat(slices, dim=\"time\", combine_attrs=\"override\")\n    with ProgressBar():\n        data = cube.median(dim=\"time\", skipna=True).compute().astype(\"float32\")\n        data = data.where(data >= 0, 0)\n\n    data = data.rio.write_nodata(np.nan).rio.write_crs(f\"EPSG:{epsg}\")\n    data = interpolate_missing_pixels(data, max_distance=80)\n    data = apply_selective_filtering(data, filter_size=3)\n    report_statistics(data, [\"Blue(B02)\", \"Green(B03)\", \"Red(B04)\", \"NIR(B08)\", \"SWIR1(B11)\", \"SWIR2(B12)\"])\n\n    stem     = f\"{label}_s2_baseline_{date_start}_{date_end}\"\n    tif_path = os.path.join(output_dir, stem + \".tif\")\n    data.rio.to_raster(tif_path, compress=\"LZW\", tiled=True,\n                       blockxsize=256, blockysize=256, dtype=\"float32\", nodata=np.nan)\n    print(f\"  GeoTIFF: {tif_path}\")\n\n    save_visual_png(data, os.path.join(output_dir, stem + \"_visual.png\"),\n                    gamma=gamma, low_pct=low_pct, high_pct=high_pct)\n\n    print(f\"  Done in {time.time()-t0:.1f}s | {data.shape[2]}x{data.shape[1]}px\")\n    return data\n\n\n# ==========================================\n# 6. SENTINEL-1 EVENT DOWNLOADER\n#    SINGLE ORBIT DIRECTION ENFORCED\n# ==========================================\ndef download_s1_event(\n    lat: float,\n    lon: float,\n    radius_km: float,\n    date_start: str,\n    date_end: str,\n    label: str,\n    output_dir: str = \".\",\n    orbit_direction: Optional[str] = None,   # \"ascending\" | \"descending\" | None = auto-select\n    save_composite: bool = True,\n) -> List[Tuple[str, xr.DataArray]]:\n    \"\"\"\n    Download Sentinel-1 RTC acquisitions for the active flood window.\n\n    ORBIT DIRECTION CONTRACT\n    ------------------------\n    orbit_direction MUST be either \"ascending\" or \"descending\".\n    If None is passed, select_best_orbit() is called to automatically\n    pick the direction with more acquisitions for this AOI + window,\n    and that single direction is locked for the entire download.\n\n    Mixing ascending and descending passes in a temporal stack is FORBIDDEN.\n    The reason: opposite look angles produce inverted shadow/layover geometry,\n    different incidence angles alter baseline sigma0 for all surface types,\n    and the temporal mean composite becomes geometrically incoherent.\n    On terrain (Nowshera, DG Khan) this produces unusable garbage.\n    On flat ground it still introduces backscatter biases that shift flood\n    probability estimates and corrupt the severity index.\n\n    Each saved GeoTIFF filename encodes the orbit direction:\n      {label}_s1_{date}_{ascending|descending}.tif\n    The inference notebook uses all chips matching the label prefix, so\n    all chips will share the same orbit direction after this fix.\n\n    Returns list of (acquisition_date, DataArray) tuples.\n    Each DataArray: shape (2, H, W), band 0 = VV dB, band 1 = VH dB.\n    dB conversion: 10 * log10(linear_sigma0), clipped to [-35, 5] dB.\n    \"\"\"\n    os.makedirs(output_dir, exist_ok=True)\n    t0 = time.time()\n\n    utm_bounds, epsg, wgs_bounds = get_utm_params(lat, lon, radius_km)\n    catalog = open_catalog()\n\n    # ── Enforce single orbit direction ────────────────────────────────\n    if orbit_direction is None:\n        print(f\"\\n  orbit_direction=None: running auto-selection...\")\n        orbit_direction = select_best_orbit(wgs_bounds, date_start, date_end, catalog)\n    elif orbit_direction not in (\"ascending\", \"descending\"):\n        raise ValueError(\n            f\"orbit_direction must be 'ascending', 'descending', or None. \"\n            f\"Got: '{orbit_direction}'. \"\n            f\"Passing orbit_direction=None mixes SAR look angles and corrupts the stack.\"\n        )\n\n    print(f\"\\n{'='*70}\")\n    print(f\"  [S1 EVENT] {label}  |  {date_start} -> {date_end}\")\n    print(f\"  Orbit: {orbit_direction.upper()} only  |  All-weather, no cloud filter\")\n    print(f\"{'='*70}\")\n\n    search = catalog.search(\n        collections=[\"sentinel-1-rtc\"],\n        bbox=wgs_bounds,\n        datetime=f\"{date_start}/{date_end}\",\n        query={\"sat:orbit_state\": {\"eq\": orbit_direction}},   # STRICT: single direction\n        sortby=[{\"field\": \"properties.datetime\", \"direction\": \"asc\"}],\n        max_items=100,\n    )\n    items = list(search.items())\n\n    if not items:\n        print(f\"  FAILED: No {orbit_direction} S1-RTC scenes found.\")\n        print(f\"  Options:\")\n        print(f\"    1. Try orbit_direction='{'descending' if orbit_direction == 'ascending' else 'ascending'}'\")\n        print(f\"    2. Widen the date range\")\n        print(f\"    3. Verify sentinel-1-rtc PC coverage for this bbox\")\n        return []\n\n    print(f\"  Found {len(items)} {orbit_direction} acquisitions\")\n\n    acquisitions = []\n    acq_dates    = []\n\n    for i, item in enumerate(items):\n        dt    = item.properties.get(\"datetime\", \"?\")[:10]\n        orbit = item.properties.get(\"sat:orbit_state\", \"?\")\n        plat  = item.properties.get(\"platform\", \"?\")\n\n        # Double-check: reject any item that slipped through with wrong direction\n        if orbit != orbit_direction:\n            print(f\"    [{i+1}] SKIP: unexpected orbit={orbit} (expected {orbit_direction})\")\n            continue\n\n        try:\n            cube = stackstac.stack(\n                item,\n                assets=[\"vv\", \"vh\"],\n                bounds=utm_bounds,\n                epsg=epsg,\n                resolution=10,\n                dtype=\"float64\",\n                rescale=False,       # keep linear sigma0; convert to dB below\n                fill_value=np.nan,\n            ).squeeze()\n\n            with ProgressBar():\n                arr = cube.compute().astype(\"float32\")\n\n        except Exception as e:\n            print(f\"    [{i+1}/{len(items)}] {dt} SKIP: {e}\")\n            continue\n\n        # Convert linear sigma0 -> dB\n        arr_db = arr.copy()\n        for bi in range(arr.shape[0]):\n            band       = arr[bi].values.copy()\n            valid      = (band > 0) & ~np.isnan(band)\n            band[~valid] = np.nan\n            band[valid]  = 10.0 * np.log10(band[valid])\n            band         = np.clip(band, -35.0, 5.0)\n            arr_db[bi].values = band\n\n        arr_db = arr_db.rio.write_nodata(np.nan).rio.write_crs(f\"EPSG:{epsg}\")\n\n        # Filename encodes orbit direction for traceability\n        acq_stem = f\"{label}_s1_{dt}_{orbit_direction}\"\n        tif_path = os.path.join(output_dir, acq_stem + \".tif\")\n        arr_db.rio.to_raster(\n            tif_path,\n            compress=\"LZW\", tiled=True,\n            blockxsize=256, blockysize=256,\n            dtype=\"float32\", nodata