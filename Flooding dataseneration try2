 ONLY\n======================================================================\n  Found 35 scenes, using top 8\n    [1/8] 2022-05-28 | cloud:0.5%\n    [2/8] 2022-05-28 | cloud:0.5%\n    [3/8] 2022-05-28 | cloud:0.0%\n    [4/8] 2022-05-28 | cloud:0.0%\n    [5/8] 2022-05-18 | cloud:0.0%\n    [6/8] 2022-05-18 | cloud:0.0%\n    [7/8] 2022-05-18 | cloud:0.0%\n    [8/8] 2022-05-18 | cloud:0.0%\n[########################################] | 100% Completed | 69.68 s\n  NaN coverage: 0.0% — acceptable.\n   PNG: KwaZuluNatal_SA_s2_visual_after_2022-04-11_2022-05-31.png (4000x4000px)\n  Done in 115.9s\n\n######################################################################\n  SUMMARY: KwaZuluNatal_SA\n  S2 baseline    : OK\n  S1 acquisitions: 3 chips (ready for inference)\n  S2 visual after: OK\n######################################################################\n\n","output_type":"stream"}],"execution_count":11},{"cell_type":"code","source":"# !pip install segmentation-models-pytorch rasterio -q\n\nimport os, glob, json, warnings\nimport numpy as np\nimport torch\nimport torch.nn as nn\nimport torch.nn.functional as F\nimport segmentation_models_pytorch as smp\nimport rasterio\nfrom rasterio.enums import Resampling\nimport matplotlib.pyplot as plt\nimport matplotlib.patches as mpatches\nimport matplotlib.gridspec as gridspec\nfrom matplotlib.colors import ListedColormap\nfrom PIL import Image, ImageEnhance\nfrom tqdm.auto import tqdm\nwarnings.filterwarnings(\"ignore\")\n\n# ═══════════════════════════════════════════════════════════════════════\n# CONFIG\n# ═══════════════════════════════════════════════════════════════════════\nCOMPOSITES_DIR = \"./flood_composites\"\nMODEL_PATH     = \"/kaggle/input/models/muhammadmubeenxt/flooding-model/pytorch/default/1/ablation_best_flood_model_full.pth\"\nMASKS_PNG_DIR  = \"./masks_pngs\"\nMETRICS_JSON   = \"./flood_metrics.json\"\nos.makedirs(MASKS_PNG_DIR, exist_ok=True)\n\n# Locations - label must match exactly what the downloader used\nLOCATIONS = [\n    (\"Sialkot_punjab\",    32.496304,  74.538327),\n    (\"Dadu_Sindh\",        26.73,      67.78),\n    (\"Sukkur_Sindh\",      27.70,      68.87),\n    (\"Jacobabad_Sindh\",   28.28,      68.43),\n    (\"DG_Khan_Punjab\",    30.06,      70.64),\n    (\"Nowshera_KPK\",      34.01,      71.99),\n    # (\"Sylhet_Bangladesh\", 24.90,  91.87),\n    # (\"Kherson_Ukraine\",   46.64,  32.62),\n    # (\"KwaZuluNatal_SA\",  -29.86,  31.01),\n]\n\nFLOOD_THRESHOLD  = 0.35    # Lowered from 0.50: accounts for S1-RTC calibration offset vs GRD\nPERM_WATER_MNDWI = 0.00    # MNDWI > 0 = permanent water\nSAR_ONLY_MODE    = True    # ALWAYS True: dry-season S2 + event-period S1 = contradicting streams\nTILE_SIZE        = 512\nTILE_OVERLAP     = 128\nTILE_STRIDE      = TILE_SIZE - TILE_OVERLAP\nPIXEL_AREA_KM2   = (10.0 * 10.0) / 1e6\n\ndevice = torch.device(\"cuda\" if torch.cuda.is_available() else \"cpu\")\nprint(f\"Device     : {device}\")\nprint(f\"SAR only   : {SAR_ONLY_MODE}\")\nprint(f\"Threshold  : {FLOOD_THRESHOLD}\")\n\n\n# ═══════════════════════════════════════════════════════════════════════\n# MODEL\n# ═══════════════════════════════════════════════════════════════════════\nclass CBAM(nn.Module):\n    def __init__(self, channels, reduction=8):\n        super().__init__()\n        self.avg = nn.AdaptiveAvgPool2d(1)\n        self.max = nn.AdaptiveMaxPool2d(1)\n        self.fc  = nn.Sequential(\n            nn.Linear(channels, channels // reduction, bias=False),\n            nn.ReLU(inplace=True),\n            nn.Linear(channels // reduction, channels, bias=False))\n        self.sc  = nn.Conv2d(2, 1, kernel_size=7, padding=3, bias=False)\n\n    def forward(self, x):\n        b, c = x.shape[:2]\n        a = self.fc(self.avg(x).view(b, c))\n        m = self.fc(self.max(x).view(b, c))\n        x = x * torch.sigmoid(a + m).view(b, c, 1, 1)\n        s = torch.cat([x.mean(1, keepdim=True), x.max(1, keepdim=True)[0]], dim=1)\n        return x * torch.sigmoid(self.sc(s))\n\n\nclass DualStreamUNetPP(nn.Module):\n    # SAR stream [ch 0,1,7]: VV,VH,SAR-ratio (3ch)\n    # Opt stream [ch 2-6,8-9]: B,G,R,NIR,NDWI,SWIR1,MNDWI (7ch)\n    # SAR_ONLY_MODE=True zeros ch 2-9 before forward pass\n    def __init__(self, use_cbam=True):\n        super().__init__()\n        self.use_cbam = use_cbam\n        self.sar_enc  = smp.UnetPlusPlus(encoder_name=\"resnet50\", encoder_weights=None,\n                                          in_channels=3, classes=32)\n        self.opt_enc  = smp.UnetPlusPlus(encoder_name=\"resnet50\", encoder_weights=None,\n                                          in_channels=7, classes=32)\n        if use_cbam:\n            self.cbam = CBAM(64)\n        self.head = nn.Sequential(\n            nn.Conv2d(64, 32, 3, padding=1, bias=False),\n            nn.BatchNorm2d(32), nn.ReLU(inplace=True),\n            nn.Dropout2d(p=0.15), nn.Conv2d(32, 1, 1))\n\n    def forward(self, x):\n        sar = torch.cat([x[:, 0:2], x[:, 7:8]], dim=1)    # VV, VH, ratio\n        opt = torch.cat([x[:, 2:7], x[:, 8:10]], dim=1)   # optical 7ch\n        f   = torch.cat([self.sar_enc(sar), self.opt_enc(opt)], dim=1)\n        if self.use_cbam:\n            f = self.cbam(f)\n        return self.head(f)\n\n\ndef load_model(path, device):\n    if not os.path.exists(path):\n        raise FileNotFoundError(f\"Checkpoint not found: {path}\")\n    m     = DualStreamUNetPP(use_cbam=True)\n    raw   = torch.load(path, map_location=device)\n    state = raw.get(\"model_state\", raw)\n    # Strip DataParallel prefix\n    state = {k.replace(\"module.\", \"\"): v for k, v in state.items()}\n    # Remap v7 key names -> v8 (sar_encoder -> sar_enc, opt_encoder -> opt_enc)\n    remapped = {}\n    for k, v in state.items():\n        k = k.replace(\"sar_encoder.\", \"sar_enc.\").replace(\"opt_encoder.\", \"opt_enc.\")\n        remapped[k] = v\n    missing, unexpected = m.load_state_dict(remapped, strict=False)\n    if missing:    print(f\"  Missing keys   : {missing[:3]}\")\n    if unexpected: print(f\"  Unexpected keys: {unexpected[:3]}\")\n    m.to(device).eval()\n    print(f\"  Model loaded: {sum(p.numel() for p in m.parameters())/1e6:.1f}M params\")\n    return m\n\nmodel = load_model(MODEL_PATH, device)\n\n\n# ═══════════════════════════════════════════════════════════════════════\n# FILE DISCOVERY\n# Naming from flood_image_downloader.py:\n#   S2 baseline TIF : {label}_s2_baseline_{start}_{end}.tif\n#   S1 composite TIF: {label}_s1_{orbit}_composite_{start}_{end}.tif\n#   S1 falsecolor PNG:{label}_s1_{orbit}_falsecolor_{start}_{end}.png\n#   S2 before PNG   : {label}_s2_baseline_{start}_{end}_visual.png\n#   S2 after PNG    : {label}_s2_visual_after_{start}_{end}.png\n# ═══════════════════════════════════════════════════════════════════════\ndef find_file(base_dir, pattern):\n    # Glob for a file; return the most recent match or None.\n    hits = sorted(glob.glob(os.path.join(base_dir, pattern)))\n    return hits[-1] if hits else None\n\ndef discover(label, composites_dir):\n    # (see function name for description)\n    d = {}\n    # S2 baseline GeoTIFF  (reflectance [0,1], 6 bands: B02 B03 B04 B08 B11 B12)\n    d[\"s2_tif\"] = find_file(composites_dir, f\"{label}_s2_baseline_*.tif\")\n\n    # S1 composite GeoTIFF (already in dB, 2 bands: VV VH)\n    # NEW naming from fixed downloader: {label}_s1_{orbit}_composite_{start}_{end}.tif\n    # OLD naming (pre-orbit-fix):        {label}_s1_composite_{start}_{end}.tif\n    # Accept both patterns; prefer new\n    d[\"s1_tif\"] = (\n        find_file(composites_dir, f\"{label}_s1_*_composite_*.tif\") or\n        find_file(composites_dir, f\"{label}_s1_composite_*.tif\")\n    )\n\n    # Visual PNGs (already rendered by downloader, load directly)\n    d[\"s2_before_png\"] = find_file(composites_dir, f\"{label}_s2_baseline_*_visual.png\")\n    d[\"s1_after_png\"]  = (\n        find_file(composites_dir, f\"{label}_s1_*_falsecolor_*.png\") or\n        find_file(composites_dir, f\"{label}_s1_falsecolor_*.png\")\n    )\n    d[\"s2_after_png\"]  = find_file(composites_dir, f\"{label}_s2_visual_after_*.png\")\n\n    return d\n\n\n# ═══════════════════════════════════════════════════════════════════════\n# TENSOR BUILDER\n# S2: already [0,1] from downloader (stackstac rescale=True) - NO /10000\n# S1: already in dB  from downloader (log10 done at download time) - NO log10 again\n# SAR_ONLY_MODE: zero channels 2-9; matches cloud_sim_mode=True training path\n# ═══════════════════════════════════════════════════════════════════════\ndef load_tif(path):\n    with rasterio.open(path) as src:\n        return src.read().astype(np.float32), src.transform, src.crs\n\ndef match_hw(arr, target_hw):\n    # Resize source [C,H,W] to target_hw=(H,W) using bilinear interpolation.\n    tH, tW = target_hw\n    if arr.shape[1] == tH and arr.shape[2] == tW:\n        return arr\n    t = torch.from_numpy(arr).unsqueeze(0).float()\n    t = F.interpolate(t, size=(tH, tW), mode=\"bilinear\", align_corners=False)\n    return t.squeeze(0).numpy()\n\ndef build_tensor(s2_arr, s1_arr_db, sar_only=SAR_ONLY_MODE):\n    # (see function name for description)\n    H, W = s2_arr.shape[1], s2_arr.shape[2]\n    s1_arr_db = match_hw(s1_arr_db, (H, W))\n\n    # --- SAR normalization: dB -> [0,1] (exact training formula) ---\n    vv = np.clip((s1_arr_db[0] + 30.0) / 30.0, 0.0, 1.0)\n    vh = np.clip((s1_arr_db[1] + 30.0) / 30.0, 0.0, 1.0)\n    vv = np.nan_to_num(vv, nan=0.0)\n    vh = np.nan_to_num(vh, nan=0.0)\n\n    # SAR ratio (VV/VH), clipped to [0,10]\n    with np.errstate(divide=\"ignore\", invalid=\"ignore\"):\n        sar_r = np.where(vh > 1e-8, vv / vh, 0.0)\n    sar_r = np.clip(np.nan_to_num(sar_r, nan=0.0, posinf=0.0), 0.0, 10.0).astype(np.float32)\n\n    if sar_only:\n        # Zero all optical channels.\n        # Feeding dry-season S2 (negative MNDWI) against event-period S1 (low VV)\n        # puts contradicting signals into CBAM attention and suppresses flood output.\n        # Zeroed channels = cloud_sim_mode=True from training. Model handles this correctly.\n        tensor       = np.zeros((10, H, W), dtype=np.float32)\n        tensor[0]    = vv\n        tensor[1]    = vh\n        tensor[7]    = sar_r\n        return tensor\n\n    # Full 10-ch mode (only valid if S2 is from the same event window as S1)\n    blue  = np.clip(np.nan_to_num(s2_arr[0], nan=0.0), 0.0, 1.0)\n    green = np.clip(np.nan_to_num(s2_arr[1], nan=0.0), 0.0, 1.0)\n    red   = np.clip(np.nan_to_num(s2_arr[2], nan=0.0), 0.0, 1.0)\n    nir   = np.clip(np.nan_to_num(s2_arr[3], nan=0.0), 0.0, 1.0)\n    swir1 = np.clip(np.nan_to_num(s2_arr[4], nan=0.0), 0.0, 1.0)\n\n    with np.errstate(divide=\"ignore\", invalid=\"ignore\"):\n        ndwi  = np.where((green+nir)   > 1e-8, (green-nir)   / (green+nir),   0.0)\n        mndwi = np.where((green+swir1) > 1e-8, (green-swir1) / (green+swir1), 0.0)\n\n    tensor = np.stack([\n        vv, vh, blue, green, red, nir,\n        np.nan_to_num(ndwi,  nan=0.0).astype(np.float32),\n        sar_r, swir1,\n        np.nan_to_num(mndwi, nan=0.0).astype(np.float32),\n    ], axis=0).astype(np.float32)\n    return tensor\n\n\n# ═══════════════════════════════════════════════════════════════════════\n# TILED INFERENCE\n# ═══════════════════════════════════════════════════════════════════════\ndef _hanning_window(size):\n    lin = np.hanning(size).astype(np.float64)\n    w   = np.outer(lin, lin)\n    return np.clip(w, 1e-6, None)\n\n@torch.no_grad()\ndef tiled_predict(model, tensor, device):\n    # (see function name for description)\n    C, H, W = tensor.shape\n    win     = _hanning_window(TILE_SIZE)\n\n    pad_h = (-H) % TILE_STRIDE\n    pad_w = (-W) % TILE_STRIDE\n    if pad_h or pad_w:\n        tensor = np.pad(tensor, ((0,0),(0,pad_h),(0,pad_w)), mode=\"reflect\")\n    _, PH, PW = tensor.shape\n\n    acc   = np.zeros((PH, PW), dtype=np.float64)\n    count = np.zeros((PH, PW), dtype=np.float64)\n\n    ys = list(range(0, PH - TILE_SIZE + 1, TILE_STRIDE))\n    xs = list(range(0, PW - TILE_SIZE + 1, TILE_STRIDE))\n    if ys and ys[-1] + TILE_SIZE < PH: ys.append(PH - TILE_SIZE)\n    if xs and xs[-1] + TILE_SIZE < PW: xs.append(PW - TILE_SIZE)\n\n    model.eval()\n    coords = [(y, x) for y in ys for x in xs]\n    for y0, x0 in tqdm(coords, desc=f\"  Tiles\", leave=False):\n        chip = tensor[:, y0:y0+TILE_SIZE, x0:x0+TILE_SIZE]\n        xt   = torch.from_numpy(chip).unsqueeze(0).to(device)\n        with torch.amp.autocast(\"cuda\", enabled=(device.type == \"cuda\")):\n            prob = torch.sigmoid(model(xt)).squeeze().cpu().numpy().astype(np.float64)\n        acc  [y0:y0+TILE_SIZE, x0:x0+TILE_SIZE] += prob * win\n        count[y0:y0+TILE_SIZE, x0:x0+TILE_SIZE] += win\n\n    prob_map = (acc / np.where(count > 0, count, 1.0)).astype(np.float32)\n    prob_map = prob_map[:H, :W]\n    binary   = (prob_map >= FLOOD_THRESHOLD).astype(np.uint8)\n    return prob_map, binary\n\n\n# ═══════════════════════════════════════════════════════════════════════\n# VISUAL HELPERS\n# ═══════════════════════════════════════════════════════════════════════\ndef load_png_rgb(path):\n    # Load any PNG as uint8 RGB [H,W,3].\n    return np.array(Image.open(path).convert(\"RGB\"))\n\ndef s2_to_rgb(s2_arr, gamma=0.55, lo=1.0, hi=98.0, sat=1.3):\n    # (see function name for description)\n    chs = []\n    for idx in [2, 1, 0]:\n        b = s2_arr[idx].astype(np.float32)\n        v = b[~np.isnan(b)]\n        if not len(v):\n            chs.append(np.zeros(b.shape, np.float32)); continue\n        lo_v, hi_v = np.percentile(v, [lo, hi])\n        b = np.clip(b, lo_v, hi_v)\n        b = (b - lo_v) / (hi_v - lo_v + 1e-10)\n        b = np.power(np.clip(np.nan_to_num(b, nan=0.0), 0, 1), gamma)\n        chs.append(b)\n    rgb = np.stack(chs, axis=-1)\n    try:\n        pil = Image.fromarray((rgb*255).astype(np.uint8), \"RGB\")\n        pil = ImageEnhance.Color(pil).enhance(sat)\n        rgb = np.array(pil).astype(np.float32) / 255.0\n    except Exception:\n        pass\n    return (rgb * 255).astype(np.uint8)\n\ndef mndwi_permanent_water(s2_arr):\n    # (see function name for description)\n    green = np.clip(np.nan_to_num(s2_arr[1], nan=0.0), 0, 1)\n    swir1 = np.clip(np.nan_to_num(s2_arr[4], nan=0.0), 0, 1)\n    with np.errstate(divide=\"ignore\", invalid=\"ignore\"):\n        mndwi = np.where((green+swir1) > 1e-8, (green-swir1)/(green+swir1), 0.0)\n    mndwi = np.nan_to_num(mndwi, nan=0.0).astype(np.float32)\n    return mndwi, (mndwi > PERM_WATER_MNDWI).astype(np.uint8)\n\n\n# ═══════════════════════════════════════════════════════════════════════\n# PNG EXPORT\n# ═══════════════════════════════════════════════════════════════════════\ndef export_pngs(label, r, masks_dir):\n    # (see function name for description)\n    loc_dir = os.path.join(masks_dir, label)\n    os.makedirs(loc_dir, exist_ok=True)\n\n    def _force_uint8(arr):\n        arr = np.array(arr, dtype=np.float32)\n        if arr.max() <= 1.0:\n            arr = np.clip(arr, 0, 1) * 255\n        return np.nan_to_num(arr, nan=0.0).astype(np.uint8)\n\n    # ── UI assets ──────────────────────────────────────────────────────\n    # Before: prefer the downloader's pre-rendered PNG; fall back to computing from TIF\n    before_rgb = (load_png_rgb(r[\"s2_before_png\"])\n                  if r.get(\"s2_before_png\") else\n                  s2_to_rgb(r[\"s2_arr\"]))\n    Image.fromarray(_force_uint8(before_rgb), \"RGB\").save(\n        os.path.join(loc_dir, f\"{label}_UI_BEFORE_OPTICAL.png\"))\n\n    # After: prefer S1 falsecolor PNG (already rendered by downloader)\n    if r.get(\"s1_after_png\"):\n        after_rgb = load_png_rgb(r[\"s1_after_png\"])\n    elif r.get(\"s2_after_png\"):\n        after_rgb = load_png_rgb(r[\"s2_after_png\"])\n    else:\n        # Fallback: build S1 false-color from dB array\n        vv = r[\"s1_arr_db\"][0]; vh = r[\"s1_arr_db\"][1]\n        def _s(a, lo=2, hi=98):\n            v = a[~np.isnan(a)]\n            if not len(v): return np.zeros_like(a, np.float32)\n            lv, hv = np.percentile(v, [lo, hi])\n            return np.clip(np.nan_to_num((a-lv)/(hv-lv+1e-10), nan=0.0), 0, 1)\n        ratio = np.where(np.power(10,vh/10) > 1e-10,\n                         np.power(10,vv/10)/np.power(10,vh/10), 0.0)\n        after_rgb = (np.stack([_s(vv),_s(vh),\n                     np.clip(np.nan_to_num((ratio-np.nanpercentile(ratio[ratio>0],5))/\n                     (np.nanpercentile(ratio[ratio>0],95)-np.nanpercentile(ratio[ratio>0],5)+1e-10),nan=0.0),0,1)],\n                     axis=-1) * 255).astype(np.uint8)\n    Image.fromarray(_force_uint8(after_rgb), \"RGB\").save(\n        os.path.join(loc_dir, f\"{label}_UI_AFTER_RAW_EVENT.png\"))\n\n    # Mask overlay on baseline\n    base = before_rgb.astype(np.float32)\n    base[r[\"perm_water\"]==1] = base[r[\"perm_water\"]==1]*0.4 + np.array([0,0,128],np.float32)*0.6\n    base[r[\"new_inund\"]  ==1] = base[r[\"new_inund\"]==1]*0.2 + np.array([0,102,255],np.float32)*0.8\n    Image.fromarray(np.clip(base,0,255).astype(np.uint8), \"RGB\").save(\n        os.path.join(loc_dir, f\"{label}_UI_AFTER_MASK_OVERLAY.png\"))\n\n    # ── Backend masks ─────────────────────────────────────────────────\n    Image.fromarray((r[\"perm_water\"]*255).astype(np.uint8), \"L\").save(\n        os.path.join(loc_dir, f\"{label}_mask_perm_water.png\"))\n    plt.imsave(os.path.join(loc_dir, f\"{label}_mask_prob_map.png\"),\n               r[\"prob_map\"], cmap=\"inferno\", vmin=0, vmax=1)\n    Image.fromarray((r[\"binary_mask\"]*255).astype(np.uint8), \"L\").save(\n        os.path.join(loc_dir, f\"{label}_mask_prediction.png\"))\n    Image.fromarray((r[\"new_inund\"]*255).astype(np.uint8), \"L\").save(\n        os.path.join(loc_dir, f\"{label}_mask_new_inundation.png\"))\n\n    print(f\"    Saved 7 assets -> {loc_dir}/\")\n\n\n# ═══════════════════════════════════════════════════════════════════════\n# DASHBOARD VISUALIZATION\n# ═══════════════════════════════════════════════════════════════════════\nCMAP_PERM  = ListedColormap([\"#00000000\", \"#000080\"])   # navy  = permanent water\nCMAP_FLOOD = ListedColormap([\"#00000000\", \"#0066FF\"])   # royal blue = new inundation\n\ndef visualize(label, r, masks_dir):\n    H, W = r[\"binary_mask\"].shape\n    flood_pct = 100.0 * r[\"new_inund\"].sum() / (H * W)\n\n    before_rgb = (load_png_rgb(r[\"s2_before_png\"])\n                  if r.get(\"s2_before_png\") else s2_to_rgb(r[\"s2_arr\"]))\n    if r.get(\"s1_after_png\"):\n        after_rgb = load_png_rgb(r[\"s1_after_png\"])\n    elif r.get(\"s2_after_png\"):\n        after_rgb = load_png_rgb(r[\"s2_after_png\"])\n    else:\n        after_rgb = before_rgb  # last resort: show baseline again\n\n    fig = plt.figure(figsize=(26, 12), facecolor=\"#080808\")\n    gs  = gridspec.GridSpec(2, 4, figure=fig, hspace=0.2, wspace=0.1)\n\n    # Main panel: flood extent overlay\n    ax_main = fig.add_subplot(gs[:, :2])\n    ax_main.imshow(before_rgb)\n    ax_main.imshow(r[\"perm_water\"],  cmap=CMAP_PERM,  alpha=0.6, vmin=0, vmax=1)\n    ax_main.imshow(r[\"new_inund\"],   cmap=CMAP_FLOOD, alpha=0.8, vmin=0, vmax=1)\n    ax_main.set_title(\"OFFICIAL FLOOD EXTENT\", color=\"#0066FF\", fontsize=16, fontweight=\"bold\")\n    ax_main.axis(\"off\")\n    ax_main.legend(handles=[\n        mpatches.Patch(color=\"#000080\", label=\"Permanent Waterways\"),\n        mpatches.Patch(color=\"#0066FF\", label=\"Detected New Inundation\"),\n    ], loc=\"lower left\", facecolor=\"#111111\", labelcolor=\"white\", edgecolor=\"none\")\n\n    # Top right: before\n    ax_pre = fig.add_subplot(gs[0, 2])\n    ax_pre.imshow(before_rgb); ax_pre.axis(\"off\")\n    ax_pre.set_title(\"BEFORE\", color=\"white\", fontsize=11)\n\n    # Bottom right: after (SAR false-color or S2 visual)\n    ax_post = fig.add_subplot(gs[1, 2])\n    ax_post.imshow(after_rgb); ax_post.axis(\"off\")\n    after_label = \"AFTER (SAR)\" if r.get(\"s1_after_png\") else \"AFTER (S2 Visual)\"\n    ax_post.set_title(after_label, color=\"white\", fontsize=11)\n\n    # Far right: confidence\n    ax_prob = fig.add_subplot(gs[:, 3])\n    im = ax_prob.imshow(r[\"prob_map\"], cmap=\"viridis\", vmin=0, vmax=1)\n    ax_prob.set_title(\"AI CONFIDENCE SCORE\", color=\"white\", fontsize=11)\n    ax_prob.axis(\"off\")\n    cb = plt.colorbar(im, ax=ax_prob, fraction=0.046, pad=0.04)\n    cb.ax.yaxis.set_tick_params(color=\"white\")\n    plt.setp(cb.ax.yaxis.get_ticklabels(), color=\"white\", fontsize=8)\n\n    fig.text(0.5, 0.02,\n             f\"MANZAR ANALYSIS: {label} | NET INUNDATION: {flood_pct:.2f}%\",\n             ha=\"center\", color=\"white\", fontsize=14, fontweight=\"bold\")\n\n    loc_dir   = os.path.join(masks_dir, label)\n    os.makedirs(loc_dir, exist_ok=True)\n    report_path = os.path.join(loc_dir, f\"{label}_CLEAN_REPORT.png\")\n    plt.savefig(report_path, dpi=200, facecolor=\"#080808\", bbox_inches=\"tight\")\n    print(f\"    Dashboard -> {report_path}\")\n    plt.show()\n    plt.close(fig)\n\n\n# ═══════════════════════════════════════════════════════════════════════\n# MAIN PIPELINE\n# ═══════════════════════════════════════════════════════════════════════\nall_results = {}\nmetrics_log = []\n\nfor label, lat, lon in LOCATIONS:\n    print(f\"\\n{'='*65}\")\n    print(f\"  {label}\")\n    print(f\"{'='*65}\")\n\n    files = discover(label, COMPOSITES_DIR)\n\n    # Validate required files\n    if not files[\"s2_tif\"]:\n        print(f\"  SKIP: S2 baseline TIF not found.\")\n        print(f\"  Expected: {COMPOSITES_DIR}/{label}_s2_baseline_*.tif\")\n        continue\n    if not files[\"s1_tif\"]:\n        print(f\"  SKIP: S1 composite TIF not found.\")\n        print(f\"  Expected: {COMPOSITES_DIR}/{label}_s1_*_composite_*.tif\")\n        continue\n\n    print(f\"  S2 TIF   : {os.path.basename(files['s2_tif'])}\")\n    print(f\"  S1 TIF   : {os.path.basename(files['s1_tif'])}\")\n    if files[\"s2_before_png\"]: print(f\"  Before   : {os.path.basename(files['s2_before_png'])}\")\n    if files[\"s1_after_png\"]:  print(f\"  After    : {os.path.basename(files['s1_after_png'])}\")\n\n    # ── Load arrays ───────────────────────────────────────────────────\n    s2_arr, s2_tf, s2_crs = load_tif(files[\"s2_tif\"])\n    # S2 from downloader: stackstac rescale=True -> already [0,1]. No /10000.\n    s2_arr = np.clip(s2_arr, 0.0, 1.0)\n\n    s1_arr_db, s1_tf, s1_crs = load_tif(files[\"s1_tif\"])\n    # S1 composite from downloader: already converted to dB at download time.\n    # Do NOT apply log10 again. Values are already in [-35, 5] dB range.\n    # Guard: if values look like linear sigma0 (all very small positive floats < 1),\n    # then the file was saved before the dB fix - convert once as a safeguard.\n    if np.nanmedian(s1_arr_db) < 0.05 and np.nanmedian(s1_arr_db) >= 0:\n        print(\"  WARNING: S1 data looks like linear sigma0, not dB. Converting now.\")\n        s1_arr_db = np.clip(10.0 * np.log10(s1_arr_db + 1e-9), -35.0, 5.0)\n\n    # ── Permanent water mask (from S2 dry-season baseline) ────────────\n    mndwi, perm_water = mndwi_permanent_water(s2_arr)\n\n    # ── Build 10-channel tensor and run inference ─────────────────────\n    tensor = build_tensor(s2_arr, s1_arr_db, sar_only=SAR_ONLY_MODE)\n    print(f\"  Tensor shape : {tensor.shape}  SAR_ONLY={SAR_ONLY_MODE}\")\n\n    prob_map, binary_mask = tiled_predict(model, tensor, device)\n\n    # ── Align perm_water to S1 grid if needed ─────────────────────────\n    H, W = binary_mask.shape\n    if perm_water.shape != (H, W):\n        pw_t = torch.from_numpy(perm_water.astype(np.float32)).unsqueeze(0).unsqueeze(0)\n        pw_t = F.interpolate(pw_t, size=(H, W), mode=\"nearest\")\n        perm_water = (pw_t.squeeze().numpy() > 0.5).astype(np.uint8)\n\n    # ── New inundation = flood AND NOT permanent water ─────────────────\n    new_inund = ((binary_mask == 1) & (perm_water == 0)).astype(np.uint8)\n\n    # ── Metrics ───────────────────────────────────────────────────────\n    flood_km2 = float(binary_mask.sum())  * PIXEL_AREA_KM2\n    new_km2   = float(new_inund.sum())    * PIXEL_AREA_KM2\n    perm_km2  = float(perm_water.sum())   * PIXEL_AREA_KM2\n    net_pct   = 100.0 * new_inund.sum() / (H * W)\n\n    print(f\"  Flood extent   : {flood_km2:.2f} km2\")\n    print(f\"  New inundation : {new_km2:.2f} km2  ({net_pct:.2f}% of scene)\")\n    print(f\"  Perm water     : {perm_km2:.2f} km2 (excluded)\")\n\n    metrics_log.append({\n        \"location\": label, \"lat\": lat, \"lon\": lon,\n        \"flood_extent_km2\": round(flood_km2, 3),\n        \"new_inundation_km2\": round(new_km2, 3),\n        \"perm_water_km2\": round(perm_km2, 3),\n        \"net_inundation_pct\": round(net_pct, 4),\n    })\n\n    # ── Store result ──────────────────────────────────────────────────\n    all_results[label] = {\n        \"s2_arr\": s2_arr, \"s1_arr_db\": s1_arr_db,\n        \"prob_map\": prob_map, \"binary_mask\": binary_mask,\n        \"perm_water\": perm_water, \"new_inund\": new_inund,\n        \"mndwi\": mndwi,\n        \"s2_before_png\": files[\"s2_before_png\"],\n        \"s1_after_png\":  files[\"s1_after_png\"],\n        \"s2_after_png\":  files[\"s2_after_png\"],\n    }\n\n# ── Save metrics JSON ─────────────────────────────────────────────────\nwith open(METRICS_JSON, \"w\") as f:\n    json.dump(metrics_log, f, indent=2)\nprint(f\"\\nMetrics saved: {METRICS_JSON}\")\n\n# ── Visualize + export PNGs for all processed locations ───────────────\nprint(f\"\\nRendering dashboards for {len(all_results)} locations...\")\nfor label, r in all_results.items():\n    print(f\"\\n  {label}\")\n    export_pngs(label, r, MASKS_PNG_DIR)\n    visualize(label, r, MASKS_PNG_DIR)\n\nprint(f\"\\nDone. Results in: {MASKS_PNG_DIR}/\")\nprint(f\"Processed: {len(all_results)}/{len(LOCATIONS)} locations\")\nfor m in metrics_log:\n    print(f\"  {m['location']:25s}: {m['new_inundation_km2']:.2f} km2 new inundation ({m['net_inundation_pct']:.2f}%)\")\n","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"!rm -rf /kaggle/working/flood_composites\nprint(\"Done\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-26T07:44:25.136450Z","iopub.execute_input":"2026-04-26T07:44:25.138277Z","iopub.status.idle":"2026-04-26T07:44:25.593932Z","shell.execute_reply.started":"2026-04-26T07:44:25.138223Z","shell.execute_reply":"2026-04-26T07:44:25.592328Z"}},"outputs":[{"name":"stdout","text":"Done\n","output_type":"stream"}],"execution_count":7}]}