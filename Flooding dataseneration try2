datetime=f\"{date_start}/{date_end}\",\n        query={\"eo:cloud_cover\": {\"lt\": max_cloud}},\n        sortby=[{\"field\": \"properties.eo:cloud_cover\", \"direction\": \"asc\"}],\n        max_items=50,\n    )\n    items = list(search.items())\n\n    if not items:\n        print(\"  No S2 scenes. Use S1 false-color for UI after-panel.\")\n        return None\n\n    n = min(max_items, len(items))\n    print(f\"  Found {len(items)} scenes, using top {n}\")\n\n    reflectance_bands = [\"B02\", \"B03\", \"B04\", \"B08\", \"B11\", \"B12\"]\n    slices = []\n\n    for i, item in enumerate(items[:n]):\n        pb = item.properties.get(\"s2:processing_baseline\", \"02.00\")\n        try:\n            is_new = float(pb) >= 4.0\n        except (ValueError, TypeError):\n            is_new = str(pb) >= \"04.00\"\n        cc = item.properties.get(\"eo:cloud_cover\", \"?\")\n        dt = item.properties.get(\"datetime\", \"?\")[:10]\n\n        try:\n            cube = stackstac.stack(\n                item,\n                assets=reflectance_bands + [\"SCL\"],\n                bounds=utm_bounds, epsg=epsg, resolution=10,\n                dtype=\"float64\", rescale=True, fill_value=np.nan,\n            ).squeeze()\n        except Exception as e:\n            print(f\"    [{i+1}/{n}] SKIP: {e}\")\n            continue\n\n        if is_new:\n            for b in reflectance_bands:\n                if b in cube.band.values:\n                    cube.loc[dict(band=b)] -= 0.1\n\n        if \"SCL\" in cube.band.values:\n            bad = cube.sel(band=\"SCL\").isin([0, 1, 3, 8, 9, 10])\n            for b in reflectance_bands:\n                if b in cube.band.values:\n                    cube.loc[dict(band=b)] = cube.sel(band=b).where(~bad)\n\n        slices.append(cube.sel(band=reflectance_bands))\n        print(f\"    [{i+1}/{n}] {dt} | cloud:{cc:.1f}%\")\n\n    if not slices:\n        print(\"  All scenes errored. Use S1 false-color for UI.\")\n        return None\n\n    cube = 