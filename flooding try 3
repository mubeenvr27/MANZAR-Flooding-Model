{"metadata":{"kernelspec":{"language":"python","display_name":"Python 3","name":"python3"},"language_info":{"name":"python","version":"3.12.12","mimetype":"text/x-python","codemirror_mode":{"name":"ipython","version":3},"pygments_lexer":"ipython3","nbconvert_exporter":"python","file_extension":".py"},"kaggle":{"accelerator":"nvidiaTeslaT4","dataSources":[{"sourceType":"modelInstanceVersion","sourceId":847241,"databundleVersionId":16904755,"modelInstanceId":644235,"modelId":656197,"isSourceIdPinned":false}],"dockerImageVersionId":31329,"isInternetEnabled":true,"language":"python","sourceType":"notebook","isGpuEnabled":true}},"nbformat_minor":4,"nbformat":4,"cells":[{"source":"<a href=\"https://www.kaggle.com/code/muhammadmubeenxt/flooding-try-3?scriptVersionId=314910314\" target=\"_blank\"><img align=\"left\" alt=\"Kaggle\" title=\"Open in Kaggle\" src=\"https://kaggle.com/static/images/open-in-kaggle.svg\"></a>","metadata":{},"cell_type":"markdown"},{"cell_type":"code","source":"","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# Run this cell first to install all required packages\n!pip install pystac-client planetary-computer stackstac pyproj rioxarray dask -q\n!pip install segmentation-models-pytorch rasterio -q","metadata":{"_uuid":"8f2839f25d086af736a60e9eeb907d3b93b6e0e5","_cell_guid":"b1076dfc-b9ad-4769-8c92-a6c4dae69d19","trusted":true,"execution":{"iopub.status.busy":"2026-04-27T21:12:38.126372Z","iopub.execute_input":"2026-04-27T21:12:38.126633Z","iopub.status.idle":"2026-04-27T21:12:51.29019Z","shell.execute_reply.started":"2026-04-27T21:12:38.126607Z","shell.execute_reply":"2026-04-27T21:12:51.289303Z"}},"outputs":[{"name":"stdout","text":"\u001b[2K   \u001b[90m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m \u001b[32m41.8/41.8 kB\u001b[0m \u001b[31m1.2 MB/s\u001b[0m eta \u001b[36m0:00:00\u001b[0m\n\u001b[2K   \u001b[90m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m \u001b[32m64.3/64.3 kB\u001b[0m \u001b[31m3.3 MB/s\u001b[0m eta \u001b[36m0:00:00\u001b[0m\n\u001b[2K   \u001b[90m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m \u001b[32m72.0/72.0 kB\u001b[0m \u001b[31m4.1 MB/s\u001b[0m eta \u001b[36m0:00:00\u001b[0m\n\u001b[2K   \u001b[90m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m \u001b[32m208.5/208.5 kB\u001b[0m \u001b[31m7.4 MB/s\u001b[0m eta \u001b[36m0:00:00\u001b[0m\n\u001b[2K   \u001b[90m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m \u001b[32m1.4/1.4 MB\u001b[0m \u001b[31m36.1 MB/s\u001b[0m eta \u001b[36m0:00:00\u001b[0m00:01\u001b[0m\n\u001b[2K   \u001b[90m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m \u001b[32m154.8/154.8 kB\u001b[0m \u001b[31m4.0 MB/s\u001b[0m eta \u001b[36m0:00:00\u001b[0m00:01\u001b[0m\n\u001b[?25h","output_type":"stream"}],"execution_count":1},{"cell_type":"code","source":"# ═══════════════════════════════════════════════════════════════════════════════\n# CELL 1 — DATA DOWNLOAD\n# Downloads S2 dry-season baseline + S1-RTC event chips for each location.\n# Outputs GeoTIFFs and visual PNGs to ./flood_composites/\n# ═══════════════════════════════════════════════════════════════════════════════\n\n!pip install pystac-client planetary-computer stackstac pyproj rioxarray dask -q\n!pip install segmentation-models-pytorch rasterio -q\n\nimport pystac_client\nimport planetary_computer\nimport stackstac\nimport pyproj\nimport numpy as np\nimport xarray as xr\nfrom shapely.geometry import box\nfrom shapely.ops import transform\nfrom dask.diagnostics import ProgressBar\nimport rioxarray\nimport warnings\nfrom scipy.ndimage import median_filter\nfrom scipy.spatial import cKDTree\nfrom typing import List, Optional, Tuple\nfrom PIL import Image, ImageEnhance\nimport time\nimport os\n\nwarnings.filterwarnings(\"ignore\")\n\nOUTPUT_DIR = \"./flood_composites\"\nos.makedirs(OUTPUT_DIR, exist_ok=True)\n\n\n# ─────────────────────────────────────────────────────────────────────\n# UTILITIES\n# ─────────────────────────────────────────────────────────────────────\n\ndef get_utm_params(lat: float, lon: float, radius_km: float):\n    utm_zone = int((lon + 180) / 6) + 1\n    epsg = 32600 + utm_zone if lat >= 0 else 32700 + utm_zone\n    wgs84  = pyproj.CRS(\"EPSG:4326\")\n    utm    = pyproj.CRS.from_epsg(epsg)\n    to_utm = pyproj.Transformer.from_crs(wgs84, utm, always_xy=True).transform\n    to_wgs = pyproj.Transformer.from_crs(utm, wgs84, always_xy=True).transform\n    x_c, y_c = to_utm(lon, lat)\n    x_c, y_c = round(x_c / 10) * 10, round(y_c / 10) * 10\n    r_m = radius_km * 1000\n    utm_bounds = (x_c - r_m, y_c - r_m, x_c + r_m, y_c + r_m)\n    wgs_bounds = transform(to_wgs, box(*utm_bounds)).bounds\n    return utm_bounds, epsg, wgs_bounds\n\n\ndef open_catalog() -> pystac_client.Client:\n    return pystac_client.Client.open(\n        \"https://planetarycomputer.microsoft.com/api/stac/v1\",\n        modifier=planetary_computer.sign_inplace,\n    )\n\n\ndef interpolate_missing_pixels(data: xr.DataArray, max_distance: int = 80) -> xr.DataArray:\n    out = data.copy()\n    for bi in range(data.shape[0]):\n        band = data[bi].values.copy()\n        nan_n = int(np.sum(np.isnan(band)))\n        if nan_n == 0:\n            continue\n        valid_coords   = np.argwhere(~np.isnan(band))\n        invalid_coords = np.argwhere(np.isnan(band))\n        if len(valid_coords) == 0:\n            continue\n        tree = cKDTree(valid_coords)\n        dists, idxs = tree.query(invalid_coords, k=1)\n        for i in np.where(dists < max_distance)[0]:\n            iy, ix = invalid_coords[i]\n            vy, vx = valid_coords[idxs[i]]\n            band[iy, ix] = band[vy, vx]\n        filled = nan_n - int(np.sum(np.isnan(band)))\n        print(f\"      Band {bi+1}: {filled:,} filled, {int(np.sum(np.isnan(band))):,} remain\")\n        out[bi].values = band\n    return out\n\n\ndef apply_selective_filtering(data: xr.DataArray, filter_size: int = 3) -> xr.DataArray:\n    out = data.copy()\n    for bi in range(data.shape[0]):\n        band = data[bi].values\n        valid = ~np.isnan(band)\n        if not np.any(valid):\n            continue\n        tmp = band.copy()\n        tmp[~valid] = float(np.median(band[valid]))\n        filtered = median_filter(tmp, size=filter_size, mode=\"nearest\")\n        band[valid] = filtered[valid]\n        out[bi].values = band\n    return out\n\n\ndef report_statistics(data: xr.DataArray, names: List[str]):\n    print(\"   \" + \"-\" * 65)\n    print(\"   {:14} {:>9} {:>9} {:>9} {:>9} {:>9}\".format(\n        \"Band\", \"Mean\", \"Std\", \"Min\", \"Max\", \"NaN%\"))\n    print(\"   \" + \"-\" * 65)\n    for i in range(data.shape[0]):\n        b = data[i].values\n        v = b[~np.isnan(b)]\n        nm = names[i] if i < len(names) else f\"Band {i}\"\n        if len(v) > 0:\n            print(\"   {:14} {:>9.4f} {:>9.4f} {:>9.4f} {:>9.4f} {:>8.2f}%\".format(\n                nm, float(np.mean(v)), float(np.std(v)),\n                float(np.min(v)), float(np.max(v)),\n                np.sum(np.isnan(b)) / b.size * 100))\n        else:\n            print(f\"   {nm:14} ALL NaN\")\n\n\ndef apply_visual_enhancement(data, gamma=0.55, low_pct=1.0, high_pct=98.0, saturation_boost=1.3):\n    rgb_indices = [2, 1, 0]\n    channels = []\n    for idx in rgb_indices:\n        band = data[idx].values.astype(np.float32)\n        valid = band[~np.isnan(band)]\n        if len(valid) == 0:\n            channels.append(np.zeros(band.shape, dtype=np.float32))\n            continue\n        lo, hi = np.percentile(valid, [low_pct, high_pct])\n        band = np.clip(band, lo, hi)\n        band = (band - lo) / (hi - lo + 1e-10)\n        band = np.where(np.isnan(band), 0.0, band)\n        band = np.power(band, gamma)\n        channels.append(band)\n    rgb = np.stack(channels, axis=-1)\n    try:\n        pil_img = Image.fromarray((rgb * 255).astype(np.uint8), mode=\"RGB\")\n        pil_img = ImageEnhance.Color(pil_img).enhance(saturation_boost)\n        rgb = np.array(pil_img).astype(np.float32) / 255.0\n    except Exception:\n        pass\n    return (rgb * 255).astype(np.uint8)\n\n\ndef save_visual_png(data, path, **kw):\n    arr = apply_visual_enhancement(data, **kw)\n    Image.fromarray(arr, mode=\"RGB\").save(path)\n    h, w = arr.shape[:2]\n    print(f\"   PNG: {os.path.basename(path)} ({w}x{h}px)\")\n\n\n# ─────────────────────────────────────────────────────────────────────\n# ORBIT AUTO-SELECTOR\n# ─────────────────────────────────────────────────────────────────────\n\ndef select_best_orbit(wgs_bounds, date_start, date_end, catalog):\n    counts = {}\n    for direction in (\"ascending\", \"descending\"):\n        result = catalog.search(\n            collections=[\"sentinel-1-rtc\"],\n            bbox=wgs_bounds,\n            datetime=f\"{date_start}/{date_end}\",\n            query={\"sat:orbit_state\": {\"eq\": direction}},\n            max_items=200,\n        )\n        counts[direction] = len(list(result.items()))\n        print(f\"  Orbit survey: {direction:12s} -> {counts[direction]} acquisitions\")\n    best = max(counts, key=counts.get)\n    if counts[\"ascending\"] == counts[\"descending\"]:\n        best = \"descending\"\n    print(f\"  Auto-selected: {best.upper()} ({counts[best]} acqs)\")\n    return best\n\n\n# ─────────────────────────────────────────────────────────────────────\n# SENTINEL-2 BASELINE\n# Bands: [B02, B03, B04, B08, B11, B12], float32, [0, 1]\n# Purpose: MNDWI permanent-water mask + before-panel visual.\n# ─────────────────────────────────────────────────────────────────────\n\ndef download_s2_baseline(\n    lat, lon, radius_km, date_start, date_end, label,\n    max_cloud=30, max_items=15, output_dir=\".\",\n    gamma=0.55, low_pct=1.0, high_pct=98.0,\n):\n    os.makedirs(output_dir, exist_ok=True)\n    t0 = time.time()\n    print(f\"\\n{'='*70}\")\n    print(f\"  [S2 BASELINE] {label}  |  {date_start} -> {date_end}  |  cloud<{max_cloud}%\")\n    print(f\"{'='*70}\")\n\n    utm_bounds, epsg, wgs_bounds = get_utm_params(lat, lon, radius_km)\n    catalog = open_catalog()\n\n    def _search(cloud_limit):\n        return list(catalog.search(\n            collections=[\"sentinel-2-l2a\"],\n            bbox=wgs_bounds,\n            datetime=f\"{date_start}/{date_end}\",\n            query={\"eo:cloud_cover\": {\"lt\": cloud_limit}},\n            sortby=[{\"field\": \"properties.eo:cloud_cover\", \"direction\": \"asc\"}],\n            max_items=50,\n        ).items())\n\n    items = _search(max_cloud)\n    if not items:\n        relaxed = min(max_cloud + 15, 50)\n        print(f\"  No scenes at <{max_cloud}%. Retrying at <{relaxed}%...\")\n        items = _search(relaxed)\n    if not items:\n        print(\"  FAILED: No S2 scenes found.\")\n        return None\n\n    reflectance_bands = [\"B02\", \"B03\", \"B04\", \"B08\", \"B11\", \"B12\"]\n    n = min(max_items, len(items))\n    print(f\"  Found {len(items)} scenes, stacking top {n}\")\n    slices = []\n\n    for i, item in enumerate(items[:n]):\n        pb = item.properties.get(\"s2:processing_baseline\", \"02.00\")\n        try:\n            is_new = float(pb) >= 4.0\n        except (ValueError, TypeError):\n            is_new = str(pb) >= \"04.00\"\n        cc = item.properties.get(\"eo:cloud_cover\", \"?\")\n        dt = item.properties.get(\"datetime\", \"?\")[:10]\n        try:\n            cube = stackstac.stack(\n                item, assets=reflectance_bands + [\"SCL\"],\n                bounds=utm_bounds, epsg=epsg, resolution=10,\n                dtype=\"float64\", rescale=True, fill_value=np.nan,\n            ).squeeze()\n        except Exception as e:\n            print(f\"    [{i+1}/{n}] SKIP: {e}\")\n            continue\n        if is_new:\n            for b in reflectance_bands:\n                if b in cube.band.values:\n                    cube.loc[dict(band=b)] -= 0.1\n        if \"SCL\" in cube.band.values:\n            bad = cube.sel(band=\"SCL\").isin([0, 1, 3, 8, 9, 10])\n            for b in reflectance_bands:\n                if b in cube.band.values:\n                    cube.loc[dict(band=b)] = cube.sel(band=b).where(~bad)\n        slices.append(cube.sel(band=reflectance_bands))\n        print(f\"    [{i+1}/{n}] {dt} | cloud:{cc:.1f}%\")\n\n    if not slices:\n        print(\"  FAILED: All scenes errored.\")\n        return None\n\n    print(f\"\\n  Computing median composite ({len(slices)} scenes)...\")\n    cube = xr.concat(slices, dim=\"time\", combine_attrs=\"override\")\n    with ProgressBar():\n        data = cube.median(dim=\"time\", skipna=True).compute().astype(\"float32\")\n        data = data.where(data >= 0, 0)\n\n    data = data.rio.write_nodata(np.nan).rio.write_crs(f\"EPSG:{epsg}\")\n    data = interpolate_missing_pixels(data, max_distance=80)\n    data = apply_selective_filtering(data, filter_size=3)\n    report_statistics(data, [\"Blue(B02)\", \"Green(B03)\", \"Red(B04)\", \"NIR(B08)\", \"SWIR1(B11)\", \"SWIR2(B12)\"])\n\n    stem     = f\"{label}_s2_baseline_{date_start}_{date_end}\"\n    tif_path = os.path.join(output_dir, stem + \".tif\")\n    data.rio.to_raster(tif_path, compress=\"LZW\", tiled=True,\n                       blockxsize=256, blockysize=256, dtype=\"float32\", nodata=np.nan)\n    print(f\"  GeoTIFF: {tif_path}\")\n    save_visual_png(data, os.path.join(output_dir, stem + \"_visual.png\"),\n                    gamma=gamma, low_pct=low_pct, high_pct=high_pct)\n    print(f\"  Done in {time.time()-t0:.1f}s | {data.shape[2]}x{data.shape[1]}px\")\n    return data\n\n\n# ─────────────────────────────────────────────────────────────────────\n# SENTINEL-1 RTC EVENT DOWNLOADER\n# Enforces single orbit direction. Saves per-acquisition chips in dB.\n# ─────────────────────────────────────────────────────────────────────\n\ndef download_s1_event(\n    lat, lon, radius_km, date_start, date_end, label,\n    output_dir=\".\", orbit_direction=None, save_composite=True,\n):\n    os.makedirs(output_dir, exist_ok=True)\n    t0 = time.time()\n\n    utm_bounds, epsg, wgs_bounds = get_utm_params(lat, lon, radius_km)\n    catalog = open_catalog()\n\n    if orbit_direction is None:\n        print(f\"\\n  orbit_direction=None: running auto-selection...\")\n        orbit_direction = select_best_orbit(wgs_bounds, date_start, date_end, catalog)\n    elif orbit_direction not in (\"ascending\", \"descending\"):\n        raise ValueError(\n            f\"orbit_direction must be 'ascending', 'descending', or None. Got: '{orbit_direction}'\")\n\n    print(f\"\\n{'='*70}\")\n    print(f\"  [S1 EVENT] {label}  |  {date_start} -> {date_end}\")\n    print(f\"  Orbit: {orbit_direction.upper()} only\")\n    print(f\"{'='*70}\")\n\n    items = list(catalog.search(\n        collections=[\"sentinel-1-rtc\"],\n        bbox=wgs_bounds,\n        datetime=f\"{date_start}/{date_end}\",\n        query={\"sat:orbit_state\": {\"eq\": orbit_direction}},\n        sortby=[{\"field\": \"properties.datetime\", \"direction\": \"asc\"}],\n        max_items=100,\n    ).items())\n\n    if not items:\n        print(f\"  FAILED: No {orbit_direction} S1-RTC scenes found.\")\n        return []\n\n    print(f\"  Found {len(items)} {orbit_direction} acquisitions\")\n    acquisitions, acq_dates = [], []\n\n    for i, item in enumerate(items):\n        dt    = item.properties.get(\"datetime\", \"?\")[:10]\n        orbit = item.properties.get(\"sat:orbit_state\", \"?\")\n        plat  = item.properties.get(\"platform\", \"?\")\n        if orbit != orbit_direction:\n            print(f\"    [{i+1}] SKIP: unexpected orbit={orbit}\")\n            continue\n        try:\n            cube = stackstac.stack(\n                item, assets=[\"vv\", \"vh\"],\n                bounds=utm_bounds, epsg=epsg, resolution=10,\n                dtype=\"float64\", rescale=False, fill_value=np.nan,\n            ).squeeze()\n            with ProgressBar():\n                arr = cube.compute().astype(\"float32\")\n        except Exception as e:\n            print(f\"    [{i+1}/{len(items)}] {dt} SKIP: {e}\")\n            continue\n\n        arr_db = arr.copy()\n        for bi in range(arr.shape[0]):\n            band = arr[bi].values.copy()\n            valid = (band > 0) & ~np.isnan(band)\n            band[~valid] = np.nan\n            band[valid] = 10.0 * np.log10(band[valid])\n            band = np.clip(band, -35.0, 5.0)\n            arr_db[bi].values = band\n\n        arr_db = arr_db.rio.write_nodata(np.nan).rio.write_crs(f\"EPSG:{epsg}\")\n        acq_stem = f\"{label}_s1_{dt}_{orbit_direction}\"\n        tif_path = os.path.join(output_dir, acq_stem + \".tif\")\n        arr_db.rio.to_raster(\n            tif_path, compress=\"LZW\", tiled=True,\n            blockxsize=256, blockysize=256, dtype=\"float32\", nodata=np.nan,\n        )\n        acquisitions.append((dt, arr_db))\n        acq_dates.append(dt)\n        print(f\"    [{i+1}/{len(items)}] {dt} | {orbit_direction} | {plat} -> {os.path.basename(tif_path)}\")\n\n    if not acquisitions:\n        print(\"  FAILED: All acquisitions errored.\")\n        return []\n\n    if save_composite:\n        print(f\"\\n  Building {orbit_direction} composite ({len(acquisitions)} acqs)...\")\n        stacked   = xr.concat([a[1] for a in acquisitions], dim=\"time\")\n        composite = stacked.mean(dim=\"time\", skipna=True).astype(\"float32\")\n        composite = composite.rio.write_nodata(np.nan).rio.write_crs(f\"EPSG:{epsg}\")\n        comp_path = os.path.join(\n            output_dir,\n            f\"{label}_s1_{orbit_direction}_composite_{date_start}_{date_end}.tif\"\n        )\n        composite.rio.to_raster(comp_path, compress=\"LZW\", tiled=True,\n                                blockxsize=256, blockysize=256, dtype=\"float32\", nodata=np.nan)\n        print(f\"  Composite: {comp_path}\")\n\n        try:\n            def _stretch(a, lo=2, hi=98):\n                v = a[~np.isnan(a)]\n                if not len(v):\n                    return np.zeros_like(a, np.float32)\n                lv, hv = np.percentile(v, [lo, hi])\n                out = np.clip(a, lv, hv)\n                out = (out - lv) / (hv - lv + 1e-10)\n                return np.where(np.isnan(out), 0.0, out)\n            vv    = composite[0].values\n            vh    = composite[1].values\n            ratio = np.where((~np.isnan(vv)) & (~np.isnan(vh)), vv - vh, np.nan)\n            rgb   = np.stack([\n                (_stretch(vv)    * 255).astype(np.uint8),\n                (_stretch(vh)    * 255).astype(np.uint8),\n                (_stretch(ratio) * 255).astype(np.uint8),\n            ], axis=-1)\n            fc_path = os.path.join(\n                output_dir,\n                f\"{label}_s1_{orbit_direction}_falsecolor_{date_start}_{date_end}.png\"\n            )\n            Image.fromarray(rgb, mode=\"RGB\").save(fc_path)\n            print(f\"  False-color PNG: {fc_path}\")\n        except Exception as e:\n            print(f\"  False-color PNG failed: {e}\")\n\n    print(f\"\\n  S1 done | orbit={orbit_direction} | {len(acquisitions)} chips\")\n    print(f\"  Dates: {', '.join(acq_dates)}\")\n    print(f\"  Elapsed: {time.time()-t0:.1f}s\")\n    return acquisitions\n\n\n# ─────────────────────────────────────────────────────────────────────\n# OPTIONAL S2 VISUAL AFTER (display only, high cloud OK)\n# ─────────────────────────────────────────────────────────────────────\n\ndef download_s2_visual_after(\n    lat, lon, radius_km, date_start, date_end, label,\n    max_cloud=70, max_items=8, output_dir=\".\",\n    gamma=0.55, low_pct=1.0, high_pct=98.0,\n):\n    os.makedirs(output_dir, exist_ok=True)\n    t0 = time.time()\n    print(f\"\\n{'='*70}\")\n    print(f\"  [S2 VISUAL AFTER] {label}  |  cloud<{max_cloud}% | DISPLAY ONLY\")\n    print(f\"{'='*70}\")\n\n    utm_bounds, epsg, wgs_bounds = get_utm_params(lat, lon, radius_km)\n    catalog = open_catalog()\n\n    items = list(catalog.search(\n        collections=[\"sentinel-2-l2a\"],\n        bbox=wgs_bounds,\n        datetime=f\"{date_start}/{date_end}\",\n        query={\"eo:cloud_cover\": {\"lt\": max_cloud}},\n        sortby=[{\"field\": \"properties.eo:cloud_cover\", \"direction\": \"asc\"}],\n        max_items=50,\n    ).items())\n\n    if not items:\n        print(\"  No S2 scenes. Use S1 false-color for UI after-panel.\")\n        return None\n\n    reflectance_bands = [\"B02\", \"B03\", \"B04\", \"B08\", \"B11\", \"B12\"]\n    n = min(max_items, len(items))\n    print(f\"  Found {len(items)} scenes, using top {n}\")\n    slices = []\n\n    for i, item in enumerate(items[:n]):\n        pb = item.properties.get(\"s2:processing_baseline\", \"02.00\")\n        try:\n            is_new = float(pb) >= 4.0\n        except (ValueError, TypeError):\n            is_new = str(pb) >= \"04.00\"\n        cc = item.properties.get(\"eo:cloud_cover\", \"?\")\n        dt = item.properties.get(\"datetime\", \"?\")[:10]\n        try:\n            cube = stackstac.stack(\n                item, assets=reflectance_bands + [\"SCL\"],\n                bounds=utm_bounds, epsg=epsg, resolution=10,\n                dtype=\"float64\", rescale=True, fill_value=np.nan,\n            ).squeeze()\n        except Exception as e:\n            print(f\"    [{i+1}/{n}] SKIP: {e}\")\n            continue\n        if is_new:\n            for b in reflectance_bands:\n                if b in cube.band.values:\n                    cube.loc[dict(band=b)] -= 0.1\n        if \"SCL\" in cube.band.values:\n            bad = cube.sel(band=\"SCL\").isin([0, 1, 3, 8, 9, 10])\n            for b in reflectance_bands:\n                if b in cube.band.values:\n                    cube.loc[dict(band=b)] = cube.sel(band=b).where(~bad)\n        slices.append(cube.sel(band=reflectance_bands))\n        print(f\"    [{i+1}/{n}] {dt} | cloud:{cc:.1f}%\")\n\n    if not slices:\n        print(\"  All scenes errored. Use S1 false-color for UI.\")\n        return None\n\n    cube = xr.concat(slices, dim=\"time\", combine_attrs=\"override\")\n    with ProgressBar():\n        data = cube.median(dim=\"time\", skipna=True).compute().astype(\"float32\")\n        data = data.where(data >= 0, 0)\n\n    data = data.rio.write_nodata(np.nan).rio.write_crs(f\"EPSG:{epsg}\")\n    data = interpolate_missing_pixels(data, max_distance=120)\n    data = apply_selective_filtering(data, filter_size=3)\n\n    avg_nan = float(np.mean([\n        np.sum(np.isnan(data[i].values)) / data[i].values.size * 100\n        for i in range(data.shape[0])\n    ]))\n    if avg_nan > 40:\n        print(f\"  WARNING: {avg_nan:.1f}% NaN. Use S1 false-color for after-panel.\")\n    else:\n        print(f\"  NaN coverage: {avg_nan:.1f}%\")\n\n    stem = f\"{label}_s2_visual_after_{date_start}_{date_end}\"\n    data.rio.to_raster(os.path.join(output_dir, stem + \".tif\"),\n                       compress=\"LZW\", tiled=True, blockxsize=256, blockysize=256,\n                       dtype=\"float32\", nodata=np.nan)\n    save_visual_png(data, os.path.join(output_dir, stem + \".png\"),\n                    gamma=gamma, low_pct=low_pct, high_pct=high_pct)\n    print(f\"  Done in {time.time()-t0:.1f}s\")\n    return data\n\n\n# ─────────────────────────────────────────────────────────────────────\n# ORCHESTRATOR\n# ─────────────────────────────────────────────────────────────────────\n\ndef download_flood_pair(\n    lat, lon, radius_km,\n    baseline_start, baseline_end,\n    event_start, event_end,\n    label,\n    orbit_direction=None,\n    output_dir=\".\",\n    fetch_s2_visual_after=True,\n    gamma=0.55, low_pct=1.0, high_pct=98.0,\n):\n    print(f\"\\n{'#'*70}\")\n    print(f\"  FLOOD PAIR: {label.upper()}\")\n    print(f\"  Baseline : {baseline_start} -> {baseline_end}  [S2]\")\n    print(f\"  Event    : {event_start} -> {event_end}  [S1 SAR]\")\n    print(f\"  Orbit    : {'AUTO-SELECT' if orbit_direction is None else orbit_direction.upper()}\")\n    print(f\"{'#'*70}\")\n\n    results = {}\n    results[\"s2_baseline\"] = download_s2_baseline(\n        lat, lon, radius_km, baseline_start, baseline_end, label,\n        max_cloud=30, max_items=15, output_dir=output_dir,\n        gamma=gamma, low_pct=low_pct, high_pct=high_pct,\n    )\n    results[\"s1_acquisitions\"] = download_s1_event(\n        lat, lon, radius_km, event_start, event_end, label,\n        output_dir=output_dir, orbit_direction=orbit_direction, save_composite=True,\n    )\n    if fetch_s2_visual_after:\n        results[\"s2_visual_after\"] = download_s2_visual_after(\n            lat, lon, radius_km, event_start, event_end, label,\n            max_cloud=70, max_items=8, output_dir=output_dir,\n            gamma=gamma, low_pct=low_pct, high_pct=high_pct,\n        )\n    else:\n        results[\"s2_visual_after\"] = None\n\n    n_acq = len(results[\"s1_acquisitions\"])\n    print(f\"\\n{'#'*70}\")\n    print(f\"  SUMMARY: {label}\")\n    print(f\"  S2 baseline    : {'OK' if results['s2_baseline'] is not None else 'FAILED'}\")\n    print(f\"  S1 acquisitions: {n_acq} chips {'(ready for inference)' if n_acq > 0 else '(FAILED)'}\")\n    s2v = results[\"s2_visual_after\"]\n    print(f\"  S2 visual after: {'OK' if s2v is not None else 'Not available - use S1 false-color'}\")\n    print(f\"{'#'*70}\\n\")\n    return results\n\n\n# ─────────────────────────────────────────────────────────────────────\n# RUN\n# ─────────────────────────────────────────────────────────────────────\n\npakistan_locations = [\n    # label                 lat         lon        r_km  orbit\n    (\"Sialkot_punjab\",   32.496304,  74.538327,   10,   \"ascending\"),\n    (\"Dadu_Sindh\",       26.73,      67.78,       10,   \"descending\"),\n    (\"Sukkur_Sindh\",     27.70,      68.87,       10,   \"descending\"),\n    (\"Jacobabad_Sindh\",  28.28,      68.43,       10,   \"descending\"),\n    (\"DG_Khan_Punjab\",   30.06,      70.64,       10,   \"descending\"),\n    (\"Nowshera_KPK\",     34.01,      71.99,       10,   \"descending\"),\n]\n\nfor label, lat, lon, radius_km, orbit in pakistan_locations:\n    try:\n        if \"Sialkot\" in label:\n            bl_start, bl_end = \"2025-01-01\", \"2025-06-30\"\n            ev_start, ev_end = \"2025-07-15\", \"2025-09-15\"\n        else:\n            bl_start, bl_end = \"2022-01-01\", \"2022-06-30\"\n            ev_start, ev_end = \"2022-08-01\", \"2022-09-30\"\n        download_flood_pair(\n            lat=lat, lon=lon, radius_km=radius_km,\n            baseline_start=bl_start, baseline_end=bl_end,\n            event_start=ev_start, event_end=ev_end,\n            label=label, orbit_direction=orbit,\n            output_dir=OUTPUT_DIR,\n            fetch_s2_visual_after=True,\n        )\n    except Exception as e:\n        print(f\"  ERROR [{label}]: {type(e).__name__}: {e}\")\n\n# Uncomment to run international locations:\ninternational_locations = [\n     {\"label\": \"Sylhet_Bangladesh\", \"lat\": 24.90, \"lon\": 91.87, \"radius_km\": 10, \"orbit\": None,\n      \"baseline_start\": \"2022-01-01\", \"baseline_end\": \"2022-04-30\",\n      \"event_start\": \"2022-06-01\", \"event_end\": \"2022-07-31\"},\n     {\"label\": \"Kherson_Ukraine\", \"lat\": 46.64, \"lon\": 32.62, \"radius_km\": 10, \"orbit\": \"ascending\",\n      \"baseline_start\": \"2023-03-01\", \"baseline_end\": \"2023-05-31\",\n      \"event_start\": \"2023-06-06\", \"event_end\": \"2023-07-31\"},\n     {\"label\": \"KwaZuluNatal_SA\", \"lat\": -29.86, \"lon\": 31.01, \"radius_km\": 10, \"orbit\": \"descending\",\n      \"baseline_start\": \"2022-01-01\", \"baseline_end\": \"2022-03-31\",\n      \"event_start\": \"2022-04-11\", \"event_end\": \"2022-05-31\"},\n ]\nfor loc in international_locations:\n     try:\n         download_flood_pair(**{k: loc[k] for k in\n             [\"lat\",\"lon\",\"radius_km\",\"baseline_start\",\"baseline_end\",\"event_start\",\"event_end\",\"label\"]},\n             orbit_direction=loc[\"orbit\"], output_dir=OUTPUT_DIR, fetch_s2_visual_after=True,\n         )\n     except Exception as e:\n         print(f\"  ERROR [{loc['label']}]: {type(e).__name__}: {e}\")\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-27T18:02:12.51003Z","iopub.execute_input":"2026-04-27T18:02:12.510285Z","iopub.status.idle":"2026-04-27T18:40:09.210807Z","shell.execute_reply.started":"2026-04-27T18:02:12.510257Z","shell.execute_reply":"2026-04-27T18:40:09.209868Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# !pip install segmentation-models-pytorch rasterio -q\n\nimport os, glob, json, warnings\nimport numpy as np\nimport torch\nimport torch.nn as nn\nimport torch.nn.functional as F\nimport segmentation_models_pytorch as smp\nimport rasterio\nfrom rasterio.enums import Resampling\nimport matplotlib.pyplot as plt\nimport matplotlib.patches as mpatches\nimport matplotlib.gridspec as gridspec\nfrom matplotlib.colors import ListedColormap\nfrom PIL import Image, ImageEnhance\nfrom tqdm.auto import tqdm\nimport datetime\nwarnings.filterwarnings(\"ignore\")\n\n# ═══════════════════════════════════════════════════════════════════════\n# CONFIG\n# ═══════════════════════════════════════════════════════════════════════\nCOMPOSITES_DIR = \"./flood_composites\"\nMODEL_PATH     = \"/kaggle/input/models/muhammadmubeenxt/ablation-flooding/pytorch/default/1/ablation_best_flood_model_full.pth\"\nMASKS_PNG_DIR  = \"./masks_pngs\"\nMETRICS_JSON   = \"./flood_metrics.json\"\nDEBUG_LOG      = \"./flood_debug.log\"\nos.makedirs(MASKS_PNG_DIR, exist_ok=True)\n\n# Locations\nLOCATIONS = [\n    (\"Sialkot_punjab\",    32.496304,  74.538327),\n    #(\"Dadu_Sindh\",        26.73,      67.78),\n    #(\"Sukkur_Sindh\",      27.70,      68.87),\n    #(\"Jacobabad_Sindh\",   28.28,      68.43),\n    #(\"DG_Khan_Punjab\",    30.06,      70.64),\n    #(\"Nowshera_KPK\",      34.01,      71.99),\n]\n\nFLOOD_THRESHOLD  = 0.50\nPERM_WATER_MNDWI = -0.07\nSAR_ONLY_MODE    = False\nTILE_SIZE        = 256\nTILE_OVERLAP     = 64\nTILE_STRIDE      = TILE_SIZE - TILE_OVERLAP\nPIXEL_AREA_KM2   = (10.0 * 10.0) / 1e6\n\ndevice = torch.device(\"cuda\" if torch.cuda.is_available() else \"cpu\")\ntorch.cuda.empty_cache()\n\n# Setup debug logging\ndef debug_log(msg, level=\"INFO\"):\n    timestamp = datetime.datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\")\n    log_msg = f\"[{timestamp}] [{level}] {msg}\"\n    print(log_msg)\n    with open(DEBUG_LOG, \"a\") as f:\n        f.write(log_msg + \"\\n\")\n\ndebug_log(f\"=== FLOOD DETECTION STARTED ===\")\ndebug_log(f\"Device: {device}, TILE_SIZE: {TILE_SIZE}, Threshold: {FLOOD_THRESHOLD}\")\n\n# ═══════════════════════════════════════════════════════════════════════\n# MODEL DEFINITION\n# ═══════════════════════════════════════════════════════════════════════\nclass CBAM(nn.Module):\n    def __init__(self, channels, reduction=8):\n        super().__init__()\n        self.avg = nn.AdaptiveAvgPool2d(1)\n        self.max = nn.AdaptiveMaxPool2d(1)\n        self.fc  = nn.Sequential(\n            nn.Linear(channels, channels // reduction, bias=False),\n            nn.ReLU(inplace=True),\n            nn.Linear(channels // reduction, channels, bias=False))\n        self.sc  = nn.Conv2d(2, 1, kernel_size=7, padding=3, bias=False)\n\n    def forward(self, x):\n        b, c = x.shape[:2]\n        a = self.fc(self.avg(x).view(b, c))\n        m = self.fc(self.max(x).view(b, c))\n        x = x * torch.sigmoid(a + m).view(b, c, 1, 1)\n        s = torch.cat([x.mean(1, keepdim=True), x.max(1, keepdim=True)[0]], dim=1)\n        return x * torch.sigmoid(self.sc(s))\n\nclass DualStreamUNetPP(nn.Module):\n    def __init__(self, use_cbam=True):\n        super().__init__()\n        self.use_cbam = use_cbam\n        self.sar_enc  = smp.UnetPlusPlus(encoder_name=\"resnet50\", encoder_weights=None,\n                                          in_channels=3, classes=32)\n        self.opt_enc  = smp.UnetPlusPlus(encoder_name=\"resnet50\", encoder_weights=None,\n                                          in_channels=7, classes=32)\n        if use_cbam:\n            self.cbam = CBAM(64)\n        self.head = nn.Sequential(\n            nn.Conv2d(64, 32, 3, padding=1, bias=False),\n            nn.BatchNorm2d(32), nn.ReLU(inplace=True),\n            nn.Dropout2d(p=0.15), nn.Conv2d(32, 1, 1))\n\n    def forward(self, x):\n        sar = torch.cat([x[:, 0:2], x[:, 7:8]], dim=1)\n        opt = torch.cat([x[:, 2:7], x[:, 8:10]], dim=1)\n        f   = torch.cat([self.sar_enc(sar), self.opt_enc(opt)], dim=1)\n        if self.use_cbam:\n            f = self.cbam(f)\n        return self.head(f)\n\ndef load_model(path, device):\n    debug_log(f\"Loading model from: {path}\")\n    if not os.path.exists(path):\n        raise FileNotFoundError(f\"Checkpoint not found: {path}\")\n    \n    m = DualStreamUNetPP(use_cbam=True)\n    raw = torch.load(path, map_location=device)\n    state = raw.get(\"model_state\", raw)\n    \n    # Strip DataParallel prefix\n    state = {k.replace(\"module.\", \"\"): v for k, v in state.items()}\n    \n    # Remap keys\n    remapped = {}\n    for k, v in state.items():\n        k = k.replace(\"sar_encoder.\", \"sar_enc.\").replace(\"opt_encoder.\", \"opt_enc.\")\n        remapped[k] = v\n    \n    missing, unexpected = m.load_state_dict(remapped, strict=False)\n    if missing:\n        debug_log(f\"Missing keys: {missing[:3]}\", \"WARNING\")\n    if unexpected:\n        debug_log(f\"Unexpected keys: {unexpected[:3]}\", \"WARNING\")\n    \n    m.to(device).eval()\n    param_count = sum(p.numel() for p in m.parameters())/1e6\n    debug_log(f\"Model loaded: {param_count:.1f}M params\")\n    \n    # Test model\n    debug_log(\"Testing model with dummy input...\")\n    dummy_input = torch.randn(1, 10, 256, 256).to(device)\n    with torch.no_grad():\n        dummy_output = m(dummy_input)\n    debug_log(f\"Dummy output shape: {dummy_output.shape}\")\n    \n    return m\n\n# ═══════════════════════════════════════════════════════════════════════\n# FILE DISCOVERY\n# ═══════════════════════════════════════════════════════════════════════\ndef find_file(base_dir, pattern):\n    hits = sorted(glob.glob(os.path.join(base_dir, pattern)))\n    return hits[-1] if hits else None\n\ndef discover(label, composites_dir):\n    d = {}\n    d[\"s2_tif\"] = find_file(composites_dir, f\"{label}_s2_baseline_*.tif\")\n    d[\"s1_tif\"] = (\n        find_file(composites_dir, f\"{label}_s1_*_composite_*.tif\") or\n        find_file(composites_dir, f\"{label}_s1_composite_*.tif\")\n    )\n    d[\"s2_before_png\"] = find_file(composites_dir, f\"{label}_s2_baseline_*_visual.png\")\n    d[\"s1_after_png\"]  = (\n        find_file(composites_dir, f\"{label}_s1_*_falsecolor_*.png\") or\n        find_file(composites_dir, f\"{label}_s1_falsecolor_*.png\")\n    )\n    d[\"s2_after_png\"]  = find_file(composites_dir, f\"{label}_s2_visual_after_*.png\")\n    return d\n\n# ═══════════════════════════════════════════════════════════════════════\n# DATA LOADING - FIXED VERSION\n# ═══════════════════════════════════════════════════════════════════════\ndef load_tif_corrected(path, is_sar=False):\n    \"\"\"Load GeoTIFF - S2 gets scaled to 0-1, S1 stays in dB\"\"\"\n    debug_log(f\"Loading GeoTIFF: {path}\")\n    \n    with rasterio.open(path) as src:\n        data = src.read().astype(np.float32)\n        \n        if is_sar:\n            # SAR data: convert linear to dB if needed\n            if data.max() > 10:  # Linear scale\n                debug_log(f\"  Converting SAR from linear to dB (max={data.max():.2f})\")\n                data = np.clip(10 * np.log10(data + 1e-9), -35, 5)\n            debug_log(f\"  SAR dB - range: [{data.min():.2f}, {data.max():.2f}], mean: {data.mean():.2f}\")\n        else:\n            # S2 optical: scale 0-10000 to 0-1\n            if data.max() > 10:\n                debug_log(f\"  Scaling S2 (max={data.max():.2f}) to 0-1\")\n                data = data / 10000.0\n            data = np.clip(data, 0.0, 1.0)\n            debug_log(f\"  S2 scaled - range: [{data.min():.4f}, {data.max():.4f}], mean: {data.mean():.4f}\")\n        \n        return data, src.transform, src.crs\n\ndef match_hw(arr, target_hw):\n    tH, tW = target_hw\n    if arr.shape[1] == tH and arr.shape[2] == tW:\n        return arr\n    t = torch.from_numpy(arr).unsqueeze(0).float()\n    t = F.interpolate(t, size=(tH, tW), mode=\"bilinear\", align_corners=False)\n    return t.squeeze(0).numpy()\n\ndef build_tensor_fixed(s2_arr, s1_arr_db, sar_only=False):\n    \"\"\"Build 10-channel input tensor\"\"\"\n    debug_log(\"Building input tensor...\")\n    H, W = s2_arr.shape[1], s2_arr.shape[2]\n    s1_arr_db = match_hw(s1_arr_db, (H, W))\n    \n    # Normalize dB to [0,1] for model input\n    vv = np.clip((s1_arr_db[0] + 30.0) / 30.0, 0.0, 1.0)\n    vh = np.clip((s1_arr_db[1] + 30.0) / 30.0, 0.0, 1.0)\n    vv = np.nan_to_num(vv, nan=0.0)\n    vh = np.nan_to_num(vh, nan=0.0)\n    \n    debug_log(f\"  Normalized VV - range: [{vv.min():.4f}, {vv.max():.4f}], unique: {len(np.unique(vv))}\")\n    debug_log(f\"  Normalized VH - range: [{vh.min():.4f}, {vh.max():.4f}], unique: {len(np.unique(vh))}\")\n    \n    # SAR ratio\n    with np.errstate(divide=\"ignore\", invalid=\"ignore\"):\n        sar_r = np.where(vh > 1e-8, vv / vh, 0.0)\n    sar_r = np.clip(np.nan_to_num(sar_r, nan=0.0, posinf=0.0), 0.0, 10.0)\n    \n    if sar_only:\n        tensor = np.zeros((10, H, W), dtype=np.float32)\n        tensor[0] = vv\n        tensor[1] = vh\n        tensor[7] = sar_r\n        return tensor\n    \n    # Optical bands\n    blue = np.clip(np.nan_to_num(s2_arr[0], nan=0.0), 0.0, 1.0)\n    green = np.clip(np.nan_to_num(s2_arr[1], nan=0.0), 0.0, 1.0)\n    red = np.clip(np.nan_to_num(s2_arr[2], nan=0.0), 0.0, 1.0)\n    nir = np.clip(np.nan_to_num(s2_arr[3], nan=0.0), 0.0, 1.0)\n    swir1 = np.clip(np.nan_to_num(s2_arr[4], nan=0.0), 0.0, 1.0)\n    \n    debug_log(f\"  S2 means - B:{blue.mean():.3f} G:{green.mean():.3f} R:{red.mean():.3f}\")\n    \n    # Indices\n    with np.errstate(divide=\"ignore\", invalid=\"ignore\"):\n        ndwi = np.where((green+nir) > 1e-8, (green-nir) / (green+nir), 0.0)\n        mndwi = np.where((green+swir1) > 1e-8, (green-swir1) / (green+swir1), 0.0)\n    \n    ndwi = np.nan_to_num(ndwi, nan=0.0)\n    mndwi = np.nan_to_num(mndwi, nan=0.0)\n    \n    tensor = np.stack([\n        vv, vh, blue, green, red, nir, ndwi, sar_r, swir1, mndwi\n    ], axis=0).astype(np.float32)\n    \n    debug_log(f\"  Tensor - range: [{tensor.min():.4f}, {tensor.max():.4f}], mean: {tensor.mean():.4f}\")\n    return tensor\n\n# ═══════════════════════════════════════════════════════════════════════\n# TILED INFERENCE\n# ═══════════════════════════════════════════════════════════════════════\ndef _hanning_window(size):\n    lin = np.hanning(size).astype(np.float64)\n    w = np.outer(lin, lin)\n    return np.clip(w, 1e-6, None)\n\n@torch.no_grad()\ndef tiled_predict(model, tensor, device):\n    debug_log(\"Starting tiled prediction...\")\n    C, H, W = tensor.shape\n    debug_log(f\"  Input shape: {tensor.shape}\")\n    \n    torch.cuda.empty_cache()\n    win = _hanning_window(TILE_SIZE)\n    \n    pad_h = (-H) % TILE_STRIDE\n    pad_w = (-W) % TILE_STRIDE\n    if pad_h or pad_w:\n        debug_log(f\"  Padding: h={pad_h}, w={pad_w}\")\n        tensor = np.pad(tensor, ((0,0),(0,pad_h),(0,pad_w)), mode=\"reflect\")\n    \n    _, PH, PW = tensor.shape\n    acc = np.zeros((PH, PW), dtype=np.float64)\n    count = np.zeros((PH, PW), dtype=np.float64)\n    \n    ys = list(range(0, PH - TILE_SIZE + 1, TILE_STRIDE))\n    xs = list(range(0, PW - TILE_SIZE + 1, TILE_STRIDE))\n    if ys and ys[-1] + TILE_SIZE < PH:\n        ys.append(PH - TILE_SIZE)\n    if xs and xs[-1] + TILE_SIZE < PW:\n        xs.append(PW - TILE_SIZE)\n    \n    debug_log(f\"  Tiles: {len(ys)} x {len(xs)} = {len(ys)*len(xs)} tiles\")\n    \n    model.eval()\n    coords = [(y, x) for y in ys for x in xs]\n    \n    for idx, (y0, x0) in enumerate(tqdm(coords, desc=\"  Tiles\", leave=False)):\n        chip = tensor[:, y0:y0+TILE_SIZE, x0:x0+TILE_SIZE]\n        xt = torch.from_numpy(chip).unsqueeze(0).to(device)\n        \n        with torch.amp.autocast(\"cuda\", enabled=(device.type == \"cuda\")):\n            prob = torch.sigmoid(model(xt)).squeeze().cpu().numpy().astype(np.float64)\n        \n        acc[y0:y0+TILE_SIZE, x0:x0+TILE_SIZE] += prob * win\n        count[y0:y0+TILE_SIZE, x0:x0+TILE_SIZE] += win\n        \n        if idx % 20 == 0:\n            torch.cuda.empty_cache()\n    \n    prob_map = (acc / np.where(count > 0, count, 1.0)).astype(np.float32)\n    prob_map = prob_map[:H, :W]\n    binary = (prob_map >= FLOOD_THRESHOLD).astype(np.uint8)\n    \n    debug_log(f\"  Probability - min: {prob_map.min():.4f}, max: {prob_map.max():.4f}, mean: {prob_map.mean():.4f}\")\n    debug_log(f\"  Flood pixels: {binary.sum()} ({100*binary.sum()/(H*W):.2f}%)\")\n    \n    return prob_map, binary\n\n# ═══════════════════════════════════════════════════════════════════════\n# VISUALIZATION HELPERS\n# ═══════════════════════════════════════════════════════════════════════\ndef load_png_rgb(path):\n    return np.array(Image.open(path).convert(\"RGB\"))\n\ndef s2_to_rgb(s2_arr, gamma=0.55, lo=1.0, hi=98.0, sat=1.3):\n    chs = []\n    for idx in [2, 1, 0]:\n        b = s2_arr[idx].astype(np.float32)\n        v = b[~np.isnan(b)]\n        if not len(v):\n            chs.append(np.zeros(b.shape, np.float32))\n            continue\n        lo_v, hi_v = np.percentile(v, [lo, hi])\n        b = np.clip(b, lo_v, hi_v)\n        b = (b - lo_v) / (hi_v - lo_v + 1e-10)\n        b = np.power(np.clip(np.nan_to_num(b, nan=0.0), 0, 1), gamma)\n        chs.append(b)\n    rgb = np.stack(chs, axis=-1)\n    try:\n        pil = Image.fromarray((rgb*255).astype(np.uint8), \"RGB\")\n        pil = ImageEnhance.Color(pil).enhance(sat)\n        rgb = np.array(pil).astype(np.float32) / 255.0\n    except Exception:\n        pass\n    return (rgb * 255).astype(np.uint8)\n\ndef mndwi_permanent_water(s2_arr):\n    green = np.clip(np.nan_to_num(s2_arr[1], nan=0.0), 0, 1)\n    swir1 = np.clip(np.nan_to_num(s2_arr[4], nan=0.0), 0, 1)\n    with np.errstate(divide=\"ignore\", invalid=\"ignore\"):\n        mndwi = np.where((green+swir1) > 1e-8, (green-swir1)/(green+swir1), 0.0)\n    mndwi = np.nan_to_num(mndwi, nan=0.0).astype(np.float32)\n    return mndwi, (mndwi > PERM_WATER_MNDWI).astype(np.uint8)\n\ndef export_pngs(label, r, masks_dir):\n    loc_dir = os.path.join(masks_dir, label)\n    os.makedirs(loc_dir, exist_ok=True)\n    \n    def _force_uint8(arr):\n        arr = np.array(arr, dtype=np.float32)\n        if arr.max() <= 1.0:\n            arr = np.clip(arr, 0, 1) * 255\n        return np.nan_to_num(arr, nan=0.0).astype(np.uint8)\n    \n    before_rgb = (load_png_rgb(r[\"s2_before_png\"]) if r.get(\"s2_before_png\") else s2_to_rgb(r[\"s2_arr\"]))\n    Image.fromarray(_force_uint8(before_rgb), \"RGB\").save(os.path.join(loc_dir, f\"{label}_UI_BEFORE_OPTICAL.png\"))\n    \n    if r.get(\"s1_after_png\"):\n        after_rgb = load_png_rgb(r[\"s1_after_png\"])\n    elif r.get(\"s2_after_png\"):\n        after_rgb = load_png_rgb(r[\"s2_after_png\"])\n    else:\n        vv = r[\"s1_arr_db\"][0]\n        vh = r[\"s1_arr_db\"][1]\n        def _s(a, lo=2, hi=98):\n            v = a[~np.isnan(a)]\n            if not len(v):\n                return np.zeros_like(a, np.float32)\n            lv, hv = np.percentile(v, [lo, hi])\n            return np.clip(np.nan_to_num((a-lv)/(hv-lv+1e-10), nan=0.0), 0, 1)\n        ratio = np.where(np.power(10,vh/10) > 1e-10, np.power(10,vv/10)/np.power(10,vh/10), 0.0)\n        after_rgb = (np.stack([_s(vv),_s(vh), np.clip(np.nan_to_num((ratio-np.nanpercentile(ratio[ratio>0],5))/(np.nanpercentile(ratio[ratio>0],95)-np.nanpercentile(ratio[ratio>0],5)+1e-10),nan=0.0),0,1)], axis=-1) * 255).astype(np.uint8)\n    Image.fromarray(_force_uint8(after_rgb), \"RGB\").save(os.path.join(loc_dir, f\"{label}_UI_AFTER_RAW_EVENT.png\"))\n    \n    base = before_rgb.astype(np.float32)\n    base[r[\"perm_water\"]==1] = base[r[\"perm_water\"]==1]*0.4 + np.array([0,0,128],np.float32)*0.6\n    base[r[\"new_inund\"]==1] = base[r[\"new_inund\"]==1]*0.2 + np.array([0,102,255],np.float32)*0.8\n    Image.fromarray(np.clip(base,0,255).astype(np.uint8), \"RGB\").save(os.path.join(loc_dir, f\"{label}_UI_AFTER_MASK_OVERLAY.png\"))\n    \n    Image.fromarray((r[\"perm_water\"]*255).astype(np.uint8), \"L\").save(os.path.join(loc_dir, f\"{label}_mask_perm_water.png\"))\n    plt.imsave(os.path.join(loc_dir, f\"{label}_mask_prob_map.png\"), r[\"prob_map\"], cmap=\"inferno\", vmin=0, vmax=1)\n    Image.fromarray((r[\"binary_mask\"]*255).astype(np.uint8), \"L\").save(os.path.join(loc_dir, f\"{label}_mask_prediction.png\"))\n    Image.fromarray((r[\"new_inund\"]*255).astype(np.uint8), \"L\").save(os.path.join(loc_dir, f\"{label}_mask_new_inundation.png\"))\n    \n    print(f\"    Saved 7 assets -> {loc_dir}/\")\n\nCMAP_PERM = ListedColormap([\"#00000000\", \"#000080\"])\nCMAP_FLOOD = ListedColormap([\"#00000000\", \"#0066FF\"])\n\ndef visualize(label, r, masks_dir):\n    H, W = r[\"binary_mask\"].shape\n    flood_pct = 100.0 * r[\"new_inund\"].sum() / (H * W)\n    \n    before_rgb = (load_png_rgb(r[\"s2_before_png\"]) if r.get(\"s2_before_png\") else s2_to_rgb(r[\"s2_arr\"]))\n    if r.get(\"s1_after_png\"):\n        after_rgb = load_png_rgb(r[\"s1_after_png\"])\n    elif r.get(\"s2_after_png\"):\n        after_rgb = load_png_rgb(r[\"s2_after_png\"])\n    else:\n        after_rgb = before_rgb\n    \n    fig = plt.figure(figsize=(26, 12), facecolor=\"#080808\")\n    gs = gridspec.GridSpec(2, 4, figure=fig, hspace=0.2, wspace=0.1)\n    \n    ax_main = fig.add_subplot(gs[:, :2])\n    ax_main.imshow(before_rgb)\n    ax_main.imshow(r[\"perm_water\"], cmap=CMAP_PERM, alpha=0.6, vmin=0, vmax=1)\n    ax_main.imshow(r[\"new_inund\"], cmap=CMAP_FLOOD, alpha=0.8, vmin=0, vmax=1)\n    ax_main.set_title(\"OFFICIAL FLOOD EXTENT\", color=\"#0066FF\", fontsize=16, fontweight=\"bold\")\n    ax_main.axis(\"off\")\n    ax_main.legend(handles=[\n        mpatches.Patch(color=\"#000080\", label=\"Permanent Waterways\"),\n        mpatches.Patch(color=\"#0066FF\", label=\"Detected New Inundation\"),\n    ], loc=\"lower left\", facecolor=\"#111111\", labelcolor=\"white\", edgecolor=\"none\")\n    \n    ax_pre = fig.add_subplot(gs[0, 2])\n    ax_pre.imshow(before_rgb)\n    ax_pre.axis(\"off\")\n    ax_pre.set_title(\"BEFORE\", color=\"white\", fontsize=11)\n    \n    ax_post = fig.add_subplot(gs[1, 2])\n    ax_post.imshow(after_rgb)\n    ax_post.axis(\"off\")\n    after_label = \"AFTER (SAR)\" if r.get(\"s1_after_png\") else \"AFTER (S2 Visual)\"\n    ax_post.set_title(after_label, color=\"white\", fontsize=11)\n    \n    ax_prob = fig.add_subplot(gs[:, 3])\n    im = ax_prob.imshow(r[\"prob_map\"], cmap=\"viridis\", vmin=0, vmax=1)\n    ax_prob.set_title(\"AI CONFIDENCE SCORE\", color=\"white\", fontsize=11)\n    ax_prob.axis(\"off\")\n    cb = plt.colorbar(im, ax=ax_prob, fraction=0.046, pad=0.04)\n    cb.ax.yaxis.set_tick_params(color=\"white\")\n    plt.setp(cb.ax.yaxis.get_ticklabels(), color=\"white\", fontsize=8)\n    \n    fig.text(0.5, 0.02, f\"MANZAR ANALYSIS: {label} | NET INUNDATION: {flood_pct:.2f}%\", ha=\"center\", color=\"white\", fontsize=14, fontweight=\"bold\")\n    \n    loc_dir = os.path.join(masks_dir, label)\n    os.makedirs(loc_dir, exist_ok=True)\n    report_path = os.path.join(loc_dir, f\"{label}_CLEAN_REPORT.png\")\n    plt.savefig(report_path, dpi=200, facecolor=\"#080808\", bbox_inches=\"tight\")\n    print(f\"    Dashboard -> {report_path}\")\n    plt.show()\n    plt.close(fig)\n\n# ═══════════════════════════════════════════════════════════════════════\n# MAIN PIPELINE\n# ═══════════════════════════════════════════════════════════════════════\ntry:\n    model = load_model(MODEL_PATH, device)\nexcept Exception as e:\n    debug_log(f\"Failed to load model: {e}\", \"ERROR\")\n    raise\n\nall_results = {}\nmetrics_log = []\n\nfor label, lat, lon in LOCATIONS:\n    debug_log(f\"\\n{'='*65}\")\n    debug_log(f\"Processing: {label}\")\n    print(f\"\\n{'='*65}\\n  {label}\\n{'='*65}\")\n    \n    files = discover(label, COMPOSITES_DIR)\n    \n    if not files[\"s2_tif\"] or not files[\"s1_tif\"]:\n        debug_log(f\"SKIP: Missing files for {label}\", \"WARNING\")\n        print(f\"  SKIP: Missing S2 or S1 data for {label}\")\n        continue\n    \n    print(f\"  S2 TIF: {os.path.basename(files['s2_tif'])}\")\n    print(f\"  S1 TIF: {os.path.basename(files['s1_tif'])}\")\n    \n    # Load data with correct handling\n    s2_arr, s2_tf, s2_crs = load_tif_corrected(files[\"s2_tif\"], is_sar=False)\n    s1_arr_db, s1_tf, s1_crs = load_tif_corrected(files[\"s1_tif\"], is_sar=True)\n    \n    # Permanent water mask\n    mndwi, perm_water = mndwi_permanent_water(s2_arr)\n    debug_log(f\"Permanent water: {perm_water.sum()} pixels ({100*perm_water.sum()/perm_water.size:.2f}%)\")\n    \n    # Build tensor\n    tensor = build_tensor_fixed(s2_arr, s1_arr_db, sar_only=SAR_ONLY_MODE)\n    print(f\"  Tensor shape: {tensor.shape}\")\n    \n    # Run inference\n    prob_map, binary_mask = tiled_predict(model, tensor, device)\n    \n    # Align masks\n    H, W = binary_mask.shape\n    if perm_water.shape != (H, W):\n        pw_t = torch.from_numpy(perm_water.astype(np.float32)).unsqueeze(0).unsqueeze(0)\n        pw_t = F.interpolate(pw_t, size=(H, W), mode=\"nearest\")\n        perm_water = (pw_t.squeeze().numpy() > 0.5).astype(np.uint8)\n    \n    # New inundation (flood minus permanent water)\n    new_inund = ((binary_mask == 1) & (perm_water == 0)).astype(np.uint8)\n    \n    # Calculate metrics\n    flood_km2 = float(binary_mask.sum()) * PIXEL_AREA_KM2\n    new_km2 = float(new_inund.sum()) * PIXEL_AREA_KM2\n    perm_km2 = float(perm_water.sum()) * PIXEL_AREA_KM2\n    net_pct = 100.0 * new_inund.sum() / (H * W)\n    \n    debug_log(f\"Results: {new_km2:.2f} km2 ({net_pct:.2f}%)\")\n    print(f\"  New inundation: {new_km2:.2f} km2 ({net_pct:.2f}%)\")\n    print(f\"  Permanent water: {perm_km2:.2f} km2\")\n    \n    metrics_log.append({\n        \"location\": label, \"lat\": lat, \"lon\": lon,\n        \"flood_extent_km2\": round(flood_km2, 3),\n        \"new_inundation_km2\": round(new_km2, 3),\n        \"perm_water_km2\": round(perm_km2, 3),\n        \"net_inundation_pct\": round(net_pct, 4),\n    })\n    \n    all_results[label] = {\n        \"s2_arr\": s2_arr, \"s1_arr_db\": s1_arr_db,\n        \"prob_map\": prob_map, \"binary_mask\": binary_mask,\n        \"perm_water\": perm_water, \"new_inund\": new_inund,\n        \"mndwi\": mndwi,\n        \"s2_before_png\": files[\"s2_before_png\"],\n        \"s1_after_png\": files[\"s1_after_png\"],\n        \"s2_after_png\": files[\"s2_after_png\"],\n    }\n\n# Save metrics\nwith open(METRICS_JSON, \"w\") as f:\n    json.dump(metrics_log, f, indent=2)\nprint(f\"\\nMetrics saved: {METRICS_JSON}\")\n\n# Visualize results\nprint(f\"\\nRendering dashboards for {len(all_results)} locations...\")\nfor label, r in all_results.items():\n    print(f\"\\n  {label}\")\n    export_pngs(label, r, MASKS_PNG_DIR)\n    visualize(label, r, MASKS_PNG_DIR)\n\nprint(f\"\\n✅ Done! Results in: {MASKS_PNG_DIR}/\")\nprint(f\"📊 Processed: {len(all_results)}/{len(LOCATIONS)} locations\")\nprint(f\"📝 Debug log: {DEBUG_LOG}\")\n\nprint(\"\\n=== FINAL METRICS ===\")\nfor m in metrics_log:\n    print(f\"  {m['location']:25s}: {m['new_inundation_km2']:.2f} km2 ({m['net_inundation_pct']:.2f}%)\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-27T20:05:54.960808Z","iopub.execute_input":"2026-04-27T20:05:54.961524Z","iopub.status.idle":"2026-04-27T20:06:32.333452Z","shell.execute_reply.started":"2026-04-27T20:05:54.961496Z","shell.execute_reply":"2026-04-27T20:06:32.332485Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# !pip install segmentation-models-pytorch rasterio -q\n\nimport os, glob, json, warnings\nimport numpy as np\nimport torch\nimport torch.nn as nn\nimport torch.nn.functional as F\nimport segmentation_models_pytorch as smp\nimport rasterio\nfrom rasterio.enums import Resampling\nimport matplotlib.pyplot as plt\nimport matplotlib.patches as mpatches\nimport matplotlib.gridspec as gridspec\nfrom matplotlib.colors import ListedColormap\nfrom PIL import Image, ImageEnhance\nfrom tqdm.auto import tqdm\nimport datetime\nwarnings.filterwarnings(\"ignore\")\n\n# ═══════════════════════════════════════════════════════════════════════\n# CONFIG\n# ═══════════════════════════════════════════════════════════════════════\nCOMPOSITES_DIR = \"./flood_composites\"\nMODEL_PATH     = \"/kaggle/input/models/muhammadmubeenxt/ablation-flooding/pytorch/default/1/ablation_best_flood_model_full.pth\"\nMASKS_PNG_DIR  = \"./masks_pngs\"\nMETRICS_JSON   = \"./flood_metrics.json\"\nDEBUG_LOG      = \"./flood_debug.log\"\nos.makedirs(MASKS_PNG_DIR, exist_ok=True)\n\n# Locations\nLOCATIONS = [\n    #(\"Sialkot_punjab\",    32.496304,  74.538327),\n    (\"Dadu_Sindh\",        26.73,      67.78),\n    (\"Sukkur_Sindh\",      27.70,      68.87),\n    (\"Jacobabad_Sindh\",   28.28,      68.43),\n    (\"DG_Khan_Punjab\",    30.06,      70.64),\n    (\"Nowshera_KPK\",      34.01,      71.99),\n]\n\nFLOOD_THRESHOLD  = 0.55\nPERM_WATER_MNDWI = -0.1\nSAR_ONLY_MODE    = False\nTILE_SIZE        = 256\nTILE_OVERLAP     = 64\nTILE_STRIDE      = TILE_SIZE - TILE_OVERLAP\nPIXEL_AREA_KM2   = (10.0 * 10.0) / 1e6\n\ndevice = torch.device(\"cuda\" if torch.cuda.is_available() else \"cpu\")\ntorch.cuda.empty_cache()\n\n# Setup debug logging\ndef debug_log(msg, level=\"INFO\"):\n    timestamp = datetime.datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\")\n    log_msg = f\"[{timestamp}] [{level}] {msg}\"\n    print(log_msg)\n    with open(DEBUG_LOG, \"a\") as f:\n        f.write(log_msg + \"\\n\")\n\ndebug_log(f\"=== FLOOD DETECTION STARTED ===\")\ndebug_log(f\"Device: {device}, TILE_SIZE: {TILE_SIZE}, Threshold: {FLOOD_THRESHOLD}\")\n\n# ═══════════════════════════════════════════════════════════════════════\n# MODEL DEFINITION\n# ═══════════════════════════════════════════════════════════════════════\nclass CBAM(nn.Module):\n    def __init__(self, channels, reduction=8):\n        super().__init__()\n        self.avg = nn.AdaptiveAvgPool2d(1)\n        self.max = nn.AdaptiveMaxPool2d(1)\n        self.fc  = nn.Sequential(\n            nn.Linear(channels, channels // reduction, bias=False),\n            nn.ReLU(inplace=True),\n            nn.Linear(channels // reduction, channels, bias=False))\n        self.sc  = nn.Conv2d(2, 1, kernel_size=7, padding=3, bias=False)\n\n    def forward(self, x):\n        b, c = x.shape[:2]\n        a = self.fc(self.avg(x).view(b, c))\n        m = self.fc(self.max(x).view(b, c))\n        x = x * torch.sigmoid(a + m).view(b, c, 1, 1)\n        s = torch.cat([x.mean(1, keepdim=True), x.max(1, keepdim=True)[0]], dim=1)\n        return x * torch.sigmoid(self.sc(s))\n\nclass DualStreamUNetPP(nn.Module):\n    def __init__(self, use_cbam=True):\n        super().__init__()\n        self.use_cbam = use_cbam\n        self.sar_enc  = smp.UnetPlusPlus(encoder_name=\"resnet50\", encoder_weights=None,\n                                          in_channels=3, classes=32)\n        self.opt_enc  = smp.UnetPlusPlus(encoder_name=\"resnet50\", encoder_weights=None,\n                                          in_channels=7, classes=32)\n        if use_cbam:\n            self.cbam = CBAM(64)\n        self.head = nn.Sequential(\n            nn.Conv2d(64, 32, 3, padding=1, bias=False),\n            nn.BatchNorm2d(32), nn.ReLU(inplace=True),\n            nn.Dropout2d(p=0.15), nn.Conv2d(32, 1, 1))\n\n    def forward(self, x):\n        sar = torch.cat([x[:, 0:2], x[:, 7:8]], dim=1)\n        opt = torch.cat([x[:, 2:7], x[:, 8:10]], dim=1)\n        f   = torch.cat([self.sar_enc(sar), self.opt_enc(opt)], dim=1)\n        if self.use_cbam:\n            f = self.cbam(f)\n        return self.head(f)\n\ndef load_model(path, device):\n    debug_log(f\"Loading model from: {path}\")\n    if not os.path.exists(path):\n        raise FileNotFoundError(f\"Checkpoint not found: {path}\")\n    \n    m = DualStreamUNetPP(use_cbam=True)\n    raw = torch.load(path, map_location=device)\n    state = raw.get(\"model_state\", raw)\n    \n    # Strip DataParallel prefix\n    state = {k.replace(\"module.\", \"\"): v for k, v in state.items()}\n    \n    # Remap keys\n    remapped = {}\n    for k, v in state.items():\n        k = k.replace(\"sar_encoder.\", \"sar_enc.\").replace(\"opt_encoder.\", \"opt_enc.\")\n        remapped[k] = v\n    \n    missing, unexpected = m.load_state_dict(remapped, strict=False)\n    if missing:\n        debug_log(f\"Missing keys: {missing[:3]}\", \"WARNING\")\n    if unexpected:\n        debug_log(f\"Unexpected keys: {unexpected[:3]}\", \"WARNING\")\n    \n    m.to(device).eval()\n    param_count = sum(p.numel() for p in m.parameters())/1e6\n    debug_log(f\"Model loaded: {param_count:.1f}M params\")\n    \n    # Test model\n    debug_log(\"Testing model with dummy input...\")\n    dummy_input = torch.randn(1, 10, 256, 256).to(device)\n    with torch.no_grad():\n        dummy_output = m(dummy_input)\n    debug_log(f\"Dummy output shape: {dummy_output.shape}\")\n    \n    return m\n\n# ═══════════════════════════════════════════════════════════════════════\n# FILE DISCOVERY\n# ═══════════════════════════════════════════════════════════════════════\ndef find_file(base_dir, pattern):\n    hits = sorted(glob.glob(os.path.join(base_dir, pattern)))\n    return hits[-1] if hits else None\n\ndef discover(label, composites_dir):\n    d = {}\n    d[\"s2_tif\"] = find_file(composites_dir, f\"{label}_s2_baseline_*.tif\")\n    d[\"s1_tif\"] = (\n        find_file(composites_dir, f\"{label}_s1_*_composite_*.tif\") or\n        find_file(composites_dir, f\"{label}_s1_composite_*.tif\")\n    )\n    d[\"s2_before_png\"] = find_file(composites_dir, f\"{label}_s2_baseline_*_visual.png\")\n    d[\"s1_after_png\"]  = (\n        find_file(composites_dir, f\"{label}_s1_*_falsecolor_*.png\") or\n        find_file(composites_dir, f\"{label}_s1_falsecolor_*.png\")\n    )\n    d[\"s2_after_png\"]  = find_file(composites_dir, f\"{label}_s2_visual_after_*.png\")\n    return d\n\n# ═══════════════════════════════════════════════════════════════════════\n# DATA LOADING - FIXED VERSION\n# ═══════════════════════════════════════════════════════════════════════\ndef load_tif_corrected(path, is_sar=False):\n    \"\"\"Load GeoTIFF - S2 gets scaled to 0-1, S1 stays in dB\"\"\"\n    debug_log(f\"Loading GeoTIFF: {path}\")\n    \n    with rasterio.open(path) as src:\n        data = src.read().astype(np.float32)\n        \n        if is_sar:\n            # SAR data: convert linear to dB if needed\n            if data.max() > 10:  # Linear scale\n                debug_log(f\"  Converting SAR from linear to dB (max={data.max():.2f})\")\n                data = np.clip(10 * np.log10(data + 1e-9), -35, 5)\n            debug_log(f\"  SAR dB - range: [{data.min():.2f}, {data.max():.2f}], mean: {data.mean():.2f}\")\n        else:\n            # S2 optical: scale 0-10000 to 0-1\n            if data.max() > 10:\n                debug_log(f\"  Scaling S2 (max={data.max():.2f}) to 0-1\")\n                data = data / 10000.0\n            data = np.clip(data, 0.0, 1.0)\n            debug_log(f\"  S2 scaled - range: [{data.min():.4f}, {data.max():.4f}], mean: {data.mean():.4f}\")\n        \n        return data, src.transform, src.crs\n\ndef match_hw(arr, target_hw):\n    tH, tW = target_hw\n    if arr.shape[1] == tH and arr.shape[2] == tW:\n        return arr\n    t = torch.from_numpy(arr).unsqueeze(0).float()\n    t = F.interpolate(t, size=(tH, tW), mode=\"bilinear\", align_corners=False)\n    return t.squeeze(0).numpy()\n\ndef build_tensor_fixed(s2_arr, s1_arr_db, sar_only=False):\n    \"\"\"Build 10-channel input tensor\"\"\"\n    debug_log(\"Building input tensor...\")\n    H, W = s2_arr.shape[1], s2_arr.shape[2]\n    s1_arr_db = match_hw(s1_arr_db, (H, W))\n    \n    # Normalize dB to [0,1] for model input\n    vv = np.clip((s1_arr_db[0] + 30.0) / 30.0, 0.0, 1.0)\n    vh = np.clip((s1_arr_db[1] + 30.0) / 30.0, 0.0, 1.0)\n    vv = np.nan_to_num(vv, nan=0.0)\n    vh = np.nan_to_num(vh, nan=0.0)\n    \n    debug_log(f\"  Normalized VV - range: [{vv.min():.4f}, {vv.max():.4f}], unique: {len(np.unique(vv))}\")\n    debug_log(f\"  Normalized VH - range: [{vh.min():.4f}, {vh.max():.4f}], unique: {len(np.unique(vh))}\")\n    \n    # SAR ratio\n    with np.errstate(divide=\"ignore\", invalid=\"ignore\"):\n        sar_r = np.where(vh > 1e-8, vv / vh, 0.0)\n    sar_r = np.clip(np.nan_to_num(sar_r, nan=0.0, posinf=0.0), 0.0, 10.0)\n    \n    if sar_only:\n        tensor = np.zeros((10, H, W), dtype=np.float32)\n        tensor[0] = vv\n        tensor[1] = vh\n        tensor[7] = sar_r\n        return tensor\n    \n    # Optical bands\n    blue = np.clip(np.nan_to_num(s2_arr[0], nan=0.0), 0.0, 1.0)\n    green = np.clip(np.nan_to_num(s2_arr[1], nan=0.0), 0.0, 1.0)\n    red = np.clip(np.nan_to_num(s2_arr[2], nan=0.0), 0.0, 1.0)\n    nir = np.clip(np.nan_to_num(s2_arr[3], nan=0.0), 0.0, 1.0)\n    swir1 = np.clip(np.nan_to_num(s2_arr[4], nan=0.0), 0.0, 1.0)\n    \n    debug_log(f\"  S2 means - B:{blue.mean():.3f} G:{green.mean():.3f} R:{red.mean():.3f}\")\n    \n    # Indices\n    with np.errstate(divide=\"ignore\", invalid=\"ignore\"):\n        ndwi = np.where((green+nir) > 1e-8, (green-nir) / (green+nir), 0.0)\n        mndwi = np.where((green+swir1) > 1e-8, (green-swir1) / (green+swir1), 0.0)\n    \n    ndwi = np.nan_to_num(ndwi, nan=0.0)\n    mndwi = np.nan_to_num(mndwi, nan=0.0)\n    \n    tensor = np.stack([\n        vv, vh, blue, green, red, nir, ndwi, sar_r, swir1, mndwi\n    ], axis=0).astype(np.float32)\n    \n    debug_log(f\"  Tensor - range: [{tensor.min():.4f}, {tensor.max():.4f}], mean: {tensor.mean():.4f}\")\n    return tensor\n\n# ═══════════════════════════════════════════════════════════════════════\n# TILED INFERENCE\n# ═══════════════════════════════════════════════════════════════════════\ndef _hanning_window(size):\n    lin = np.hanning(size).astype(np.float64)\n    w = np.outer(lin, lin)\n    return np.clip(w, 1e-6, None)\n\n@torch.no_grad()\ndef tiled_predict(model, tensor, device):\n    debug_log(\"Starting tiled prediction...\")\n    C, H, W = tensor.shape\n    debug_log(f\"  Input shape: {tensor.shape}\")\n    \n    torch.cuda.empty_cache()\n    win = _hanning_window(TILE_SIZE)\n    \n    pad_h = (-H) % TILE_STRIDE\n    pad_w = (-W) % TILE_STRIDE\n    if pad_h or pad_w:\n        debug_log(f\"  Padding: h={pad_h}, w={pad_w}\")\n        tensor = np.pad(tensor, ((0,0),(0,pad_h),(0,pad_w)), mode=\"reflect\")\n    \n    _, PH, PW = tensor.shape\n    acc = np.zeros((PH, PW), dtype=np.float64)\n    count = np.zeros((PH, PW), dtype=np.float64)\n    \n    ys = list(range(0, PH - TILE_SIZE + 1, TILE_STRIDE))\n    xs = list(range(0, PW - TILE_SIZE + 1, TILE_STRIDE))\n    if ys and ys[-1] + TILE_SIZE < PH:\n        ys.append(PH - TILE_SIZE)\n    if xs and xs[-1] + TILE_SIZE < PW:\n        xs.append(PW - TILE_SIZE)\n    \n    debug_log(f\"  Tiles: {len(ys)} x {len(xs)} = {len(ys)*len(xs)} tiles\")\n    \n    model.eval()\n    coords = [(y, x) for y in ys for x in xs]\n    \n    for idx, (y0, x0) in enumerate(tqdm(coords, desc=\"  Tiles\", leave=False)):\n        chip = tensor[:, y0:y0+TILE_SIZE, x0:x0+TILE_SIZE]\n        xt = torch.from_numpy(chip).unsqueeze(0).to(device)\n        \n        with torch.amp.autocast(\"cuda\", enabled=(device.type == \"cuda\")):\n            prob = torch.sigmoid(model(xt)).squeeze().cpu().numpy().astype(np.float64)\n        \n        acc[y0:y0+TILE_SIZE, x0:x0+TILE_SIZE] += prob * win\n        count[y0:y0+TILE_SIZE, x0:x0+TILE_SIZE] += win\n        \n        if idx % 20 == 0:\n            torch.cuda.empty_cache()\n    \n    prob_map = (acc / np.where(count > 0, count, 1.0)).astype(np.float32)\n    prob_map = prob_map[:H, :W]\n    binary = (prob_map >= FLOOD_THRESHOLD).astype(np.uint8)\n    \n    debug_log(f\"  Probability - min: {prob_map.min():.4f}, max: {prob_map.max():.4f}, mean: {prob_map.mean():.4f}\")\n    debug_log(f\"  Flood pixels: {binary.sum()} ({100*binary.sum()/(H*W):.2f}%)\")\n    \n    return prob_map, binary\n\n# ═══════════════════════════════════════════════════════════════════════\n# VISUALIZATION HELPERS\n# ═══════════════════════════════════════════════════════════════════════\ndef load_png_rgb(path):\n    return np.array(Image.open(path).convert(\"RGB\"))\n\ndef s2_to_rgb(s2_arr, gamma=0.55, lo=1.0, hi=98.0, sat=1.3):\n    chs = []\n    for idx in [2, 1, 0]:\n        b = s2_arr[idx].astype(np.float32)\n        v = b[~np.isnan(b)]\n        if not len(v):\n            chs.append(np.zeros(b.shape, np.float32))\n            continue\n        lo_v, hi_v = np.percentile(v, [lo, hi])\n        b = np.clip(b, lo_v, hi_v)\n        b = (b - lo_v) / (hi_v - lo_v + 1e-10)\n        b = np.power(np.clip(np.nan_to_num(b, nan=0.0), 0, 1), gamma)\n        chs.append(b)\n    rgb = np.stack(chs, axis=-1)\n    try:\n        pil = Image.fromarray((rgb*255).astype(np.uint8), \"RGB\")\n        pil = ImageEnhance.Color(pil).enhance(sat)\n        rgb = np.array(pil).astype(np.float32) / 255.0\n    except Exception:\n        pass\n    return (rgb * 255).astype(np.uint8)\n\ndef mndwi_permanent_water(s2_arr):\n    green = np.clip(np.nan_to_num(s2_arr[1], nan=0.0), 0, 1)\n    swir1 = np.clip(np.nan_to_num(s2_arr[4], nan=0.0), 0, 1)\n    with np.errstate(divide=\"ignore\", invalid=\"ignore\"):\n        mndwi = np.where((green+swir1) > 1e-8, (green-swir1)/(green+swir1), 0.0)\n    mndwi = np.nan_to_num(mndwi, nan=0.0).astype(np.float32)\n    return mndwi, (mndwi > PERM_WATER_MNDWI).astype(np.uint8)\n\ndef export_pngs(label, r, masks_dir):\n    loc_dir = os.path.join(masks_dir, label)\n    os.makedirs(loc_dir, exist_ok=True)\n    \n    def _force_uint8(arr):\n        arr = np.array(arr, dtype=np.float32)\n        if arr.max() <= 1.0:\n            arr = np.clip(arr, 0, 1) * 255\n        return np.nan_to_num(arr, nan=0.0).astype(np.uint8)\n    \n    before_rgb = (load_png_rgb(r[\"s2_before_png\"]) if r.get(\"s2_before_png\") else s2_to_rgb(r[\"s2_arr\"]))\n    Image.fromarray(_force_uint8(before_rgb), \"RGB\").save(os.path.join(loc_dir, f\"{label}_UI_BEFORE_OPTICAL.png\"))\n    \n    if r.get(\"s1_after_png\"):\n        after_rgb = load_png_rgb(r[\"s1_after_png\"])\n    elif r.get(\"s2_after_png\"):\n        after_rgb = load_png_rgb(r[\"s2_after_png\"])\n    else:\n        vv = r[\"s1_arr_db\"][0]\n        vh = r[\"s1_arr_db\"][1]\n        def _s(a, lo=2, hi=98):\n            v = a[~np.isnan(a)]\n            if not len(v):\n                return np.zeros_like(a, np.float32)\n            lv, hv = np.percentile(v, [lo, hi])\n            return np.clip(np.nan_to_num((a-lv)/(hv-lv+1e-10), nan=0.0), 0, 1)\n        ratio = np.where(np.power(10,vh/10) > 1e-10, np.power(10,vv/10)/np.power(10,vh/10), 0.0)\n        after_rgb = (np.stack([_s(vv),_s(vh), np.clip(np.nan_to_num((ratio-np.nanpercentile(ratio[ratio>0],5))/(np.nanpercentile(ratio[ratio>0],95)-np.nanpercentile(ratio[ratio>0],5)+1e-10),nan=0.0),0,1)], axis=-1) * 255).astype(np.uint8)\n    Image.fromarray(_force_uint8(after_rgb), \"RGB\").save(os.path.join(loc_dir, f\"{label}_UI_AFTER_RAW_EVENT.png\"))\n    \n    base = before_rgb.astype(np.float32)\n    base[r[\"perm_water\"]==1] = base[r[\"perm_water\"]==1]*0.4 + np.array([0,0,128],np.float32)*0.6\n    base[r[\"new_inund\"]==1] = base[r[\"new_inund\"]==1]*0.2 + np.array([0,102,255],np.float32)*0.8\n    Image.fromarray(np.clip(base,0,255).astype(np.uint8), \"RGB\").save(os.path.join(loc_dir, f\"{label}_UI_AFTER_MASK_OVERLAY.png\"))\n    \n    Image.fromarray((r[\"perm_water\"]*255).astype(np.uint8), \"L\").save(os.path.join(loc_dir, f\"{label}_mask_perm_water.png\"))\n    plt.imsave(os.path.join(loc_dir, f\"{label}_mask_prob_map.png\"), r[\"prob_map\"], cmap=\"inferno\", vmin=0, vmax=1)\n    Image.fromarray((r[\"binary_mask\"]*255).astype(np.uint8), \"L\").save(os.path.join(loc_dir, f\"{label}_mask_prediction.png\"))\n    Image.fromarray((r[\"new_inund\"]*255).astype(np.uint8), \"L\").save(os.path.join(loc_dir, f\"{label}_mask_new_inundation.png\"))\n    \n    print(f\"    Saved 7 assets -> {loc_dir}/\")\n\nCMAP_PERM = ListedColormap([\"#00000000\", \"#000080\"])\nCMAP_FLOOD = ListedColormap([\"#00000000\", \"#0066FF\"])\n\ndef visualize(label, r, masks_dir):\n    H, W = r[\"binary_mask\"].shape\n    flood_pct = 100.0 * r[\"new_inund\"].sum() / (H * W)\n    \n    before_rgb = (load_png_rgb(r[\"s2_before_png\"]) if r.get(\"s2_before_png\") else s2_to_rgb(r[\"s2_arr\"]))\n    if r.get(\"s1_after_png\"):\n        after_rgb = load_png_rgb(r[\"s1_after_png\"])\n    elif r.get(\"s2_after_png\"):\n        after_rgb = load_png_rgb(r[\"s2_after_png\"])\n    else:\n        after_rgb = before_rgb\n    \n    fig = plt.figure(figsize=(26, 12), facecolor=\"#080808\")\n    gs = gridspec.GridSpec(2, 4, figure=fig, hspace=0.2, wspace=0.1)\n    \n    ax_main = fig.add_subplot(gs[:, :2])\n    ax_main.imshow(before_rgb)\n    ax_main.imshow(r[\"perm_water\"], cmap=CMAP_PERM, alpha=0.6, vmin=0, vmax=1)\n    ax_main.imshow(r[\"new_inund\"], cmap=CMAP_FLOOD, alpha=0.8, vmin=0, vmax=1)\n    ax_main.set_title(\"OFFICIAL FLOOD EXTENT\", color=\"#0066FF\", fontsize=16, fontweight=\"bold\")\n    ax_main.axis(\"off\")\n    ax_main.legend(handles=[\n        mpatches.Patch(color=\"#000080\", label=\"Permanent Waterways\"),\n        mpatches.Patch(color=\"#0066FF\", label=\"Detected New Inundation\"),\n    ], loc=\"lower left\", facecolor=\"#111111\", labelcolor=\"white\", edgecolor=\"none\")\n    \n    ax_pre = fig.add_subplot(gs[0, 2])\n    ax_pre.imshow(before_rgb)\n    ax_pre.axis(\"off\")\n    ax_pre.set_title(\"BEFORE\", color=\"white\", fontsize=11)\n    \n    ax_post = fig.add_subplot(gs[1, 2])\n    ax_post.imshow(after_rgb)\n    ax_post.axis(\"off\")\n    after_label = \"AFTER (SAR)\" if r.get(\"s1_after_png\") else \"AFTER (S2 Visual)\"\n    ax_post.set_title(after_label, color=\"white\", fontsize=11)\n    \n    ax_prob = fig.add_subplot(gs[:, 3])\n    im = ax_prob.imshow(r[\"prob_map\"], cmap=\"viridis\", vmin=0, vmax=1)\n    ax_prob.set_title(\"AI CONFIDENCE SCORE\", color=\"white\", fontsize=11)\n    ax_prob.axis(\"off\")\n    cb = plt.colorbar(im, ax=ax_prob, fraction=0.046, pad=0.04)\n    cb.ax.yaxis.set_tick_params(color=\"white\")\n    plt.setp(cb.ax.yaxis.get_ticklabels(), color=\"white\", fontsize=8)\n    \n    fig.text(0.5, 0.02, f\"MANZAR ANALYSIS: {label} | NET INUNDATION: {flood_pct:.2f}%\", ha=\"center\", color=\"white\", fontsize=14, fontweight=\"bold\")\n    \n    loc_dir = os.path.join(masks_dir, label)\n    os.makedirs(loc_dir, exist_ok=True)\n    report_path = os.path.join(loc_dir, f\"{label}_CLEAN_REPORT.png\")\n    plt.savefig(report_path, dpi=200, facecolor=\"#080808\", bbox_inches=\"tight\")\n    print(f\"    Dashboard -> {report_path}\")\n    plt.show()\n    plt.close(fig)\n\n# ═══════════════════════════════════════════════════════════════════════\n# MAIN PIPELINE\n# ═══════════════════════════════════════════════════════════════════════\ntry:\n    model = load_model(MODEL_PATH, device)\nexcept Exception as e:\n    debug_log(f\"Failed to load model: {e}\", \"ERROR\")\n    raise\n\nall_results = {}\nmetrics_log = []\n\nfor label, lat, lon in LOCATIONS:\n    debug_log(f\"\\n{'='*65}\")\n    debug_log(f\"Processing: {label}\")\n    print(f\"\\n{'='*65}\\n  {label}\\n{'='*65}\")\n    \n    files = discover(label, COMPOSITES_DIR)\n    \n    if not files[\"s2_tif\"] or not files[\"s1_tif\"]:\n        debug_log(f\"SKIP: Missing files for {label}\", \"WARNING\")\n        print(f\"  SKIP: Missing S2 or S1 data for {label}\")\n        continue\n    \n    print(f\"  S2 TIF: {os.path.basename(files['s2_tif'])}\")\n    print(f\"  S1 TIF: {os.path.basename(files['s1_tif'])}\")\n    \n    # Load data with correct handling\n    s2_arr, s2_tf, s2_crs = load_tif_corrected(files[\"s2_tif\"], is_sar=False)\n    s1_arr_db, s1_tf, s1_crs = load_tif_corrected(files[\"s1_tif\"], is_sar=True)\n    \n    # Permanent water mask\n    mndwi, perm_water = mndwi_permanent_water(s2_arr)\n    debug_log(f\"Permanent water: {perm_water.sum()} pixels ({100*perm_water.sum()/perm_water.size:.2f}%)\")\n    \n    # Build tensor\n    tensor = build_tensor_fixed(s2_arr, s1_arr_db, sar_only=SAR_ONLY_MODE)\n    print(f\"  Tensor shape: {tensor.shape}\")\n    \n    # Run inference\n    prob_map, binary_mask = tiled_predict(model, tensor, device)\n    \n    # Align masks\n    H, W = binary_mask.shape\n    if perm_water.shape != (H, W):\n        pw_t = torch.from_numpy(perm_water.astype(np.float32)).unsqueeze(0).unsqueeze(0)\n        pw_t = F.interpolate(pw_t, size=(H, W), mode=\"nearest\")\n        perm_water = (pw_t.squeeze().numpy() > 0.5).astype(np.uint8)\n    \n    # New inundation (flood minus permanent water)\n    new_inund = ((binary_mask == 1) & (perm_water == 0)).astype(np.uint8)\n    \n    # Calculate metrics\n    flood_km2 = float(binary_mask.sum()) * PIXEL_AREA_KM2\n    new_km2 = float(new_inund.sum()) * PIXEL_AREA_KM2\n    perm_km2 = float(perm_water.sum()) * PIXEL_AREA_KM2\n    net_pct = 100.0 * new_inund.sum() / (H * W)\n    \n    debug_log(f\"Results: {new_km2:.2f} km2 ({net_pct:.2f}%)\")\n    print(f\"  New inundation: {new_km2:.2f} km2 ({net_pct:.2f}%)\")\n    print(f\"  Permanent water: {perm_km2:.2f} km2\")\n    \n    metrics_log.append({\n        \"location\": label, \"lat\": lat, \"lon\": lon,\n        \"flood_extent_km2\": round(flood_km2, 3),\n        \"new_inundation_km2\": round(new_km2, 3),\n        \"perm_water_km2\": round(perm_km2, 3),\n        \"net_inundation_pct\": round(net_pct, 4),\n    })\n    \n    all_results[label] = {\n        \"s2_arr\": s2_arr, \"s1_arr_db\": s1_arr_db,\n        \"prob_map\": prob_map, \"binary_mask\": binary_mask,\n        \"perm_water\": perm_water, \"new_inund\": new_inund,\n        \"mndwi\": mndwi,\n        \"s2_before_png\": files[\"s2_before_png\"],\n        \"s1_after_png\": files[\"s1_after_png\"],\n        \"s2_after_png\": files[\"s2_after_png\"],\n    }\n\n# Save metrics\nwith open(METRICS_JSON, \"w\") as f:\n    json.dump(metrics_log, f, indent=2)\nprint(f\"\\nMetrics saved: {METRICS_JSON}\")\n\n# Visualize results\nprint(f\"\\nRendering dashboards for {len(all_results)} locations...\")\nfor label, r in all_results.items():\n    print(f\"\\n  {label}\")\n    export_pngs(label, r, MASKS_PNG_DIR)\n    visualize(label, r, MASKS_PNG_DIR)\n\nprint(f\"\\n✅ Done! Results in: {MASKS_PNG_DIR}/\")\nprint(f\"📊 Processed: {len(all_results)}/{len(LOCATIONS)} locations\")\nprint(f\"📝 Debug log: {DEBUG_LOG}\")\n\nprint(\"\\n=== FINAL METRICS ===\")\nfor m in metrics_log:\n    print(f\"  {m['location']:25s}: {m['new_inundation_km2']:.2f} km2 ({m['net_inundation_pct']:.2f}%)\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-27T20:07:50.818446Z","iopub.execute_input":"2026-04-27T20:07:50.81923Z","iopub.status.idle":"2026-04-27T20:09:55.733189Z","shell.execute_reply.started":"2026-04-27T20:07:50.819202Z","shell.execute_reply":"2026-04-27T20:09:55.732227Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# !pip install segmentation-models-pytorch rasterio -q\n\nimport os, glob, json, warnings\nimport numpy as np\nimport torch\nimport torch.nn as nn\nimport torch.nn.functional as F\nimport segmentation_models_pytorch as smp\nimport rasterio\nfrom rasterio.enums import Resampling\nimport matplotlib.pyplot as plt\nimport matplotlib.patches as mpatches\nimport matplotlib.gridspec as gridspec\nfrom matplotlib.colors import ListedColormap\nfrom PIL import Image, ImageEnhance\nfrom tqdm.auto import tqdm\nimport datetime\nwarnings.filterwarnings(\"ignore\")\n\n# ═══════════════════════════════════════════════════════════════════════\n# CONFIG\n# ═══════════════════════════════════════════════════════════════════════\nCOMPOSITES_DIR = \"./flood_composites\"\nMODEL_PATH     = \"/kaggle/input/models/muhammadmubeenxt/ablation-flooding/pytorch/default/1/ablation_best_flood_model_full.pth\"\nMASKS_PNG_DIR  = \"./masks_pngs\"\nMETRICS_JSON   = \"./flood_metrics.json\"\nDEBUG_LOG      = \"./flood_debug.log\"\nos.makedirs(MASKS_PNG_DIR, exist_ok=True)\n\n# Locations\nLOCATIONS = [\n    #(\"Sialkot_punjab\",    32.496304,  74.538327),\n    #(\"Dadu_Sindh\",        26.73,      67.78),\n    #(\"Sukkur_Sindh\",      27.70,      68.87),\n    #(\"Jacobabad_Sindh\",   28.28,      68.43),\n    #(\"DG_Khan_Punjab\",    30.06,      70.64),\n    #(\"Nowshera_KPK\",      34.01,      71.99),\n    (\"KwaZuluNatal_SA\",     -29.86,      31.01),\n    (\"Sylhet_Bangladesh\",    24.90,      91.87),\n    (\"Kherson_Ukraine\",      46.64,      32.62),\n]\n\n\n#{\"label\": \"Sylhet_Bangladesh\", \"lat\": 24.90, \"lon\": 91.87, \"radius_km\": 20, \"orbit\": None,\n     # \"baseline_start\": \"2022-01-01\", \"baseline_end\": \"2022-04-30\",\n     # \"event_start\": \"2022-06-01\", \"event_end\": \"2022-07-31\"},\n     #{\"label\": \"Kherson_Ukraine\", \"lat\": 46.64, \"lon\": 32.62, \"radius_km\": 20, \"orbit\": \"ascending\",\n      #\"baseline_start\": \"2023-03-01\", \"baseline_end\": \"2023-05-31\",\n      #\"event_start\": \"2023-06-06\", \"event_end\": \"2023-07-31\"},\n     #{\"label\": \"KwaZuluNatal_SA\", \"lat\": -29.86, \"lon\": 31.01, \"radius_km\": 20, \"orbit\": \"descending\",\n     # \"baseline_start\": \"2022-01-01\", \"baseline_end\": \"2022-03-31\",\n     # \"event_start\": \"2022-04-11\", \"event_end\": \"2022-05-31\"},\n\nFLOOD_THRESHOLD  = 0.40\nPERM_WATER_MNDWI = -0.01\nSAR_ONLY_MODE    = False\nTILE_SIZE        = 256\nTILE_OVERLAP     = 64\nTILE_STRIDE      = TILE_SIZE - TILE_OVERLAP\nPIXEL_AREA_KM2   = (10.0 * 10.0) / 1e6\n\ndevice = torch.device(\"cuda\" if torch.cuda.is_available() else \"cpu\")\ntorch.cuda.empty_cache()\n\n# Setup debug logging\ndef debug_log(msg, level=\"INFO\"):\n    timestamp = datetime.datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\")\n    log_msg = f\"[{timestamp}] [{level}] {msg}\"\n    print(log_msg)\n    with open(DEBUG_LOG, \"a\") as f:\n        f.write(log_msg + \"\\n\")\n\ndebug_log(f\"=== FLOOD DETECTION STARTED ===\")\ndebug_log(f\"Device: {device}, TILE_SIZE: {TILE_SIZE}, Threshold: {FLOOD_THRESHOLD}\")\n\n# ═══════════════════════════════════════════════════════════════════════\n# MODEL DEFINITION\n# ═══════════════════════════════════════════════════════════════════════\nclass CBAM(nn.Module):\n    def __init__(self, channels, reduction=8):\n        super().__init__()\n        self.avg = nn.AdaptiveAvgPool2d(1)\n        self.max = nn.AdaptiveMaxPool2d(1)\n        self.fc  = nn.Sequential(\n            nn.Linear(channels, channels // reduction, bias=False),\n            nn.ReLU(inplace=True),\n            nn.Linear(channels // reduction, channels, bias=False))\n        self.sc  = nn.Conv2d(2, 1, kernel_size=7, padding=3, bias=False)\n\n    def forward(self, x):\n        b, c = x.shape[:2]\n        a = self.fc(self.avg(x).view(b, c))\n        m = self.fc(self.max(x).view(b, c))\n        x = x * torch.sigmoid(a + m).view(b, c, 1, 1)\n        s = torch.cat([x.mean(1, keepdim=True), x.max(1, keepdim=True)[0]], dim=1)\n        return x * torch.sigmoid(self.sc(s))\n\nclass DualStreamUNetPP(nn.Module):\n    def __init__(self, use_cbam=True):\n        super().__init__()\n        self.use_cbam = use_cbam\n        self.sar_enc  = smp.UnetPlusPlus(encoder_name=\"resnet50\", encoder_weights=None,\n                                          in_channels=3, classes=32)\n        self.opt_enc  = smp.UnetPlusPlus(encoder_name=\"resnet50\", encoder_weights=None,\n                                          in_channels=7, classes=32)\n        if use_cbam:\n            self.cbam = CBAM(64)\n        self.head = nn.Sequential(\n            nn.Conv2d(64, 32, 3, padding=1, bias=False),\n            nn.BatchNorm2d(32), nn.ReLU(inplace=True),\n            nn.Dropout2d(p=0.15), nn.Conv2d(32, 1, 1))\n\n    def forward(self, x):\n        sar = torch.cat([x[:, 0:2], x[:, 7:8]], dim=1)\n        opt = torch.cat([x[:, 2:7], x[:, 8:10]], dim=1)\n        f   = torch.cat([self.sar_enc(sar), self.opt_enc(opt)], dim=1)\n        if self.use_cbam:\n            f = self.cbam(f)\n        return self.head(f)\n\ndef load_model(path, device):\n    debug_log(f\"Loading model from: {path}\")\n    if not os.path.exists(path):\n        raise FileNotFoundError(f\"Checkpoint not found: {path}\")\n    \n    m = DualStreamUNetPP(use_cbam=True)\n    raw = torch.load(path, map_location=device)\n    state = raw.get(\"model_state\", raw)\n    \n    # Strip DataParallel prefix\n    state = {k.replace(\"module.\", \"\"): v for k, v in state.items()}\n    \n    # Remap keys\n    remapped = {}\n    for k, v in state.items():\n        k = k.replace(\"sar_encoder.\", \"sar_enc.\").replace(\"opt_encoder.\", \"opt_enc.\")\n        remapped[k] = v\n    \n    missing, unexpected = m.load_state_dict(remapped, strict=False)\n    if missing:\n        debug_log(f\"Missing keys: {missing[:3]}\", \"WARNING\")\n    if unexpected:\n        debug_log(f\"Unexpected keys: {unexpected[:3]}\", \"WARNING\")\n    \n    m.to(device).eval()\n    param_count = sum(p.numel() for p in m.parameters())/1e6\n    debug_log(f\"Model loaded: {param_count:.1f}M params\")\n    \n    # Test model\n    debug_log(\"Testing model with dummy input...\")\n    dummy_input = torch.randn(1, 10, 256, 256).to(device)\n    with torch.no_grad():\n        dummy_output = m(dummy_input)\n    debug_log(f\"Dummy output shape: {dummy_output.shape}\")\n    \n    return m\n\n# ═══════════════════════════════════════════════════════════════════════\n# FILE DISCOVERY\n# ═══════════════════════════════════════════════════════════════════════\ndef find_file(base_dir, pattern):\n    hits = sorted(glob.glob(os.path.join(base_dir, pattern)))\n    return hits[-1] if hits else None\n\ndef discover(label, composites_dir):\n    d = {}\n    d[\"s2_tif\"] = find_file(composites_dir, f\"{label}_s2_baseline_*.tif\")\n    d[\"s1_tif\"] = (\n        find_file(composites_dir, f\"{label}_s1_*_composite_*.tif\") or\n        find_file(composites_dir, f\"{label}_s1_composite_*.tif\")\n    )\n    d[\"s2_before_png\"] = find_file(composites_dir, f\"{label}_s2_baseline_*_visual.png\")\n    d[\"s1_after_png\"]  = (\n        find_file(composites_dir, f\"{label}_s1_*_falsecolor_*.png\") or\n        find_file(composites_dir, f\"{label}_s1_falsecolor_*.png\")\n    )\n    d[\"s2_after_png\"]  = find_file(composites_dir, f\"{label}_s2_visual_after_*.png\")\n    return d\n\n# ═══════════════════════════════════════════════════════════════════════\n# DATA LOADING - FIXED VERSION\n# ═══════════════════════════════════════════════════════════════════════\ndef load_tif_corrected(path, is_sar=False):\n    \"\"\"Load GeoTIFF - S2 gets scaled to 0-1, S1 stays in dB\"\"\"\n    debug_log(f\"Loading GeoTIFF: {path}\")\n    \n    with rasterio.open(path) as src:\n        data = src.read().astype(np.float32)\n        \n        if is_sar:\n            # SAR data: convert linear to dB if needed\n            if data.max() > 10:  # Linear scale\n                debug_log(f\"  Converting SAR from linear to dB (max={data.max():.2f})\")\n                data = np.clip(10 * np.log10(data + 1e-9), -35, 5)\n            debug_log(f\"  SAR dB - range: [{data.min():.2f}, {data.max():.2f}], mean: {data.mean():.2f}\")\n        else:\n            # S2 optical: scale 0-10000 to 0-1\n            if data.max() > 10:\n                debug_log(f\"  Scaling S2 (max={data.max():.2f}) to 0-1\")\n                data = data / 10000.0\n            data = np.clip(data, 0.0, 1.0)\n            debug_log(f\"  S2 scaled - range: [{data.min():.4f}, {data.max():.4f}], mean: {data.mean():.4f}\")\n        \n        return data, src.transform, src.crs\n\ndef match_hw(arr, target_hw):\n    tH, tW = target_hw\n    if arr.shape[1] == tH and arr.shape[2] == tW:\n        return arr\n    t = torch.from_numpy(arr).unsqueeze(0).float()\n    t = F.interpolate(t, size=(tH, tW), mode=\"bilinear\", align_corners=False)\n    return t.squeeze(0).numpy()\n\ndef build_tensor_fixed(s2_arr, s1_arr_db, sar_only=False):\n    \"\"\"Build 10-channel input tensor\"\"\"\n    debug_log(\"Building input tensor...\")\n    H, W = s2_arr.shape[1], s2_arr.shape[2]\n    s1_arr_db = match_hw(s1_arr_db, (H, W))\n    \n    # Normalize dB to [0,1] for model input\n    vv = np.clip((s1_arr_db[0] + 30.0) / 30.0, 0.0, 1.0)\n    vh = np.clip((s1_arr_db[1] + 30.0) / 30.0, 0.0, 1.0)\n    vv = np.nan_to_num(vv, nan=0.0)\n    vh = np.nan_to_num(vh, nan=0.0)\n    \n    debug_log(f\"  Normalized VV - range: [{vv.min():.4f}, {vv.max():.4f}], unique: {len(np.unique(vv))}\")\n    debug_log(f\"  Normalized VH - range: [{vh.min():.4f}, {vh.max():.4f}], unique: {len(np.unique(vh))}\")\n    \n    # SAR ratio\n    with np.errstate(divide=\"ignore\", invalid=\"ignore\"):\n        sar_r = np.where(vh > 1e-8, vv / vh, 0.0)\n    sar_r = np.clip(np.nan_to_num(sar_r, nan=0.0, posinf=0.0), 0.0, 10.0)\n    \n    if sar_only:\n        tensor = np.zeros((10, H, W), dtype=np.float32)\n        tensor[0] = vv\n        tensor[1] = vh\n        tensor[7] = sar_r\n        return tensor\n    \n    # Optical bands\n    blue = np.clip(np.nan_to_num(s2_arr[0], nan=0.0), 0.0, 1.0)\n    green = np.clip(np.nan_to_num(s2_arr[1], nan=0.0), 0.0, 1.0)\n    red = np.clip(np.nan_to_num(s2_arr[2], nan=0.0), 0.0, 1.0)\n    nir = np.clip(np.nan_to_num(s2_arr[3], nan=0.0), 0.0, 1.0)\n    swir1 = np.clip(np.nan_to_num(s2_arr[4], nan=0.0), 0.0, 1.0)\n    \n    debug_log(f\"  S2 means - B:{blue.mean():.3f} G:{green.mean():.3f} R:{red.mean():.3f}\")\n    \n    # Indices\n    with np.errstate(divide=\"ignore\", invalid=\"ignore\"):\n        ndwi = np.where((green+nir) > 1e-8, (green-nir) / (green+nir), 0.0)\n        mndwi = np.where((green+swir1) > 1e-8, (green-swir1) / (green+swir1), 0.0)\n    \n    ndwi = np.nan_to_num(ndwi, nan=0.0)\n    mndwi = np.nan_to_num(mndwi, nan=0.0)\n    \n    tensor = np.stack([\n        vv, vh, blue, green, red, nir, ndwi, sar_r, swir1, mndwi\n    ], axis=0).astype(np.float32)\n    \n    debug_log(f\"  Tensor - range: [{tensor.min():.4f}, {tensor.max():.4f}], mean: {tensor.mean():.4f}\")\n    return tensor\n\n# ═══════════════════════════════════════════════════════════════════════\n# TILED INFERENCE\n# ═══════════════════════════════════════════════════════════════════════\ndef _hanning_window(size):\n    lin = np.hanning(size).astype(np.float64)\n    w = np.outer(lin, lin)\n    return np.clip(w, 1e-6, None)\n\n@torch.no_grad()\ndef tiled_predict(model, tensor, device):\n    debug_log(\"Starting tiled prediction...\")\n    C, H, W = tensor.shape\n    debug_log(f\"  Input shape: {tensor.shape}\")\n    \n    torch.cuda.empty_cache()\n    win = _hanning_window(TILE_SIZE)\n    \n    pad_h = (-H) % TILE_STRIDE\n    pad_w = (-W) % TILE_STRIDE\n    if pad_h or pad_w:\n        debug_log(f\"  Padding: h={pad_h}, w={pad_w}\")\n        tensor = np.pad(tensor, ((0,0),(0,pad_h),(0,pad_w)), mode=\"reflect\")\n    \n    _, PH, PW = tensor.shape\n    acc = np.zeros((PH, PW), dtype=np.float64)\n    count = np.zeros((PH, PW), dtype=np.float64)\n    \n    ys = list(range(0, PH - TILE_SIZE + 1, TILE_STRIDE))\n    xs = list(range(0, PW - TILE_SIZE + 1, TILE_STRIDE))\n    if ys and ys[-1] + TILE_SIZE < PH:\n        ys.append(PH - TILE_SIZE)\n    if xs and xs[-1] + TILE_SIZE < PW:\n        xs.append(PW - TILE_SIZE)\n    \n    debug_log(f\"  Tiles: {len(ys)} x {len(xs)} = {len(ys)*len(xs)} tiles\")\n    \n    model.eval()\n    coords = [(y, x) for y in ys for x in xs]\n    \n    for idx, (y0, x0) in enumerate(tqdm(coords, desc=\"  Tiles\", leave=False)):\n        chip = tensor[:, y0:y0+TILE_SIZE, x0:x0+TILE_SIZE]\n        xt = torch.from_numpy(chip).unsqueeze(0).to(device)\n        \n        with torch.amp.autocast(\"cuda\", enabled=(device.type == \"cuda\")):\n            prob = torch.sigmoid(model(xt)).squeeze().cpu().numpy().astype(np.float64)\n        \n        acc[y0:y0+TILE_SIZE, x0:x0+TILE_SIZE] += prob * win\n        count[y0:y0+TILE_SIZE, x0:x0+TILE_SIZE] += win\n        \n        if idx % 20 == 0:\n            torch.cuda.empty_cache()\n    \n    prob_map = (acc / np.where(count > 0, count, 1.0)).astype(np.float32)\n    prob_map = prob_map[:H, :W]\n    binary = (prob_map >= FLOOD_THRESHOLD).astype(np.uint8)\n    \n    debug_log(f\"  Probability - min: {prob_map.min():.4f}, max: {prob_map.max():.4f}, mean: {prob_map.mean():.4f}\")\n    debug_log(f\"  Flood pixels: {binary.sum()} ({100*binary.sum()/(H*W):.2f}%)\")\n    \n    return prob_map, binary\n\n# ═══════════════════════════════════════════════════════════════════════\n# VISUALIZATION HELPERS\n# ═══════════════════════════════════════════════════════════════════════\ndef load_png_rgb(path):\n    return np.array(Image.open(path).convert(\"RGB\"))\n\ndef s2_to_rgb(s2_arr, gamma=0.55, lo=1.0, hi=98.0, sat=1.3):\n    chs = []\n    for idx in [2, 1, 0]:\n        b = s2_arr[idx].astype(np.float32)\n        v = b[~np.isnan(b)]\n        if not len(v):\n            chs.append(np.zeros(b.shape, np.float32))\n            continue\n        lo_v, hi_v = np.percentile(v, [lo, hi])\n        b = np.clip(b, lo_v, hi_v)\n        b = (b - lo_v) / (hi_v - lo_v + 1e-10)\n        b = np.power(np.clip(np.nan_to_num(b, nan=0.0), 0, 1), gamma)\n        chs.append(b)\n    rgb = np.stack(chs, axis=-1)\n    try:\n        pil = Image.fromarray((rgb*255).astype(np.uint8), \"RGB\")\n        pil = ImageEnhance.Color(pil).enhance(sat)\n        rgb = np.array(pil).astype(np.float32) / 255.0\n    except Exception:\n        pass\n    return (rgb * 255).astype(np.uint8)\n\ndef mndwi_permanent_water(s2_arr):\n    green = np.clip(np.nan_to_num(s2_arr[1], nan=0.0), 0, 1)\n    swir1 = np.clip(np.nan_to_num(s2_arr[4], nan=0.0), 0, 1)\n    with np.errstate(divide=\"ignore\", invalid=\"ignore\"):\n        mndwi = np.where((green+swir1) > 1e-8, (green-swir1)/(green+swir1), 0.0)\n    mndwi = np.nan_to_num(mndwi, nan=0.0).astype(np.float32)\n    return mndwi, (mndwi > PERM_WATER_MNDWI).astype(np.uint8)\n\ndef export_pngs(label, r, masks_dir):\n    loc_dir = os.path.join(masks_dir, label)\n    os.makedirs(loc_dir, exist_ok=True)\n    \n    def _force_uint8(arr):\n        arr = np.array(arr, dtype=np.float32)\n        if arr.max() <= 1.0:\n            arr = np.clip(arr, 0, 1) * 255\n        return np.nan_to_num(arr, nan=0.0).astype(np.uint8)\n    \n    before_rgb = (load_png_rgb(r[\"s2_before_png\"]) if r.get(\"s2_before_png\") else s2_to_rgb(r[\"s2_arr\"]))\n    Image.fromarray(_force_uint8(before_rgb), \"RGB\").save(os.path.join(loc_dir, f\"{label}_UI_BEFORE_OPTICAL.png\"))\n    \n    if r.get(\"s1_after_png\"):\n        after_rgb = load_png_rgb(r[\"s1_after_png\"])\n    elif r.get(\"s2_after_png\"):\n        after_rgb = load_png_rgb(r[\"s2_after_png\"])\n    else:\n        vv = r[\"s1_arr_db\"][0]\n        vh = r[\"s1_arr_db\"][1]\n        def _s(a, lo=2, hi=98):\n            v = a[~np.isnan(a)]\n            if not len(v):\n                return np.zeros_like(a, np.float32)\n            lv, hv = np.percentile(v, [lo, hi])\n            return np.clip(np.nan_to_num((a-lv)/(hv-lv+1e-10), nan=0.0), 0, 1)\n        ratio = np.where(np.power(10,vh/10) > 1e-10, np.power(10,vv/10)/np.power(10,vh/10), 0.0)\n        after_rgb = (np.stack([_s(vv),_s(vh), np.clip(np.nan_to_num((ratio-np.nanpercentile(ratio[ratio>0],5))/(np.nanpercentile(ratio[ratio>0],95)-np.nanpercentile(ratio[ratio>0],5)+1e-10),nan=0.0),0,1)], axis=-1) * 255).astype(np.uint8)\n    Image.fromarray(_force_uint8(after_rgb), \"RGB\").save(os.path.join(loc_dir, f\"{label}_UI_AFTER_RAW_EVENT.png\"))\n    \n    base = before_rgb.astype(np.float32)\n    base[r[\"perm_water\"]==1] = base[r[\"perm_water\"]==1]*0.4 + np.array([0,0,128],np.float32)*0.6\n    base[r[\"new_inund\"]==1] = base[r[\"new_inund\"]==1]*0.2 + np.array([0,102,255],np.float32)*0.8\n    Image.fromarray(np.clip(base,0,255).astype(np.uint8), \"RGB\").save(os.path.join(loc_dir, f\"{label}_UI_AFTER_MASK_OVERLAY.png\"))\n    \n    Image.fromarray((r[\"perm_water\"]*255).astype(np.uint8), \"L\").save(os.path.join(loc_dir, f\"{label}_mask_perm_water.png\"))\n    plt.imsave(os.path.join(loc_dir, f\"{label}_mask_prob_map.png\"), r[\"prob_map\"], cmap=\"inferno\", vmin=0, vmax=1)\n    Image.fromarray((r[\"binary_mask\"]*255).astype(np.uint8), \"L\").save(os.path.join(loc_dir, f\"{label}_mask_prediction.png\"))\n    Image.fromarray((r[\"new_inund\"]*255).astype(np.uint8), \"L\").save(os.path.join(loc_dir, f\"{label}_mask_new_inundation.png\"))\n    \n    print(f\"    Saved 7 assets -> {loc_dir}/\")\n\nCMAP_PERM = ListedColormap([\"#00000000\", \"#000080\"])\nCMAP_FLOOD = ListedColormap([\"#00000000\", \"#0066FF\"])\n\ndef visualize(label, r, masks_dir):\n    H, W = r[\"binary_mask\"].shape\n    flood_pct = 100.0 * r[\"new_inund\"].sum() / (H * W)\n    \n    before_rgb = (load_png_rgb(r[\"s2_before_png\"]) if r.get(\"s2_before_png\") else s2_to_rgb(r[\"s2_arr\"]))\n    if r.get(\"s1_after_png\"):\n        after_rgb = load_png_rgb(r[\"s1_after_png\"])\n    elif r.get(\"s2_after_png\"):\n        after_rgb = load_png_rgb(r[\"s2_after_png\"])\n    else:\n        after_rgb = before_rgb\n    \n    fig = plt.figure(figsize=(26, 12), facecolor=\"#080808\")\n    gs = gridspec.GridSpec(2, 4, figure=fig, hspace=0.2, wspace=0.1)\n    \n    ax_main = fig.add_subplot(gs[:, :2])\n    ax_main.imshow(before_rgb)\n    ax_main.imshow(r[\"perm_water\"], cmap=CMAP_PERM, alpha=0.6, vmin=0, vmax=1)\n    ax_main.imshow(r[\"new_inund\"], cmap=CMAP_FLOOD, alpha=0.8, vmin=0, vmax=1)\n    ax_main.set_title(\"OFFICIAL FLOOD EXTENT\", color=\"#0066FF\", fontsize=16, fontweight=\"bold\")\n    ax_main.axis(\"off\")\n    ax_main.legend(handles=[\n        mpatches.Patch(color=\"#000080\", label=\"Permanent Waterways\"),\n        mpatches.Patch(color=\"#0066FF\", label=\"Detected New Inundation\"),\n    ], loc=\"lower left\", facecolor=\"#111111\", labelcolor=\"white\", edgecolor=\"none\")\n    \n    ax_pre = fig.add_subplot(gs[0, 2])\n    ax_pre.imshow(before_rgb)\n    ax_pre.axis(\"off\")\n    ax_pre.set_title(\"BEFORE\", color=\"white\", fontsize=11)\n    \n    ax_post = fig.add_subplot(gs[1, 2])\n    ax_post.imshow(after_rgb)\n    ax_post.axis(\"off\")\n    after_label = \"AFTER (SAR)\" if r.get(\"s1_after_png\") else \"AFTER (S2 Visual)\"\n    ax_post.set_title(after_label, color=\"white\", fontsize=11)\n    \n    ax_prob = fig.add_subplot(gs[:, 3])\n    im = ax_prob.imshow(r[\"prob_map\"], cmap=\"viridis\", vmin=0, vmax=1)\n    ax_prob.set_title(\"AI CONFIDENCE SCORE\", color=\"white\", fontsize=11)\n    ax_prob.axis(\"off\")\n    cb = plt.colorbar(im, ax=ax_prob, fraction=0.046, pad=0.04)\n    cb.ax.yaxis.set_tick_params(color=\"white\")\n    plt.setp(cb.ax.yaxis.get_ticklabels(), color=\"white\", fontsize=8)\n    \n    fig.text(0.5, 0.02, f\"MANZAR ANALYSIS: {label} | NET INUNDATION: {flood_pct:.2f}%\", ha=\"center\", color=\"white\", fontsize=14, fontweight=\"bold\")\n    \n    loc_dir = os.path.join(masks_dir, label)\n    os.makedirs(loc_dir, exist_ok=True)\n    report_path = os.path.join(loc_dir, f\"{label}_CLEAN_REPORT.png\")\n    plt.savefig(report_path, dpi=200, facecolor=\"#080808\", bbox_inches=\"tight\")\n    print(f\"    Dashboard -> {report_path}\")\n    plt.show()\n    plt.close(fig)\n\n# ═══════════════════════════════════════════════════════════════════════\n# MAIN PIPELINE\n# ═══════════════════════════════════════════════════════════════════════\ntry:\n    model = load_model(MODEL_PATH, device)\nexcept Exception as e:\n    debug_log(f\"Failed to load model: {e}\", \"ERROR\")\n    raise\n\nall_results = {}\nmetrics_log = []\n\nfor label, lat, lon in LOCATIONS:\n    debug_log(f\"\\n{'='*65}\")\n    debug_log(f\"Processing: {label}\")\n    print(f\"\\n{'='*65}\\n  {label}\\n{'='*65}\")\n    \n    files = discover(label, COMPOSITES_DIR)\n    \n    if not files[\"s2_tif\"] or not files[\"s1_tif\"]:\n        debug_log(f\"SKIP: Missing files for {label}\", \"WARNING\")\n        print(f\"  SKIP: Missing S2 or S1 data for {label}\")\n        continue\n    \n    print(f\"  S2 TIF: {os.path.basename(files['s2_tif'])}\")\n    print(f\"  S1 TIF: {os.path.basename(files['s1_tif'])}\")\n    \n    # Load data with correct handling\n    s2_arr, s2_tf, s2_crs = load_tif_corrected(files[\"s2_tif\"], is_sar=False)\n    s1_arr_db, s1_tf, s1_crs = load_tif_corrected(files[\"s1_tif\"], is_sar=True)\n    \n    # Permanent water mask\n    mndwi, perm_water = mndwi_permanent_water(s2_arr)\n    debug_log(f\"Permanent water: {perm_water.sum()} pixels ({100*perm_water.sum()/perm_water.size:.2f}%)\")\n    \n    # Build tensor\n    tensor = build_tensor_fixed(s2_arr, s1_arr_db, sar_only=SAR_ONLY_MODE)\n    print(f\"  Tensor shape: {tensor.shape}\")\n    \n    # Run inference\n    prob_map, binary_mask = tiled_predict(model, tensor, device)\n    \n    # Align masks\n    H, W = binary_mask.shape\n    if perm_water.shape != (H, W):\n        pw_t = torch.from_numpy(perm_water.astype(np.float32)).unsqueeze(0).unsqueeze(0)\n        pw_t = F.interpolate(pw_t, size=(H, W), mode=\"nearest\")\n        perm_water = (pw_t.squeeze().numpy() > 0.5).astype(np.uint8)\n    \n    # New inundation (flood minus permanent water)\n    new_inund = ((binary_mask == 1) & (perm_water == 0)).astype(np.uint8)\n    \n    # Calculate metrics\n    flood_km2 = float(binary_mask.sum()) * PIXEL_AREA_KM2\n    new_km2 = float(new_inund.sum()) * PIXEL_AREA_KM2\n    perm_km2 = float(perm_water.sum()) * PIXEL_AREA_KM2\n    net_pct = 100.0 * new_inund.sum() / (H * W)\n    \n    debug_log(f\"Results: {new_km2:.2f} km2 ({net_pct:.2f}%)\")\n    print(f\"  New inundation: {new_km2:.2f} km2 ({net_pct:.2f}%)\")\n    print(f\"  Permanent water: {perm_km2:.2f} km2\")\n    \n    metrics_log.append({\n        \"location\": label, \"lat\": lat, \"lon\": lon,\n        \"flood_extent_km2\": round(flood_km2, 3),\n        \"new_inundation_km2\": round(new_km2, 3),\n        \"perm_water_km2\": round(perm_km2, 3),\n        \"net_inundation_pct\": round(net_pct, 4),\n    })\n    \n    all_results[label] = {\n        \"s2_arr\": s2_arr, \"s1_arr_db\": s1_arr_db,\n        \"prob_map\": prob_map, \"binary_mask\": binary_mask,\n        \"perm_water\": perm_water, \"new_inund\": new_inund,\n        \"mndwi\": mndwi,\n        \"s2_before_png\": files[\"s2_before_png\"],\n        \"s1_after_png\": files[\"s1_after_png\"],\n        \"s2_after_png\": files[\"s2_after_png\"],\n    }\n\n# Save metrics\nwith open(METRICS_JSON, \"w\") as f:\n    json.dump(metrics_log, f, indent=2)\nprint(f\"\\nMetrics saved: {METRICS_JSON}\")\n\n# Visualize results\nprint(f\"\\nRendering dashboards for {len(all_results)} locations...\")\nfor label, r in all_results.items():\n    print(f\"\\n  {label}\")\n    export_pngs(label, r, MASKS_PNG_DIR)\n    visualize(label, r, MASKS_PNG_DIR)\n\nprint(f\"\\n✅ Done! Results in: {MASKS_PNG_DIR}/\")\nprint(f\"📊 Processed: {len(all_results)}/{len(LOCATIONS)} locations\")\nprint(f\"📝 Debug log: {DEBUG_LOG}\")\n\nprint(\"\\n=== FINAL METRICS ===\")\nfor m in metrics_log:\n    print(f\"  {m['location']:25s}: {m['new_inundation_km2']:.2f} km2 ({m['net_inundation_pct']:.2f}%)\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-27T20:10:19.573449Z","iopub.execute_input":"2026-04-27T20:10:19.573959Z","iopub.status.idle":"2026-04-27T20:11:34.967561Z","shell.execute_reply.started":"2026-04-27T20:10:19.573932Z","shell.execute_reply":"2026-04-27T20:11:34.966542Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"import os\nimport json\nimport numpy as np\nfrom PIL import Image\nfrom scipy import ndimage\nfrom scipy.spatial.distance import cdist\nfrom skimage.measure import regionprops\nimport math\nimport warnings\nwarnings.filterwarnings(\"ignore\")\n\n# ═══════════════════════════════════════════════════════════════════════\n# FAST FLOOD METRICS CALCULATOR WITH CENTER AND RADIUS\n# ═══════════════════════════════════════════════════════════════════════\n\nclass FastFloodMetricsCalculator:\n    def __init__(self, pixel_size_km=0.01):  # 10m = 0.01km\n        self.pixel_size_km = pixel_size_km\n        self.pixel_area_km2 = pixel_size_km ** 2\n    \n    def load_mask(self, mask_path):\n        \"\"\"Load binary flood mask\"\"\"\n        mask = np.array(Image.open(mask_path))\n        if mask.max() > 1:\n            mask = mask // 255\n        return mask.astype(np.uint8)\n    \n    def convert_to_serializable(self, obj):\n        \"\"\"Convert numpy types to Python native types for JSON serialization\"\"\"\n        if isinstance(obj, np.integer):\n            return int(obj)\n        elif isinstance(obj, np.floating):\n            return float(obj)\n        elif isinstance(obj, np.ndarray):\n            return obj.tolist()\n        elif isinstance(obj, tuple):\n            return tuple(self.convert_to_serializable(x) for x in obj)\n        elif isinstance(obj, dict):\n            return {k: self.convert_to_serializable(v) for k, v in obj.items()}\n        elif isinstance(obj, list):\n            return [self.convert_to_serializable(x) for x in obj]\n        else:\n            return obj\n    \n    def calculate_component_radius(self, prop, center_x, center_y):\n        \"\"\"Calculate the effective radius of a flood component\"\"\"\n        # Method 1: Equivalent radius (area-based)\n        area_pixels = prop.area\n        equivalent_radius_km = np.sqrt(area_pixels / np.pi) * self.pixel_size_km\n        \n        # Method 2: Max distance from center to any edge (bounding radius)\n        coords = prop.coords\n        distances = np.sqrt((coords[:, 1] - center_x)**2 + (coords[:, 0] - center_y)**2)\n        max_radius_km = np.max(distances) * self.pixel_size_km\n        \n        # Method 3: Mean distance from center (average radius)\n        mean_radius_km = np.mean(distances) * self.pixel_size_km\n        \n        return {\n            'equivalent_radius_km': round(equivalent_radius_km, 2),\n            'max_radius_km': round(max_radius_km, 2),\n            'mean_radius_km': round(mean_radius_km, 2)\n        }\n    \n    def get_bounding_circle(self, prop, center_x, center_y):\n        \"\"\"Get bounding circle parameters for the component\"\"\"\n        coords = prop.coords\n        distances = np.sqrt((coords[:, 1] - center_x)**2 + (coords[:, 0] - center_y)**2)\n        max_distance_px = np.max(distances)\n        \n        # Calculate circle area and coverage\n        circle_area_km2 = np.pi * (max_distance_px * self.pixel_size_km)**2\n        component_area_km2 = prop.area * self.pixel_area_km2\n        coverage_percentage = (component_area_km2 / circle_area_km2) * 100 if circle_area_km2 > 0 else 0\n        \n        return {\n            'radius_km': round(max_distance_px * self.pixel_size_km, 2),\n            'circumference_km': round(2 * np.pi * max_distance_px * self.pixel_size_km, 2),\n            'circle_area_km2': round(circle_area_km2, 2),\n            'component_fill_percentage': round(coverage_percentage, 2)\n        }\n    \n    def fast_analyze(self, mask, label, prob_map=None):\n        \"\"\"Fast analysis using scikit-image regionprops\"\"\"\n        from skimage.measure import label as sklabel, regionprops\n        \n        print(f\"  🔍 Analyzing {label}...\")\n        \n        # Basic metrics\n        total_flood_pixels = int(mask.sum())\n        total_flood_area_km2 = total_flood_pixels * self.pixel_area_km2\n        total_pixels = mask.size\n        flood_percentage = (total_flood_pixels / total_pixels) * 100\n        \n        # Label connected components\n        print(f\"  🔗 Finding connected components...\")\n        labeled_mask = sklabel(mask, connectivity=2)\n        num_components = int(labeled_mask.max())\n        \n        print(f\"  📊 Found {num_components:,} flood components\")\n        \n        # Extract region properties\n        props = regionprops(labeled_mask)\n        \n        # Sort by area (largest first)\n        props.sort(key=lambda x: x.area, reverse=True)\n        \n        # Process components\n        components = []\n        component_centers_km = []\n        all_component_centers = []\n        \n        for i, prop in enumerate(props[:50]):  # Process top 50 components\n            area_pixels = int(prop.area)\n            area_km2 = float(area_pixels * self.pixel_area_km2)\n            \n            # Center coordinates (centroid)\n            center_y, center_x = float(prop.centroid[0]), float(prop.centroid[1])\n            center_km = (float(center_x * self.pixel_size_km), float(center_y * self.pixel_size_km))\n            \n            # Calculate radius information\n            radius_info = self.calculate_component_radius(prop, center_x, center_y)\n            bounding_circle = self.get_bounding_circle(prop, center_x, center_y)\n            \n            # Bounding box\n            min_row, min_col, max_row, max_col = [int(x) for x in prop.bbox]\n            width_km = float((max_col - min_col) * self.pixel_size_km)\n            height_km = float((max_row - min_row) * self.pixel_size_km)\n            \n            # Equivalent diameter (km)\n            equiv_diameter_km = float(prop.equivalent_diameter * self.pixel_size_km)\n            \n            # Calculate approximate distances to edges\n            edge_distances = {\n                'north': float((prop.centroid[0] - min_row) * self.pixel_size_km),\n                'south': float((max_row - prop.centroid[0]) * self.pixel_size_km),\n                'west': float((prop.centroid[1] - min_col) * self.pixel_size_km),\n                'east': float((max_col - prop.centroid[1]) * self.pixel_size_km)\n            }\n            \n            percentage = float((area_km2 / total_flood_area_km2 * 100)) if total_flood_area_km2 > 0 else 0\n            \n            # Component entry with center and radius\n            component = {\n                'id': i + 1,\n                'area_km2': round(area_km2, 2),\n                'area_pixels': area_pixels,\n                'percentage_of_total': round(percentage, 2),\n                'center': {\n                    'x_km': round(center_km[0], 2),\n                    'y_km': round(center_km[1], 2),\n                    'x_pixel': round(center_x, 2),\n                    'y_pixel': round(center_y, 2)\n                },\n                'radius': radius_info,\n                'bounding_circle': bounding_circle,\n                'bbox_km': {\n                    'min_x': float(min_col * self.pixel_size_km),\n                    'min_y': float(min_row * self.pixel_size_km),\n                    'max_x': float(max_col * self.pixel_size_km),\n                    'max_y': float(max_row * self.pixel_size_km),\n                    'width_km': round(width_km, 2),\n                    'height_km': round(height_km, 2)\n                },\n                'edge_distances_km': edge_distances,\n                'equivalent_diameter_km': round(equiv_diameter_km, 2)\n            }\n            \n            components.append(component)\n            component_centers_km.append(center_km)\n            all_component_centers.append({\n                'id': i + 1,\n                'center_km': center_km,\n                'radius_km': radius_info['max_radius_km'],\n                'area_km2': area_km2\n            })\n        \n        # Calculate overall center of mass for entire flood extent\n        y_center, x_center = ndimage.center_of_mass(mask)\n        overall_center_km = (float(x_center * self.pixel_size_km), float(y_center * self.pixel_size_km))\n        \n        # Calculate overall flood extent radius (max distance from center to any flood pixel)\n        flood_coords = np.argwhere(mask)\n        if len(flood_coords) > 0:\n            distances_from_center = np.sqrt(\n                (flood_coords[:, 1] - x_center)**2 + \n                (flood_coords[:, 0] - y_center)**2\n            )\n            overall_max_radius_km = float(np.max(distances_from_center) * self.pixel_size_km)\n            overall_mean_radius_km = float(np.mean(distances_from_center) * self.pixel_size_km)\n        else:\n            overall_max_radius_km = 0\n            overall_mean_radius_km = 0\n        \n        # Calculate perimeter and shape index\n        from skimage.measure import perimeter\n        perimeter_pixels = float(perimeter(mask))\n        perimeter_km = perimeter_pixels * self.pixel_size_km\n        \n        # Shape index (1 = circle, higher = more complex)\n        if total_flood_pixels > 0:\n            radius = np.sqrt(total_flood_pixels / np.pi)\n            expected_perimeter = 2 * np.pi * radius\n            shape_index = float(perimeter_pixels / expected_perimeter) if expected_perimeter > 0 else 0\n        else:\n            shape_index = 0\n        \n        # Get probability stats if available\n        prob_stats = {}\n        if prob_map is not None:\n            flood_probs = prob_map[mask == 1]\n            if len(flood_probs) > 0:\n                prob_stats = {\n                    'mean_confidence': round(float(flood_probs.mean()), 4),\n                    'std_confidence': round(float(flood_probs.std()), 4),\n                    'min_confidence': round(float(flood_probs.min()), 4),\n                    'max_confidence': round(float(flood_probs.max()), 4)\n                }\n        \n        # Compile results\n        results = {\n            'location': label,\n            'summary': {\n                'total_flood_area_km2': round(total_flood_area_km2, 2),\n                'total_flood_pixels': total_flood_pixels,\n                'flood_percentage': round(flood_percentage, 2),\n                'number_of_flood_components': num_components,\n                'largest_component_area_km2': components[0]['area_km2'] if components else 0,\n                'largest_component_percentage': components[0]['percentage_of_total'] if components else 0,\n                'perimeter_km': round(perimeter_km, 2),\n                'shape_index': round(shape_index, 3),\n                'overall_center': {\n                    'x_km': round(overall_center_km[0], 2),\n                    'y_km': round(overall_center_km[1], 2)\n                },\n                'overall_radius': {\n                    'max_radius_km': round(overall_max_radius_km, 2),\n                    'mean_radius_km': round(overall_mean_radius_km, 2)\n                }\n            },\n            'top_components': components[:15],  # Top 15 components\n            'all_component_centers': all_component_centers,  # Summary of all components\n            'zonal_statistics': prob_stats,\n            'total_components_found': num_components\n        }\n        \n        # Convert any remaining numpy types\n        results = self.convert_to_serializable(results)\n        \n        return results\n\n# ═══════════════════════════════════════════════════════════════════════\n# MAIN ANALYSIS FUNCTION\n# ═══════════════════════════════════════════════════════════════════════\n\ndef analyze_all_floods(masks_dir=\"./masks_pngs\", output_dir=\"./flood_metrics_advanced\"):\n    \"\"\"Fast analysis of all flood masks\"\"\"\n    \n    os.makedirs(output_dir, exist_ok=True)\n    calculator = FastFloodMetricsCalculator(pixel_size_km=0.01)\n    \n    all_results = {}\n    \n    # Get all location folders\n    location_folders = [f for f in os.listdir(masks_dir) \n                       if os.path.isdir(os.path.join(masks_dir, f))]\n    \n    print(f\"\\n{'='*70}\")\n    print(f\"FLOOD METRICS ANALYZER (With Center & Radius)\")\n    print(f\"{'='*70}\")\n    print(f\"Found {len(location_folders)} locations: {', '.join(location_folders)}\")\n    \n    for location in location_folders:\n        print(f\"\\n{'='*70}\")\n        print(f\"📍 Analyzing: {location}\")\n        print(f\"{'='*70}\")\n        \n        # Load flood mask\n        mask_path = os.path.join(masks_dir, location, f\"{location}_mask_new_inundation.png\")\n        prob_path = os.path.join(masks_dir, location, f\"{location}_mask_prob_map.png\")\n        \n        if not os.path.exists(mask_path):\n            print(f\"  ❌ Mask not found: {mask_path}\")\n            continue\n        \n        # Load mask\n        mask = calculator.load_mask(mask_path)\n        print(f\"  ✅ Mask loaded: {mask.shape} ({mask.sum():,} flood pixels)\")\n        \n        # Load probability map if available\n        prob_map = None\n        if os.path.exists(prob_path):\n            prob_map = np.array(Image.open(prob_path)) / 255.0\n            print(f\"  ✅ Probability map loaded\")\n        \n        # Run fast analysis\n        results = calculator.fast_analyze(mask, location, prob_map)\n        \n        # Print summary\n        print(f\"\\n  📊 FLOOD SUMMARY:\")\n        print(f\"     ├─ Total flood area: {results['summary']['total_flood_area_km2']:,.2f} km²\")\n        print(f\"     ├─ Flood percentage: {results['summary']['flood_percentage']:.2f}%\")\n        print(f\"     ├─ Number of components: {results['summary']['number_of_flood_components']:,}\")\n        print(f\"     ├─ Largest component: {results['summary']['largest_component_area_km2']:,.2f} km²\")\n        print(f\"     ├─ Overall center: ({results['summary']['overall_center']['x_km']}, {results['summary']['overall_center']['y_km']}) km\")\n        print(f\"     ├─ Overall max radius: {results['summary']['overall_radius']['max_radius_km']:.2f} km\")\n        print(f\"     └─ Overall mean radius: {results['summary']['overall_radius']