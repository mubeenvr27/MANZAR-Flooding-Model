abels(locations, rotation=45, ha='right', fontsize=9)\n    ax1.set_ylabel('Flood Area (km²)', fontsize=11)\n    ax1.set_title('Total Flood Area by Location', fontsize=12, fontweight='bold')\n    for bar, val in zip(bars1, flood_areas):\n        ax1.text(bar.get_x() + bar.get_width()/2, bar.get_height() + 5,\n                f'{val:.1f}', ha='center', va='bottom', fontsize=9)\n    \n    # Population affected bar chart\n    bars2 = ax2.bar(range(len(locations)), populations, color='coral', alpha=0.7)\n    ax2.set_xticks(range(len(locations)))\n    ax2.set_xticklabels(locations, rotation=45, ha='right', fontsize=9)\n    ax2.set_ylabel('Population Affected', fontsize=11)\n    ax2.set_title('Population Affected by Location', fontsize=12, fontweight='bold')\n    for bar, val in zip(bars2, populations):\n        ax2.text(bar.get_x() + bar.get_width()/2, bar.get_height() + val*0.02,\n                f'{val:,}', ha='center', va='bottom', fontsize=8, rotation=90)\n    \n    plt.tight_layout()\n    output_path = os.path.join(output_dir, \"impact_comparison_chart.png\")\n    plt.savefig(output_path, dpi=150, bbox_inches='tight')\n    plt.close()\n    print(f\"  📊 Saved comparison chart: {output_path}\")\n\n# ═══════════════════════════════════════════════════════════════════════════════\n# LOAD EXISTING RESULTS\n# ═══════════════════════════════════════════════════════════════════════════════\n\ndef load_existing_results():\n    \"\"\"Load previously saved results.\"\"\"\n    results_json = os.path.join(LULC_OUTPUT_DIR, \"lulc_impact_results.json\")\n    if os.path.exists(results_json):\n        try:\n            with open(results_json, 'r') as f:\n                return json.load(f)\n        except:\n            pass\n    return []\n\n# ═══════════════════════════════════════════════════════════════════════════════\n# RUN EVERYTHING\n# ═══════════════════════════════════════════════════════════════════════════════\n\n# Find all locations with flood masks\nlocations = []\nfor f