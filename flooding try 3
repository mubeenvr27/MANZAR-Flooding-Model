gle/working')\n\n# 2. Compress the directory (creates masks_archive.zip in current dir)\nprint(\"Zipping masks...\")\nshutil.make_archive('flood_metrics_advanced', 'zip', 'flood_metrics_advanced')\n\nprint(\"Done. Click the link below to download:\")\n\n# 3. Generate the link using ONLY the relative filename\ndisplay(FileLink('flood_metrics_advanced.zip'))","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-27T21:08:46.994555Z","iopub.execute_input":"2026-04-27T21:08:46.995415Z","iopub.status.idle":"2026-04-27T21:08:47.785984Z","shell.execute_reply.started":"2026-04-27T21:08:46.995385Z","shell.execute_reply":"2026-04-27T21:08:47.78522Z"}},"outputs":[{"name":"stdout","text":"Zipping masks...\nDone. Click the link below to download:\n","output_type":"stream"},{"output_type":"display_data","data":{"text/plain":"/kaggle/working/flood_metrics_advanced.zip","text/html":"<a href='flood_metrics_advanced.zip' target='_blank'>flood_metrics_advanced.zip</a><br>"},"metadata":{}}],"execution_count":8},{"cell_type":"markdown","source":"# Flooding with LULC","metadata":{}},{"cell_type":"code","source":"# ═══════════════════════════════════════════════════════════════════════════════\n# CELL: LULC CLASSIFICATION & POPULATION IMPACT ASSESSMENT\n# Uses existing flood masks from previous inference\n# Adds: MANZAR LULC classification + WorldPop population intersection\n# ═══════════════════════════════════════════════════════════════════════════════\n\nimport os, json, warnings, glob\nimport numpy as np\nimport pandas as pd\nimport torch\nimport pyproj\nimport rasterio\nfrom rasterio.transform import from_bounds\nfrom rasterio.warp import reproject, Resampling\nfrom rasterio.io import MemoryFile\nfrom rasterio.features import geometry_mask\nimport pystac_client\nimport planetary_computer\nimport stackstac\nimport requests\nfrom dask.diagnostics import ProgressBar\nfrom shapely.geometry import mapping, box as shapely_box\nfrom shapely.ops import transform as shapely_transform\nfrom PIL import Image\nimport matplotlib.pyplot as plt\nfrom matplotlib.colors import ListedColormap\nimport matplotlib.patches as mpatches\n\nwarnings.filterwarnings(\"ignore\")\n\n# ── GPU acceleration ──────────────────────────────────────────────────────────\ntry:\n    import cupy as cp\n    _GPU = True\n    print(\"[INFO] CuPy available - GPU acceleration ENABLED\")\nexcept ImportError:\n    cp = np\n    _GPU = False\n    print(\"[INFO] CuPy not found - using NumPy\")\n\n# ═══════════════════════════════════════════════════════════════════════════════\n# CONFIGURATION\n# ═══════════════════════════════════════════════════════════════════════════════\nPIXEL_M = 10.0\nPIXEL_KM2 = (PIXEL_M ** 2) / 1e6\n\n# Paths\nMASKS_DIR = \"./masks_pngs\"\nCOMPOSITES_DIR = \"./flood_composites\"\nLULC_OUTPUT_DIR = \"./lulc_analysis\"\nos.makedirs(LULC_OUTPUT_DIR, exist_ok=True)\n\n# LULC Model\nLULC_MODEL_PATH = \"/kaggle/input/models/muhammadmubeenxt/manzar-lulc-try-1/pytorch/default/1/manzar_lulc_try_1.pt\"\n\n# LULC class mapping\nLULC_CLASS_MAP = {\n    0: \"Tree_cover\",\n    1: \"Shrubland\", \n    2: \"Grassland\",\n    3: \"Cropland\",\n    4: \"Built_up\",\n    5: \"Bare_sparse_vegetation\",\n    6: \"Permanent_water\",\n    7: \"Mangroves\",\n}\n\n# LULC Colors for visualization\nLULC_COLORS = {\n    \"Tree_cover\": \"#228B22\",\n    \"Shrubland\": \"#8B7355\",\n    \"Grassland\": \"#90EE90\", \n    \"Cropland\": \"#DAA520\",\n    \"Built_up\": \"#8B0000\",\n    \"Bare_sparse_vegetation\": \"#DEB887\",\n    \"Permanent_water\": \"#4169E1\",\n    \"Mangroves\": \"#006400\",\n}\n\n# WorldPop mapping\n_WORLDPOP_CATALOGUE = {\n    \"Sialkot\": (\"PAK\", 2020), \"Dadu\": (\"PAK\", 2020), \"Sukkur\": (\"PAK\", 2020),\n    \"Jacobabad\": (\"PAK\", 2020), \"DG\": (\"PAK\", 2020), \"Nowshera\": (\"PAK\", 2020),\n    \"Sylhet\": (\"BGD\", 2020), \"Kherson\": (\"UKR\", 2020), \"KwaZuluNatal\": (\"ZAF\", 2020),\n}\n\n# Dry season date ranges (baseline for LULC)\nLULC_DATE_RANGES = {\n    \"Sialkot_punjab\": (\"2025-01-01\", \"2025-06-30\"),\n    \"Dadu_Sindh\": (\"2022-01-01\", \"2022-06-30\"),\n    \"Sukkur_Sindh\": (\"2022-01-01\", \"2022-06-30\"),\n    \"Jacobabad_Sindh\": (\"2022-01-01\", \"2022-06-30\"),\n    \"DG_Khan_Punjab\": (\"2022-01-01\", \"2022-06-30\"),\n    \"Nowshera_KPK\": (\"2022-01-01\", \"2022-06-30\"),\n    \"Sylhet_Bangladesh\": (\"2022-01-01\", \"2022-04-30\"),\n    \"Kherson_Ukraine\": (\"2023-03-01\", \"2023-05-31\"),\n    \"KwaZuluNatal_SA\": (\"2022-01-01\", \"2022-03-31\"),\n}\n\n# ═══════════════════════════════════════════════════════════════════════════════\n# LOAD LULC MODEL\n# ═══════════════════════════════════════════════════════════════════════════════\n\ndevice = torch.device(\"cuda\" if torch.cuda.is_available() else \"cpu\")\nprint(f\"[INFO] Device: {device}\")\n\nif not os.path.exists(LULC_MODEL_PATH):\n    raise FileNotFoundError(f\"LULC model not found: {LULC_MODEL_PATH}\")\n\nlulc_model = torch.jit.load(LULC_MODEL_PATH, map_location=device)\nlulc_model.eval()\nprint(f\"[INFO] LULC model loaded: {os.path.basename(LULC_MODEL_PATH)}\")\n\n# ═══════════════════════════════════════════════════════════════════════════════\n# HELPER FUNCTIONS\n# ═══════════════════════════════════════════════════════════════════════════════\n\ndef get_utm_zone(lon, lat):\n    \"\"\"Calculate UTM zone EPSG code.\"\"\"\n    zone = int((lon + 180) / 6) + 1\n    return 32600 + zone if lat >= 0 else 32700 + zone\n\ndef reconstruct_georeference(lat, lon, radius_km, array_shape):\n    \"\"\"Reconstruct affine transform matching the SAR downloader.\"\"\"\n    utm_zone = int((lon + 180) / 6) + 1\n    epsg = 32600 + utm_zone if lat >= 0 else 32700 + utm_zone\n    \n    wgs84 = pyproj.CRS(\"EPSG:4326\")\n    utm = pyproj.CRS.from_epsg(epsg)\n    to_utm = pyproj.Transformer.from_crs(wgs84, utm, always_xy=True).transform\n    \n    x_c, y_c = to_utm(lon, lat)\n    x_c = round(x_c / 10) * 10\n    y_c = round(y_c / 10) * 10\n    r_m = radius_km * 1000\n    \n    west, south, east, north = x_c - r_m, y_c - r_m, x_c + r_m, y_c + r_m\n    H, W = array_shape\n    tf = from_bounds(west, south, east, north, W, H)\n    return tf, epsg, (west, south, east, north)\n\ndef fetch_s2_for_lulc(label, lat, lon, radius_km, target_shape, target_transform, target_epsg, max_cloud=30):\n    \"\"\"Fetch S2 L2A 9-band median composite for LULC inference.\"\"\"\n    date_start, date_end = LULC_DATE_RANGES.get(label, (\"2022-01-01\", \"2022-06-30\"))\n    epsg = get_utm_zone(lon, lat)\n    \n    # Get UTM bounds\n    wgs84 = pyproj.CRS(\"EPSG:4326\")\n    utm = pyproj.CRS.from_epsg(epsg)\n    to_utm = pyproj.Transformer.from_crs(wgs84, utm, always_xy=True).transform\n    to_wgs = pyproj.Transformer.from_crs(utm, wgs84, always_xy=True).transform\n    \n    x_c, y_c = to_utm(lon, lat)\n    x_c = round(x_c / 10) * 10\n    y_c = round(y_c / 10) * 10\n    r_m = radius_km * 1000\n    utm_bounds = (x_c - r_m, y_c - r_m, x_c + r_m, y_c + r_m)\n    \n    wgs_geom = shapely_transform(to_wgs, shapely_box(*utm_bounds))\n    \n    # STAC search\n    catalog = pystac_client.Client.open(\n        \"https://planetarycomputer.microsoft.com/api/stac/v1\",\n        modifier=planetary_computer.sign_inplace,\n    )\n    \n    items = []\n    for cloud_try in [max_cloud, max_cloud + 20, 60]:\n        search = catalog.search(\n            collections=[\"sentinel-2-l2a\"],\n            intersects=mapping(wgs_geom),\n            datetime=f\"{date_start}/{date_end}\",\n            query={\"eo:cloud_cover\": {\"lt\": cloud_try}},\n            max_items=30,\n        )\n        items = list(search.items())\n        if items:\n            print(f\"    S2: {len(items[:20])} scenes (cloud<{cloud_try}%) for {date_start}→{date_end}\")\n            break\n    \n    if not items:\n        raise RuntimeError(f\"No S2 scenes for {label}\")\n    \n    # Stack bands (9 spectral bands needed for LULC)\n    spectral = [\"B02\", \"B03\", \"B04\", \"B05\", \"B06\", \"B07\", \"B08\", \"B11\", \"B12\"]\n    stack = stackstac.stack(\n        items[:20],\n        assets=spectral + [\"SCL\"],\n        bounds=utm_bounds,\n        epsg=epsg,\n        resolution=10,\n        dtype=\"float32\",\n        fill_value=np.float32(np.nan),\n        rescale=False,\n    )\n    \n    # Cloud masking\n    scl_mask = stack.sel(band=\"SCL\").isin([0, 1, 3, 8, 9, 10, 11])\n    clean = stack.sel(band=spectral).where(~scl_mask) / 10000.0\n    \n    with ProgressBar():\n        median = clean.median(dim=\"time\", skipna=True).compute()\n    \n    arr = np.nan_to_num(median.values, nan=0.0).astype(np.float32)\n    \n    # Reproject to target grid\n    H, W = target_shape\n    target_crs = rasterio.CRS.from_epsg(target_epsg)\n    src_crs = rasterio.CRS.from_epsg(epsg)\n    src_tf = from_bounds(*utm_bounds, arr.shape[2], arr.shape[1])\n    out_arr = np.zeros((9, H, W), dtype=np.float32)\n    \n    for i in range(9):\n        reproject(\n            source=arr[i], destination=out_arr[i],\n            src_transform=src_tf, src_crs=src_crs,\n            dst_transform=target_transform, dst_crs=target_crs,\n            resampling=Resampling.bilinear,\n        )\n    \n    return out_arr\n\ndef compute_lulc_14ch(img_9band):\n    \"\"\"Build 14-channel input for MANZAR LULC model.\"\"\"\n    b2, b3, b4, b5, b6, b7, b8, b11, b12 = img_9band\n    eps = 1e-8\n    \n    # Spectral indices\n    ndvi = (b8 - b4) / (b8 + b4 + eps)\n    ndwi = (b3 - b8) / (b3 + b8 + eps)\n    ndmi = (b8 - b11) / (b8 + b11 + eps)\n    ndsi = (b3 - b11) / (b3 + b11 + eps)\n    \n    # S2REP (Red Edge Position)\n    re_num = ((b4 + b7) / 2.0) - b5\n    re_denom = b6 - b5 + eps\n    s2rep_raw = 705.0 + 35.0 * (re_num / re_denom)\n    s2rep = np.clip((s2rep_raw - 700.0) / 50.0, 0.0, 1.0)\n    \n    stack = np.concatenate([img_9band, np.stack([ndvi, ndwi, ndmi, ndsi, s2rep])], axis=0)\n    \n    # Clipping per LULC training\n    stack[:9] = np.clip(stack[:9], 0.0, 1.0)\n    stack[9:13] = np.clip(stack[9:13], -1.0, 1.0)\n    stack[13] = np.clip(stack[13], 0.0, 1.0)\n    \n    return np.nan_to_num(stack, nan=0.0).astype(np.float32)\n\ndef run_lulc_inference(model, arr_14ch, tile_size=512, overlap=0.5):\n    \"\"\"Tiled inference with overlapping windows.\"\"\"\n    C, H, W = arr_14ch.shape\n    stride = int(tile_size * (1.0 - overlap))\n    \n    # Pad to tile boundaries\n    pad_h = (tile_size - H % tile_size) % tile_size\n    pad_w = (tile_size - W % tile_size) % tile_size\n    padded = np.pad(arr_14ch, ((0, 0), (0, pad_h), (0, pad_w)), mode=\"reflect\")\n    \n    Hp, Wp = padded.shape[1], padded.shape[2]\n    probs = np.zeros((8, Hp, Wp), dtype=np.float32)\n    counts = np.zeros((Hp, Wp), dtype=np.float32)\n    \n    with torch.no_grad():\n        for y in range(0, Hp - tile_size + 1, stride):\n            for x in range(0, Wp - tile_size + 1, stride):\n                patch = padded[:, y:y+tile_size, x:x+tile_size]\n                tensor = torch.from_numpy(patch).unsqueeze(0).float().to(device)\n                logits = model(tensor)\n                score = torch.softmax(logits, dim=1).cpu().numpy()[0]\n                probs[:, y:y+tile_size, x:x+tile_size] += score\n                counts[y:y+tile_size, x:x+tile_size] += 1.0\n    \n    avg = probs / np.maximum(counts, 1e-6)\n    pred = np.argmax(avg, axis=0).astype(np.uint8)\n    return pred[:H, :W]\n\ndef fetch_worldpop(label, target_shape, target_transform, target_epsg):\n    \"\"\"Fetch and reproject WorldPop data with area correction.\"\"\"\n    # Get ISO3 code\n    iso3, year = (\"PAK\", 2020)\n    for prefix, val in _WORLDPOP_CATALOGUE.items():\n        if label.startswith(prefix):\n            iso3, year = val\n            break\n    \n    cache_key = f\"{iso3}_{year}\"\n    url = f\"https://data.worldpop.org/GIS/Population/Global_2000_2020_Unconstrained/{year}/{iso3}/{iso3.lower()}_ppp_{year}_UNadj.tif\"\n    \n    print(f\"    Downloading WorldPop {iso3} {year}...\")\n    resp = requests.get(url, stream=True, timeout=300)\n    resp.raise_for_status()\n    \n    H, W = target_shape\n    target_crs = rasterio.CRS.from_epsg(target_epsg)\n    pop_grid = np.zeros((H, W), dtype=np.float32)\n    \n    with MemoryFile(resp.content) as mem:\n        with mem.open() as src:\n            src_res = abs(src.transform.a)\n            dst_res = abs(target_transform.a)\n            reproject(\n                source=rasterio.band(src, 1),\n                destination=pop_grid,\n                src_transform=src.transform,\n                src_crs=src.crs,\n                dst_transform=target_transform,\n                dst_crs=target_crs,\n                resampling=Resampling.nearest,\n            )\n    \n    # Area correction for upscaling (100m -> 10m)\n    area_ratio = (dst_res / src_res) ** 2\n    return np.clip(pop_grid * area_ratio, 0.0, None)\n\ndef load_flood_mask(location):\n    \"\"\"Load the flood mask from previous inference.\"\"\"\n    mask_path = os.path.join(MASKS_DIR, location, f\"{location}_mask_new_inundation.png\")\n    if not os.path.exists(mask_path):\n        # Try alternative naming\n        mask_path = os.path.join(MASKS_DIR, location, f\"{location}_mask_prediction.png\")\n    \n    if not os.path.exists(mask_path):\n        print(f\"  ⚠️ Flood mask not found for {location}\")\n        return None\n    \n    mask = np.array(Image.open(mask_path))\n    if mask.max() > 1:\n        mask = mask // 255\n    return mask.astype(np.uint8)\n\ndef load_location_metadata(location):\n    \"\"\"Extract lat/lon/radius from location name (approximate).\"\"\"\n    # This is a lookup - you can expand with exact coordinates\n    coordinates = {\n        \"Sialkot_punjab\": (32.496304, 74.538327, 10),\n        \"Dadu_Sindh\": (26.73, 67.78, 10),\n        \"Sukkur_Sindh\": (27.70, 68.87, 10),\n        \"Jacobabad_Sindh\": (28.28, 68.43, 10),\n        \"DG_Khan_Punjab\": (30.06, 70.64, 10),\n        \"Nowshera_KPK\": (34.01, 71.99, 10),\n        \"Sylhet_Bangladesh\": (24.01, 91.87, 10),\n        \"Kherson_Ukraine\": (46.64, 32.62, 10),\n        \"KwaZuluNatal_SA\": (-29.86, 31.01, 10),\n    }\n    \n    return coordinates.get(location, (0, 0, 10))\n\n# ═══════════════════════════════════════════════════════════════════════════════\n# MAIN PROCESSING LOOP\n# ═══════════════════════════════════════════════════════════════════════════════\n\ndef process_location(location):\n    \"\"\"Process a single location: LULC classification + population impact.\"\"\"\n    print(f\"\\n{'='*70}\")\n    print(f\"  PROCESSING: {location}\")\n    print(f\"{'='*70}\")\n    \n    # Load flood mask\n    flood_mask = load_flood_mask(location)\n    if flood_mask is None:\n        return None\n    \n    print(f\"  Flood mask shape: {flood_mask.shape}\")\n    print(f\"  Flood pixels: {flood_mask.sum():,} ({flood_mask.sum()*PIXEL_KM2:.2f} km²)\")\n    \n    # Get location metadata\n    lat, lon, radius_km = load_location_metadata(location)\n    print(f\"  Location: ({lat:.4f}, {lon:.4f}), radius: {radius_km} km\")\n    \n    # Reconstruct georeference\n    tf, epsg, bounds = reconstruct_georeference(lat, lon, radius_km, flood_mask.shape)\n    print(f\"  EPSG: {epsg}\")\n    \n    # Fetch S2 data for LULC\n    print(\"\\n  Fetching Sentinel-2 data for LULC classification...\")\n    try:\n        s2_9band = fetch_s2_for_lulc(location, lat, lon, radius_km, flood_mask.shape, tf, epsg)\n        print(f\"  S2 data shape: {s2_9band.shape}, range: [{s2_9band.min():.3f}, {s2_9band.max():.3f}]\")\n    except Exception as e:\n        print(f\"  ❌ Error fetching S2: {e}\")\n        return None\n    \n    # Build 14-channel input\n    print(\"\\n  Building 14-channel LULC input...\")\n    arr_14ch = compute_lulc_14ch(s2_9band)\n    \n    # Run LULC inference\n    print(\"\\n  Running LULC classification (this may take a few minutes)...\")\n    lulc_mask = run_lulc_inference(lulc_model, arr_14ch)\n    print(f\"  LULC unique classes: {np.unique(lulc_mask)}\")\n    \n    # Fetch population data\n    print(\"\\n  Fetching WorldPop population data...\")\n    try:\n        pop_grid = fetch_worldpop(location, flood_mask.shape, tf, epsg)\n        print(f\"  Population grid shape: {pop_grid.shape}\")\n        print(f\"  Total population in scene: {pop_grid.sum():,.0f}\")\n    except Exception as e:\n        print(f\"  ❌ Error fetching WorldPop: {e}\")\n        pop_grid = np.zeros_like(flood_mask, dtype=np.float32)\n    \n    # Calculate impacts\n    print(\"\\n  Calculating flood impacts...\")\n    \n    # Flooded area by LULC class\n    flooded_pixels = flood_mask == 1\n    flooded_lulc = lulc_mask[flooded_pixels]\n    \n    lulc_impact = {}\n    for class_idx, class_name in LULC_CLASS_MAP.items():\n        class_pixels = np.sum(flooded_lulc == class_idx)\n        class_area_km2 = class_pixels * PIXEL_KM2\n        if class_area_km2 > 0:\n            lulc_impact[class_name] = round(class_area_km2, 3)\n    \n    # Population affected\n    affected_population = np.sum(pop_grid[flooded_pixels])\n    \n    # LULC distribution (whole scene)\n    total_lulc_dist = {}\n    for class_idx, class_name in LULC_CLASS_MAP.items():\n        class_pixels = np.sum(lulc_mask == class_idx)\n        class_area_km2 = class_pixels * PIXEL_KM2\n        if class_area_km2 > 0:\n            total_lulc_dist[class_name] = round(class_area_km2, 3)\n    \n    # Compile results\n    results = {\n        \"location\": location,\n        \"lat\": lat,\n        \"lon\": lon,\n        \"radius_km\": radius_km,\n        \"epsg\": epsg,\n        \"flood_mask_shape\": list(flood_mask.shape),\n        \"total_flood_area_km2\": round(float(flood_mask.sum()) * PIXEL_KM2, 3),\n        \"affected_population\": int(round(affected_population)),\n        \"lulc_impact\": lulc_impact,\n        \"total_lulc_distribution\": total_lulc_dist,\n        \"flood_percentage_by_class\": {},\n    }\n    \n    # Calculate flood percentage per LULC class\n    for class_idx, class_name in LULC_CLASS_MAP.items():\n        total_class_pixels = np.sum(lulc_mask == class_idx)\n        flooded_class_pixels = np.sum((lulc_mask == class_idx) & flooded_pixels)\n        if total_class_pixels > 0:\n            pct = (flooded_class_pixels / total_class_pixels) * 100\n            results[\"flood_percentage_by_class\"][class_name] = round(pct, 2)\n    \n    print(f\"\\n  ✅ RESULTS FOR {location}:\")\n    print(f\"     Total flood area: {results['total_flood_area_km2']:.2f} km²\")\n    print(f\"     Population affected: {results['affected_population']:,}\")\n    print(f\"\\n     Flooded LULC breakdown:\")\n    for lulc_name, area in sorted(lulc_impact.items(), key=lambda x: x[1], reverse=True):\n        pct = results[\"flood_percentage_by_class\"].get(lulc_name, 0)\n        print(f\"        {lulc_name:<30}: {area:>8.2f} km² ({pct:.1f}% of class)\")\n    \n    return results\n\n# ═══════════════════════════════════════════════════════════════════════════════\n# VISUALIZATION\n# ═══════════════════════════════════════════════════════════════════════════════\n\ndef create_lulc_flood_map(location, lulc_mask, flood_mask, results, output_dir=\"./lulc_analysis\"):\n    \"\"\"Create a comprehensive LULC + flood map.\"\"\"\n    fig, axes = plt.subplots(1, 3, figsize=(18, 8))\n    \n    # 1. LULC Classification\n    lulc_viz = np.zeros((lulc_mask.shape[0], lulc_mask.shape[1], 3))\n    for class_idx, class_name in LULC_CLASS_MAP.items():\n        color = LULC_COLORS.get(class_name, \"#FFFFFF\")\n        rgb = tuple(int(color[i:i+2], 16)/255 for i in (1, 3, 5))\n        lulc_viz[lulc_mask == class_idx] = rgb\n    \n    axes[0].imshow(lulc_viz)\n    axes[0].set_title(f\"{location}\\nLULC Classification\", fontsize=12, fontweight='bold')\n    axes[0].axis('off')\n    \n    # 2. Flood Mask\n    axes[1].imshow(flood_mask, cmap='Blues', interpolation='none')\n    axes[1].set_title(f\"Flood Extent\\n{results['total_flood_area_km2']:.2f} km²\", \n                    