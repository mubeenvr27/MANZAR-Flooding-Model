an_to_num((ratio-np.nanpercentile(ratio[ratio>0],5))/(np.nanpercentile(ratio[ratio>0],95)-np.nanpercentile(ratio[ratio>0],5)+1e-10),nan=0.0),0,1)], axis=-1) * 255).astype(np.uint8)\n    Image.fromarray(_force_uint8(after_rgb), \"RGB\").save(os.path.join(loc_dir, f\"{label}_UI_AFTER_RAW_EVENT.png\"))\n    \n    base = before_rgb.astype(np.float32)\n    base[r[\"perm_water\"]==1] = base[r[\"perm_water\"]==1]*0.4 + np.array([0,0,128],np.float32)*0.6\n    base[r[\"new_inund\"]==1] = base[r[\"new_inund\"]==1]*0.2 + np.array([0,102,255],np.float32)*0.8\n    Image.fromarray(np.clip(base,0,255).astype(np.uint8), \"RGB\").save(os.path.join(loc_dir, f\"{label}_UI_AFTER_MASK_OVERLAY.png\"))\n    \n    Image.fromarray((r[\"perm_water\"]*255).astype(np.uint8), \"L\").save(os.path.join(loc_dir, f\"{label}_mask_perm_water.png\"))\n    plt.imsave(os.path.join(loc_dir, f\"{label}_mask_prob_map.png\"), r[\"prob_map\"], cmap=\"inferno\", vmin=0, vmax=1)\n    Image.fromarray((r[\"binary_mask\"]*255).astype(np.uint8), \"L\").save(os.path.join(loc_dir, f\"{label}_mask_prediction.png\"))\n    Image.fromarray((r[\"new_inund\"]*255).astype(np.uint8), \"L\").save(os.path.join(loc_dir, f\"{label}_mask_new_inundation.png\"))\n    \n    print(f\"    Saved 7 assets -> {loc_dir}/\")\n\nCMAP_PERM = ListedColormap([\"#00000000\", \"#000080\"])\nCMAP_FLOOD = ListedColormap([\"#00000000\", \"#0066FF\"])\n\ndef visualize(label, r, masks_dir):\n    H, W = r[\"binary_mask\"].shape\n    flood_pct = 100.0 * r[\"new_inund\"].sum() / (H * W)\n    \n    before_rgb = (load_png_rgb(r[\"s2_before_png\"]) if r.get(\"s2_before_png\") else s2_to_rgb(r[\"s2_arr\"]))\n    if r.get(\"s1_after_png\"):\n        after_rgb = load_png_rgb(r[\"s1_after_png\"])\n    elif r.get(\"s2_after_png\"):\n        after_rgb = load_png_rgb(r[\"s2_after_png\"])\n    else:\n        after_rgb = before_rgb\n    \n    fig = plt.figure(figsize=(26, 12), facecolor=\"#080808\")\n    gs = gridspec.GridSpec(2, 4, figure=fig, hspace=0.2, wspace=0.1)\n    \n    ax_main = fig.add_subplot(gs[:, :2])\n    ax_main.imshow(before_rgb)\n    ax_main.imshow(r[\"perm_water\"], cmap=CMAP_PERM, alpha=0.6, vmin=0, vmax=1)\n    ax_main.imshow(r[\"new_inund\"], cmap=CMAP_FLOOD, alpha=0.8, vmin=0, vmax=1)\n    ax_main.set_title(\"OFFICIAL FLOOD EXTENT\", color=\"#0066FF\", fontsize=16, fontweight=\"bold\")\n    ax_main.axis(\"off\")\n    ax_main.legend(handles=[\n        mpatches.Patch(color=\"#000080\", label=\"Permanent Waterways\"),\n        mpatches.Patch(color=\"#0066FF\", label=\"Detected New Inundation\"),\n    ], loc=\"lower left\", facecolor=\"#111111\", labelcolor=\"white\", edgecolor=\"none\")\n    \n    ax_pre = fig.add_subplot(gs[0, 2])\n    ax_pre.imshow(before_rgb)\n    ax_pre.axis(\"off\")\n    ax_pre.set_title(\"BEFORE\", color=\"white\", fontsize=11)\n    \n    ax_post = fig.add_subplot(gs[1, 2])\n    ax_post.imshow(after_rgb)\n    ax_post.axis(\"off\")\n    after_label = \"AFTER (SAR)\" if r.get(\"s1_after_png\") else \"AFTER (S2 Visual)\"\n    ax_post.set_title(after_label, color=\"white\", fontsize=11)\n    \n    ax_prob = fig.add_subplot(gs[:, 3])\n    im = ax_prob.imshow(r[\"prob_map\"], cmap=\"viridis\", vmin=0, vmax=1)\n    ax_prob.set_title(\"AI CONFIDENCE SCORE\", color=\"white\", fontsize=11)\n    ax_prob.axis(\"off\")\n    cb = plt.colorbar(im, ax=ax_prob, fraction=0.046, pad=0.04)\n    cb.ax.yaxis.set_tick_params(color=\"white\")\n    plt.setp(cb.ax.yaxis.get_ticklabels(), color=\"white\", fontsize=8)\n    \n    fig.text(0.5, 0.02, f\"MANZAR ANALYSIS: {label} | NET INUNDATION: {flood_pct:.2f}%\", ha=\"center\", color=\"white\", fontsize=14, fontweight=\"bold\")\n    \n    loc_dir = os.path.join(masks_dir, label)\n    os.makedirs(loc_dir, exist_ok=True)\n    report_path = os.path.join(loc_dir, f\"{label}_CLEAN_REPORT.png\")\n    plt.savefig(report_path, dpi=200, facecolor=\"#080808\", bbox_inches=\"tight\")\n    print(f\"    Dashboard -> {report_path}\")\n    plt.show()\n    plt.close(fig)\n\n# ═══════════════════════════════════════════════════════════════════════\n# MAIN PIPELINE\n# ═══════════════════════════════════════════════════════════════════════\ntry:\n    model = load_model(MODEL_PATH, device)\nexcept Exception as e:\n    debug_log(f\"Failed to load model: {e}\", \"ERROR\")\n    raise\n\nall_results = {}\nmetrics_log = []\n\nfor label, lat, lon in LOCATIONS:\n    debug_log(f\"\\n{'='*65}\")\n    debug_log(f\"Processing: {label}\")\n    print(f\"\\n{'='*65}\\n  {label}\\n{'='*65}\")\n    \n    files = discover(label, COMPOSITES_DIR)\n    \n    if not files[\"s2_tif\"] or not files[\"s1_tif\"]:\n        debug_log(f\"SKIP: Missing files for {label}\", \"WARNING\")\n        print(f\"  SKIP: Missing S2 or S1 data for {label}\")\n        continue\n    \n    print(f\"  S2 TIF: {os.path.basename(files['s2_tif'])}\")\n    print(f\"  S1 TIF: {os.path.basename(files['s1_tif'])}\")\n    \n    # Load data with correct handling\n    s2_arr, s2_tf, s2_crs = load_tif_corrected(files[\"s2_tif\"], is_sar=False)\n    s1_arr_db, s1_tf, s1_crs = load_tif_corrected(files[\"s1_tif\"], is_sar=True)\n    \n    # Permanent water mask\n    mndwi, perm_water = mndwi_permanent_water(s2_arr)\n    debug_log(f\"Permanent water: {perm_water.sum()} pixels ({100*perm_water.sum()/perm_water.size:.2f}%)\")\n    \n    # Build tensor\n    tensor = build_tensor_fixed(s2_arr, s1_arr_db, sar_only=SAR_ONLY_MODE)\n    print(f\"  Tensor shape: {tensor.shape}\")\n    \n    # Run inference\n    prob_map, binary_mask = tiled_predict(model, tensor, device)\n    \n    # Align masks\n    H, W = binary_mask.shape\n    if perm_water.shape != (H, W):\n        pw_t = torch.from_numpy(perm_water.astype(np.float32)).unsqueeze(0).unsqueeze(0)\n        pw_t = F.interpolate(pw_t, size=(H, W), mode=\"nearest\")\n        perm_water = (pw_t.squeeze().numpy() > 0.5).astype(np.uint8)\n    \n    # New inundation (flood minus permanent water)\n    new_inund = ((binary_mask == 1) & (perm_water == 0)).astype(np.uint8)\n    \n    # Calculate metrics\n    flood_km2 = float(binary_mask.sum()) * PIXEL_AREA_KM2\n    new_km2 = float(new_inund.sum()) * PIXEL_AREA_KM2\n    perm_km2 = float(perm_water.sum()) * PIXEL_AREA_KM2\n    net_pct = 100.0 * new_inund.sum() / (H * W)\n    \n    debug_log(f\"Results: {new_km2:.2f} km2 ({net_pct:.2f}%)\")\n    print(f\"  New inundation: {new_km2:.2f} km2 ({net_pct:.2f}%)\")\n    print(f\"  Permanent water: {perm_km2:.2f} km2\")\n    \n    metrics_log.append({\n        \"location\": label, \"lat\": lat, \"lon\": lon,\n        \"flood_extent_km2\": round(flood_km2, 3),\n        \"new_inundation_km2\": round(new_km2, 3),\n        \"perm_water_km2\": round(perm_km2, 3),\n        \"net_inundation_pct\": round(net_pct, 4),\n    })\n    \n    all_results[label] = {\n        \"s2_arr\": s2_arr, \"s1_arr_db\": s1_arr_db,\n        \"prob_map\": prob_map, \"binary_mask\": binary_mask,\n        \"perm_water\": perm_water, \"new_inund\": new_inund,\n        \"mndwi\": mndwi,\n        \"s2_before_png\": files[\"s2_before_png\"],\n        \"s1_after_png\": files[\"s1_after_png\"],\n        \"s2_after_png\": files[\"s2_after_png\"],\n    }\n\n# Save metrics\nwith open(METRICS_JSON, \"w\") as f:\n    json.dump(metrics_log, f, indent=2)\nprint(f\"\\nMetrics saved: {METRICS_JSON}\")\n\n# Visualize results\nprint(f\"\\nRendering dashboards for {len(all_results)} locations...\")\nfor label, r in all_results.items():\n    print(f\"\\n  {label}\")\n    export_pngs(label, r, MASKS_PNG_DIR)\n    visualize(label, r, MASKS_PNG_DIR)\n\nprint(f\"\\n✅ Done! Results in: {MASKS_PNG_DIR}/\")\nprint(f\"📊 Processed: {len(all_results)}/{len(LOCATIONS)} locations\")\nprint(f\"📝 Debug log: {DEBUG_LOG}\")\n\nprint(\"\\n=== FINAL METRICS ===\")\nfor m in metrics_log:\n    print(f\"  {m['location']:25s}: {m['new_inundation_km2']:.2f} km2 ({m['net_inundation_pct']:.2f}%)\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-27T20:05:54.960808Z","iopub.execute_input":"2026-04-27T20:05:54.961524Z","iopub.status.idle":"2026-04-27T20:06:32.333452Z","shell.execute_reply.started":"2026-04-27T20:05:54.961496Z","shell.execute_reply":"2026-04-27T20:06:32.332485Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# !pip install segmentation-models-pytorch rasterio -q\n\nimport os, glob, json, warnings\nimport numpy as np\nimport torch\nimport torch.nn as nn\nimport torch.nn.functional as F\nimport segmentation_models_pytorch as smp\nimport rasterio\nfrom rasterio.enums import Resampling\nimport matplotlib.pyplot as plt\nimport matplotlib.patches as mpatches\nimport matplotlib.gridspec as gridspec\nfrom matplotlib.colors import ListedColormap\nfrom PIL import Image, ImageEnhance\nfrom tqdm.auto import tqdm\nimport datetime\nwarnings.filterwarnings(\"ignore\")\n\n# ═══════════════════════════════════════════════════════════════════════\n# CONFIG\n# ═══════════════════════════════════════════════════════════════════════\nCOMPOSITES_DIR = \"./flood_composites\"\nMODEL_PATH     = \"/kaggle/input/models/muhammadmubeenxt/ablation-flooding/pytorch/default/1/ablation_best_flood_model_full.pth\"\nMASKS_PNG_DIR  = \"./masks_pngs\"\nMETRICS_JSON   = \"./flood_metrics.json\"\nDEBUG_LOG      = \"./flood_debug.log\"\nos.makedirs(MASKS_PNG_DIR, exist_ok=True)\n\n# Locations\nLOCATIONS = [\n    #(\"Sialkot_punjab\",    32.496304,  74.538327),\n    (\"Dadu_Sindh\",        26.73,      67.78),\n    (\"Sukkur_Sindh\",      27.70,      68.87),\n    (\"Jacobabad_Sindh\",   28.28,      68.43),\n    (\"DG_Khan_Punjab\",    30.06,      70.64),\n    (\"Nowshera_KPK\",      34.01,      71.99),\n]\n\nFLOOD_THRESHOLD  = 0.55\nPERM_WATER_MNDWI = -0.1\nSAR_ONLY_MODE    = False\nTILE_SIZE        = 256\nTILE_OVERLAP     = 64\nTILE_STRIDE      = TILE_SIZE - TILE_OVERLAP\nPIXEL_AREA_KM2   = (10.0 * 10.0) / 1e6\n\ndevice = torch.device(\"cuda\" if torch.cuda.is_available() else \"cpu\")\ntorch.cuda.empty_cache()\n\n# Setup debug logging\ndef debug_log(msg, level=\"INFO\"):\n    timestamp = datetime.datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\")\n    log_msg = f\"[{timestamp}] [{level}] {msg}\"\n    print(log_msg)\n    with open(DEBUG_LOG, \"a\") as f:\n        f.write(log_msg + \"\\n\")\n\ndebug_log(f\"=== FLOOD DETECTION STARTED ===\")\ndebug_log(f\"Device: {device}, TILE_SIZE: {TILE_SIZE}, Threshold: {FLOOD_THRESHOLD}\")\n\n# ═══════════════════════════════════════════════════════════════════════\n# MODEL DEFINITION\n# ═══════════════════════════════════════════════════════════════════════\nclass CBAM(nn.Module):\n    def __init__(self, channels, reduction=8):\n        super().__init__()\n        self.avg = nn.AdaptiveAvgPool2d(1)\n        self.max = nn.AdaptiveMaxPool2d(1)\n        self.fc  = nn.Sequential(\n            nn.Linear(channels, channels // reduction, bias=False),\n            nn.ReLU(inplace=True),\n            nn.Linear(channels // reduction, channels, bias=False))\n        self.sc  = nn.Conv2d(2, 1, kernel_size=7, padding=3, bias=False)\n\n    def forward(self, x):\n        b, c = x.shape[:2]\n        a = self.fc(self.avg(x).view(b, c))\n        m = self.fc(self.max(x).view(b, c))\n        x = x * torch.sigmoid(a + m).view(b, c, 1, 1)\n        s = torch.cat([x.mean(1, keepdim=True), x.max(1, keepdim=True)[0]], dim=1)\n        return x * torch.sigmoid(self.sc(s))\n\nclass DualStreamUNetPP(nn.Module):\n    def __init__(self, use_cbam=True):\n        super().__init__()\n        self.use_cbam = use_cbam\n        self.sar_enc  = smp.UnetPlusPlus(encoder_name=\"resnet50\", encoder_weights=None,\n                                          in_channels=3, classes=32)\n        self.opt_enc  = smp.UnetPlusPlus(encoder_name=\"resnet50\", encoder_weights=None,\n                                          in_channels=7, classes=32)\n        if use_cbam:\n            self.cbam = CBAM(64)\n        self.head = nn.Sequential(\n            nn.Conv2d(64, 32, 3, padding=1, bias=False),\n            nn.BatchNorm2d(32), nn.ReLU(inplace=True),\n            nn.Dropout2d(p=0.15), nn.Conv2d(32, 1, 1))\n\n    def forward(self, x):\n        sar = torch.cat([x[:, 0:2], x[:, 7:8]], dim=1)\n        opt = torch.cat([x[:, 2:7], x[:, 8:10]], dim=1)\n        f   = torch.cat([self.sar_enc(sar), self.opt_enc(opt)], dim=1)\n        if self.use_cbam:\n            f = self.cbam(f)\n        return self.head(f)\n\ndef load_model(path, device):\n    debug_log(f\"Loading model from: {path}\")\n    if not os.path.exists(path):\n        raise FileNotFoundError(f\"Checkpoint not found: {path}\")\n    \n    m = DualStreamUNetPP(use_cbam=True)\n    raw = torch.load(path, map_location=device)\n    state = raw.get(\"model_state\", raw)\n    \n    # Strip DataParallel prefix\n    state = {k.replace(\"module.\", \"\"): v for k, v in state.items()}\n    \n    # Remap keys\n    remapped = {}\n    for k, v in state.items():\n        k = k.replace(\"sar_encoder.\", \"sar_enc.\").replace(\"opt_encoder.\", \"opt_enc.\")\n        remapped[k] = v\n    \n    missing, unexpected = m.load_state_dict(remapped, strict=False)\n    if missing:\n        debug_log(f\"Missing keys: {missing[:3]}\", \"WARNING\")\n    if unexpected:\n        debug_log(f\"Unexpected keys: {unexpected[:3]}\", \"WARNING\")\n    \n    m.to(device).eval()\n    param_count = sum(p.numel() for p in m.parameters())/1e6\n    debug_log(f\"Model loaded: {param_count:.1f}M params\")\n    \n    # Test model\n    debug_log(\"Testing model with dummy input...\")\n    dummy_input = torch.randn(1, 10, 256, 256).to(device)\n    with torch.no_grad():\n        dummy_output = m(dummy_input)\n    debug_log(f\"Dummy output shape: {dummy_output.shape}\")\n    \n    return m\n\n# ═══════════════════════════════════════════════════════════════════════\n# FILE DISCOVERY\n# ═══════════════════════════════════════════════════════════════════════\ndef find_file(base_dir, pattern):\n    hits = sorted(glob.glob(os.path.join(base_dir, pattern)))\n    return hits[-1] if hits else None\n\ndef discover(label, composites_dir):\n    d = {}\n    d[\"s2_tif\"] = find_file(composites_dir, f\"{label}_s2_baseline_*.tif\")\n    d[\"s1_tif\"] = (\n        find_file(composites_dir, f\"{label}_s1_*_composite_*.tif\") or\n        find_file(composites_dir, f\"{label}_s1_composite_*.tif\")\n    )\n    d[\"s2_before_png\"] = find_file(composites_dir, f\"{label}_s2_baseline_*_visual.png\")\n    d[\"s1_after_png\"]  = (\n        find_file(composites_dir, f\"{label}_s1_*_falsecolor_*.png\") or\n        find_file(composites_dir, f\"{label}_s1_falsecolor_*.png\")\n    )\n    d[\"s2_after_png\"]  = find_file(composites_dir, f\"{label}_s2_visual_after_*.png\")\n    return d\n\n# ═══════════════════════════════════════════════════════════════════════\n# DATA LOADING - FIXED VERSION\n# ═══════════════════════════════════════════════════════════════════════\ndef load_tif_corrected(path, is_sar=False):\n    \"\"\"Load GeoTIFF - S2 gets scaled to 0-1, S1 stays in dB\"\"\"\n    debug_log(f\"Loading GeoTIFF: {path}\")\n    \n    with rasterio.open(path) as src:\n        data = src.read().astype(np.float32)\n        \n        if is_sar:\n            # SAR data: convert linear to dB if needed\n            if data.max() > 10:  # Linear scale\n                debug_log(f\"  Converting SAR from linear to dB (max={data.max():.2f})\")\n                data = np.clip(10 * np.log10(data + 1e-9), -35, 5)\n            debug_log(f\"  SAR dB - range: [{data.min():.2f}, {data.max():.2f}], mean: {data.mean():.2f}\")\n        else:\n            # S2 optical: scale 0-10000 to 0-1\n            if data.max() > 10:\n                debug_log(f\"  Scaling S2 (max={data.max():.2f}) to 0-1\")\n                data = data / 10000.0\n            data = np.clip(data, 0.0, 1.0)\n            debug_log(f\"  S2 scaled - range: [{data.min():.4f}, {data.max():.4f}], mean: {data.mean():.4f}\")\n        \n        return data, src.transform, src.crs\n\ndef match_hw(arr, target_hw):\n    tH, tW = target_hw\n    if arr.shape[1] == tH and arr.shape[2] == tW:\n        return arr\n    t = torch.from_numpy(arr).unsqueeze(0).float()\n    t = F.interpolate(t, size=(tH, tW), mode=\"bilinear\", align_corners=False)\n    return t.squeeze(0).numpy()\n\ndef build_tensor_fixed(s2_arr, s1_arr_db, sar_only=False):\n    \"\"\"Build 10-channel input tensor\"\"\"\n    debug_log(\"Building input tensor...\")\n    H, W = s2_arr.shape[1], s2_arr.shape[2]\n    s1_arr_db = match_hw(s1_arr_db, (H, W))\n    \n    # Normalize dB to [0,1] for model input\n    vv = np.clip((s1_arr_db[0] + 30.0) / 30.0, 0.0, 1.0)\n    vh = np.clip((s1_arr_db[1] + 30.0) / 30.0, 0.0, 1.0)\n    vv = np.nan_to_num(vv, nan=0.0)\n    vh = np.nan_to_num(vh, nan=0.0)\n    \n    debug_log(f\"  Normalized VV - range: [{vv.min():.4f}, {vv.max():.4f}], unique: {len(np.unique(vv))}\")\n    debug_log(f\"  Normalized VH - range: [{vh.min():.4f}, {vh.max():.4f}], unique: {len(np.unique(vh))}\")\n    \n    # SAR ratio\n    with np.errstate(divide=\"ignore\", invalid=\"ignore\"):\n        sar_r = np.where(vh > 1e-8, vv / vh, 0.0)\n    sar_r = np.clip(np.nan_to_num(sar_r, nan=0.0, posinf=0.0), 0.0, 10.0)\n    \n    if sar_only:\n        tensor = np.zeros((10, H, W), dtype=np.float32)\n        tensor[0] = vv\n        tensor[1] = vh\n        tensor[7] = sar_r\n        return tensor\n    \n    # Optical bands\n    blue = np.clip(np.nan_to_num(s2_arr[0], nan=0.0), 0.0, 1.0)\n    green = np.clip(np.nan_to_num(s2_arr[1], nan=0.0), 0.0, 1.0)\n    red = np.clip(np.nan_to_num(s2_arr[2], nan=0.0), 0.0, 1.0)\n    nir = np.clip(np.nan_to_num(s2_arr[3], nan=0.0), 0.0, 1.0)\n    swir1 = np.clip(np.nan_to_num(s2_arr[4], nan=0.0), 0.0, 1.0)\n    \n    debug_log(f\"  S2 means - B:{blue.mean():.3f} G:{green.mean():.3f} R:{red.mean():.3f}\")\n    \n    # Indices\n    with np.errstate(divide=\"ignore\", invalid=\"ignore\"):\n        ndwi = np.where((green+nir) > 1e-8, (green-nir) / (green+nir), 0.0)\n        mndwi = np.where((green+swir1) > 1e-8, (green-swir1) / (green+swir1), 0.0)\n    \n    ndwi = np.nan_to_num(ndwi, nan=0.0)\n    mndwi = np.nan_to_num(mndwi, nan=0.0)\n    \n    tensor = np.stack([\n        vv, vh, blue, green, red, nir, ndwi, sar_r, swir1, mndwi\n    ], axis=0).astype(np.float32)\n    \n    debug_log(f\"  Tensor - range: [{tensor.min():.4f}, {tensor.max():.4f}], mean: {tensor.mean():.4f}\")\n    return tensor\n\n# ═══════════════════════════════════════════════════════════════════════\n# TILED INFERENCE\n# ═══════════════════════════════════════════════════════════════════════\ndef _hanning_window(size):\n    lin = np.hanning(size).astype(np.float64)\n    w = np.outer(lin, lin)\n    return np.clip(w, 1e-6, None)\n\n@torch.no_grad()\ndef tiled_predict(model, tensor, device):\n    debug_log(\"Starting tiled prediction...\")\n    C, H, W = tensor.shape\n    debug_log(f\"  Input shape: {tensor.shape}\")\n    \n    torch.cuda.empty_cache()\n    win = _hanning_window(TILE_SIZE)\n    \n    pad_h = (-H) % TILE_STRIDE\n    pad_w = (-W) % TILE_STRIDE\n    if pad_h or pad_w:\n        debug_log(f\"  Padding: h={pad_h}, w={pad_w}\")\n        tensor = np.pad(tensor, ((0,0),(0,pad_h),(0,pad_w)), mode=\"reflect\")\n    \n    _, PH, PW = tensor.shape\n    acc = np.zeros((PH, PW), dtype=np.float64)\n    count = np.zeros((PH, PW), dtype=np.float64)\n    \n    ys = list(range(0, PH - TILE_SIZE + 1, TILE_STRIDE))\n    xs = list(range(0, PW - TILE_SIZE + 1, TILE_STRIDE))\n    if ys and ys[-1] + TILE_SIZE < PH:\n        ys.append(PH - TILE_SIZE)\n    if xs and xs[-1] + TILE_SIZE < PW:\n        xs.append(PW - TILE_SIZE)\n    \n    debug_log(f\"  Tiles: {len(ys)} x {len(xs)} = {len(ys)*len(xs)} tiles\")\n    \n    model.eval()\n    coords = [(y, x) for y in ys for x in xs]\n    \n    for idx, (y0, x0) in enumerate(tqdm(coords, desc=\"  Tiles\", leave=False)):\n        chip = tensor[:, y0:y0+TILE_SIZE, x0:x0+TILE_SIZE]\n        xt = torch.from_numpy(chip).unsqueeze(0).to(device)\n        \n        with torch.amp.autocast(\"cuda\", enabled=(device.type == \"cuda\")):\n            prob = torch.sigmoid(model(xt)).squeeze().cpu().numpy().astype(np.float64)\n        \n        acc[y0:y0+TILE_SIZE, x0:x0+TILE_SIZE] += prob * win\n        count[y0:y0+TILE_SIZE, x0:x0+TILE_SIZE] += win\n        \n        if idx % 20 == 0:\n            torch.cuda.empty_cache()\n    \n    prob_map = (acc / np.where(count > 0, count, 1.0)).astype(np.float32)\n    prob_map = prob_map[:H, :W]\n    binary = (prob_map >= FLOOD_THRESHOLD).astype(np.uint8)\n    \n    debug_log(f\"  Probability - min: {prob_map.min():.4f}, max: {prob_map.max():.4f}, mean: {prob_map.mean():.4f}\")\n    debug_log(f\"  Flood pixels: {binary.sum()} ({100*binary.sum()/(H*W):.2f}%)\")\n    \n    return prob_map, binary\n\n# ═══════════════════════════════════════════════════════════════════════\n# VISUALIZATION HELPERS\n# ═══════════════════════════════════════════════════════════════════════\ndef load_png_rgb(path):\n    return np.array(Image.open(path).convert(\"RGB\"))\n\ndef s2_to_rgb(s2_arr, gamma=0.55, lo=1.0, hi=98.0, sat=1.3):\n    chs = []\n    for idx in [2, 1, 0]:\n        b = s2_arr[idx].astype(np.float32)\n        v = b[~np.isnan(b)]\n        if not len(v):\n            chs.append(np.zeros(b.shape, np.float32))\n            continue\n        lo_v, hi_v = np.percentile(v, [lo, hi])\n        b = np.clip(b, lo_v, hi_v)\n        b = (b - lo_v) / (hi_v - lo_v + 1e-10)\n        b = np.power(np.clip(np.nan_to_num(b, nan=0.0), 0, 1), gamma)\n        chs.append(b)\n    rgb = np.stack(chs, axis=-1)\n    try:\n        pil = Image.fromarray((rgb*255).astype(np.uint8), \"RGB\")\n        pil = ImageEnhance.Color(pil).enhance(sat)\n        rgb = np.array(pil).astype(np.float32) / 255.0\n    except Exception:\n        pass\n    return (rgb * 255).astype(np.uint8)\n\ndef mndwi_permanent_water(s2_arr):\n    green = np.clip(np.nan_to_num(s2_arr[1], nan=0.0), 0, 1)\n    swir1 = np.clip(np.nan_to_num(s2_arr[4], nan=0.0), 0, 1)\n    with np.errstate(divide=\"ignore\", invalid=\"ignore\"):\n        mndwi = np.where((green+swir1) > 1e-8, (green-swir1)/(green+swir1), 0.0)\n    mndwi = np.nan_to_num(mndwi, nan=0.0).astype(np.float32)\n    return mndwi, (mndwi > PERM_WATER_MNDWI).astype(np.uint8)\n\ndef export_pngs(label, r, masks_dir):\n    loc_dir = os.path.join(masks_dir, label)\n    os.makedirs(loc_dir, exist_ok=True)\n    \n    def _force_uint8(arr):\n        arr = np.array(arr, dtype=np.float32)\n        if arr.max() <= 1.0:\n            arr = np.clip(arr, 0, 1) * 255\n        return np.nan_to_num(arr, nan=0.0).astype(np.uint8)\n    \n    before_rgb = (load_png_rgb(r[\"s2_before_png\"]) if r.get(\"s2_before_png\") else s2_to_rgb(r[\"s2_arr\"]))\n    Image.fromarray(_force_uint8(before_rgb), \"RGB\").save(os.path.join(loc_dir, f\"{label}_UI_BEFORE_OPTICAL.png\"))\n    \n    if r.get(\"s1_after_png\"):\n        after_rgb = load_png_rgb(r[\"s1_after_png\"])\n    elif r.get(\"s2_after_png\"):\n        after_rgb = load_png_rgb(r[\"s2_after_png\"])\n    else:\n        vv = r[\"s1_arr_db\"][0]\n        vh = r[\"s1_arr_db\"][1]\n        def _s(a, lo=2, hi=98):\n            v = a[~np.isnan(a)]\n            if not len(v):\n                return np.zeros_like(a, np.float32)\n            lv, hv = np.percentile(v, [lo, hi])\n            return np.clip(np.nan_to_num((a-lv)/(hv-lv+1e-10), nan=0.0), 0, 1)\n        ratio = np.where(np.power(10,vh/10) > 1e-10, np.power(10,vv/10)/np.power(10,vh/10), 0.0)\n        after_rgb = (np.stack([_s(vv),_s(vh), np.clip(np.nan_to_num((ratio-np.nanpercentile(ratio[ratio>0],5))/(np.nanpercentile(ratio[ratio>0],95)-np.nanpercentile(ratio[ratio>0],5)+1e-10),nan=0.0),0,1)], axis=-1) * 255).astype(np.uint8)\n    Image.fromarray(_force_uint8(after_rgb), \"RGB\").save(os.path.join(loc_dir, f\"{label}_UI_AFTER_RAW_EVENT.png\"))\n    \n    base = before_rgb.astype(np.float32)\n    base[r[\"perm_water\"]==1] = base[r[\"perm_water\"]==1]*0.4 + np.array([0,0,128],np.float32)*0.6\n    base[r[\"new_inund\"]==1] = base[r[\"new_inund\"]==1]*0.2 + np.array([0,102,255],np.float32)*0.8\n    Image.fromarray(np.clip(base,0,255).astype(np.uint8), \"RGB\").save(os.path.join(loc_dir, f\"{label}_UI_AFTER_MASK_OVERLAY.png\"))\n    \n    Image.fromarray((r[\"perm_water\"]*255).astype(np.uint8), \"L\").save(os.path.join(loc_dir, f\"{label}_mask_perm_water.png\"))\n    plt.imsave(os.path.join(loc_dir, f\"{label}_mask_prob_map.png\"), r[\"prob_map\"], cmap=\"inferno\", vmin=0, vmax=1)\n    Image.fromarray((r[\"binary_mask\"]*255).astype(np.uint8), \"L\").save(os.path.join(loc_dir, f\"{label}_mask_prediction.png\"))\n    Image.fromarray((r[\"new_inund\"]*255).astype(np.uint8), \"L\").save(os.path.join(loc_dir, f\"{label}_mask_new_inundation.png\"))\n    \n    print(f\"    Saved 7 assets -> {loc_dir}/\")\n\nCMAP_PERM = ListedColormap([\"#00000000\", \"#000080\"])\nCMAP_FLOOD = ListedColormap([\"#00000000\", \"#0066FF\"])\n\ndef visualize(label, r, masks_dir):\n    H, W = r[\"binary_mask\"].shape\n    flood_pct = 100.0 * r[\"new_inund\"].sum() / (H * W)\n    \n    before_rgb = (load_png_rgb(r[\"s2_before_png\"]) if r.get(\"s2_before_png\") else s2_to_rgb(r[\"s2_arr\"]))\n    if r.get(\"s1_after_png\"):\n        after_rgb = load_png_rgb(r[\"s1_after_png\"])\n    elif r.get(\"s2_after_png\"):\n        after_rgb = load_png_rgb(r[\"s2_after_png\"])\n    else:\n        after_rgb = before_rgb\n    \n    fig = plt.figure(figsize=(26, 12), facecolor=\"#080808\")\n    gs = gridspec.GridSpec(2, 4, figure=fig, hspace=0.2, wspace=0.1)\n    \n    ax_main = fig.add_subplot(gs[:, :2])\n    ax_main.imshow(before_rgb)\n    ax_main.imshow(r[\"perm_water\"], cmap=CMAP_PERM, alpha=0.6, vmin=0, vmax=1)\n    ax_main.imshow(r[\"new_inund\"], cmap=CMAP_FLOOD, alpha=0.8, vmin=0, vmax=1)\n    ax_main.set_title(\"OFFICIAL FLOOD EXTENT\", color=\"#0066FF\", fontsize=16, fontweight=\"bold\")\n    ax_main.axis(\"off\")\n    ax_main.legend(handles=[\n        mpatches.Patch(color=\"#000080\", label=\"Permanent Waterways\"),\n        mpatches.Patch(color=\"#0066FF\", label=\"Detected New Inundation\"),\n    ], loc=\"lower left\", facecolor=\"#111111\", labelcolor=\"white\", edgecolor=\"none\")\n    \n    ax_pre = fig.add_subplot(gs[0, 2])\n    ax_pre.imshow(before_rgb)\n    ax_pre.axis(\"off\")\n    ax_pre.set_title(\"BEFORE\", color=\"white\", fontsize=11)\n    \n    ax_post = fig.add_subplot(gs[1, 2])\n    ax_post.imshow(after_rgb)\n    ax_post.axis(\"off\")\n    after_label = \"AFTER (SAR)\" if r.get(\"s1_after_png\") else \"AFTER (S2 Visual)\"\n    ax_post.set_title(after_label, color=\"white\", fontsize=11)\n    \n    ax_prob = fig.add_subplot(gs[:, 3])\n    im = ax_prob.imshow(r[\"prob_map\"], cmap=\"viridis\", vmin=0, vmax=1)\n    ax_prob.set_title(\"AI CONFIDENCE SCORE\", color=\"white\", fontsize=11)\n    ax_prob.axis(\"off\")\n    cb = plt.colorbar(im, ax=ax_prob, fraction=0.046, pad=0.04)\n    cb.ax.yaxis.set_tick_params(color=\"white\")\n    plt.setp(cb.ax.yaxis.get_ticklabels(), color=\"white\", fontsize=8)\n    \n    fig.text(0.5, 0.02, f\"MANZAR ANALYSIS: {label} | NET INUNDATION: {flood_pct:.2f}%\", ha=\"center\", color=\"white\", fontsize=14, fontweight=\"bold\")\n    \n    loc_dir = os.path.join(masks_dir, label)\n    os.makedirs(loc_dir, exist_ok=True)\n    report_path = os.path.join(loc_dir, f\"{label}_CLEAN_REPORT.png\")\n    plt.savefig(report_path, dpi=200, facecolor=\"#080808\", bbox_inches=\"tight\")\n    print(f\"    Dashboard -> {report_path}\")\n    plt.show()\n    plt.close(fig)\n\n# ═══════════════════════════════════════════════════════════════════════\n# MAIN PIPELINE\n# ═══════════════════════════════════════════════════════════════════════\ntry:\n    model = load_model(MODEL_PATH, device)\nexcept Exception as e:\n    debug_log(f\"Failed to load model: {e}\", \"ERROR\")\n    raise\n\nall_results = {}\nmetrics_log = []\n\nfor label, lat, lon in LOCATIONS:\n    debug_log(f\"\\n{'='*65}\")\n    debug_log(f\"Processing: {label}\")\n    print(f\"\\n{'='*65}\\n  {label}\\n{'='*65}\")\n    \n    files = discover(label, COMPOSITES_DIR)\n    \n    if not files[\"s2_tif\"] or not files[\"s1_tif\"]:\n        debug_log(f\"SKIP: Missing files for {label}\", \"WARNING\")\n        print(f\"  SKIP: Missing S2 or S1 data for {label}\")\n        continue\n    \n    print(f\"  S2 TIF: {os.path.basename(files['s2_tif'])}\")\n    print(f\"  S1 TIF: {os.path.basename(files['s1_tif'])}\")\n    \n    # Load data with correct handling\n    s2_arr, s2_tf, s2_crs = load_tif_corrected(files[\"s2_tif\"], is_sar=False)\n    s1_arr_db, s1_tf, s1_crs = load_tif_corrected(files[\"s1_tif\"], is_sar=True)\n    \n    # Permanent water mask\n    mndwi, perm_water = mndwi_permanent_water(s2_arr)\n    debug_log(f\"Permanent water: {perm_water.sum()} pixels ({100*perm_water.sum()/perm_water.size:.2f}%)\")\n    \n    # Build tensor\n    tensor = build_tensor_fixed(s2_arr, s1_arr_db, sar_only=SAR_ONLY_MODE)\n    print(f\"  Tensor shape: {tensor.shape}\")\n    \n    # Run inference\n    prob_map, binary_mask = tiled_predict(model, tensor, device)\n    \n    # Align masks\n    H, W = binary_mask.shape\n    if perm_water.shape != (H, W):\n        pw_t = torch.from_numpy(perm_water.astype(np.float32)).unsqueeze(0).unsqueeze(0)\n        pw_t = F.interpolate(pw_t, size=(H, W), mode=\"nearest\")\n        perm_water = (pw_t.squeeze().numpy() > 0.5).astype(np.uint8)\n    \n    # New inundation (flood minus permanent water)\n    new_inund = ((binary_mask == 1) & (perm_water == 0)).astype(np.uint8)\n    \n    # Calculate metrics\n    flood_km2 = float(binary_mask.sum()) * PIXEL_AREA_KM2\n    new_km2 = float(new_inund.sum()) * PIXEL_AREA_KM2\n    perm_km2 = float(perm_water.sum()) * PIXEL_AREA_KM2\n    net_pct = 100.0 * new_inund.sum() / (H * W)\n    \n    debug_log(f\"Results: {new_km2:.2f} km2 ({net_pct:.2f}%)\")\n    print(f\"  New inundation: {new_km2:.2f} km2 ({net_pct:.2f}%)\")\n    print(f\"  Permanent water: {perm_km2:.2f} km2\")\n    \n    metrics_log.append({\n        \"location\": label, \"lat\": lat, \"lon\": lon,\n        \"flood_extent_km2\": round(flood_km2, 3),\n        \"new_inundation_km2\": round(new_km2, 3),\n        \"perm_water_km2\": round(perm_km2, 3),\n        \"net_inundation_pct\": round(net_pct, 4),\n    })\n    \n    all_results[label] = {\n        \"s2_arr\": s2_arr, \"s1_arr_db\": s1_arr_db,\n        \"prob_map\": prob_map, \"binary_mask\": binary_mask,\n        \"perm_water\": perm_water, \"new_inund\": new_inund,\n        \"mndwi\": mndwi,\n        \"s2_before_png\": files[\"s2_before_png\"],\n        \"s1_after_png\": files[\"s1_after_png\"],\n        \"s2_after_png\": files[\"s2_after_png\"],\n    }\n\n# Save metrics\nwith open(METRICS_JSON, \"w\") as f:\n    json.dump(metrics_log, f, indent=2)\nprint(f\"\\nMetrics saved: {METRICS_JSON}\")\n\n# Visualize results\nprint(f\"\\nRendering dashboards for {len(all_results)} locations...\")\nfor label, r in all_results.items():\n    print(f\"\\n  {label}\")\n    export_pngs(label, r, MASKS_PNG_DIR)\n    visualize(label, r, MASKS_PNG_DIR)\n\nprint(f\"\\n✅ Done! Results in: {MASKS_PNG_DIR}/\")\nprint(f\"📊 Processed: {len(all_results)}/{len(LOCATIONS)} locations\")\nprint(f\"📝 Debug log: {DEBUG_LOG}\")\n\nprint(\"\\n=== FINAL METRICS ===\")\nfor m in metrics_log:\n    print(f\"  {m['location']:25s}: {m['new_inundation_km2']:.2f} km2 ({m['net_inundation_pct']:.2f}%)\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-27T20:07:50.818446Z","iopub.execute_input":"2026-04-27T20:07:50.81923Z","iopub.status.idle":"2026-04-27T20:09:55.733189Z","shell.execute_reply.started":"2026-04-27T20:07:50.819202Z","shell.execute_reply":"2026-04-27T20:09:55.732227Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# !pip install segmentation-models-pytorch rasterio -q\n\nimport os, glob, json, warnings\nimport numpy as np\nimport torch\nimport torch.nn as nn\nimport torch.nn.functional as F\nimport segmentation_models_pytorch as smp\nimport rasterio\nfrom rasterio.enums import Resampling\nimport matplotlib.pyplot as plt\nimport matplotlib.patches as mpatches\nimport matplotlib.gridspec as gridspec\nfrom matplotlib.colors import ListedColormap\nfrom PIL import Image, ImageEnhance\nfrom tqdm.auto import tqdm\nimport datetime\nwarnings.filterwarnings(\"ignore\")\n\n# ═══════════════════════════════════════════════════════════════════════\n# CONFIG\n# ═══════════════════════════════════════════════════════════════════════\nCOMPOSITES_DIR = \"./flood_composites\"\nMODEL_PATH     = \"/kaggle/input/models/muhammadmubeenxt/ablation-flooding/pytorch/default/1/ablation_best_flood_model_full.pth\"\nMASKS_PNG_DIR  = \"./masks_pngs\"\nMETRICS_JSON   = \"./flood_metrics.json\"\nDEBUG_LOG      = \"./flood_debug.log\"\nos.makedirs(MASKS_PNG_DIR, exist_ok=True)\n\n# Locations\nLOCATIONS = [\n    #(\"Sialkot_punjab\",    32.496304,  74.538327),\n    #(\"Dadu_Sindh\",        26.73,      67.78),\n    #(\"Sukkur_Sindh\",      27.70,      68.87),\n    #(\"Jacobabad_Sindh\",   28.28,      68.43),\n    #(\"DG_Khan_Punjab\",    30.06,      70.64),\n    #(\"Nowshera_KPK\",      34.01,      71.99),\n    (\"KwaZuluNatal_SA\",     -29.86,      31.01),\n    (\"Sylhet_Bangladesh\",    24.90,      91.87),\n    (\"Kherson_Ukraine\",      46.64,      32.62),\n]\n\n\n#{\"label\": \"Sylhet_Bangladesh\", \"lat\": 24.90, \"lon\": 91.87, \"radius_km\": 20, \"orbit\": None,\n     # \"baseline_start\": \"2022-01-01\", \"baseline_end\": \"2022-04-30\",\n     # \"event_start\": \"2022-06-01\", \"event_end\": \"2022-07-31\"},\n     #{\"label\": \"Kherson_Ukraine\", \"lat\": 46.64, \"lon\": 32.62, \"radius_km\": 20, \"orbit\": \"ascending\",\n      #\"baseline_start\": \"2023-03-01\", \"baseline_end\": \"2023-05-31\",\n      #\"event_start\": \"2023-06-06\", \"event_end\": \"2023-07-31\"},\n     #{\"label\": \"KwaZuluNatal_SA\", \"lat\": -29.86, \"lon\": 31.01, \"radius_km\": 20, \"orbit\": \"descending\",\n     # \"baseline_start\": \"2022-01-01\", \"baseline_end\": \"2022-03-31\",\n     # \"event_start\": \"2022-04-11\", \"event_end\": \"2022-05-31\"},\n\nFLOOD_THRESHOLD  = 0.40\nPERM_WATER_MNDWI = -0.01\nSAR_ONLY_MODE    = False\nTILE_SIZE        = 256\nTILE_OVERLAP     = 64\nTILE_STRIDE      = TILE_SIZE - TILE_OVERLAP\nPIXEL_AREA_KM2   = (10.0 * 10.0) / 1e6\n\ndevice = torch.device(\"cuda\" if torch.cuda.is_available() else \"cpu\")\ntorch.cuda.empty_cache()\n\n# Setup debug logging\ndef debug_log(msg, level=\"INFO\"):\n    timestamp = datetime.datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\")\n    log_msg = f\"[{timestamp}] [{level}] {msg}\"\n    print(log_msg)\n    with open(DEBUG_LOG, \"a\") as f:\n        f.write(log_msg + \"\\n\")\n\ndebug_log(f\"=== FLOOD DETECTION STARTED ===\")\ndebug_log(f\"Device: {device}, TILE_SIZE: {TILE_SIZE}, Threshold: {FLOOD_THRESHOLD}\")\n\n# ═══════════════════════════════════════════════════════════════════════\n# MODEL DEFINITION\n# ═══════════════════════════════════════════════════════════════════════\nclass CBAM(nn.Module):\n    def __init__(self, channels, reduction=8):\n        super().__init__()\n        self.avg = nn.AdaptiveAvgPool2d(1)\n        self.max = nn.AdaptiveMaxPool2d(1)\n        self.fc  = nn.Sequential(\n            nn.Linear(channels, channels // reduction, bias=False),\n            nn.ReLU(inplace=True),\n            nn.Linear(channels // reduction, channels, bias=False))\n        self.sc  = nn.Conv2d(2, 1, kernel_size=7, padding=3, bias=False)\n\n    def forward(self, x):\n        b, c = x.shape[:2]\n        a = self.fc(self.avg(x).view(b, c))\n        m = self.fc(self.max(x).view(b, c))\n        x = x * torch.sigmoid(a + m).view(b, c, 1, 1)\n        s = torch.cat([x.mean(1, keepdim=True), x.max(1, keepdim=True)[0]], dim=1)\n        return x * torch.sigmoid(self.sc(s))\n\nclass DualStreamUNetPP(nn.Module):\n    def __init__(self, use_cbam=True):\n        super().__init__()\n        self.use_cbam = use_cbam\n        self.sar_enc  = smp.UnetPlusPlus(encoder_name=\"resnet50\", encoder_weights=None,\n                                          in_channels=3, classes=32)\n        self.opt_enc  = smp.UnetPlusPlus(encoder_name=\"resnet50\", encoder_weights=None,\n                                          in_channels=7, classes=32)\n        if use_cbam:\n            self.cbam = CBAM(64)\n        self.head = nn.Sequential(\n            nn.Conv2d(64, 32, 3, padding=1, bias=False),\n            nn.BatchNorm2d(32), nn.ReLU(inplace=True),\n            nn.Dropout2d(p=0.15), nn.Conv2d(32, 1, 1))\n\n    def forward(self, x):\n        sar = torch.cat([x[:, 0:2], x[:, 7:8]], dim=1)\n        opt = torch.cat([x[:, 2:7], x[:, 8:10]], dim=1)\n        f   = torch.cat([self.sar_enc(sar), self.opt_enc(opt)], dim=1)\n        if self.use_cbam:\n            f = self.cbam(f)\n        return self.head(f)\n\ndef load_model(path, device):\n    debug_log(f\"Loading model from: {path}\")\n    if not os.path.exists(path):\n        raise FileNotFoundError(f\"Checkpoint not found: {path}\")\n    \n    m = DualStreamUNetPP(use_cbam=True)\n    raw = torch.load(path, map_location=device)\n    state = raw.get(\"model_state\", raw)\n    \n    # Strip DataParallel prefix\n    state = {k.replace(\"module.\", \"\"): v for k, v in state.items()}\n    \n    # Remap keys\n    remapped = {}\n    for k, v in state.items():\n        k = k.replace(\"sar_encoder.\", \"sar_enc.\").replace(\"opt_encoder.\", \"opt_enc.\")\n        remapped[k] = v\n    \n    missing, unexpected = m.load_state_dict(remapped, strict=False)\n    if missing:\n        debug_log(f\"Missing keys: {missing[:3]}\", \"WARNING\")\n    if unexpected:\n        debug_log(f\"Unexpected keys: {unexpected[:3]}\", \"WARNING\")\n    \n    m.to(device).eval()\n    param_count = sum(p.numel() for p in m.parameters())/1e6\n    debug_log(f\"Model loaded: {param_count:.1f}M params\")\n    \n    # Test model\n    debug_log(\"Testing model with dummy input...\")\n    dummy_input = torch.randn(1, 10, 256, 256).to(device)\n    with torch.no_grad():\n        dummy_output = m(dummy_input)\n    debug_log(f\"Dummy output shape: {dummy_output.shape}\")\n    \n    return m\n\n# ═══════════════════════════════════════════════════════════════════════\n# FILE DISCOVERY\n# ═══════════════════════════════════════════════════════════════════════\ndef find_file(base_dir, pattern):\n    hits = sorted(glob.glob(os.path.join(base_dir, pattern)))\n    return hits[-1] if hits else None\n\ndef discover(label, composites_dir):\n    d = {}\n    d[\"s2_tif\"] = find_file(composites_dir, f\"{label}_s2_baseline_*.tif\")\n    d[\"s1_tif\"] = (\n        find_file(composites_dir, f\"{label}_s1_*_composite_*.tif\") or\n        find_file(composites_dir, f\"{label}_s1_composite_*.tif\")\n    )\n    d[\"s2_before_png\"] = find_file(composites_dir, f\"{label}_s2_baseline_*_visual.png\")\n    d[\"s1_after_png\"]  = (\n        find_file(composites_dir, f\"{label}_s1_*_falsecolor_*.png\") or\n        find_file(composites_dir, f\"{label}_s1_falsecolor_*.png\")\n    )\n    d[\"s2_after_png\"]  = find_file(composites_dir, f\"{label}_s2_visual_after_*.png\")\n    return d\n\n# ═══════════════════════════════════════════════════════════════════════\n# DATA LOADING - FIXED VERSION\n# ═══════════════════════════════════════════════════════════════════════\ndef load_tif_corrected(path, is_sar=False):\n    \"\"\"Load GeoTIFF - S2 gets scaled to 0-1, S1 stays in dB\"\"\"\n    debug_log(f\"Loading GeoTIFF: {path}\")\n    \n    with rasterio.open(path) as src:\n        data = src.read().astype(np.float32)\n        \n        if is_sar:\n            # SAR data: convert linear to dB if needed\n            if data.max() > 10:  # Linear scale\n                debug_log(f\"  Converting SAR from linear to dB (max={data.max():.2f})\")\n                data = np.clip(10 * np.log10(data + 1e-9), -35, 5)\n            debug_log(f\"  SAR dB - range: [{data.min():.2f}, {data.max():.2f}], mean: {data.mean():.2f}\")\n        else:\n            # S2 optical: scale 0-10000 to 0-1\n            if data.max() > 10:\n                debug_log(f\"  Scaling S2 (max={data.max():.2f}) to 0-1\")\n                data = data / 10000.0\n            data = np.clip(data, 0.0, 1.0)\n            debug_log(f\"  S2 scaled - range: [{data.min():.4f}, {data.max():.4f}], mean: {data.mean():.4f}\")\n        \n        return data, src.transform, src.crs\n\ndef match_hw(arr, target_hw):\n    tH, tW = target_hw\n    if arr.shape[1] == tH and arr.shape[2] == tW:\n        return arr\n    t = torch.from_numpy(arr).unsqueeze(0).float()\n    t = F.interpolate(t, size=(tH, tW), mode=\"bilinear\", align_corners=False)\n    return t.squeeze(0).numpy()\n\ndef build_tensor_fixed(s2_arr, s1_arr_db, sar_only=False):\n    \"\"\"Build 10-channel input tensor\"\"\"\n    debug_log(\"Building input tensor...\")\n    H, W = s2_arr.shape[1], s2_arr.shape[2]\n    s1_arr_db = match_hw(s1_arr_db, (H, W))\n    \n    # Normalize dB to [0,1] for model input\n    vv = np.clip((s1_arr_db[0] + 30.0) / 30.0, 0.0, 1.0)\n    vh = np.clip((s1_arr_db[1] + 30.0) / 30.0, 0.0, 1.0)\n    vv = np.nan_to_num(vv, nan=0.0)\n    vh = np.nan_to_num(vh, nan=0.0)\n    \n    debug_log(f\"  Normalized VV - range: [{vv.min():.4f}, {vv.max():.4f}], unique: {len(np.unique(vv))}\")\n    debug_log(f\"  Normalized VH - range: [{vh.min():.4f}, {vh.max():.4f}], unique: {len(np.unique(vh))}\")\n    \n    # SAR ratio\n    with np.errstate(divide=\"ignore\", invalid=\"ignore\"):\n        sar_r = np.where(vh > 1e-8, vv / vh, 0.0)\n    sar_r = np.clip(np.nan_to_num(sar_r, nan=0.0, posinf=0.0), 0.0, 10.0)\n    \n    if sar_only:\n        tensor = np.zeros((10, H, W), dtype=np.float32)\n        tensor[0] = vv\n        tensor[1] = vh\n        tensor[7] = sar_r\n        return tensor\n    \n    # Optical bands\n    blue = np.clip(np.nan_to_num(s2_arr[0], nan=0.0), 0.0, 1.0)\n    green = np.clip(np.nan_to_num(s2_arr[1], nan=0.0), 0.0, 1.0)\n    red = np.clip(np.nan_to_num(s2_arr[2], nan=0.0), 0.0, 1.0)\n    nir = np.clip(np.nan_to_num(s2_arr[3], nan=0.0), 0.0, 1.0)\n    swir1 = np.clip(np.nan_to_num(s2_arr[4], nan=0.0), 0.0, 1.0)\n    \n    debug_log(f\"  S2 means - B:{blue.mean():.3f} G:{green.mean():.3f} R:{red.mean():.3f}\")\n    \n    # Indices\n    with np.errstate(divide=\"ignore\", invalid=\"ignore\"):\n        ndwi = np.where((green+nir) > 1e-8, (green-nir) / (green+nir), 0.0)\n        mndwi = np.where((green+swir1) > 1e-8, (green-swir1) / (green+swir1), 0.0)\n    \n    ndwi = np.nan_to_num(ndwi, nan=0.0)\n    mndwi = np.nan_to_num(mndwi, nan=0.0)\n    \n    tensor = np.stack([\n        vv, vh, blue, green, red, nir, ndwi, sar_r, swir1, mndwi\n    ], axis=0).astype(np.float32)\n    \n    debug_log(f\"  Tensor - range: [{tensor.min():.4f}, {tensor.max():.4f}], mean: {tensor.mean():.4f}\")\n    return tensor\n\n# ═══════════════════════════════════════════════════════════════════════\n# TILED INFERENCE\n# ═══════════════════════════════════════════════════════════════════════\ndef _hanning_window(size):\n    lin = np.hanning(size).astype(np.float64)\n    w = np.outer(lin, lin)\n    return np.clip(w, 1e-6, None)\n\n@torch.no_grad()\ndef tiled_predict(model, tensor, device):\n    debug_log(\"Starting tiled prediction...\")\n    C, H, W = tensor.shape\n    debug_log(f\"  Input shape: {tensor.shape}\")\n    \n    torch.cuda.empty_cache()\n    win = _hanning_window(TILE_SIZE)\n    \n    pad_h = (-H) % TILE_STRIDE\n    pad_w = (-W) % TILE_STRIDE\n    if pad_h or pad_w:\n        debug_log(f\"  Padding: h={pad_h}, w={pad_w}\")\n        tensor = np.pad(tensor, ((0,0),(0,pad_h),(0,pad_w)), mode=\"reflect\")\n    \n    _, PH, PW = tensor.shape\n    acc = np.zeros((PH, PW), dtype=np.float64)\n    count = np.zeros((PH, PW), dtype=np.float64)\n    \n    ys = list(range(0, PH - TILE_SIZE + 1, TILE_STRIDE))\n    xs = list(range(0, PW - TILE_SIZE + 1, TILE_STRIDE))\n    if ys and ys[-1] + TILE_SIZE < PH:\n        ys.append(PH - TILE_SIZE)\n    if xs and xs[-1] + TILE_SIZE < PW:\n        xs.append(PW - TILE_SIZE)\n    \n    debug_log(f\"  Tiles: {len(ys)} x {len(xs)} = {len(ys)*len(xs)} tiles\")\n    \n    model.eval()\n    coords = [(y, x) for y in ys for x in xs]\n    \n    for idx, (y0, x0) in enumerate(tqdm(coords, desc=\"  Tiles\", leave=False)):\n        chip = tensor[:, y0:y0+TILE_SIZE, x0:x0+TILE_SIZE]\n        xt = torch.from_numpy(chip).unsqueeze(0).to(device)\n        \n        with torch.amp.autocast(\"cuda\", enabled=(device.type == \"cuda\")):\n            prob = torch.sigmoid(model(xt)).squeeze().cpu().numpy().astype(np.float64)\n        \n        acc[y0:y0+TILE_SIZE, x0:x0+TILE_SIZE] += prob * win\n        count[y0:y0+TILE_SIZE, x0:x0+TILE_SIZE] += win\n        \n        if idx % 20 == 0:\n            torch.cuda.empty_cache()\n    \n    prob_map = (acc / np.where(count > 0, count, 1.0)).astype(np.float32)\n    prob_map = prob_map[:H, :W]\n    binary = (prob_map >= FLOOD_THRESHOLD).astype(np.uint8)\n    \n    debug_log(f\"  Probability - min: {prob_map.min():.4f}, max: {prob_map.max():.4f}, mean: {prob_map.mean():.4f}\")\n    debug_log(f\"  Flood pixels: {binary.sum()} ({100*binary.sum()/(H*W):.2f}%)\")\n    \n    return prob_map, binary\n\n# ═══════════════════════════════════════════════════════════════════════\n# VISUALIZATION HELPERS\n# ═══════════════════════════════════════════════════════════════════════\ndef load_png_rgb(path):\n    return np.array(Image.open(path).convert(\"RGB\"))\n\ndef s2_to_rgb(s2_arr, gamma=0.55, lo=1.0, hi=98.0, sat=1.3):\n    chs = []\n    for idx in [2, 1, 0]:\n        b = s2_arr[idx].astype(np.float32)\n        v = b[~np.isnan(b)]\n        if not len(v):\n            chs.append(np.zeros(b.shape, np.float32))\n            continue\n        lo_v, hi_v = np.percentile(v, [lo, hi])\n        b = np.clip(b, lo_v, hi_v)\n        b = (b - lo_v) / (hi_v - lo_v + 1e-10)\n        b = np.power(np.clip(np.nan_to_num(b, nan=0.0), 0, 1), gamma)\n        chs.append(b)\n    rgb = np.stack(chs, axis=-1)\n    try:\n        pil = Image.fromarray((rgb*255).astype(np.uint8), \"RGB\")\n        pil = ImageEnhance.Color(pil).enhance(sat)\n        rgb = np.array(pil).astype(np.float32) / 255.0\n    except Exception:\n        pass\n    return (rgb * 255).astype(np.uint8)\n\ndef mndwi_permanent_water(s2_arr):\n    green = np.clip(np.nan_to_num(s2_arr[1], nan=0.0), 0, 1)\n    swir1 = np.clip(np.nan_to_num(s2_arr[4], nan=0.0), 0, 1)\n    with np.errstate(divide=\"ignore\", invalid=\"ignore\"):\n        mndwi = np.where((green+swir1) > 1e-8, (green-swir1)/(green+swir1), 0.0)\n    mndwi = np.nan_to_num(mndwi, nan=0.0).astype(np.float32)\n    return mndwi, (mndwi > PERM_WATER_MNDWI).astype(np.uint8)\n\ndef export_pngs(label, r, masks_dir):\n    loc_dir = os.path.join(masks_dir, label)\n    os.makedirs(loc_dir, exist_ok=True)\n    \n    def _force_uint8(arr):\n        arr = np.array(arr, dtype=np.float32)\n        if arr.max() <= 1.0:\n            arr = np.clip(arr, 0, 1) * 255\n        return np.nan_to_num(arr, nan=0.0).astype(np.uint8)\n    \n    before_rgb = (load_png_rgb(r[\"s2_before_png\"]) if r.get(\"s2_before_png\") else s2_to_rgb(r[\"s2_arr\"]))\n    Image.fromarray(_force_uint8(before_rgb), \"RGB\").save(os.path.join(loc_dir, f\"{label}_UI_BEFORE_OPTICAL.png\"))\n    \n    if r.get(\"s1_after_png\"):\n        after_rgb = load_png_rgb(r[\"s1_after_png\"])\n    elif r.get(\"s2_after_png\"):\n        after_rgb = load_png_rgb(r[\"s2_after_png\"])\n    else:\n        vv = r[\"s1_arr_db\"][0]\n        vh = r[\"s1_arr_db\"][1]\n        def _s(a, lo=2, hi=98):\n            v = a[~np.isnan(a)]\n            if not len(v):\n                return np.zeros_like(a, np.float32)\n            lv, hv = np.percentile(v, [lo, hi])\n            return np.clip(np.nan_to_num((a-lv)/(hv-lv+1e-10), nan=0.0), 0, 1)\n        ratio = np.where(np.power(10,vh/10) > 1e-10, np.power(10,vv/10)/np.power(10,vh/10), 0.0)\n        after_rgb = (np.stack([_s(vv),_s(vh), np.clip(np.nan_to_num((ratio-np.nanpercentile(ratio[ratio>0],5))/(np.nanpercentile(ratio[ratio>0],95)-np.nanpercentile(ratio[ratio>0],5)+1e-10),nan=0.0),0,1)], axis=-1) * 255).astype(np.uint8)\n    Image.fromarray(_force_uint8(after_rgb), \"RGB\").save(os.path.join(loc_dir, f\"{label}_UI_AFTER_RAW_EVENT.png\"))\n    \n    base = before_rgb.astype(np.float32)\n    base[r[\"perm_water\"]==1] = base[r[\"perm_water\"]==1]*0.4 + np.array([0,0,128],np.float32)*0.6\n    base[r[\"new_inund\"]==1] = base[r[\"new_inund\"]==1]*0.2 + np.array([0,102,255],np.float32)*0.8\n    Image.fromarray(np.clip(base,0,255).astype(np.uint8), \"RGB\").save(os.path.join(loc_dir, f\"{label}_UI_AFTER_MASK_OVERLAY.png\"))\n    \n    Image.fromarray((r[\"perm_water\"]*255).astype(np.uint8), \"L\").save(os.path.join(loc_dir, f\"{label}_mask_perm_water.png\"))\n    plt.imsave(os.path.join(loc_dir, f\"{label}_mask_prob_map.png\"), r[\"prob_map\"], cmap=\"inferno\", vmin=0, vmax=1)\n    Image.fromarray((r[\"binary_mask\"]*255).astype(np.uint8), \"L\").save(os.path.join(loc_dir, f\"{label}_mask_prediction.png\"))\n    Image.fromarray((r[\"new_inund\"]*255).astype(np.uint8), \"L\").save(os.path.join(loc_dir, f\"{label}_mask_new_inundation.png\"))\n    \n    print(f\"    Saved 7 assets -> {loc_dir}/\")\n\nCMAP_PERM = ListedColormap([\"#00000000\", \"#000080\"])\nCMAP_FLOOD = ListedColormap([\"#00000000\", \"#0066FF\"])\n\ndef visualize(label, r, masks_dir):\n    H, W = r[\"binary_mask\"].shape\n    flood_pct = 100.0 * r[\"new_inund\"].sum() / (H * W)\n    \n    before_rgb = (load_png_rgb(r[\"s2_before_png\"]) if r.get(\"s2_before_png\") else s2_to_rgb(r[\"s2_arr\"]))\n    if r.get(\"s1_after_png\"):\n        after_rgb = load_png_rgb(r[\"s1_after_png\"])\n    elif r.get(\"s2_after_png\"):\n        after_rgb = load_png_rgb(r[\"s2_after_png\"])\n    else:\n        after_rgb = before_rgb\n    \n    fig = plt.figure(figsize=(26, 12), facecolor=\"#080808\")\n    gs = gridspec.GridSpec(2, 4, figure=fig, hspace=0.2, wspace=0.1)\n    \n    ax_main = fig.add_subplot(gs[:, :2])\n    ax_main.imshow(before_rgb)\n    ax_main.imshow(r[\"perm_water\"], cmap=CMAP_PERM, alpha=0.6, vmin=0, vmax=1)\n    ax_main.imshow(r[\"new_inund\"], cmap=CMAP_FLOOD, alpha=0.8, vmin=0, vmax=1)\n    ax_main.set_title(\"OFFICIAL FLOOD EXTENT\", color=\"#0066FF\", fontsize=16, fontweight=\"bold\")\n    ax_main.axis(\"off\")\n    ax_main.legend(handles=[\n        mpatches.Patch(color=\"#000080\", label=\"Permanent Waterways\"),\n        mpatches.Patch(color=\"#0066FF\", label=\"Detected New Inundation\"),\n    ], loc=\"lower left\", facecolor=\"#111111\", labelcolor=\"white\", edgecolor=\"none\")\n    \n    ax_pre = fig.add_subplot(gs[0, 2])\n    ax_pre.imshow(before_rgb)\n    ax_pre.axis(\"off\")\n    ax_pre.set_title(\"BEFORE\", color=\"white\", fontsize=11)\n    \n    ax_post = fig.add_subplot(gs[1, 2])\n    ax_post.imshow(after_rgb)\n    ax_post.axis(\"off\")\n    after_label = \"AFTER (SAR)\" if r.get(\"s1_after_png\") else \"AFTER (S2 Visual)\"\n    ax_post.set_title(after_label, color=\"white\", fontsize=11)\n    \n    ax_prob = fig.add_subplot(gs[:, 3])\n    im = ax_prob.imshow(r[\"prob_map\"], cmap=\"viridis\", vmin=0, vmax=1)\n    ax_prob.set_title(\"AI CONFIDENCE SCORE\", color=\"white\", fontsize=11)\n    ax_prob.axis(\"off\")\n    cb = plt.colorbar(im, ax=ax_prob, fraction=0.046, pad=0.04)\n    cb.ax.yaxis.set_tick_params(color=\"white\")\n    plt.setp(cb.ax.yaxis.get_ticklabels(), color=\"white\", fontsize=8)\n    \n    fig.text(0.5, 0.02, f\"MANZAR ANALYSIS: {label} | NET INUNDATION: {flood_pct:.2f}%\", ha=\"center\", color=\"white\", fontsize=14, fontweight=\"bold\")\n    \n    loc_dir = os.path.join(masks_dir, label)\n    os.makedirs(loc_dir, exist_ok=True)\n    report_path = os.path.join(loc_dir, f\"{label}_CLEAN_REPORT.png\")\n    plt.savefig(report_path, dpi=200, facecolor=\"#080808\", bbox_inches=\"tight\")\n    print(f\"    Dashboard -> {report_path}\")\n    plt.show()\n    plt.close(fig)\n\n# ═══════════════════════════════════════════════════════════════════════\n# MAIN PIPELINE\n# ═══════════════════════════════════════════════════════════════════════\ntry:\n    model = load_model(MODEL_PATH, device)\nexcept Exception as e:\n    debug_log(f\"Failed to load model: {e}\", \"ERROR\")\n    raise\n\nall_results = {}\nmetrics_log = []\n\nfor label, lat, lon in LOCATIONS:\n    debug_log(f\"\\n{'='*65}\")\n    debug_log(f\"Processing: {label}\")\n    print(f\"\\n{'='*65}\\n  {label}\\n{'='*65}\")\n    \n    files = discover(label, COMPOSITES_DIR)\n    \n    if not files[\"s2_tif\"] or not files[\"s1_tif\"]:\n        debug_log(f\"SKIP: Missing files for {label}\", \"WARNING\")\n        print(f\"  SKIP: Missing S2 or S1 data for {label}\")\n        continue\n    \n    print(f\"  S2 TIF: {os.path.basename(files['s2_tif'])}\")\n    print(f\"  S1 TIF: {os.path.basename(files['s1_tif'])}\")\n    \n    # Load data with correct handling\n    s2_arr, s2_tf, s2_crs = load_tif_corrected(files[\"s2_tif\"], is_sar=False)\n    s1_arr_db, s1_tf, s1_crs = load_tif_corrected(files[\"s1_tif\"], is_sar=True)\n    \n    # Permanent water mask\n    mndwi, perm_water = mndwi_permanent_water(s2_arr)\n    debug_log(f\"Permanent water: {perm_water.sum()} pixels ({100*perm_water.sum()/perm_water.size:.2f}%)\")\n    \n    # Build tensor\n    tensor = build_tensor_fixed(s2_arr, s1_arr_db, sar_only=SAR_ONLY_MODE)\n    print(f\"  Tensor shape: {tensor.shape}\")\n    \n    # Run inference\n    prob_map, binary_mask = tiled_predict(model, tensor, device)\n    \n    # Align masks\n    H, W = binary_mask.shape\n    if perm_water.shape != (H, W):\n        pw_t = torch.from_numpy(perm_water.astype(np.float32)).unsqueeze(0).unsqueeze(0)\n        pw_t = F.interpolate(pw_t, size=(H, W), mode=\"nearest\")\n        perm_water = (pw_t.squeeze().numpy() > 0.5).astype(np.uint8)\n    \n    # New inundation (flood minus permanent water)\n    new_inund = ((binary_mask == 1) & (perm_water == 0)).astype(np.uint8)\n    \n    # Calculate metrics\n    flood_km2 = float(binary_mask.sum()) * PIXEL_AREA_KM2\n    new_km2 = float(new_inund.sum()) * PIXEL_AREA_KM2\n    perm_km2 = float(perm_water.sum()) * PIXEL_AREA_KM2\n    net_pct = 100.0 * new_inund.sum() / (H * W)\n    \n    debug_log(f\"Results: {new_km2:.2f} km2 ({net_pct:.2f}%)\")\n    print(f\"  New inundation: {new_km2:.2f} km2 ({net_pct:.2f}%)\")\n    print(f\"  Permanent water: {perm_km2:.2f} km2\")\n    \n    metrics_log.append({\n        \"location\": label, \"lat\": lat, \"lon\": lon,\n        \"flood_extent_km2\": round(flood_km2, 3),\n        \"new_inundation_km2\": round(new_km2, 3),\n        \"perm_water_km2\": round(perm_km2, 3),\n        \"net_inundation_pct\": round(net_pct, 4),\n    })\n    \n    all_results[label] = {\n        \"s2_arr\": s2_arr, \"s1_arr_db\": s1_arr_db,\n        \"prob_map\": prob_map, \"binary_mask\": binary_mask,\n        \"perm_water\": perm_water, \"new_inund\": new_inund,\n        \"mndwi\": mndwi,\n        \"s2_before_png\": files[\"s2_before_png\"],\n        \"s1_after_png\": files[\"s1_after_png\"],\n        \"s2_after_png\": files[\"s2_after_png\"],\n    }\n\n# Save metrics\nwith open(METRICS_JSON, \"w\") as f:\n    json.dump(metrics_log, f, indent=2)\nprint(f\"\\nMetrics saved: {METRICS_JSON}\")\n\n# Visualize results\nprint(f\"\\nRendering dashboards for {len(all_results)} locations...\")\nfor label, r in all_results.items():\n    print(f\"\\n  {label}\")\n    export_pngs(label, r, MASKS_PNG_DIR)\n    visualize(label, r, MASKS_PNG_DIR)\n\nprint(f\"\\n✅ Done! Results in: {MASKS_PNG_DIR}/\")\nprint(f\"📊 Processed: {len(all_results)}/{len(LOCATIONS)} locations\")\nprint(f\"📝 Debug log: {DEBUG_LOG}\")\n\nprint(\"\\n=== FINAL METRICS ===\")\nfor m in metrics_log:\n    print(f\"  {m['location']:25s}: {m['new_inundation_km2']:.2f} km2 ({m['net_inundation_pct']:.2f}%)\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-27T20:10:19.573449Z","iopub.execute_input":"2026-04-27T20:10:19.573959Z","iopub.status.idle":"2026-04-27T20:11:34.967561Z","shell.execute_reply.started":"2026-04-27T20:10:19.573932Z","shell.execute_reply":"2026-04-27T20:11:34.966542Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"import os\nimport json\nimport numpy as np\nfrom PIL import Image\nfrom scipy import ndimage\nfrom scipy.spatial.distance import cdist\nfrom skimage.measure import regionprops\nimport math\nimport warnings\nwarnings.filterwarnings(\"ignore\")\n\n# ═══════════════════════════════════════════════════════════════════════\n# FAST FLOOD METRICS CALCULATOR WITH CENTER AND RADIUS\n# ═══════════════════════════════════════════════════════════════════════\n\nclass FastFloodMetricsCalculator:\n    def __init__(self, pixel_size_km=0.01):  # 10m = 0.01km\n        self.pixel_size_km = pixel_size_km\n        self.pixel_area_km2 = pixel_size_km ** 2\n    \n    def load_mask(self, mask_path):\n        \"\"\"Load binary flood mask\"\"\"\n        mask = np.array(Image.open(mask_path))\n        if mask.max() > 1:\n            mask = mask // 255\n        return mask.astype(np.uint8)\n    \n    def convert_to_serializable(self, obj):\n        \"\"\"Convert numpy types to Python native types for JSON serialization\"\"\"\n        if isinstance(obj, np.integer):\n            return int(obj)\n        elif isinstance(obj, np.floating):\n            return float(obj)\n        elif isinstance(obj, np.ndarray):\n            return obj.tolist()\n        elif isinstance(obj, tuple):\n            return tuple(self.convert_to_serializable(x) for x in obj)\n        elif isinstance(obj, dict):\n            return {k: self.convert_to_serializable(v) for k, v in obj.items()}\n        elif isinstance(obj, list):\n            return [self.convert_to_serializable(x) for x in obj]\n        else:\n            return obj\n    \n    def calculate_component_radius(self, prop, center_x, center_y):\n        \"\"\"Calculate the effective radius of a flood component\"\"\"\n        # Method 1: Equivalent radius (area-based)\n        area_pixels = prop.area\n        equivalent_radius_km = np.sqrt(area_pixels / np.pi) * self.pixel_size_km\n        \n        # Method 2: Max distance from center to any edge (bounding radius)\n        coords = prop.coords\n        distances = np.sqrt((coords[:, 1] - center_x)**2 + (coords[:, 0] - center_y)**2)\n        max_radius_km = np.max(distances) * self.pixel_size_km\n        \n        # Method 3: Mean distance from center (average radius)\n        mean_radius_km = np.mean(distances) * self.pixel_size_km\n        \n        return {\n            'equivalent_radius_km': round(equivalent_radius_km, 2),\n            'max_radius_km': round(max_radius_km, 2),\n            'mean_radius_km': round(mean_radius_km, 2)\n        }\n    \n    def get_bounding_circle(self, prop, center_x, center_y):\n        \"\"\"Get bounding circle parameters for the component\"\"\"\n        coords = prop.coords\n        distances = np.sqrt((coords[:, 1] - center_x)**2 + (coords[:, 0] - center_y)**2)\n        max_distance_px = np.max(distances)\n        \n        # Calculate circle area and coverage\n        circle_area_km2 = np.pi * (max_distance_px * self.pixel_size_km)**2\n        component_area_km2 = prop.area * self.pixel_area_km2\n        coverage_percentage = (component_area_km2 / circle_area_km2) * 100 if circle_area_km2 > 0 else 0\n        \n        return {\n            'radius_km': round(max_distance_px * self.pixel_size_km, 2),\n            'circumference_km': round(2 * np.pi * max_distance_px * self.pixel_size_km, 2),\n            'circle_area_km2': round(circle_area_km2, 2),\n            'component_fill_percentage': round(coverage_percentage, 2)\n        }\n    \n    def fast_analyze(self, mask, label, prob_map=None):\n        \"\"\"Fast analysis using scikit-image regionprops\"\"\"\n        from skimage.measure import label as sklabel, regionprops\n        \n        print(f\"  🔍 Analyzing {label}...\")\n        \n        # Basic metrics\n        total_flood_pixels = int(mask.sum())\n        total_flood_area_km2 = total_flood_pixels * self.pixel_area_km2\n        total_pixels = mask.size\n        flood_percentage = (total_flood_pixels / total_pixels) * 100\n        \n        # Label connected components\n        print(f\"  🔗 Finding connected components...\")\n        labeled_mask = sklabel(mask, connectivity=2)\n        num_components = int(labeled_mask.max())\n        \n        print(f\"  📊 Found {num_components:,} flood components\")\n        \n        # Extract region properties\n        props = regionprops(labeled_mask)\n        \n        # Sort by area (largest first)\n        props.sort(key=lambda x: x.area, reverse=True)\n        \n        # Process components\n        components = []\n        component_centers_km = []\n        all_component_centers = []\n        \n        for i, prop in enumerate(props[:50]):  # Process top 50 components\n            area_pixels = int(prop.area)\n            area_km2 = float(area_pixels * self.pixel_area_km2)\n            \n            # Center coordinates (centroid)\n            center_y, center_x = float(prop.centroid[0]), float(prop.centroid[1])\n            center_km = (float(center_x * self.pixel_size_km), float(center_y * self.pixel_size_km))\n            \n            # Calculate radius information\n            radius_info = self.calculate_component_radius(prop, center_x, center_y)\n            bounding_circle = self.get_bounding_circle(prop, center_x, center_y)\n            \n            # Bounding box\n            min_row, min_col, max_row, max_col = [int(x) for x in prop.bbox]\n            width_km = float((max_col - min_col) * self.pixel_size_km)\n            height_km = float((max_row - min_row) * self.pixel_size_km)\n            \n            # Equivalent diameter (km)\n            equiv_diameter_km = float(prop.equivalent_diameter * self.pixel_size_km)\n            \n            # Calculate approximate distances to edges\n            edge_distances = {\n                'north': float((prop.centroid[0] - min_row) * self.pixel_size_km),\n                'south': float((max_row - prop.centroid[0]) * self.pixel_size_km),\n                'west': float((prop.centroid[1] - min_col) * self.pixel_size_km),\n                'east': float((max_col - prop.centroid[1]) * self.pixel_size_km)\n            }\n            \n            percentage = float((area_km2 / total_flood_area_km2 * 100)) if total_flood_area_km2 > 0 else 0\n            \n            # Component entry with center and radius\n            component = {\n                'id': i + 1,\n                'area_km2': round(area_km2, 2),\n                'area_pixels': area_pixels,\n                'percentage_of_total': round(percentage, 2),\n                'center': {\n                    'x_km': round(center_km[0], 2),\n                    'y_km': round(center_km[1], 2),\n                    'x_pixel': round(center_x, 2),\n                    'y_pixel': round(center_y, 2)\n                },\n                'radius': radius_info,\n                'bounding_circle': bounding_circle,\n                'bbox_km': {\n                    'min_x': float(min_col * self.pixel_size_km),\n                    'min_y': float(min_row * self.pixel_size_km),\n                    'max_x': float(max_col * self.pixel_size_km),\n                    'max_y': float(max_row * self.pixel_size_km),\n                    'width_km': round(width_km, 2),\n                    'height_km': round(height_km, 2)\n                },\n                'edge_distances_km': edge_distances,\n                'equivalent_diameter_km': round(equiv_diameter_km, 2)\n            }\n            \n            components.append(component)\n            component_centers_km.append(center_km)\n            all_component_centers.append({\n                'id': i + 1,\n                'center_km': center_km,\n                'radius_km': radius_info['max_radius_km'],\n                'area_km2': area_km2\n            })\n        \n        # Calculate overall center of mass for entire flood extent\n        y_center, x_center = ndimage.center_of_mass(mask)\n        overall_center_km = (float(x_center * self.pixel_size_km), float(y_center * self.pixel_size_km))\n        \n        # Calculate overall flood extent radius (max distance from center to any flood pixel)\n        flood_coords = np.argwhere(mask)\n        if len(flood_coords) > 0:\n            distances_from_center = np.sqrt(\n                (flood_coords[:, 1] - x_center)**2 + \n                (flood_coords[:, 0] - y_center)**2\n            )\n            overall_max_radius_km = float(np.max(distances_from_center) * self.pixel_size_km)\n            overall_mean_radius_km = float(np.mean(distances_from_center) * self.pixel_size_km)\n        else:\n            overall_max_radius_km = 0\n            overall_mean_radius_km = 0\n        \n        # Calculate perimeter and shape index\n        from skimage.measure import perimeter\n        perimeter_pixels = float(perimeter(mask))\n        perimeter_km = perimeter_pixels * self.pixel_size_km\n        \n        # Shape index (1 = circle, higher = more complex)\n        if total_flood_pixels > 0:\n            radius = np.sqrt(total_flood_pixels / np.pi)\n            expected_perimeter = 2 * np.pi * radius\n            shape_index = float(perimeter_pixels / expected_perimeter) if expected_perimeter > 0 else 0\n        else:\n            shape_index = 0\n        \n        # Get probability stats if available\n        prob_stats = {}\n        if prob_map is not None:\n            flood_probs = prob_map[mask == 1]\n            if len(flood_probs) > 0:\n                prob_stats = {\n                    'mean_confidence': round(float(flood_probs.mean()), 4),\n                    'std_confidence': round(float(flood_probs.std()), 4),\n                    'min_confidence': round(float(flood_probs.min()), 4),\n                    'max_confidence': round(float(flood_probs.max()), 4)\n                }\n        \n        # Compile results\n        results = {\n            'location': label,\n            'summary': {\n                'total_flood_area_km2': round(total_flood_area_km2, 2),\n                'total_flood_pixels': total_flood_pixels,\n                'flood_percentage': round(flood_percentage, 2),\n                'number_of_flood_components': num_components,\n                'largest_component_area_km2': components[0]['area_km2'] if components else 0,\n                'largest_component_percentage': components[0]['percentage_of_total'] if components else 0,\n                'perimeter_km': round(perimeter_km, 2),\n                'shape_index': round(shape_index, 3),\n                'overall_center': {\n                    'x_km': round(overall_center_km[0], 2),\n                    'y_km': round(overall_center_km[1], 2)\n                },\n                'overall_radius': {\n                    'max_radius_km': round(overall_max_radius_km, 2),\n                    'mean_radius_km': round(overall_mean_radius_km, 2)\n                }\n            },\n            'top_components': components[:15],  # Top 15 components\n            'all_component_centers': all_component_centers,  # Summary of all components\n            'zonal_statistics': prob_stats,\n            'total_components_found': num_components\n        }\n        \n        # Convert any remaining numpy types\n        results = self.convert_to_serializable(results)\n        \n        return results\n\n# ═══════════════════════════════════════════════════════════════════════\n# MAIN ANALYSIS FUNCTION\n# ═══════════════════════════════════════════════════════════════════════\n\ndef analyze_all_floods(masks_dir=\"./masks_pngs\", output_dir=\"./flood_metrics_advanced\"):\n    \"\"\"Fast analysis of all flood masks\"\"\"\n    \n    os.makedirs(output_dir, exist_ok=True)\n    calculator = FastFloodMetricsCalculator(pixel_size_km=0.01)\n    \n    all_results = {}\n    \n    # Get all location folders\n    location_folders = [f for f in os.listdir(masks_dir) \n                       if os.path.isdir(os.path.join(masks_dir, f))]\n    \n    print(f\"\\n{'='*70}\")\n    print(f\"FLOOD METRICS ANALYZER (With Center & Radius)\")\n    print(f\"{'='*70}\")\n    print(f\"Found {len(location_folders)} locations: {', '.join(location_folders)}\")\n    \n    for location in location_folders:\n        print(f\"\\n{'='*70}\")\n        print(f\"📍 Analyzing: {location}\")\n        print(f\"{'='*70}\")\n        \n        # Load flood mask\n        mask_path = os.path.join(masks_dir, location, f\"{location}_mask_new_inundation.png\")\n        prob_path = os.path.join(masks_dir, location, f\"{location}_mask_prob_map.png\")\n        \n        if not os.path.exists(mask_path):\n            print(f\"  ❌ Mask not found: {mask_path}\")\n            continue\n        \n        # Load mask\n        mask = calculator.load_mask(mask_path)\n        print(f\"  ✅ Mask loaded: {mask.shape} ({mask.sum():,} flood pixels)\")\n        \n        # Load probability map if available\n        prob_map = None\n        if os.path.exists(prob_path):\n            prob_map = np.array(Image.open(prob_path)) / 255.0\n            print(f\"  ✅ Probability map loaded\")\n        \n        # Run fast analysis\n        results = calculator.fast_analyze(mask, location, prob_map)\n        \n        # Print summary\n        print(f\"\\n  📊 FLOOD SUMMARY:\")\n        print(f\"     ├─ Total flood area: {results['summary']['total_flood_area_km2']:,.2f} km²\")\n        print(f\"     ├─ Flood percentage: {results['summary']['flood_percentage']:.2f}%\")\n        print(f\"     ├─ Number of components: {results['summary']['number_of_flood_components']:,}\")\n        print(f\"     ├─ Largest component: {results['summary']['largest_component_area_km2']:,.2f} km²\")\n        print(f\"     ├─ Overall center: ({results['summary']['overall_center']['x_km']}, {results['summary']['overall_center']['y_km']}) km\")\n        print(f\"     ├─ Overall max radius: {results['summary']['overall_radius']['max_radius_km']:.2f} km\")\n        print(f\"     └─ Overall mean radius: {results['summary']['overall_radius']['mean_radius_km']:.2f} km\")\n        \n        if results['zonal_statistics']:\n            print(f\"\\n  🎯 CONFIDENCE STATISTICS:\")\n            print(f\"     ├─ Mean: {results['zonal_statistics']['mean_confidence']:.3f}\")\n            print(f\"     ├─ Std: {results['zonal_statistics']['std_confidence']:.3f}\")\n            print(f\"     ├─ Min: {results['zonal_statistics']['min_confidence']:.3f}\")\n            print(f\"     └─ Max: {results['zonal_statistics']['max_confidence']:.3f}\")\n        \n        # Print top 5 components with center and radius\n        print(f\"\\n  🗺️ TOP 5 FLOOD COMPONENTS (with Center & Radius):\")\n        for i, comp in enumerate(results['top_components'][:5]):\n            print(f\"\\n     Component {i+1}:\")\n            print(f\"        Area: {comp['area_km2']} km² ({comp['percentage_of_total']}%)\")\n            print(f\"        Center: ({comp['center']['x_km']}, {comp['center']['y_km']}) km\")\n            print(f\"        Equivalent Radius: {comp['radius']['equivalent_radius_km']} km\")\n            print(f\"        Max Radius: {comp['radius']['max_radius_km']} km\")\n            print(f\"        Mean Radius: {comp['radius']['mean_radius_km']} km\")\n            print(f\"        Bounding Circle: {comp['bounding_circle']['radius_km']} km radius\")\n        \n        # Save results as JSON\n        json_path = os.path.join(output_dir, f\"{location}_flood_metrics.json\")\n        with open(json_path, 'w') as f:\n            json.dump(results, f, indent=2)\n        print(f\"\\n  💾 Saved JSON: {json_path}\")\n        \n        # Save as human-readable text report\n        txt_path = os.path.join(output_dir, f\"{location}_flood_report.txt\")\n        with open(txt_path, 'w') as f:\n            f.write(\"=\"*70 + \"\\n\")\n            f.write(f\"FLOOD METRICS REPORT - {location}\\n\")\n            f.write(\"=\"*70 + \"\\n\\n\")\n            \n            f.write(\"SUMMARY STATISTICS:\\n\")\n            f.write(\"-\"*40 + \"\\n\")\n            for key, value in results['summary'].items():\n                if isinstance(value, dict):\n                    f.write(f\"  {key}:\\n\")\n                    for subkey, subval in value.items():\n                        f.write(f\"    {subkey}: {subval}\\n\")\n                else:\n                    f.write(f\"  {key}: {value}\\n\")\n            \n            f.write(\"\\n\\nTOP 10 FLOOD COMPONENTS (with Center and Radius):\\n\")\n            f.write(\"-\"*70 + \"\\n\")\n            for comp in results['top_components'][:10]:\n                f.write(f\"\\nComponent {comp['id']}:\\n\")\n                f.write(f\"  Area: {comp['area_km2']} km² ({comp['percentage_of_total']}% of total)\\n\")\n                f.write(f\"  Center: ({comp['center']['x_km']}, {comp['center']['y_km']}) km\\n\")\n                f.write(f\"  Radius Information:\\n\")\n                f.write(f\"    - Equivalent Radius: {comp['radius']['equivalent_radius_km']} km\\n\")\n                f.write(f\"    - Max Radius: {comp['radius']['max_radius_km']} km\\n\")\n                f.write(f\"    - Mean Radius: {comp['radius']['mean_radius_km']} km\\n\")\n                f.write(f\"  Bounding Circle:\\n\")\n                f.write(f\"    - Radius: {comp['bounding_circle']['radius_km']} km\\n\")\n                f.write(f\"    - Circumference: {comp['bounding_circle']['circumference_km']} km\\n\")\n                f.write(f\"    - Circle Area: {comp['bounding_circle']['circle_area_km2']} km²\\n\")\n                f.write(f\"    - Component fills {comp['bounding_circle']['component_fill_percentage']}% of circle\\n\")\n                f.write(f\"  Bounding Box: {comp['bbox_km']['width_km']}km x {comp['bbox_km']['height_km']}km\\n\")\n        \n        print(f\"  💾 Saved TXT: {txt_path}\")\n        \n        all_results[location] = results\n    \n    # Create summary CSV with center and radius\n    import csv\n    csv_path = os.path.join(output_dir, \"flood_summary.csv\")\n    with open(csv_path, 'w', newline='') as csvfile:\n        fieldnames = ['location', 'total_area_km2', 'flood_percentage', 'num_components', \n                     'largest_component_km2', 'overall_center_x_km', 'overall_center_y_km',\n                     'overall_max_radius_km', 'perimeter_km', 'shape_index', \n                     'mean_confidence']\n        writer = csv.DictWriter(csvfile, fieldnames=fieldnames)\n        writer.writeheader()\n        \n        for location, results in all_results.items():\n            summary = results['summary']\n            zonal = results.get('zonal_statistics', {})\n            writer.writerow({\n                'location': location,\n                'total_area_km2': summary['total_flood_area_km2'],\n                'flood_percentage': summary['flood_percentage'],\n                'num_components': summary['number_of_flood_components'],\n                'largest_component_km2': summary['largest_component_area_km2'],\n                'overall_center_x_km': summary['overall_center']['x_km'],\n                'overall_center_y_km': summary['overall_center']['y_km'],\n                'overall_max_radius_km': summary['overall_radius']['max_radius_km'],\n                'perimeter_km': summary['perimeter_km'],\n                'shape_index': summary['shape_index'],\n                'mean_confidence': zonal.get('mean_confidence', 0)\n            })\n    \n    print(f\"\\n{'='*70}\")\n    print(f\"✅ ANALYSIS COMPLETE!\")\n    print(f\"📁 Results saved to: {output_dir}\")\n    print(f\"📊 Summary CSV: {csv_path}\")\n    print(f\"{'='*70}\")\n    \n    # Print final summary table\n    print(\"\\n📊 FINAL FLOOD METRICS SUMMARY (with Center & Radius)\")\n    print(\"=\"*120)\n    print(f\"{'Location':<20} {'Area(km²)':>12} {'Flood%':>8} {'Center X':>10} {'Center Y':>10} {'Max Radius':>12}\")\n    print(\"-\"*120)\n    \n    for location, results in all_results.items():\n        summary = results['summary']\n        print(f\"{location:<20} {summary['total_flood_area_km2']:>12,.2f} \"\n              f\"{summary['flood_percentage']:>7.1f}% \"\n              f\"{summary['overall_center']['x_km']:>10.2f} \"\n              f\"{summary['overall_center']['y_km']:>10.2f} \"\n              f\"{summary['overall_radius']['max_radius_km']:>12.2f} km\")\n    \n    # Create component centers CSV\n    components_csv_path = os.path.join(output_dir, \"all_component_centers.csv\")\n    with open(components_csv_path, 'w', newline='') as csvfile:\n        fieldnames = ['location', 'component_id', 'center_x_km', 'center_y_km', \n                     'radius_km', 'area_km2']\n        writer = csv.DictWriter(csvfile, fieldnames=fieldnames)\n        writer.writeheader()\n        \n        for location, results in all_results.items():\n            for comp in results['all_component_centers']:\n                writer.writerow({\n                    'location': location,\n                    'component_id': comp['id'],\n                    'center_x_km': comp['center_km'][0],\n                    'center_y_km': comp['center_km'][1],\n                    'radius_km': comp['radius_km'],\n                    'area_km2': comp['area_km2']\n                })\n    \n    print(f\"\\n💾 Component centers CSV: {components_csv_path}\")\n    \n    # Save master JSON with all results\n    master_json_path = os.path.join(output_dir, \"all_flood_results.json\")\n    with open(master_json_path, 'w') as f:\n        json.dump(all_results, f, indent=2)\n    print(f\"💾 Master JSON saved: {master_json_path}\")\n    \n    return all_results\n\n# ═══════════════════════════════════════════════════════════════════════\n# CREATE VISUALIZATION WITH RADIUS CIRCLES\n# ═══════════════════════════════════════════════════════════════════════\n\ndef create_center_maps_with_radius(masks_dir=\"./masks_pngs\", results=None, output_dir=\"./flood_metrics_advanced\"):\n    \"\"\"Create visual maps showing flood component centers with radius circles\"\"\"\n    import matplotlib.pyplot as plt\n    from matplotlib.patches import Circle\n    \n    if results is None:\n        # Load results from JSON\n        results = {}\n        for f in os.listdir(output_dir):\n            if f.endswith('_flood_metrics.json'):\n                with open(os.path.join(output_dir, f), 'r') as file:\n                    loc = f.replace('_flood_metrics.json', '')\n                    results[loc] = json.load(file)\n    \n    for location, result in results.items():\n        overlay_path = os.path.join(masks_dir, location, f\"{location}_UI_AFTER_MASK_OVERLAY.png\")\n        \n        if not os.path.exists(overlay_path):\n            print(f\"⚠️ No overlay for {location}\")\n            continue\n        \n        fig, ax = plt.subplots(1, 1, figsize=(16, 12))\n        overlay = np.array(Image.open(overlay_path))\n        ax.imshow(overlay)\n        \n        # Plot component centers with radius circles\n        for comp in result['top_components'][:10]:  # Top 10 components\n            x, y = comp['center']['x_pixel'], comp['center']['y_pixel']\n            radius_px = comp['radius']['max_radius_km'] / 0.01  # Convert km to pixels (10m/pixel)\n            area = comp['area_km2']\n            \n            # Draw radius circle\n            circle = Circle((x, y), radius_px, fill=False, \n                           edgecolor='red', linewidth=2, alpha=0.7, linestyle='--')\n            ax.add_patch(circle)\n            \n            # Plot center point\n            ax.scatter(x, y, s=100, c='red', marker='+', \n                      edgecolors='yellow', linewidth=2, zorder=5)\n            \n            # Add label\n            ax.annotate(f\"{area:.0f}km²\\nR={comp['radius']['max_radius_km']:.1f}km\", \n                       (x, y), xytext=(10, 10), textcoords='offset points',\n                       fontsize=8, color='white', fontweight='bold',\n                       bbox=dict(boxstyle='round,pad=0.3', facecolor='black', alpha=0.7))\n        \n        # Also plot overall center\n        overall_x = result['summary']['overall_center']['x_km'] / 0.01\n        overall_y = result['summary']['overall_center']['y_km'] / 0.01\n        overall_radius_px = result['summary']['overall_radius']['max_radius_km'] / 0.01\n        \n        overall_circle = Circle((overall_x, overall_y), overall_radius_px, \n                                fill=False, edgecolor='blue', linewidth=3, \n                                alpha=0.5, linestyle='-')\n        ax.add_patch(overall_circle)\n        ax.scatter(overall_x, overall_y, s=150, c='blue', marker='*', \n                  edgecolors='white', linewidth=2, zorder=5, label='Overall Center')\n        \n        ax.set_title(f\"{location} - Flood Component Centers with Radius Circles\\n\"\n                    f\"Total Flood: {result['summary']['total_flood_area_km2']} km² | \"\n                    f\"Components: {result['summary']['number_of_flood_components']}\", \n                    fontsize=14, fontweight='bold')\n        ax.axis('off')\n        ax.legend()\n        \n        output_path = os.path.join(output_dir, f\"{location}_flood_centers_with_radius.png\")\n        plt.tight_layout()\n        plt.savefig(output_path, dpi=150, bbox_inches='tight')\n        plt.close()\n        \n        print(f\"  🗺️ Saved center map with radius: {output_path}\")\n\n# ═══════════════════════════════════════════════════════════════════════\n# RUN EVERYTHING\n# ═══════════════════════════════════════════════════════════════════════\n\nif __name__ == \"__main__\":\n    # Run the analysis\n    results = analyze_all_floods(masks_dir=\"./masks_pngs\", output_dir=\"./flood_metrics_advanced\")\n    \n    # Create visualization maps with radius circles\n    print(\"\\n📊 Creating center maps with radius circles...\")\n    create_center_maps_with_radius(masks_dir=\"./masks_pngs\", results=results, output_dir=\"./flood_metrics_advanced\")\n    \n    print(\"\\n✨ ALL DONE! Check the 'flood_metrics_advanced' folder for:\")\n    print(\"   📄 *_flood_metrics.json - Individual location JSON files (with center & radius)\")\n    print(\"   📄 *_flood_report.txt - Human-readable text reports\")\n    print(\"   📊 flood_summary.csv - Summary CSV with center coordinates and radius\")\n    print(\"   📊 all_component_centers.csv - All component centers with their radii\")\n    print(\"   📊 all_flood_results.json - Master JSON with all results\")\n    print(\"   🗺️ *_flood_centers_with_radius.png - Visual maps showing center points and radius circles\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-27T20:11:54.472343Z","iopub.execute_input":"2026-04-27T20:11:54.472985Z","iopub.status.idle":"2026-04-27T20:12:17.508753Z","shell.execute_reply.started":"2026-04-27T20:11:54.472954Z","shell.execute_reply":"2026-04-27T20:12:17.508038Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"import os\nimport shutil\nfrom IPython.display import FileLink\n\n# 1. Ensure you are operating in the correct base directory\nos.chdir('/kaggle/working')\n\n# 2. Compress the directory (creates masks_archive.zip in current dir)\nprint(\"Zipping masks...\")\nshutil.make_archive('flood_metrics_advanced', 'zip', 'flood_metrics_advanced')\n\nprint(\"Done. Click the link below to download:\")\n\n# 3. Generate the link using ONLY the relative filename\ndisplay(FileLink('flood_metrics_advanced.zip'))","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-27T20:12:26.979579Z","iopub.execute_input":"2026-04-27T20:12:26.980782Z","iopub.status.idle":"2026-04-27T20:12:27.767283Z","shell.execute_reply.started":"2026-04-27T20:12:26.980737Z","shell.execute_reply":"2026-04-27T20:12:27.766713Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# ═══════════════════════════════════════════════════════════════════════════════\n# FLOOD IMPACT ASSESSMENT  |  Population + LULC Breakdown\n# ───────────────────────────────────────────────────────────────────────────────\n# Prerequisites (run this cell AFTER the main inference loop that populates\n# `all_results` and `metrics_log`):\n#   pip install rioxarray planetary-computer pystac-client requests shapely -q\n# ═══════════════════════════════════════════════════════════════════════════════\n\nimport os, io, json, warnings\nimport numpy as np\nimport pandas as pd\nimport pyproj\nimport rasterio\nfrom rasterio.transform import from_bounds\nfrom rasterio.warp import reproject, Resampling\nfrom rasterio.io import MemoryFile\nimport pystac_client\nimport planetary_computer\nimport requests\nfrom shapely.geometry import box as shapely_box\nfrom shapely.ops import transform as shapely_transform\n\nwarnings.filterwarnings(\"ignore\", category=rasterio.errors.NotGeoreferencedWarning)\n\n# ── GPU fallback ───────────────────────────────────────────────────────────────\ntry:\n    import cupy as cp\n    _GPU = True\n    print(\"[GPU] CuPy found — intersection math on GPU.\")\nexcept ImportError:\n    cp = np\n    _GPU = False\n    print(\"[CPU] CuPy not found — falling back to NumPy.\")\n\n# ═══════════════════════════════════════════════════════════════════════════════\n# CONFIG  (must match the downloader parameters used to generate the TIFs)\n# ═══════════════════════════════════════════════════════════════════════════════\nRADIUS_KM      = 20        # All Pakistan locations in this pipeline use 20km\nPIXEL_M        = 10.0      # Sentinel-1 RTC native resolution\nPIXEL_KM2      = (PIXEL_M ** 2) / 1e6\nWORLDPOP_YEAR  = 2020      # Latest available UN-adjusted unconstrained for Pakistan\n\n# ESA WorldCover 2021 integer class codes and their human-readable names\nESA_CLASS_MAP = {\n    10:  \"Tree_cover\",\n    20:  \"Shrubland\",\n    30:  \"Grassland\",\n    40:  \"Cropland\",\n    50:  \"Built_up\",\n    60:  \"Bare_sparse_vegetation\",\n    70:  \"Snow_and_ice\",\n    80:  \"Permanent_water\",\n    90:  \"Herbaceous_wetland\",\n    95:  \"Mangroves\",\n    100: \"Moss_and_lichen\",\n}\n\n# ═══════════════════════════════════════════════════════════════════════════════\n# STEP 1 — RECONSTRUCT GEOREFERENCE\n# ───────────────────────────────────────────────────────────────────────────────\n# The main inference loop does NOT persist s1_tf / s1_crs into all_results.\n# We rebuild the exact UTM affine transform that the downloader used by\n# replicating its center-snap + radius expansion logic.  The result is\n# bit-identical to the transform stored in the S1 TIF.\n# ═══════════════════════════════════════════════════════════════════════════════\ndef reconstruct_georeference(lat, lon, radius_km, array_shape):\n    \"\"\"\n    Returns (rasterio.Affine transform, int epsg) that matches the UTM\n    grid the S1 downloader used for this location.\n\n    The downloader snaps the center to the nearest 10 m UTM grid point then\n    expands by radius_km meters in each cardinal direction.  from_bounds()\n    reproduces that affine transform exactly given the array shape.\n    \"\"\"\n    utm_zone = int((lon + 180) / 6) + 1\n    epsg     = 32600 + utm_zone if lat >= 0 else 32700 + utm_zone\n\n    wgs84  = pyproj.CRS(\"EPSG:4326\")\n    utm    = pyproj.CRS.from_epsg(epsg)\n    to_utm = pyproj.Transformer.from_crs(wgs84, utm, always_xy=True).transform\n\n    x_c, y_c = to_utm(lon, lat)\n    # Replicate the 10 m grid-snap from the downloader\n    x_c = round(x_c / 10) * 10\n    y_c = round(y_c / 10) * 10\n    r_m = radius_km * 1000\n\n    west  = x_c - r_m\n    south = y_c - r_m\n    east  = x_c + r_m\n    north = y_c + r_m\n\n    H, W = array_shape\n    tf   = from_bounds(west, south, east, north, W, H)\n    return tf, epsg, (west, south, east, north)\n\n\ndef utm_bounds_to_wgs84(utm_bounds, epsg):\n    \"\"\"Converts UTM (west, south, east, north) to WGS84 bbox for STAC queries.\"\"\"\n    west, south, east, north = utm_bounds\n    utm_crs = pyproj.CRS.from_epsg(epsg)\n    wgs84   = pyproj.CRS(\"EPSG:4326\")\n    to_wgs  = pyproj.Transformer.from_crs(utm_crs, wgs84, always_xy=True).transform\n    geom    = shapely_transform(to_wgs, shapely_box(west, south, east, north))\n    return geom.bounds   # (min_lon, min_lat, max_lon, max_lat)\n\n\n# ═══════════════════════════════════════════════════════════════════════════════\n# STEP 2 — FETCH ESA WORLDCOVER 2021  (categorical LULC)\n# ───────────────────────────────────────────────────────────────────────────────\n# Resampling.nearest is MANDATORY for categorical data.  Any other kernel\n# will blend integer class codes (e.g., Trees=10 + Built-up=50 -> 30 which\n# maps to Grassland).  That is not interpolation; it is fabrication.\n# ═══════════════════════════════════════════════════════════════════════════════\ndef fetch_worldcover(wgs_bounds, target_shape, target_transform, target_epsg):\n    \"\"\"\n    Queries ESA WorldCover 2021 via Planetary Computer STAC.\n    Reprojects to the flood mask UTM grid using nearest-neighbour resampling.\n\n    Returns a uint8 array of shape target_shape with ESA class codes.\n    \"\"\"\n    catalog = pystac_client.Client.open(\n        \"https://planetarycomputer.microsoft.com/api/stac/v1\",\n        modifier=planetary_computer.sign_inplace,\n    )\n\n    # Try with year filter first; some catalog versions do not support it\n    for extra_query in ({\"worldcover:year\": {\"eq\": 2021}}, {}):\n        search  = catalog.search(\n            collections=[\"esa-worldcover\"],\n            bbox=wgs_bounds,\n            query=extra_query if extra_query else None,\n        )\n        items = list(search.items())\n        if items:\n            break\n\n    if not items:\n        raise RuntimeError(\n            f\"No ESA WorldCover tiles found for bbox {wgs_bounds}. \"\n            \"Check that the AOI overlaps the WorldCover coverage.\"\n        )\n\n    # Planetary Computer may return multiple tiles; pick the signed href\n    # from the first (they all cover the same area at this scale)\n    item = items[0]\n    href = item.assets[\"map\"].href\n\n    H, W        = target_shape\n    target_crs  = rasterio.CRS.from_epsg(target_epsg)\n    lulc_grid   = np.zeros((H, W), dtype=np.uint8)\n\n    with rasterio.open(href) as src:\n        reproject(\n            source      = rasterio.band(src, 1),\n            destination = lulc_grid,\n            src_transform = src.transform,\n            src_crs       = src.crs,\n            dst_transform = target_transform,\n            dst_crs       = target_crs,\n            resampling    = Resampling.nearest,   # NON-NEGOTIABLE for categories\n        )\n\n    return lulc_grid\n\n\n# ═══════════════════════════════════════════════════════════════════════════════\n# STEP 3 — FETCH WORLDPOP (continuous population count)\n# ───────────────────────────────────────────────────────────────────────────────\n# WorldPop 100 m pixels store people-per-pixel (a count, not a density rate).\n# We are UPSAMPLING 100 m -> 10 m, so each 100 m source pixel fans out into\n# (100/10)^2 = 100 destination pixels.\n#\n# WRONG:  copy the 100 m count to all 100 children  -> totals inflate 100x.\n# WRONG:  Resampling.sum for upsampling             -> same inflation.\n#\n# CORRECT:\n#   1. Reproject with Resampling.nearest (assign parent count to each child).\n#   2. Scale each child by (dst_res / src_res)^2 = (10/100)^2 = 0.01.\n#      This distributes the count uniformly across children while\n#      conserving the total: 100 children * count*0.01 = count.  QED.\n#\n# Summing the scaled 10 m grid over any flood polygon therefore gives the\n# correct number of people within that area.\n# ═══════════════════════════════════════════════════════════════════════════════\n_WORLDPOP_CACHE: dict = {}   # session-level cache; avoids re-downloading 80 MB\n\ndef fetch_worldpop(target_shape, target_transform, target_epsg, year=WORLDPOP_YEAR):\n    \"\"\"\n    Downloads WorldPop Pakistan UN-adjusted unconstrained population\n    count GeoTIFF (100 m), reprojects to the flood mask UTM grid, and\n    applies the area-ratio correction to conserve population counts.\n\n    The download (~80 MB) is cached in memory for the Kaggle session.\n    Returns a float32 array of shape target_shape.\n    \"\"\"\n    cache_key = f\"PAK_{year}\"\n\n    if cache_key not in _WORLDPOP_CACHE:\n        url = (\n            f\"https://data.worldpop.org/GIS/Population/\"\n            f\"Global_2000_2020_Unconstrained/{year}/PAK/\"\n            f\"pak_ppp_{year}_UNadj.tif\"\n        )\n        print(f\"  Downloading WorldPop Pakistan {year} (~80 MB, cached after first location)...\")\n        resp = requests.get(url, stream=True, timeout=300)\n        resp.raise_for_status()\n        _WORLDPOP_CACHE[cache_key] = resp.content\n        print(f\"  Cached: {len(_WORLDPOP_CACHE[cache_key]) / 1e6:.1f} MB\")\n\n    raw_bytes  = _WORLDPOP_CACHE[cache_key]\n    H, W       = target_shape\n    target_crs = rasterio.CRS.from_epsg(target_epsg)\n    pop_grid   = np.zeros((H, W), dtype=np.float32)\n\n    with MemoryFile(raw_bytes) as memfile:\n        with memfile.open() as src:\n            src_res = abs(src.transform.a)   # ~100 m in the source CRS units\n            dst_res = abs(target_transform.a) # ~10 m in the target UTM units\n\n            reproject(\n                source      = rasterio.band(src, 1),\n                destination = pop_grid,\n                src_transform = src.transform,\n                src_crs       = src.crs,\n                dst_transform = target_transform,\n                dst_crs       = target_crs,\n                resampling    = Resampling.nearest,\n            )\n\n    # Area-ratio correction: each 10 m child inherited the full 100 m count.\n    # Scale down so children sum back to the parent count.\n    # (dst_res 