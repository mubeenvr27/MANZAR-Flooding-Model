tlib.pyplot as plt\n    from matplotlib.patches import Circle\n    \n    if results is None:\n        # Load results from JSON\n        results = {}\n        for f in os.listdir(output_dir):\n            if f.endswith('_flood_metrics.json'):\n                with open(os.path.join(output_dir, f), 'r') as file:\n                    loc = f.replace('_flood_metrics.json', '')\n                    results[loc] = json.load(file)\n    \n    for location, result in results.items():\n        overlay_path = os.path.join(masks_dir, location, f\"{location}_UI_AFTER_MASK_OVERLAY.png\")\n        \n        if not os.path.exists(overlay_path):\n            print(f\"⚠️ No overlay for {location}\")\n            continue\n        \n        fig, ax = plt.subplots(1, 1, figsize=(16, 12))\n        overlay = np.array(Image.open(overlay_path))\n        ax.imshow(overlay)\n        \n        # Plot component centers with radius circles\n        for comp in result['top_components'][:10]:  # Top 10 components\n            x, y = comp['center']['x_pixel'], comp['center']['y_pixel']\n            radius_px = comp['radius']['max_radius_km'] / 0.01  # Convert km to pixels (10m/pixel)\n            area = comp['area_km2']\n            \n            # Draw radius circle\n            circle = Circle((x, y), radius_px, fill=False, \n                           edgecolor='red', linewidth=2, alpha=0.7, linestyle='--')\n            ax.add_patch(circle)\n            \n            # Plot center point\n            ax.scatter(x, y, s=100, c='red', marker='+', \n                      edgecolors='yellow', linewidth=2, zorder=5)\n            \n            # Add label\n            ax.annotate(f\"{area:.0f}km²\\nR={comp['radius']['max_radius_km']:.1f}km\", \n                       (x, y), xytext=(10, 10), textcoords='offset points',\n                       fontsize=8, color='white', fontweight='bold',\n                       bbox=dict(boxstyle='round,pad=0.3', facecolor='black', alpha=0.7))\n        \n        # Also plot overall center\n        overall_x = result['summary']['overall_center']['x_km'] / 0.01\n        overall_y = result['summary']['overall_center']['y_km'] / 0.01\n        overall_radius_px = result['summary']['overall_radius']['max_radius_km'] / 0.01\n        \n        overall_circle = Circle((overall_x, overall_y), overall_radius_px, \n                                fill=False, edgecolor='blue', linewidth=3, \n                                alpha=0.5, linestyle='-')\n        ax.add_patch(overall_circle)\n        ax.scatter(overall_x, overall_y, s=150, c='blue', marker='*', \n                  edgecolors='white', linewidth=2, zorder=5, label='Overall Center')\n        \n        ax.set_title(f\"{location} - Flood Component Centers with Radius Circles\\n\"\n                    f\"Total Flood: {result['summary']['total_flood_area_km2']} km² | \"\n                    f\"Components: {result['summary']['number_of_flood_components']}\", \n                    fontsize=14, fontweight='bold')\n        ax.axis('off')\n        ax.legend()\n        \n        output_path = os.path.join(output_dir, f\"{location}_flood_centers_with_radius.png\")\n        plt.tight_layout()\n        plt.savefig(output_path, dpi=150, bbox_inches='tight')\n        plt.close()\n        \n        print(f\"  🗺️ Saved center map with radius: {output_path}\")\n\n# ═══════════════════════════════════════════════════════════════════════\n# RUN EVERYTHING\n# ═══════════════════════════════════════════════════════════════════════\n\nif __name__ == \"__main__\":\n    # Run the analysis\n    results = analyze_all_floods(masks_dir=\"./masks_pngs\", output_dir=\"./flood_metrics_advanced\")\n    \n    # Create visualization maps with radius circles\n    print(\"\\n📊 Creating center maps with radius circles...\")\n    create_center_maps_with_radius(masks_dir=\"./masks_pngs\", results=results, output_dir=\"./flood_metrics_advanced\")\n    \n    print(\"\\n✨ ALL DONE! Check the 'flood_metrics_advanced' folder fo