{"metadata":{"kernelspec":{"language":"python","display_name":"Python 3","name":"python3"},"language_info":{"name":"python","version":"3.12.12","mimetype":"text/x-python","codemirror_mode":{"name":"ipython","version":3},"pygments_lexer":"ipython3","nbconvert_exporter":"python","file_extension":".py"},"kaggle":{"accelerator":"none","dataSources":[{"sourceType":"modelInstanceVersion","sourceId":847241,"databundleVersionId":16904755,"modelInstanceId":644235,"modelId":656197,"isSourceIdPinned":false},{"sourceType":"modelInstanceVersion","sourceId":849653,"databundleVersionId":16937968,"modelInstanceId":645961,"modelId":657908,"isSourceIdPinned":false}],"dockerImageVersionId":31329,"isInternetEnabled":true,"language":"python","sourceType":"notebook","isGpuEnabled":false}},"nbformat_minor":4,"nbformat":4,"cells":[{"source":"<a href=\"https://www.kaggle.com/code/muhammadmubeenxt/flooding-try-3?scriptVersionId=314899350\" target=\"_blank\"><img align=\"left\" alt=\"Kaggle\" title=\"Open in Kaggle\" src=\"https://kaggle.com/static/images/open-in-kaggle.svg\"></a>","metadata":{},"cell_type":"markdown"},{"cell_type":"code","source":"","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# Run this cell first to install all required packages\n!pip install pystac-client planetary-computer stackstac pyproj rioxarray dask -q\n!pip install segmentation-models-pytorch rasterio -q","metadata":{"_uuid":"8f2839f25d086af736a60e9eeb907d3b93b6e0e5","_cell_guid":"b1076dfc-b9ad-4769-8c92-a6c4dae69d19","trusted":true,"execution":{"iopub.status.busy":"2026-04-27T20:45:14.518571Z","iopub.execute_input":"2026-04-27T20:45:14.518895Z","iopub.status.idle":"2026-04-27T20:45:28.631604Z","shell.execute_reply.started":"2026-04-27T20:45:14.518866Z","shell.execute_reply":"2026-04-27T20:45:28.630795Z"}},"outputs":[{"name":"stdout","text":"\u001b[2K   \u001b[90m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m \u001b[32m41.8/41.8 kB\u001b[0m \u001b[31m593.5 kB/s\u001b[0m eta \u001b[36m0:00:00\u001b[0m\u001b[36m0:00:01\u001b[0m\n\u001b[2K   \u001b[90m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m \u001b[32m64.3/64.3 kB\u001b[0m \u001b[31m1.6 MB/s\u001b[0m eta \u001b[36m0:00:00\u001b[0ma \u001b[36m0:00:01\u001b[0m\n\u001b[2K   \u001b[90m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m \u001b[32m72.0/72.0 kB\u001b[0m \u001b[31m2.2 MB/s\u001b[0m eta \u001b[36m0:00:00\u001b[0m\n\u001b[2K   \u001b[90m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m \u001b[32m208.5/208.5 kB\u001b[0m \u001b[31m2.8 MB/s\u001b[0m eta \u001b[36m0:00:00\u001b[0m00:01\u001b[0m00:01\u001b[0m\n\u001b[2K   \u001b[90m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m \u001b[32m1.4/1.4 MB\u001b[0m \u001b[31m11.3 MB/s\u001b[0m eta \u001b[36m0:00:00\u001b[0m00:01\u001b[0m00:01\u001b[0m\n\u001b[2K   \u001b[90m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m \u001b[32m154.8/154.8 kB\u001b[0m \u001b[31m1.3 MB/s\u001b[0m eta \u001b[36m0:00:00\u001b[0m00:01\u001b[0m0:01\u001b[0m\n\u001b[?25h","output_type":"stream"}],"execution_count":2},{"cell_type":"code","source":"# ═══════════════════════════════════════════════════════════════════════════════\n# CELL 1 — DATA DOWNLOAD\n# Downloads S2 dry-season baseline + S1-RTC event chips for each location.\n# Outputs GeoTIFFs and visual PNGs to ./flood_composites/\n# ═══════════════════════════════════════════════════════════════════════════════\n\n!pip install pystac-client planetary-computer stackstac pyproj rioxarray dask -q\n!pip install segmentation-models-pytorch rasterio -q\n\nimport pystac_client\nimport planetary_computer\nimport stackstac\nimport pyproj\nimport numpy as np\nimport xarray as xr\nfrom shapely.geometry import box\nfrom shapely.ops import transform\nfrom dask.diagnostics import ProgressBar\nimport rioxarray\nimport warnings\nfrom scipy.ndimage import median_filter\nfrom scipy.spatial import cKDTree\nfrom typing import List, Optional, Tuple\nfrom PIL import Image, ImageEnhance\nimport time\nimport os\n\nwarnings.filterwarnings(\"ignore\")\n\nOUTPUT_DIR = \"./flood_composites\"\nos.makedirs(OUTPUT_DIR, exist_ok=True)\n\n\n# ─────────────────────────────────────────────────────────────────────\n# UTILITIES\n# ─────────────────────────────────────────────────────────────────────\n\ndef get_utm_params(lat: float, lon: float, radius_km: float):\n    utm_zone = int((lon + 180) / 6) + 1\n    epsg = 32600 + utm_zone if lat >= 0 else 32700 + utm_zone\n    wgs84  = pyproj.CRS(\"EPSG:4326\")\n    utm    = pyproj.CRS.from_epsg(epsg)\n    to_utm = pyproj.Transformer.from_crs(wgs84, utm, always_xy=True).transform\n    to_wgs = pyproj.Transformer.from_crs(utm, wgs84, always_xy=True).transform\n    x_c, y_c = to_utm(lon, lat)\n    x_c, y_c = round(x_c / 10) * 10, round(y_c / 10) * 10\n    r_m = radius_km * 1000\n    utm_bounds = (x_c - r_m, y_c - r_m, x_c + r_m, y_c + r_m)\n    wgs_bounds = transform(to_wgs, box(*utm_bounds)).bounds\n    return utm_bounds, epsg, wgs_bounds\n\n\ndef open_catalog() -> pystac_client.Client:\n    return pystac_client.Client.open(\n        \"https://planetarycomputer.microsoft.com/api/stac/v1\",\n        modifier=planetary_computer.sign_inplace,\n    )\n\n\ndef interpolate_missing_pixels(data: xr.DataArray, max_distance: int = 80) -> xr.DataArray:\n    out = data.copy()\n    for bi in range(data.shape[0]):\n        band = data[bi].values.copy()\n        nan_n = int(np.sum(np.isnan(band)))\n        if nan_n == 0:\n            continue\n        valid_coords   = np.argwhere(~np.isnan(band))\n        invalid_coords = np.argwhere(np.isnan(band))\n        if len(valid_coords) == 0:\n            continue\n        tree = cKDTree(valid_coords)\n        dists, idxs = tree.query(invalid_coords, k=1)\n        for i in np.where(dists < max_distance)[0]:\n            iy, ix = invalid_coords[i]\n            vy, vx = valid_coords[idxs[i]]\n            band[iy, ix] = band[vy, vx]\n        filled = nan_n - int(np.sum(np.isnan(band)))\n        print(f\"      Band {bi+1}: {filled:,} filled, {int(np.sum(np.isnan(band))):,} remain\")\n        out[bi].values = band\n    return out\n\n\ndef apply_selective_filtering(data: xr.DataArray, filter_size: int = 3) -> xr.DataArray:\n    out = data.copy()\n    for bi in range(data.shape[0]):\n        band = data[bi].values\n        valid = ~np.isnan(band)\n        if not np.any(valid):\n            continue\n        tmp = band.copy()\n        tmp[~valid] = float(np.median(band[valid]))\n        filtered = median_filter(tmp, size=filter_size, mode=\"nearest\")\n        band[valid] = filtered[valid]\n        out[bi].values = band\n    return out\n\n\ndef report_statistics(data: xr.DataArray, names: List[str]):\n    print(\"   \" + \"-\" * 65)\n    print(\"   {:14} {:>9} {:>9} {:>9} {:>9} {:>9}\".format(\n        \"Band\", \"Mean\", \"Std\", \"Min\", \"Max\", \"NaN%\"))\n    print(\"   \" + \"-\" * 65)\n    for i in range(data.shape[0]):\n        b = data[i].values\n        v = b[~np.isnan(b)]\n        nm = names[i] if i < len(names) else f\"Band {i}\"\n        if len(v) > 0:\n            print(\"   {:14} {:>9.4f} {:>9.4f} {:>9.4f} {:>9.4f} {:>8.2f}%\".format(\n                nm, float(np.mean(v)), float(np.std(v)),\n                float(np.min(v)), float(np.max(v)),\n                np.sum(np.isnan(b)) / b.size * 100))\n        else:\n            print(f\"   {nm:14} ALL NaN\")\n\n\ndef apply_visual_enhancement(data, gamma=0.55, low_pct=1.0, high_pct=98.0, saturation_boost=1.3):\n    rgb_indices = [2, 1, 0]\n    channels = []\n    for idx in rgb_indices:\n        band = data[idx].values.astype(np.float32)\n        valid = band[~np.isnan(band)]\n        if len(valid) == 0:\n            channels.append(np.zeros(band.shape, dtype=np.float32))\n            continue\n        lo, hi = np.percentile(valid, [low_pct, high_pct])\n        band = np.clip(band, lo, hi)\n        band = (band - lo) / (hi - lo + 1e-10)\n        band = np.where(np.isnan(band), 0.0, band)\n        band = np.power(band, gamma)\n        channels.append(band)\n    rgb = np.stack(channels, axis=-1)\n    try:\n        pil_img = Image.fromarray((rgb * 255).astype(np.uint8), mode=\"RGB\")\n        pil_img = ImageEnhance.Color(pil_img).enhance(saturation_boost)\n        rgb = np.array(pil_img).astype(np.float32) / 255.0\n    except Exception:\n        pass\n    return (rgb * 255).astype(np.uint8)\n\n\ndef save_visual_png(data, path, **kw):\n    arr = apply_visual_enhancement(data, **kw)\n    Image.fromarray(arr, mode=\"RGB\").save(path)\n    h, w = arr.shape[:2]\n    print(f\"   PNG: {os.path.basename(path)} ({w}x{h}px)\")\n\n\n# ─────────────────────────────────────────────────────────────────────\n# ORBIT AUTO-SELECTOR\n# ─────────────────────────────────────────────────────────────────────\n\ndef select_best_orbit(wgs_bounds, date_start, date_end, catalog):\n    counts = {}\n    for direction in (\"ascending\", \"descending\"):\n        result = catalog.search(\n            collections=[\"sentinel-1-rtc\"],\n            bbox=wgs_bounds,\n            datetime=f\"{date_start}/{date_end}\",\n            query={\"sat:orbit_state\": {\"eq\": direction}},\n            max_items=200,\n        )\n        counts[direction] = len(list(result.items()))\n        print(f\"  Orbit survey: {direction:12s} -> {counts[direction]} acquisitions\")\n    best = max(counts, key=counts.get)\n    if counts[\"ascending\"] == counts[\"descending\"]:\n        best = \"descending\"\n    print(f\"  Auto-selected: {best.upper()} ({counts[best]} acqs)\")\n    return best\n\n\n# ─────────────────────────────────────────────────────────────────────\n# SENTINEL-2 BASELINE\n# Bands: [B02, B03, B04, B08, B11, B12], float32, [0, 1]\n# Purpose: MNDWI permanent-water mask + before-panel visual.\n# ─────────────────────────────────────────────────────────────────────\n\ndef download_s2_baseline(\n    lat, lon, radius_km, date_start, date_end, label,\n    max_cloud=30, max_items=15, output_dir=\".\",\n    gamma=0.55, low_pct=1.0, high_pct=98.0,\n):\n    os.makedirs(output_dir, exist_ok=True)\n    t0 = time.time()\n    print(f\"\\n{'='*70}\")\n    print(f\"  [S2 BASELINE] {label}  |  {date_start} -> {date_end}  |  cloud<{max_cloud}%\")\n    print(f\"{'='*70}\")\n\n    utm_bounds, epsg, wgs_bounds = get_utm_params(lat, lon, radius_km)\n    catalog = open_catalog()\n\n    def _search(cloud_limit):\n        return list(catalog.search(\n            collections=[\"sentinel-2-l2a\"],\n            bbox=wgs_bounds,\n            datetime=f\"{date_start}/{date_end}\",\n            query={\"eo:cloud_cover\": {\"lt\": cloud_limit}},\n            sortby=[{\"field\": \"properties.eo:cloud_cover\", \"direction\": \"asc\"}],\n            max_items=50,\n        ).items())\n\n    items = _search(max_cloud)\n    if not items:\n        relaxed = min(max_cloud + 15, 50)\n        print(f\"  No scenes at <{max_cloud}%. Retrying at <{relaxed}%...\")\n        items = _search(relaxed)\n    if not items:\n        print(\"  FAILED: No S2 scenes found.\")\n        return None\n\n    reflectance_bands = [\"B02\", \"B03\", \"B04\", \"B08\", \"B11\", \"B12\"]\n    n = min(max_items, len(items))\n    print(f\"  Found {len(items)} scenes, stacking top {n}\")\n    slices = []\n\n    for i, item in enumerate(items[:n]):\n        pb = item.properties.get(\"s2:processing_baseline\", \"02.00\")\n        try:\n            is_new = float(pb) >= 4.0\n        except (ValueError, TypeError):\n            is_new = str(pb) >= \"04.00\"\n        cc = item.properties.get(\"eo:cloud_cover\", \"?\")\n        dt = item.properties.get(\"datetime\", \"?\")[:10]\n        try:\n            cube = stackstac.stack(\n                item, assets=reflectance_bands + [\"SCL\"],\n                bounds=utm_bounds, epsg=epsg, resolution=10,\n                dtype=\"float64\", rescale=True, fill_value=np.nan,\n            ).squeeze()\n        except Exception as e:\n            print(f\"    [{i+1}/{n}] SKIP: {e}\")\n            continue\n        if is_new:\n            for b in reflectance_bands:\n                if b in cube.band.values:\n                    cube.loc[dict(band=b)] -= 0.1\n        if \"SCL\" in cube.band.values:\n            bad = cube.sel(band=\"SCL\").isin([0, 1, 3, 8, 9, 10])\n            for b in reflectance_bands:\n                if b in cube.band.values:\n                    cube.loc[dict(band=b)] = cube.sel(band=b).where(~bad)\n        slices.append(cube.sel(band=reflectance_bands))\n        print(f\"    [{i+1}/{n}] {dt} | cloud:{cc:.1f}%\")\n\n    if not slices:\n        print(\"  FAILED: All scenes errored.\")\n        return None\n\n    print(f\"\\n  Computing median composite ({len(slices)} scenes)...\")\n    cube = xr.concat(slices, dim=\"time\", combine_attrs=\"override\")\n    with ProgressBar():\n        data = cube.median(dim=\"time\", skipna=True).compute().astype(\"float32\")\n        data = data.where(data >= 0, 0)\n\n    data = data.rio.write_nodata(np.nan).rio.write_crs(f\"EPSG:{epsg}\")\n    data = interpolate_missing_pixels(data, max_distance=80)\n    data = apply_selective_filtering(data, filter_size=3)\n    report_statistics(data, [\"Blue(B02)\", \"Green(B03)\", \"Red(B04)\", \"NIR(B08)\", \"SWIR1(B11)\", \"SWIR2(B12)\"])\n\n    stem     = f\"{label}_s2_baseline_{date_start}_{date_end}\"\n    tif_path = os.path.join(output_dir, stem + \".tif\")\n    data.rio.to_raster(tif_path, compress=\"LZW\", tiled=True,\n                       blockxsize=256, blockysize=256, dtype=\"float32\", nodata=np.nan)\n    print(f\"  GeoTIFF: {tif_path}\")\n    save_visual_png(data, os.path.join(output_dir, stem + \"_visual.png\"),\n                    gamma=gamma, low_pct=low_pct, high_pct=high_pct)\n    print(f\"  Done in {time.time()-t0:.1f}s | {data.shape[2]}x{data.shape[1]}px\")\n    return data\n\n\n# ─────────────────────────────────────────────────────────────────────\n# SENTINEL-1 RTC EVENT DOWNLOADER\n# Enforces single orbit direction. Saves per-acquisition chips in dB.\n# ─────────────────────────────────────────────────────────────────────\n\ndef download_s1_event(\n    lat, lon, radius_km, date_start, date_end, label,\n    output_dir=\".\", orbit_direction=None, save_composite=True,\n):\n    os.makedirs(output_dir, exist_ok=True)\n    t0 = time.time()\n\n    utm_bounds, epsg, wgs_bounds = get_utm_params(lat, lon, radius_km)\n    catalog = open_catalog()\n\n    if orbit_direction is None:\n        print(f\"\\n  orbit_direction=None: running auto-selection...\")\n        orbit_direction = select_best_orbit(wgs_bounds, date_start, date_end, catalog)\n    elif orbit_direction not in (\"ascending\", \"descending\"):\n        raise ValueError(\n            f\"orbit_direction must be 'ascending', 'descending', or None. Got: '{orbit_direction}'\")\n\n    print(f\"\\n{'='*70}\")\n    print(f\"  [S1 EVENT] {label}  |  {date_start} -> {date_end}\")\n    print(f\"  Orbit: {orbit_direction.upper()} only\")\n    print(f\"{'='*70}\")\n\n    items = list(catalog.search(\n        collections=[\"sentinel-1-rtc\"],\n        bbox=wgs_bounds,\n        datetime=f\"{date_start}/{date_end}\",\n        query={\"sat:orbit_state\": {\"eq\": orbit_direction}},\n        sortby=[{\"field\": \"properties.datetime\", \"direction\": \"asc\"}],\n        max_items=100,\n    ).items())\n\n    if not items:\n        print(f\"  FAILED: No {orbit_direction} S1-RTC scenes found.\")\n        return []\n\n    print(f\"  Found {len(items)} {orbit_direction} acquisitions\")\n    acquisitions, acq_dates = [], []\n\n    for i, item in enumerate(items):\n        dt    = item.properties.get(\"datetime\", \"?\")[:10]\n        orbit = item.properties.get(\"sat:orbit_state\", \"?\")\n        plat  = item.properties.get(\"platform\", \"?\")\n        if orbit != orbit_direction:\n            print(f\"    [{i+1}] SKIP: unexpected orbit={orbit}\")\n            continue\n        try:\n            cube = stackstac.stack(\n                item, assets=[\"vv\", \"vh\"],\n                bounds=utm_bounds, epsg=epsg, resolution=10,\n                dtype=\"float64\", rescale=False, fill_value=np.nan,\n            ).squeeze()\n            with ProgressBar():\n                arr = cube.compute().astype(\"float32\")\n        except Exception as e:\n            print(f\"    [{i+1}/{len(items)}] {dt} SKIP: {e}\")\n            continue\n\n        arr_db = arr.copy()\n        for bi in range(arr.shape[0]):\n            band = arr[bi].values.copy()\n            valid = (band > 0) & ~np.isnan(band)\n            band[~valid] = np.nan\n            band[valid] = 10.0 * np.log10(band[valid])\n            band = np.clip(band, -35.0, 5.0)\n            arr_db[bi].values = band\n\n        arr_db = arr_db.rio.write_nodata(np.nan).rio.write_crs(f\"EPSG:{epsg}\")\n        acq_stem = f\"{label}_s1_{dt}_{orbit_direction}\"\n        tif_path = os.path.join(output_dir, acq_stem + \".tif\")\n        arr_db.rio.to_raster(\n            tif_path, compress=\"LZW\", tiled=True,\n            blockxsize=256, blockysize=256, dtype=\"float32\", nodata=np.nan,\n        )\n        acquisitions.append((dt, arr_db))\n        acq_dates.append(dt)\n        print(f\"    [{i+1}/{len(items)}] {dt} | {orbit_direction} | {plat} -> {os.path.basename(tif_path)}\")\n\n    if not acquisitions:\n        print(\"  FAILED: All acquisitions errored.\")\n        return []\n\n    if save_composite:\n        print(f\"\\n  Building {orbit_direction} composite ({len(acquisitions)} acqs)...\")\n        stacked   = xr.concat([a[1] for a in acquisitions], dim=\"time\")\n        composite = stacked.mean(dim=\"time\", skipna=True).astype(\"float32\")\n        composite = composite.rio.write_nodata(np.nan).rio.write_crs(f\"EPSG:{epsg}\")\n        comp_path = os.path.join(\n            output_dir,\n            f\"{label}_s1_{orbit_direction}_composite_{date_start}_{date_end}.tif\"\n        )\n        composite.rio.to_raster(comp_path, compress=\"LZW\", tiled=True,\n                                blockxsize=256, blockysize=256, dtype=\"float32\", nodata=np.nan)\n        print(f\"  Composite: {comp_path}\")\n\n        try:\n            def _stretch(a, lo=2, hi=98):\n                v = a[~np.isnan(a)]\n                if not len(v):\n                    return np.zeros_like(a, np.float32)\n                lv, hv = np.percentile(v, [lo, hi])\n                out = np.clip(a, lv, hv)\n                out = (out - lv) / (hv - lv + 1e-10)\n                return np.where(np.isnan(out), 0.0, out)\n            vv    = composite[0].values\n            vh    = composite[1].values\n            ratio = np.where((~np.isnan(vv)) & (~np.isnan(vh)), vv - vh, np.nan)\n            rgb   = np.stack([\n                (_stretch(vv)    * 255).astype(np.uint8),\n                (_stretch(vh)    * 255).astype(np.uint8),\n                (_stretch(ratio) * 255).astype(np.uint8),\n            ], axis=-1)\n            fc_path = os.path.join(\n                output_dir,\n                f\"{label}_s1_{orbit_direction}_falsecolor_{date_start}_{date_end}.png\"\n            )\n            Image.fromarray(rgb, mode=\"RGB\").save(fc_path)\n            print(f\"  False-color PNG: {fc_path}\")\n        except Exception as e:\n            print(f\"  False-color PNG failed: {e}\")\n\n    print(f\"\\n  S1 done | orbit={orbit_direction} | {len(acquisitions)} chips\")\n    print(f\"  Dates: {', '.join(acq_dates)}\")\n    print(f\"  Elapsed: {time.time()-t0:.1f}s\")\n    return acquisitions\n\n\n# ─────────────────────────────────────────────────────────────────────\n# OPTIONAL S2 VISUAL AFTER (display only, high cloud OK)\n# ─────────────────────────────────────────────────────────────────────\n\ndef download_s2_visual_after(\n    lat, lon, radius_km, date_start, date_end, label,\n    max_cloud=70, max_items=8, output_dir=\".\",\n    gamma=0.55, low_pct=1.0, high_pct=98.0,\n):\n    os.makedirs(output_dir, exist_ok=True)\n    t0 = time.time()\n    print(f\"\\n{'='*70}\")\n    print(f\"  [S2 VISUAL AFTER] {label}  |  cloud<{max_cloud}% | DISPLAY ONLY\")\n    print(f\"{'='*70}\")\n\n    utm_bounds, epsg, wgs_bounds = get_utm_params(lat, lon, radius_km)\n    catalog = open_catalog()\n\n    items = list(catalog.search(\n        collections=[\"sentinel-2-l2a\"],\n        bbox=wgs_bounds,\n        datetime=f\"{date_start}/{date_end}\",\n        query={\"eo:cloud_cover\": {\"lt\": max_cloud}},\n        sortby=[{\"field\": \"properties.eo:cloud_cover\", \"direction\": \"asc\"}],\n        max_items=50,\n    ).items())\n\n    if not items:\n        print(\"  No S2 scenes. Use S1 false-color for UI after-panel.\")\n        return None\n\n    reflectance_bands = [\"B02\", \"B03\", \"B04\", \"B08\", \"B11\", \"B12\"]\n    n = min(max_items, len(items))\n    print(f\"  Found {len(items)} scenes, using top {n}\")\n    slices = []\n\n    for i, item in enumerate(items[:n]):\n        pb = item.properties.get(\"s2:processing_baseline\", \"02.00\")\n        try:\n            is_new = float(pb) >= 4.0\n        except (ValueError, TypeError):\n            is_new = str(pb) >= \"04.00\"\n        cc = item.properties.get(\"eo:cloud_cover\", \"?\")\n        dt = item.properties.get(\"datetime\", \"?\")[:10]\n        try:\n            cube = stackstac.stack(\n                item, assets=reflectance_bands + [\"SCL\"],\n                bounds=utm_bounds, epsg=epsg, resolution=10,\n                dtype=\"float64\", rescale=True, fill_value=np.nan,\n            ).squeeze()\n        except Exception as e:\n            print(f\"    [{i+1}/{n}] SKIP: {e}\")\n            continue\n        if is_new:\n            for b in reflectance_bands:\n                if b in cube.band.values:\n                    cube.loc[dict(band=b)] -= 0.1\n        if \"SCL\" in cube.band.values:\n            bad = cube.sel(band=\"SCL\").isin([0, 1, 3, 8, 9, 10])\n            for b in reflectance_bands:\n                if b in cube.band.values:\n                    cube.loc[dict(band=b)] = cube.sel(band=b).where(~bad)\n        slices.append(cube.sel(band=reflectance_bands))\n        print(f\"    [{i+1}/{n}] {dt} | cloud:{cc:.1f}%\")\n\n    if not slices:\n        print(\"  All scenes errored. Use S1 false-color for UI.\")\n        return None\n\n    cube = xr.concat(slices, dim=\"time\", combine_attrs=\"override\")\n    with ProgressBar():\n        data = cube.median(dim=\"time\", skipna=True).compute().astype(\"float32\")\n        data = data.where(data >= 0, 0)\n\n    data = data.rio.write_nodata(np.nan).rio.write_crs(f\"EPSG:{epsg}\")\n    data = interpolate_missing_pixels(data, max_distance=120)\n    data = apply_selective_filtering(data, filter_size=3)\n\n    avg_nan = float(np.mean([\n        np.sum(np.isnan(data[i].values)) / data[i].values.size * 100\n        for i in range(data.shape[0])\n    ]))\n    if avg_nan > 40:\n        print(f\"  WARNING: {avg_nan:.1f}% NaN. Use S1 false-color for after-panel.\")\n    else:\n        print(f\"  NaN coverage: {avg_nan:.1f}%\")\n\n    stem = f\"{label}_s2_visual_after_{date_start}_{date_end}\"\n    data.rio.to_raster(os.path.join(output_dir, stem + \".tif\"),\n                       compress=\"LZW\", tiled=True, blockxsize=256, blockysize=256,\n                       dtype=\"float32\", nodata=np.nan)\n    save_visual_png(data, os.path.join(output_dir, stem + \".png\"),\n                    gamma=gamma, low_pct=low_pct, high_pct=high_pct)\n    print(f\"  Done in {time.time()-t0:.1f}s\")\n    return data\n\n\n# ─────────────────────────────────────────────────────────────────────\n# ORCHESTRATOR\n# ─────────────────────────────────────────────────────────────────────\n\ndef download_flood_pair(\n    lat, lon, radius_km,\n    baseline_start, baseline_end,\n    event_start, event_end,\n    label,\n    orbit_direction=None,\n    output_dir=\".\",\n    fetch_s2_visual_after=True,\n    gamma=0.55, low_pct=1.0, high_pct=98.0,\n):\n    print(f\"\\n{'#'*70}\")\n    print(f\"  FLOOD PAIR: {label.upper()}\")\n    print(f\"  Baseline : {baseline_start} -> {baseline_end}  [S2]\")\n    print(f\"  Event    : {event_start} -> {event_end}  [S1 SAR]\")\n    print(f\"  Orbit    : {'AUTO-SELECT' if orbit_direction is None else orbit_direction.upper()}\")\n    print(f\"{'#'*70}\")\n\n    results = {}\n    results[\"s2_baseline\"] = download_s2_baseline(\n        lat, lon, radius_km, baseline_start, baseline_end, label,\n        max_cloud=30, max_items=15, output_dir=output_dir,\n        gamma=gamma, low_pct=low_pct, high_pct=high_pct,\n    )\n    results[\"s1_acquisitions\"] = download_s1_event(\n        lat, lon, radius_km, event_start, event_end, label,\n        output_dir=output_dir, orbit_direction=orbit_direction, save_composite=True,\n    )\n    if fetch_s2_visual_after:\n        results[\"s2_visual_after\"] = download_s2_visual_after(\n            lat, lon, radius_km, event_start, event_end, label,\n            max_cloud=70, max_items=8, output_dir=output_dir,\n            gamma=gamma, low_pct=low_pct, high_pct=high_pct,\n        )\n    else:\n        results[\"s2_visual_after\"] = None\n\n    n_acq = len(results[\"s1_acquisitions\"])\n    print(f\"\\n{'#'*70}\")\n    print(f\"  SUMMARY: {label}\")\n    print(f\"  S2 baseline    : {'OK' if results['s2_baseline'] is not None else 'FAILED'}\")\n    print(f\"  S1 acquisitions: {n_acq} chips {'(ready for inference)' if n_acq > 0 else '(FAILED)'}\")\n    s2v = results[\"s2_visual_after\"]\n    print(f\"  S2 visual after: {'OK' if s2v is not None else 'Not available - use S1 false-color'}\")\n    print(f\"{'#'*70}\\n\")\n    return results\n\n\n# ─────────────────────────────────────────────────────────────────────\n# RUN\n# ─────────────────────────────────────────────────────────────────────\n\npakistan_locations = [\n    # label                 lat         lon        r_km  orbit\n    (\"Sialkot_punjab\",   32.496304,  74.538327,   10,   \"ascending\"),\n    (\"Dadu_Sindh\",       26.73,      67.78,       10,   \"descending\"),\n    (\"Sukkur_Sindh\",     27.70,      68.87,       10,   \"descending\"),\n    (\"Jacobabad_Sindh\",  28.28,      68.43,       10,   \"descending\"),\n    (\"DG_Khan_Punjab\",   30.06,      70.64,       10,   \"descending\"),\n    (\"Nowshera_KPK\",     34.01,      71.99,       10,   \"descending\"),\n]\n\nfor label, lat, lon, radius_km, orbit in pakistan_locations:\n    try:\n        if \"Sialkot\" in label:\n            bl_start, bl_end = \"2025-01-01\", \"2025-06-30\"\n            ev_start, ev_end = \"2025-07-15\", \"2025-09-15\"\n        else:\n            bl_start, bl_end = \"2022-01-01\", \"2022-06-30\"\n            ev_start, ev_end = \"2022-08-01\", \"2022-09-30\"\n        download_flood_pair(\n            lat=lat, lon=lon, radius_km=radius_km,\n            baseline_start=bl_start, baseline_end=bl_end,\n            event_start=ev_start, event_end=ev_end,\n            label=label, orbit_direction=orbit,\n            output_dir=OUTPUT_DIR,\n            fetch_s2_visual_after=True,\n        )\n    except Exception as e:\n        print(f\"  ERROR [{label}]: {type(e).__name__}: {e}\")\n\n# Uncomment to run international locations:\ninternational_locations = [\n     {\"label\": \"Sylhet_Bangladesh\", \"lat\": 24.90, \"lon\": 91.87, \"radius_km\": 10, \"orbit\": None,\n      \"baseline_start\": \"2022-01-01\", \"baseline_end\": \"2022-04-30\",\n      \"event_start\": \"2022-06-01\", \"event_end\": \"2022-07-31\"},\n     {\"label\": \"Kherson_Ukraine\", \"lat\": 46.64, \"lon\": 32.62, \"radius_km\": 10, \"orbit\": \"ascending\",\n      \"baseline_start\": \"2023-03-01\", \"baseline_end\": \"2023-05-31\",\n      \"event_start\": \"2023-06-06\", \"event_end\": \"2023-07-31\"},\n     {\"label\": \"KwaZuluNatal_SA\", \"lat\": -29.86, \"lon\": 31.01, \"radius_km\": 10, \"orbit\": \"descending\",\n      \"baseline_start\": \"2022-01-01\", \"baseline_end\": \"2022-03-31\",\n      \"event_start\": \"2022-04-11\", \"event_end\": \"2022-05-31\"},\n ]\nfor loc in international_locations:\n     try:\n         download_flood_pair(**{k: loc[k] for k in\n             [\"lat\",\"lon\",\"radius_km\",\"baseline_start\",\"baseline_end\",\"event_start\",\"event_end\",\"label\"]},\n             orbit_direction=loc[\"orbit\"], output_dir=OUTPUT_DIR, fetch_s2_visual_after=True,\n         )\n     except Exception as e:\n         print(f\"  ERROR [{loc['label']}]: {type(e).__name__}: {e}\")\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-27T18:02:12.51003Z","iopub.execute_input":"2026-04-27T18:02:12.510285Z","iopub.status.idle":"2026-04-27T18:40:09.210807Z","shell.execute_reply.started":"2026-04-27T18:02:12.510257Z","shell.execute_reply":"2026-04-27T18:40:09.209868Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# !pip install segmentation-models-pytorch rasterio -q\n\nimport os, glob, json, warnings\nimport numpy as np\nimport torch\nimport torch.nn as nn\nimport torch.nn.functional as F\nimport segmentation_models_pytorch as smp\nimport rasterio\nfrom rasterio.enums import Resampling\nimport matplotlib.pyplot as plt\nimport matplotlib.patches as mpatches\nimport matplotlib.gridspec as gridspec\nfrom matplotlib.colors import ListedColormap\nfrom PIL import Image, ImageEnhance\nfrom tqdm.auto import tqdm\nimport datetime\nwarnings.filterwarnings(\"ignore\")\n\n# ═══════════════════════════════════════════════════════════════════════\n# CONFIG\n# ═══════════════════════════════════════════════════════════════════════\nCOMPOSITES_DIR = \"./flood_composites\"\nMODEL_PATH     = \"/kaggle/input/models/muhammadmubeenxt/ablation-flooding/pytorch/default/1/ablation_best_flood_model_full.pth\"\nMASKS_PNG_DIR  = \"./masks_pngs\"\nMETRICS_JSON   = \"./flood_metrics.json\"\nDEBUG_LOG      = \"./flood_debug.log\"\nos.makedirs(MASKS_PNG_DIR, exist_ok=True)\n\n# Locations\nLOCATIONS = [\n    (\"Sialkot_punjab\",    32.496304,  74.538327),\n    #(\"Dadu_Sindh\",        26.73,      67.78),\n    #(\"Sukkur_Sindh\",      27.70,      68.87),\n    #(\"Jacobabad_Sindh\",   28.28,      68.43),\n    #(\"DG_Khan_Punjab\",    30.06,      70.64),\n    #(\"Nowshera_KPK\",      34.01,      71.99),\n]\n\nFLOOD_THRESHOLD  = 0.50\nPERM_WATER_MNDWI = -0.07\nSAR_ONLY_MODE    = False\nTILE_SIZE        = 256\nTILE_OVERLAP     = 64\nTILE_STRIDE      = TILE_SIZE - TILE_OVERLAP\nPIXEL_AREA_KM2   = (10.0 * 10.0) / 1e6\n\ndevice = torch.device(\"cuda\" if torch.cuda.is_available() else \"cpu\")\ntorch.cuda.empty_cache()\n\n# Setup debug logging\ndef debug_log(msg, level=\"INFO\"):\n    timestamp = datetime.datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\")\n    log_msg = f\"[{timestamp}] [{level}] {msg}\"\n    print(log_msg)\n    with open(DEBUG_LOG, \"a\") as f:\n        f.write(log_msg + \"\\n\")\n\ndebug_log(f\"=== FLOOD DETECTION STARTED ===\")\ndebug_log(f\"Device: {device}, TILE_SIZE: {TILE_SIZE}, Threshold: {FLOOD_THRESHOLD}\")\n\n# ═══════════════════════════════════════════════════════════════════════\n# MODEL DEFINITION\n# ═══════════════════════════════════════════════════════════════════════\nclass CBAM(nn.Module):\n    def __init__(self, channels, reduction=8):\n        super().__init__()\n        self.avg = nn.AdaptiveAvgPool2d(1)\n        self.max = nn.AdaptiveMaxPool2d(1)\n        self.fc  = nn.Sequential(\n            nn.Linear(channels, channels // reduction, bias=False),\n            nn.ReLU(inplace=True),\n            nn.Linear(channels // reduction, channels, bias=False))\n        self.sc  = nn.Conv2d(2, 1, kernel_size=7, padding=3, bias=False)\n\n    def forward(self, x):\n        b, c = x.shape[:2]\n        a = self.fc(self.avg(x).view(b, c))\n        m = self.fc(self.max(x).view(b, c))\n        x = x * torch.sigmoid(a + m).view(b, c, 1, 1)\n        s = torch.cat([x.mean(1, keepdim=True), x.max(1, keepdim=True)[0]], dim=1)\n        return x * torch.sigmoid(self.sc(s))\n\nclass DualStreamUNetPP(nn.Module):\n    def __init__(self, use_cbam=True):\n        super().__init__()\n        self.use_cbam = use_cbam\n        self.sar_enc  = smp.UnetPlusPlus(encoder_name=\"resnet50\", encoder_weights=None,\n                                          in_channels=3, classes=32)\n        self.opt_enc  = smp.UnetPlusPlus(encoder_name=\"resnet50\", encoder_weights=None,\n                                          in_channels=7, classes=32)\n        if use_cbam:\n            self.cbam = CBAM(64)\n        self.head = nn.Sequential(\n            nn.Conv2d(64, 32, 3, padding=1, bias=False),\n            nn.BatchNorm2d(32), nn.ReLU(inplace=True),\n            nn.Dropout2d(p=0.15), nn.Conv2d(32, 1, 1))\n\n    def forward(self, x):\n        sar = torch.cat([x[:, 0:2], x[:, 7:8]], dim=1)\n        opt = torch.cat([x[:, 2:7], x[:, 8:10]], dim=1)\n        f   = torch.cat([self.sar_enc(sar), self.opt_enc(opt)], dim=1)\n        if self.use_cbam:\n            f = self.cbam(f)\n        return self.head(f)\n\ndef load_model(path, device):\n    debug_log(f\"Loading model from: {path}\")\n    if not os.path.exists(path):\n        raise FileNotFoundError(f\"Checkpoint not found: {path}\")\n    \n    m = DualStreamUNetPP(use_cbam=True)\n    raw = torch.load(path, map_location=device)\n    state = raw.get(\"model_state\", raw)\n    \n    # Strip DataParallel prefix\n    state = {k.replace(\"module.\", \"\"): v for k, v in state.items()}\n    \n    # Remap keys\n    remapped = {}\n    for k, v in state.items():\n        k = k.replace(\"sar_encoder.\", \"sar_enc.\").replace(\"opt_encoder.\", \"opt_enc.\")\n        remapped[k] = v\n    \n    missing, unexpected = m.load_state_dict(remapped, strict=False)\n    if missing:\n        debug_log(f\"Missing keys: {missing[:3]}\", \"WARNING\")\n    if unexpected:\n        debug_log(f\"Unexpected keys: {unexpected[:3]}\", \"WARNING\")\n    \n    m.to(device).eval()\n    param_count = sum(p.numel() for p in m.parameters())/1e6\n    debug_log(f\"Model loaded: {param_count:.1f}M params\")\n    \n    # Test model\n    debug_log(\"Testing model with dummy input...\")\n    dummy_input = torch.randn(1, 10, 256, 256).to(device)\n    with torch.no_grad():\n        dummy_output = m(dummy_input)\n    debug_log(f\"Dummy output shape: {dummy_output.shape}\")\n    \n    return m\n\n# ═══════════════════════════════════════════════════════════════════════\n# FILE DISCOVERY\n# ═══════════════════════════════════════════════════════════════════════\ndef find_file(base_dir, pattern):\n    hits = sorted(glob.glob(os.path.join(base_dir, pattern)))\n    return hits[-1] if hits else None\n\ndef discover(label, composites_dir):\n    d = {}\n    d[\"s2_tif\"] = find_file(composites_dir, f\"{label}_s2_baseline_*.tif\")\n    d[\"s1_tif\"] = (\n        find_file(composites_dir, f\"{label}_s1_*_composite_*.tif\") or\n        find_file(composites_dir, f\"{label}_s1_composite_*.tif\")\n    )\n    d[\"s2_before_png\"] = find_file(composites_dir, f\"{label}_s2_baseline_*_visual.png\")\n    d[\"s1_after_png\"]  = (\n        find_file(composites_dir, f\"{label}_s1_*_falsecolor_*.png\") or\n        find_file(composites_dir, f\"{label}_s1_falsecolor_*.png\")\n    )\n    d[\"s2_after_png\"]  = find_file(composites_dir, f\"{label}_s2_visual_after_*.png\")\n    return d\n\n# ═══════════════════════════════════════════════════════════════════════\n# DATA LOADING - FIXED VERSION\n# ═══════════════════════════════════════════════════════════════════════\ndef load_tif_corrected(path, is_sar=False):\n    \"\"\"Load GeoTIFF - S2 gets scaled to 0-1, S1 stays in dB\"\"\"\n    debug_log(f\"Loading GeoTIFF: {path}\")\n    \n    with rasterio.open(path) as src:\n        data = src.read().astype(np.float32)\n        \n        if is_sar:\n            # SAR data: convert linear to dB if needed\n            if data.max() > 10:  # Linear scale\n                debug_log(f\"  Converting SAR from linear to dB (max={data.max():.2f})\")\n                data = np.clip(10 * np.log10(data + 1e-9), -35, 5)\n            debug_log(f\"  SAR dB - range: [{data.min():.2f}, {data.max():.2f}], mean: {data.mean():.2f}\")\n        else:\n            # S2 optical: scale 0-10000 to 0-1\n            if data.max() > 10:\n                debug_log(f\"  Scaling S2 (max={data.max():.2f}) to 0-1\")\n                data = data / 10000.0\n            data = np.clip(data, 0.0, 1.0)\n            debug_log(f\"  S2 scaled - range: [{data.min():.4f}, {data.max():.4f}], mean: {data.mean():.4f}\")\n        \n        return data, src.transform, src.crs\n\ndef match_hw(arr, target_hw):\n    tH, tW = target_hw\n    if arr.shape[1] == tH and arr.shape[2] == tW:\n        return arr\n    t = torch.from_numpy(arr).unsqueeze(0).float()\n    t = F.interpolate(t, size=(tH, tW), mode=\"bilinear\", align_corners=False)\n    return t.squeeze(0).numpy()\n\ndef build_tensor_fixed(s2_arr, s1_arr_db, sar_only=False):\n    \"\"\"Build 10-channel input tensor\"\"\"\n    debug_log(\"Building input tensor...\")\n    H, W = s2_arr.shape[1], s2_arr.shape[2]\n    s1_arr_db = match_hw(s1_arr_db, (H, W))\n    \n    # Normalize dB to [0,1] for model input\n    vv = np.clip((s1_arr_db[0] + 30.0) / 30.0, 0.0, 1.0)\n    vh = np.clip((s1_arr_db[1] + 30.0) / 30.0, 0.0, 1.0)\n    vv = np.nan_to_num(vv, nan=0.0)\n    vh = np.nan_to_num(vh, nan=0.0)\n    \n    debug_log(f\"  Normalized VV - range: [{vv.min():.4f}, {vv.max():.4f}], unique: {len(np.unique(vv))}\")\n    debug_log(f\"  Normalized VH - range: [{vh.min():.4f}, {vh.max():.4f}], unique: {len(np.unique(vh))}\")\n    \n    # SAR ratio\n    with np.errstate(divide=\"ignore\", invalid=\"ignore\"):\n        sar_r = np.where(vh > 1e-8, vv / vh, 0.0)\n    sar_r = np.clip(np.nan_to_num(sar_r, nan=0.0, posinf=0.0), 0.0, 10.0)\n    \n    if sar_only:\n        tensor = np.zeros((10, H, W), dtype=np.float32)\n        tensor[0] = vv\n        tensor[1] = vh\n        tensor[7] = sar_r\n        return tensor\n    \n    # Optical bands\n    blue = np.clip(np.nan_to_num(s2_arr[0], nan=0.0), 0.0, 1.0)\n    green = np.clip(np.nan_to_num(s2_arr[1], nan=0.0), 0.0, 1.0)\n    red = np.clip(np.nan_to_num(s2_arr[2], nan=0.0), 0.0, 1.0)\n    nir = np.clip(np.nan_to_num(s2_arr[3], nan=0.0), 0.0, 1.0)\n    swir1 = np.clip(np.nan_to_num(s2_arr[4], nan=0.0), 0.0, 1.0)\n    \n    debug_log(f\"  S2 means - B:{blue.mean():.3f} G:{green.mean():.3f} R:{red.mean():.3f}\")\n    \n    # Indices\n    with np.errstate(divide=\"ignore\", invalid=\"ignore\"):\n        ndwi = np.where((green+nir) > 1e-8, (green-nir) / (green+nir), 0.0)\n        mndwi = np.where((green+swir1) > 1e-8, (green-swir1) / (green+swir1), 0.0)\n    \n    ndwi = np.nan_to_num(ndwi, nan=0.0)\n    mndwi = np.nan_to_num(mndwi, nan=0.0)\n    \n    tensor = np.stack([\n        vv, vh, blue, green, red, nir, ndwi, sar_r, swir1, mndwi\n    ], axis=0).astype(np.float32)\n    \n    debug_log(f\"  Tensor - range: [{tensor.min():.4f}, {tensor.max():.4f}], mean: {tensor.mean():.4f}\")\n    return tensor\n\n# ═══════════════════════════════════════════════════════════════════════\n# TILED INFERENCE\n# ═══════════════════════════════════════════════════════════════════════\ndef _hanning_window(size):\n    lin = np.hanning(size).astype(np.float64)\n    w = np.outer(lin, lin)\n    return np.clip(w, 1e-6, None)\n\n@torch.no_grad()\ndef tiled_predict(model, tensor, device):\n    debug_log(\"Starting tiled prediction...\")\n    C, H, W = tensor.shape\n    debug_log(f\"  Input shape: {tensor.shape}\")\n    \n    torch.cuda.empty_cache()\n    win = _hanning_window(TILE_SIZE)\n    \n    pad_h = (-H) % TILE_STRIDE\n    pad_w = (-W) % TILE_STRIDE\n    if pad_h or pad_w:\n        debug_log(f\"  Padding: h={pad_h}, w={pad_w}\")\n        tensor = np.pad(tensor, ((0,0),(0,pad_h),(0,pad_w)), mode=\"reflect\")\n    \n    _, PH, PW = tensor.shape\n    acc = np.zeros((PH, PW), dtype=np.float64)\n    count = np.zeros((PH, PW), dtype=np.float64)\n    \n    ys = list(range(0, PH - TILE_SIZE + 1, TILE_STRIDE))\n    xs = list(range(0, PW - TILE_SIZE + 1, TILE_STRIDE))\n    if ys and ys[-1] + TILE_SIZE < PH:\n        ys.append(PH - TILE_SIZE)\n    if xs and xs[-1] + TILE_SIZE < PW:\n        xs.append(PW - TILE_SIZE)\n    \n    debug_log(f\"  Tiles: {len(ys)} x {len(xs)} = {len(ys)*len(xs)} tiles\")\n    \n    model.eval()\n    coords = [(y, x) for y in ys for x in xs]\n    \n    for idx, (y0, x0) in enumerate(tqdm(coords, desc=\"  Tiles\", leave=False)):\n        chip = tensor[:, y0:y0+TILE_SIZE, x0:x0+TILE_SIZE]\n        xt = torch.from_numpy(chip).unsqueeze(0).to(device)\n        \n        with torch.amp.autocast(\"cuda\", enabled=(device.type == \"cuda\")):\n            prob = torch.sigmoid(model(xt)).squeeze().cpu().numpy().astype(np.float64)\n        \n        acc[y0:y0+TILE_SIZE, x0:x0+TILE_SIZE] += prob * win\n        count[y0:y0+TILE_SIZE, x0:x0+TILE_SIZE] += win\n        \n        if idx % 20 == 0:\n            torch.cuda.empty_cache()\n    \n    prob_map = (acc / np.where(count > 0, count, 1.0)).astype(np.float32)\n    prob_map = prob_map[:H, :W]\n    binary = (prob_map >= FLOOD_THRESHOLD).astype(np.uint8)\n    \n    debug_log(f\"  Probability - min: {prob_map.min():.4f}, max: {prob_map.max():.4f}, mean: {prob_map.mean():.4f}\")\n    debug_log(f\"  Flood pixels: {binary.sum()} ({100*binary.sum()/(H*W):.2f}%)\")\n    \n    return prob_map, binary\n\n# ═══════════════════════════════════════════════════════════════════════\n# VISUALIZATION HELPERS\n# ═══════════════════════════════════════════════════════════════════════\ndef load_png_rgb(path):\n    return np.array(Image.open(path).convert(\"RGB\"))\n\ndef s2_to_rgb(s2_arr, gamma=0.55, lo=1.0, hi=98.0, sat=1.3):\n    chs = []\n    for idx in [2, 1, 0]:\n        b = s2_arr[idx].astype(np.float32)\n        v = b[~np.isnan(b)]\n        if not len(v):\n            chs.append(np.zeros(b.shape, np.float32))\n            continue\n        lo_v, hi_v = np.percentile(v, [lo, hi])\n        b = np.clip(b, lo_v, hi_v)\n        b = (b - lo_v) / (hi_v - lo_v + 1e-10)\n        b = np.power(np.clip(np.nan_to_num(b, nan=0.0), 0, 1), gamma)\n        chs.append(b)\n    rgb