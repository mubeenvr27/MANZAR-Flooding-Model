001b[0m\u001b[0;34m)\u001b[0m\u001b[0;34m)\u001b[0m\u001b[0;34m)\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n\u001b[1;32m    684\u001b[0m \u001b[0;34m\u001b[0m\u001b[0m\n\u001b[0;32m--> 685\u001b[0;31m         \u001b[0mresults\u001b[0m \u001b[0;34m=\u001b[0m \u001b[0mschedule\u001b[0m\u001b[0;34m(\u001b[0m\u001b[0mexpr\u001b[0m\u001b[0;34m,\u001b[0m \u001b[0mkeys\u001b[0m\u001b[0;34m,\u001b[0m \u001b[0;34m**\u001b[0m\u001b[0mkwargs\u001b[0m\u001b[0;34m)\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n\u001b[0m\u001b[1;32m    686\u001b[0m \u001b[0;34m\u001b[0m\u001b[0m\n\u001b[1;32m    687\u001b[0m     \u001b[0;32mreturn\u001b[0m \u001b[0mrepack\u001b[0m\u001b[0;34m(\u001b[0m\u001b[0mresults\u001b[0m\u001b[0;34m)\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n","\u001b[0;32m/usr/lib/python3.12/queue.py\u001b[0m in \u001b[0;36mget\u001b[0;34m(self, block, timeout)\u001b[0m\n\u001b[1;32m    169\u001b[0m             \u001b[0;32melif\u001b[0m \u001b[0mtimeout\u001b[0m \u001b[0;32mis\u001b[0m \u001b[0;32mNone\u001b[0m\u001b[0;34m:\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n\u001b[1;32m    170\u001b[0m                 \u001b[0;32mwhile\u001b[0m \u001b[0;32mnot\u001b[0m \u001b[0mself\u001b[0m\u001b[0;34m.\u001b[0m\u001b[0m_qsize\u001b[0m\u001b[0;34m(\u001b[0m\u001b[0;34m)\u001b[0m\u001b[0;34m:\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n\u001b[0;32m--> 171\u001b[0;31m                     \u001b[0mself\u001b[0m\u001b[0;34m.\u001b[0m\u001b[0mnot_empty\u001b[0m\u001b[0;34m.\u001b[0m\u001b[0mwait\u001b[0m\u001b[0;34m(\u001b[0m\u001b[0;34m)\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n\u001b[0m\u001b[1;32m    172\u001b[0m             \u001b[0;32melif\u001b[0m \u001b[0mtimeout\u001b[0m \u001b[0;34m<\u001b[0m \u001b[0;36m0\u001b[0m\u001b[0;34m:\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n\u001b[1;32m    173\u001b[0m                 \u001b[0;32mraise\u001b[0m \u001b[0mValueError\u001b[0m\u001b[0;34m(\u001b[0m\u001b[0;34m\"'timeout' must be a non-negative number\"\u001b[0m\u001b[0;34m)\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n","\u001b[0;32m/usr/lib/python3.12/threading.py\u001b[0m in \u001b[0;36mwait\u001b[0;34m(self, timeout)\u001b[0m\n\u001b[1;32m    353\u001b[0m         \u001b[0;32mtry\u001b[0m\u001b[0;34m:\u001b[0m    \u001b[0;31m# restore state no matter what (e.g., KeyboardInterrupt)\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n\u001b[1;32m    354\u001b[0m             \u001b[0;32mif\u001b[0m \u001b[0mtimeout\u001b[0m \u001b[0;32mis\u001b[0m \u001b[0;32mNone\u001b[0m\u001b[0;34m:\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n\u001b[0;32m--> 355\u001b[0;31m                 \u001b[0mwaiter\u001b[0m\u001b[0;34m.\u001b[0m\u001b[0macquire\u001b[0m\u001b[0;34m(\u001b[0m\u001b[0;34m)\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n\u001b[0m\u001b[1;32m    356\u001b[0m                 \u001b[0mgotit\u001b[0m \u001b[0;34m=\u001b[0m \u001b[0;32mTrue\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n\u001b[1;32m    357\u001b[0m             \u001b[0;32melse\u001b[0m\u001b[0;34m:\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n","\u001b[0;31mKeyboardInterrupt\u001b[0m: "],"ename":"KeyboardInterrupt","evalue":"","output_type":"error"}],"execution_count":6},{"cell_type":"code","source":"# ═══════════════════════════════════════════════════════════════════════════════\n# CELL: MERGE LULC & POPULATION METRICS WITH EXISTING FLOOD METRICS JSON\n# Uses existing LULC masks and adds population impact data to JSON files\n# NO DOWNLOADS - Just merges pre-computed results\n# ═══════════════════════════════════════════════════════════════════════════════\n\nimport os, json, warnings\nimport numpy as np\nimport pandas as pd\nfrom PIL import Image\nfrom datetime import datetime\n\nwarnings.filterwarnings(\"ignore\")\n\n# Configuration\nPIXEL_M = 10.0\nPIXEL_KM2 = (PIXEL_M ** 2) / 1e6\n\nMASKS_DIR = \"./masks_pngs\"\nLULC_OUTPUT_DIR = \"./lulc_analysis\"\nFLOOD_METRICS_DIR = \"./flood_metrics_advanced\"\n\nos.makedirs(FLOOD_METRICS_DIR, exist_ok=True)\n\n# LULC class mapping\nLULC_CLASS_MAP = {\n    0: \"Tree_cover\",\n    1: \"Shrubland\", \n    2: \"Grassland\",\n    3: \"Cropland\",\n    4: \"Built_up\",\n    5: \"Bare_sparse_vegetation\",\n    6: \"Permanent_water\",\n    7: \"Mangroves\",\n}\n\n# Population density estimates (people per km²) by LULC class\nLULC_POPULATION_DENSITY = {\n    \"Tree_cover\": 50,\n    \"Shrubland\": 20,\n    \"Grassland\": 30,\n    \"Cropland\": 400,\n    \"Built_up\": 5000,\n    \"Bare_sparse_vegetation\": 10,\n    \"Permanent_water\": 0,\n    \"Mangroves\": 15,\n}\n\n# Location coordinates\nLOCATION_COORDS = {\n    \"Sialkot_punjab\": (32.496304, 74.538327, 10),\n    \"Dadu_Sindh\": (26.73, 67.78, 10),\n    \"Sukkur_Sindh\": (27.70, 68.87, 10),\n    \"Jacobabad_Sindh\": (28.28, 68.43, 10),\n    \"DG_Khan_Punjab\": (30.06, 70.64, 10),\n    \"Nowshera_KPK\": (34.01, 71.99, 10),\n    \"Sylhet_Bangladesh\": (24.90, 91.87, 10),\n    \"Kherson_Ukraine\": (46.64, 32.62, 10),\n    \"KwaZuluNatal_SA\": (-29.86, 31.01, 10),\n}\n\ndef load_flood_mask(location):\n    mask_path = os.path.join(MASKS_DIR, location, f\"{location}_mask_new_inundation.png\")\n    if not os.path.exists(mask_path):\n        mask_path = os.path.join(MASKS_DIR, location, f\"{location}_mask_prediction.png\")\n    if not os.path.exists(mask_path):\n        return None\n    mask = np.array(Image.open(mask_path))\n    if mask.max() > 1:\n        mask = mask // 255\n    return mask.astype(np.uint8)\n\ndef calculate_population_from_lulc(lulc_mask, flood_mask):\n    \"\"\"Calculate population based on LULC class densities.\"\"\"\n    H, W = lulc_mask.shape\n    pop_grid = np.zeros((H, W), dtype=np.float32)\n    \n    # Distribute population by LULC class\n    for class_idx, class_name in LULC_CLASS_MAP.items():\n        density_per_km2 = LULC_POPULATION_DENSITY.get(class_name, 50)\n        density_per_pixel = density_per_km2 * PIXEL_KM2\n        pop_grid[lulc_mask == class_idx] = density_per_pixel\n    \n    # Calculate flooded population\n    flooded_pixels = flood_mask == 1\n    affected_population = float(pop_grid[flooded_pixels].sum())\n    total_population = float(pop_grid.sum())\n    \n    # Calculate per-class statistics\n    class_stats = {}\n    for class_idx, class_name in LULC_CLASS_MAP.items():\n        class_mask = (lulc_mask == class_idx)\n        class_pixels = int(class_mask.sum())\n        class_area_km2 = class_pixels * PIXEL_KM2\n        \n        flooded_class_pixels = int((class_mask & flooded_pixels).sum())\n        flooded_class_area = flooded_class_pixels * PIXEL_KM2\n        \n        pop_on_class = float(pop_grid[class_mask].sum())\n        flooded_pop_on_class = float(pop_grid[class_mask & flooded_pixels].sum())\n        \n        class_stats[class_name] = {\n            'total_area_km2': round(class_area_km2, 2),\n            'flooded_area_km2': round(flooded_class_area, 3),\n            'total_population': int(round(pop_on_class)),\n            'flooded_population': int(round(flooded_pop_on_class)),\n            'flood_percentage': round(100 * flooded_class_pixels / max(class_pixels, 1), 2)\n        }\n    \n    return {\n        'total_population': int(round(total_population)),\n        'affected_population': int(round(affected_population)),\n        'population_density_per_km2': round(total_population / (H * W * PIXEL_KM2), 1),\n        'class_stats': class_stats\n    }\n\ndef merge_with_existing_json(location, lulc_mask, flood_mask, results):\n    \"\"\"Merge LULC and population results with existing flood metrics JSON file\"\"\"\n    \n    # Path to existing JSON\n    existing_json_path = os.path.join(FLOOD_METRICS_DIR, f\"{location}_flood_metrics.json\")\n    \n    # Prepare LULC impact data\n    lulc_impact = {}\n    lulc_population_impact = {}\n    flood_percentage = {}\n    \n    for class_name, stats in results['class_stats'].items():\n        if stats['flooded_area_km2'] > 0:\n            lulc_impact[class_name] = stats['flooded_area_km2']\n            lulc_population_impact[class_name] = stats['flooded_population']\n            flood_percentage[class_name] = stats['flood_percentage']\n    \n    # Create new data structure with LULC results at the top\n    lulc_assessment = {\n        \"total_flood_area_km2\": float(flood_mask.sum() * PIXEL_KM2),\n        \"population_affected\": results['affected_population'],\n        \"total_population_scene\": results['total_population'],\n        \"population_density_per_km2\": results['population_density_per_km2'],\n        \"flooded_lulc_breakdown_km2\": lulc_impact,\n        \"flooded_lulc_population\": lulc_population_impact,\n        \"flood_percentage_by_lulc_class\": flood_percentage,\n        \"analysis_timestamp\": datetime.now().isoformat()\n    }\n    \n    merged_data = {\n        \"location\": location,\n        \"last_updated\": datetime.now().isoformat(),\n        \"lulc_population_assessment\": lulc_assessment\n    }\n    \n    # Load existing flood metrics if available and add under \"sar_flood_metrics\"\n    if os.path.exists(existing_json_path):\n        with open(existing_json_path, 'r') as f:\n            existing_data = json.load(f)\n        merged_data[\"sar_flood_metrics\"] = existing_data\n        print(f\"  ✅ Merged with existing flood metrics\")\n    else:\n        print(f\"  ⚠️ No existing flood metrics found, creating new file\")\n        merged_data[\"sar_flood_metrics\"] = None\n    \n    # Save merged JSON\n    with open(existing_json_path, 'w') as f:\n        json.dump(merged_data, f, indent=2)\n    \n    return merged_data\n\n# ═══════════════════════════════════════════════════════════════════════════════\n# FIND ALL LOCATIONS WITH BOTH FLOOD MASKS AND LULC MASKS\n# ═══════════════════════════════════════════════════════════════════════════════\n\n# Get all locations with flood masks\nlocations = []\nfor folder in os.listdir(MASKS_DIR):\n    folder_path = os.path.join(MASKS_DIR, folder)\n    if os.path.isdir(folder_path):\n        if os.path.exists(os.path.join(folder_path, f\"{folder}_mask_new_inundation.png\")) or \\\n           os.path.exists(os.path.join(folder_path, f\"{folder}_mask_prediction.png\")):\n            locations.append(folder)\n\nprint(f\"\\n{'='*70}\")\nprint(\"MERGE LULC & POPULATION METRICS WITH EXISTING JSON FILES\")\nprint(f\"{'='*70}\")\nprint(f\"Found {len(locations)} locations with flood masks: {', '.join(locations)}\")\n\n# Process each location\nsuccessful = []\nfailed_no_lulc = []\nfailed_no_flood = []\n\nfor location in locations:\n    print(f\"\\n{'─'*50}\")\n    print(f\"📍 {location}\")\n    print(f\"{'─'*50}\")\n    \n    # Load flood mask\n    flood_mask = load_flood_mask(location)\n    if flood_mask is None:\n        print(f\"  ❌ Flood mask not found\")\n        failed_no_flood.append(location)\n        continue\n    \n    flood_area_km2 = flood_mask.sum() * PIXEL_KM2\n    print(f\"  Flood area: {flood_area_km2:.2f} km² ({flood_mask.sum():,} pixels)\")\n    \n    # Load existing LULC mask\n    lulc_path = os.path.join(LULC_OUTPUT_DIR, f\"{location}_lulc_mask.npy\")\n    if not os.path.exists(lulc_path):\n        print(f\"  ❌ LULC mask not found at {lulc_path}\")\n        failed_no_lulc.append(location)\n        continue\n    \n    lulc_mask = np.load(lulc_path)\n    print(f\"  ✅ Loaded LULC mask: {lulc_mask.shape}\")\n    \n    # Calculate population\n    pop_stats = calculate_population_from_lulc(lulc_mask, flood_mask)\n    \n    print(f\"\\n  📊 Population Impact:\")\n    print(f\"     Population affected: {pop_stats['affected_population']:,}\")\n    print(f\"     Total scene population: {pop_stats['total_population']:,}\")\n    print(f\"     Population density: {pop_stats['population_density_per_km2']:.0f} people/km²\")\n    \n    print(f\"\\n     Flooded LULC breakdown (area