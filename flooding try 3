n            for key, value in results['summary'].items():\n                if isinstance(value, dict):\n                    f.write(f\"  {key}:\\n\")\n                    for subkey, subval in value.items():\n                        f.write(f\"    {subkey}: {subval}\\n\")\n                else:\n                    f.write(f\"  {key}: {value}\\n\")\n            \n            f.write(\"\\n\\nTOP 10 FLOOD COMPONENTS (with Center and Radius):\\n\")\n            f.write(\"-\"*70 + \"\\n\")\n            for comp in results['top_components'][:10]:\n                f.write(f\"\\nComponent {comp['id']}:\\n\")\n                f.write(f\"  Area: {comp['area_km2']} km² ({comp['percentage_of_total']}% of total)\\n\")\n                f.write(f\"  Center: ({comp['center']['x_km']}, {comp['center']['y_km']}) km\\n\")\n                f.write(f\"  Radius Information:\\n\")\n                f.write(f\"    - Equivalent Radius: {comp['radius']['equivalent_radius_km']} km\\n\")\n                f.write(f\"    - Max Radius: {comp['radius']['max_radius_km']} km\\n\")\n                f.write(f\"    - Mean Radius: {comp['radius']['mean_radius_km']} km\\n\")\n                f.write(f\"  Bounding Circle:\\n\")\n                f.write(f\"    - Radius: {comp['bounding_circle']['radius_km']} km\\n\")\n                f.write(f\"    - Circumference: {comp['bounding_circle']['circumference_km']} km\\n\")\n                f.write(f\"    - Circle Area: {comp['bounding_circle']['circle_area_km2']} km²\\n\")\n                f.write(f\"    - Component fills {comp['bounding_circle']['component_fill_percentage']}% of circle\\n\")\n                f.write(f\"  Bounding Box: {comp['bbox_km']['width_km']}km x {comp['bbox_km']['height_km']}km\\n\")\n        \n        print(f\"  💾 Saved TXT: {txt_path}\")\n        \n        all_results[location] = results\n    \n    # Create summary CSV with center and radius\n    import csv\n    csv_path = os.path.join(output_dir, \"flood_summary.csv\")\n    with ope